        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Outline and manage the innovation of technology within the organization. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Research and understand emerging future technological concepts and capabilities. Plan for IT innovation investments. Plan and execute viable innovation projects."@en,
