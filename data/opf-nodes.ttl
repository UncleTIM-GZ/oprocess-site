        "建立 wages, salaries, and benefits 战略"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.1.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2.2> ;
    skos:definition "Creating a scheme of rewards and recognition for employees to promote a results-based culture. Create specific incentives to reach desired outcomes, such as landing key clients, growing the customer base, providing exceptional servicing, and increasing profit margins."@en,
        "Creating a scheme of rewards and recognition for employees to promote a results-based culture. 创建 specific incentives to reach desired outcomes, such as landing key clients, growing the customer base, providing exceptional servicing, and increasing profit margins."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.2.2" ;
    skos:prefLabel "Establish incentive strategy"@en,
        "建立 incentive 战略"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.1.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2.2> ;
    skos:definition "Defining the approach to severance pay, including principles and guidelines, to support workforce transitions while managing financial, legal, and reputational considerations."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.2.3" ;
    skos:prefLabel "Establish a severance pay strategy"@en,
        "建立 a severance pay 战略"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Creating and implementing the plan for continuation of key positions within the organization. Identify internal people with the potential to fill key business leadership positions. Provide critical development experiences to employees who can move into important roles. Engage leaders to support the development of high-potential leaders."@en,
        "Creating and implementing the plan for continuation of key positions within the organization. 识别 internal people with the potential to fill key business leadership positions. 提供 critical development experiences to employees who can move into important roles. Engage leaders to support the development of high-potential leaders."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.3" ;
    skos:prefLabel "Develop succession plan"@en,
        "开发 succession plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Creating a program that incorporates incentives and compensation put forth by the organization to recognize high performing workers and excellence in leadership."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.4" ;
    skos:prefLabel "Develop high performers/leadership programs"@en,
        "开发 high performers/leadership programs"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Creating and implementing the plan for ensuring a diverse work force. Develop and hire employees with varying characteristics including, but not limited to, religious and political beliefs, gender, ethnicity, education, socioeconomic background, sexual orientation, and geographic location."@en,
        "Creating and implementing the plan for ensuring a diverse work force. 开发 and hire employees with varying characteristics including, but not limited to, religious and political beliefs, gender, ethnicity, education, socioeconomic background, sexual orientation, and geographic location."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.5" ;
    skos:prefLabel "Develop diversity, equity, and inclusion plan"@en,
        "开发 diversity, equity, and inclusion plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.6" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Execution of diversity, equity, and inclusion plans within an organization.  Often called a DEI plan."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.6" ;
    skos:prefLabel "Implement diversity, equity, and inclusion plan"@en,
        "实施 diversity, equity, and inclusion plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.7" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Developing a program to entice prospective resources to engage with the organization for a position of employment."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
