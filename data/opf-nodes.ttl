    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.7" ;
    skos:prefLabel "Notify originator of approve/reject decision"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.3.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.8" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
