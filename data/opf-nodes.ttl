    skos:notation "8.5.7.3" ;
    skos:prefLabel "Manage technical debt"@en,
        "管理技术债务"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Evaluate the impact of IT deployment (products/services) on the business. Compare pre and post development performance, behavior of resources, and cost to assess organizational benefit."@en,
        "评估IT部署（产品/服务）对业务的影响；对比部署前后性能表现、资源行为及成本变化，衡量组织收益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.1" ;
    skos:prefLabel "Assess IT deployment business impact"@en,
        "评估IT部署的业务影响"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Defining deployment policies regarding IT services and solutions to allow employees to plan accordingly. Reduce the negative impact to the user community."@en,
        "制定IT服务与解决方案部署政策，便于员工提前规划，降低对用户群体的负面影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.2" ;
    skos:prefLabel "Establish IT deployment policies"@en,
        "制定IT部署政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Outlining processes, methods, and equipment for deployment of IT solutions. Manage core operations servers like subversion server, production server, and development server, to make the IT services and solutions available for internal/client use."@en,
        "明确IT解决方案部署的流程、方法与设备；管理核心运维服务器（如Subversion服务器、生产服务器、开发服务器），确保IT服务与解决方案可供内部或客户使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.3" ;
    skos:prefLabel "Define and create deployment procedure workflow"@en,
        "定义并创建部署流程工作流"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Establishing guidelines for the changed/released IT services and solutions to meet business objectives with optimum utilization."@en,
        "制定已变更/已发布IT服务与解决方案的使用指南，以最优方式支撑业务目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.4" ;
    skos:prefLabel "Define IT change/release standards"@en,
        "定义IT变更/发布标准"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Coordinating development approval responsibilities based on defined change standards."@en,
        "依据既定变更标准，协调开发审批职责。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.5" ;
    skos:prefLabel "Assign deployment approval responsibilities"@en,
        "明确部署审批职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.6.1> ;
    skos:definition "Evaluating the impact (pros and cons) of IT services deployment."@en,
        "评估IT服务部署的综合影响（利弊分析）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1.6" ;
    skos:prefLabel "Analyze deployments outcomes"@en,
        "分析部署成效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Deployment Management" ;
    skos:broader <https://oprocess.net/opf/node/8.6.10> ;
    skos:definition "Activity within ITIL practice 'Deployment Management'."@en,
        "ITIL 实践‘部署管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.10.1" ;
    skos:prefLabel "Plan deployment approaches"@en,
        "规划部署方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Deployment Management" ;
    skos:broader <https://oprocess.net/opf/node/8.6.10> ;
    skos:definition "Activity within ITIL practice 'Deployment Management'."@en,
        "ITIL 实践‘部署管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.10.2" ;
    skos:prefLabel "Execute deployments to environments"@en,
        "向各环境执行部署"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Deployment Management" ;
    skos:broader <https://oprocess.net/opf/node/8.6.10> ;
    skos:definition "Activity within ITIL practice 'Deployment Management'."@en,
        "ITIL 实践‘部署管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.10.3" ;
    skos:prefLabel "Manage deployment automation"@en,
        "管理部署自动化"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Accessing threats and potential failures related to the deployment of IT services/solutions."@en,
        "识别IT服务/解决方案部署过程中面临的威胁及潜在失效风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.1" ;
    skos:prefLabel "Assess IT deployment risk"@en,
        "评估IT部署风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Defining the schedule for implementation of change. Plan and carry out a process or procedure to implement the predefined changes."@en,
        "明确变更实施的时间安排；规划并执行既定变更的实施流程或程序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.2" ;
    skos:prefLabel "Define implementation schedule and roll-out sequence"@en,
        "制定实施计划与上线顺序"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Determine requirements for implementation of IT deployment. Carry out a pre-implementation audit to assess the impact and use case. Gauge the possible vulnerabilities and impact the business operations during and after the implementation."@en,
        "确定IT部署实施所需条件；开展部署前审计，评估影响范围与业务场景；研判部署期间及之后可能引发的脆弱性及对业务运营的影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.3" ;
    skos:prefLabel "Determine implementation requirements"@en,
        "确定实施需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Plan methodologies and align resources for user testing of IT deployment."@en,
        "规划用户测试方法论，并统筹协调相关资源以支持IT部署的用户测试。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.4" ;
    skos:prefLabel "Plan and align user testing and resources"@en,
        "规划并协调用户测试及资源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Create and manage employee training programs by considering the need and availability of these programs. Manage all aspects related to the training programs."@en,
        "依据实际需求与资源可获得性，设计并管理员工培训项目；统筹管理培训项目的全部环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.5" ;
    skos:prefLabel "Develop IT training"@en,
        "开发IT培训方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.6" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Coordinating change implementation in IT services and solutions communications with employees and stakeholders."@en,
        "统筹协调IT服务与解决方案变更实施过程中的员工及利益相关方沟通工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.6" ;
    skos:prefLabel "Create implementation communications"@en,
        "制定实施沟通计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2.7" ;
    skos:broader <https://oprocess.net/opf/node/8.6.2> ;
    skos:definition "Managing procedures to return to initial pre-deployment stage or previous state from current environment."@en,
        "建立并管理回退机制，确保可从当前环境恢复至部署前初始状态或上一稳定版本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2.7" ;
    skos:prefLabel "Manage IT roll-back procedures"@en,
        "管理IT回退流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Evaluating the impact of IT change/release on the business."@en,
        "评估IT变更/发布对业务运营的影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.1" ;
    skos:prefLabel "Asses IT change/release impact"@en,
        "评估IT变更/发布影响"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Ensure that change/release meets change guidelines set by the organization."@en,
        "确保变更/发布符合组织制定的变更管理规范。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.2" ;
    skos:prefLabel "Confirm change/release compliance"@en,
        "确认变更/发布合规性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Evaluating for any kind of risks or threats which could be caused due to IT change/release deployment."@en,
        "识别因IT变更/发布部署可能引发的各类风险或威胁。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.3" ;
    skos:prefLabel "Assess IT change/release risk"@en,
        "评估IT变更/发布风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Integrate all forms of changes in IT in order to make more efficient use of resources and down time, and optimizing results."@en,
        "整合各类IT变更，提升资源利用效率、降低停机时间，并优化整体实施成效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.4" ;
    skos:prefLabel "Consolidate IT change"@en,
        "整合IT变更"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Defining and communicating the schedule for implementation to related stakeholders and functions."@en,
        "面向相关利益相关方及职能部门，明确并传达变更实施时间表。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.5" ;
    skos:prefLabel "Create and communicate deployment schedule"@en,
        "制定并发布部署计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.6" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Permitting for the change/release deployment. Approve deployment based on the evaluation of business impact due to change/release."@en,
        "审批变更/发布部署；基于业务影响评估结果决定是否批准部署。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.6" ;
    skos:prefLabel "Approve change/release deployment"@en,
        "审批变更/发布部署"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3.7" ;
    skos:broader <https://oprocess.net/opf/node/8.6.3> ;
    skos:definition "Recording outcomes related to the change/release deployment."@en,
        "记录变更/发布部署的相关结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3.7" ;
    skos:prefLabel "Document IT change/release outcome"@en,
        "记录IT变更/发布结果"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Confirm if hardware/software are operating as per the expectation."@en,
        "确认硬件/软件运行状态符合预期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.1" ;
    skos:prefLabel "Confirm hardware/software operational status"@en,
        "确认软硬件运行状态"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Confirm if operational activities of IT services could be performed."@en,
        "确认IT服务各项运维活动可正常执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.2" ;
    skos:prefLabel "Confirm operational availability"@en,
        "确认运行可用性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Executing IT implementation plan to make the IT services and solutions available for internal use."@en,
        "执行IT实施计划，使IT服务与解决方案具备内部使用条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.3" ;
    skos:prefLabel "Execute internal IT implementation plan"@en,
        "执行内部IT实施计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Confirming the completion of IT implementation."@en,
        "确认IT实施工作已完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.4" ;
    skos:prefLabel "Confirm implementation completion"@en,
        "确认实施完成"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Executing changes in software and services as per change/release schedule."@en,
        "依据变更/发布时间表，执行软件与服务层面的变更操作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.5" ;
    skos:prefLabel "Implement software change/release"@en,
        "实施软件变更/发布"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.6" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Perform testing after installation to confirm expected performance is met."@en,
        "安装后开展测试，验证系统性能是否达到预期目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.6" ;
    skos:prefLabel "Perform post-installation testing"@en,
        "开展安装后测试"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.7" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Distributing and implementing the release of changed IT solutions. Administer, implement, and install the releases onto internal systems. Provide methods for installing releases on client users."@en,
        "分发并实施变更后的IT解决方案；在内部系统中完成发布版本的管理、部署与安装；提供面向终端用户的发布安装方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.7" ;
    skos:prefLabel "Distribute software components network-wide"@en,
        "全网分发软件组件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.8" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Confirming that the release has met expectations."@en,
        "确认发布版本已满足预期目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.8" ;
    skos:prefLabel "Verify change/release implementation success"@en,
        "验证变更/发布实施成效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4.9" ;
    skos:broader <https://oprocess.net/opf/node/8.6.4> ;
    skos:definition "Execution of plan to return to the previous operating state if the change/release impedes operational expectations."@en,
        "若变更/发布导致运营未达预期，立即执行回退至先前运行状态的预案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4.9" ;
    skos:prefLabel "Execute roll-back plan"@en,
        "执行回退方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Preparing users for changes in IT solutions. Conduct training sessions and engagement activities to familiarize users with the new changes. Implementing the programs for training IT employees."@en,
        "面向用户开展IT解决方案变更准备：组织培训与宣贯活动，帮助用户熟悉新变更；落实IT员工专项培训计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.1" ;
    skos:prefLabel "Conduct IT training"@en,
        "开展IT培训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Coordinating communications regarding the changes in IT services and solutions with employees in the organization."@en,
        "统筹组织内部员工关于IT服务与解决方案变更的信息沟通工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.2" ;
    skos:prefLabel "Prepare and distribute service/solution communications"@en,
        "编制并分发服务/解决方案沟通材料"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Creating a strategy for providing support for organizational changes. Providing support to users of IT services and solutions."@en,
        "制定组织变革支持策略；为IT服务与解决方案用户提供持续支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.3" ;
    skos:prefLabel "Support organizational changes"@en,
        "支持组织变革"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Executing a plan for introducing the IT services and solutions to the organization's end user base."@en,
        "执行IT服务与解决方案向组织最终用户群体推广的实施计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.4" ;
    skos:prefLabel "Execute rollout plans"@en,
        "执行上线计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Establishing services for providing support to users of IT services and solutions for rollout. Define the plethora of services by which the organization assists users of technology products."@en,
        "建立面向IT服务与解决方案用户的上线支持服务体系；明确定义组织为技术产品用户提供的一系列支持服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.5" ;
    skos:prefLabel "Provide rollout support"@en,
        "提供上线支持"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.6" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Managing the necessary skills and competencies required to efficiently provide IT resolution for rollout through the support structure. Identify the gaps and needs in support structure."@en,
        "统筹管理支撑上线阶段高效提供IT问题解决能力所必需的技能与胜任力；识别支持体系中的能力缺口与资源需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.6" ;
    skos:prefLabel "Manage rollout support capabilities"@en,
        "管理上线支持能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5.7" ;
    skos:broader <https://oprocess.net/opf/node/8.6.5> ;
    skos:definition "Track and record any issues being faced due to rollout. Define methodology of assessment for measuring and monitoring issues."@en,
        "跟踪并记录上线过程中出现的问题；制定问题评估方法论，用于衡量与监控问题发生情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5.7" ;
    skos:prefLabel "Monitor and record rollout issues"@en,
        "监控并记录上线问题"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

