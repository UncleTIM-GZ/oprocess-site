    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4" ;
    skos:prefLabel "Ensure quality of last mile delivery"@en,
        "Ensure 质量 of last mile delivery"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

