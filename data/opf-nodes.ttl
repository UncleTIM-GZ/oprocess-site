    skos:definition "AI activity: Remediate identified biases."@en,
        "AI活动：整改已识别的偏见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.4.4" ;
    skos:prefLabel "Remediate identified biases"@en,
        "整改已识别的偏见"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

