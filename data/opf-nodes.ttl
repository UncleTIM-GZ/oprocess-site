    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.4.3" ;
    skos:prefLabel "Audit model decisions for bias"@en,
        "审计模型决策中的偏见"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

