    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.1" ;
    skos:prefLabel "Establish policies/procedures for adjustments"@en,
        "建立 policies/procedures for adjustments"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Checking changes made in accounts during the year. Examine the alterations made in final accounts to rectify errors/omissions."@en,
        "Checking 变更s made in accounts during the year. Examine the alterations made in final accounts to rectify errors/omissions."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.2" ;
    skos:prefLabel "Analyze adjustments"@en,
        "分析 adjustments"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Providing suitable offers to customers. Present different offers (e.g., discounts) available for customers or buyers."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.3" ;
    skos:prefLabel "Correspond/Negotiate with customer"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Discussing and planning with internal parties (department heads, managers, and senior management) about rules to follow in coming months."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.4" ;
    skos:prefLabel "Discuss resolution with internal parties"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Creating a mechanism for consumer protection in case of a higher price charged. When a supplier sells a product at a higher price to the distributor than the price they have set with the end user, submit a chargeback to the supplier to recover the money lost in the transaction."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.5" ;
    skos:prefLabel "Prepare chargeback invoices"@en,
        "准备 chargeback invoices"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.6" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Recording business transactions as they occur in order to provide a balanced accounts for financial reporting."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.6" ;
    skos:prefLabel "Process related entries"@en,
        "处理 related entries"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "AI-era activity: AI-Powered Fraud Detection."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.6" ;
    skos:prefLabel "AI-Powered Fraud Detection"@en ;
    opf:domain "management_support" ;
