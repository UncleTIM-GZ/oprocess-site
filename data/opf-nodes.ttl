        "建立 organizational development needs for employees. Creating a link between employee and organizational development needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4" ;
    skos:prefLabel "Develop and train employees"@en,
        "开发 and train employees"@zh ;
    opf:domain "management_support" ;
