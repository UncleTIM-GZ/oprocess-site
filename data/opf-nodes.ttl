<https://oprocess.net/opf/node/13.6.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Establishing objectives for content management that enhance the organization and accessibility of enterprise content. Objectives can include curation, findability, consistency, user-centric design, lifecycle management, governance and roles, quality assurance, and measurement and evaluation."@en,
        "Establishing objectives for 内容管理 that enhance the organization and accessibility of enterprise 内容. Objectives can include curation, findability, consistency, user-centric design, lifecycle management, 治理 and roles, 质量 assurance, and measurement and evaluation."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.1" ;
    skos:prefLabel "Establish content management objectives"@en,
        "建立 内容管理 objectives"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Establishing a structured framework with roles and responsibilities to oversee and guide content management practices within an organization to ensure content is managed consistently, remains high-quality, meets the needs of users, and enhances the overall content management strategy."@en,
        "Establishing a structured framework with roles and responsibilities to oversee and guide 内容管理 practices within an organization to ensure 内容 is managed consistently, remains high-质量, meets the needs of users, and enhances the overall 内容管理 战略."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.2" ;
    skos:prefLabel "Develop content management governance model"@en,
        "开发 内容管理 治理 模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Defining funding approaches for content management activities, capabilities, and infrastructure to support sustainable operations, investment prioritization, and alignment with organizational objectives."@en,
        "Defining funding approaches for 内容管理 activities, capabilities, and 基础设施 to support sustainable operations, investment prioritization, and 对齐 with organizational objectives."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.3" ;
    skos:prefLabel "Develop content management funding models"@en,
        "开发 内容管理 funding 模型s"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Identifying and implementing content management methodologies to effectively store, deliver, and facilitate access to enterprise content. Core methodologies may include prioritization of critical or high-value content, findability to ensure ease of locating relevant content, content lifecycle management, standardization of content creation, review and access, collaboration, and technology integration."@en,
        "Identifying and implementing 内容管理 methodologies to effectively store, deliver, and facilitate access to enterprise 内容. Core methodologies may include prioritization of critical or high-value 内容, findability to ensure ease of locating relevant 内容, 内容 lifecycle management, standardization of 内容 creation, review and access, collaboration, and technology integration."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.4" ;
    skos:prefLabel "Develop core content management methodologies"@en,
        "开发 core 内容管理 methodologies"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Assessing technology requirements for content management and collaborating with the IT function to align systems, integration, security, and support with content management needs. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "Assessing technology requirements for 内容管理 and collaborating with the IT function to align systems, integration, 安全, and support with 内容管理 needs. This includes leveraging all forms of new and evolving technology such as 人工智能 (AI)."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.5" ;
    skos:prefLabel "Assess content management IT needs and engage IT function"@en,
        "评估 内容管理 IT needs and engage IT function"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.6" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Developing training, change and communication plans to support the organization's content management practices. Define target audiences, required competencies, learning objectives, and delivery methods to ensure consistent understanding and adoption of content standards, tools, and workflows. Create communication strategies to promote awareness of content governance, reinforce expectations, and inform stakeholders of process updates, system changes, and best practices. Coordinate with internal partners to design training materials, schedule learning sessions, and disseminate communications that enable effective and compliant content creation, storage, use, and lifecycle management. Monitor participation, evaluate effectiveness, and continuously improve based on feedback and evolving organizational needs."@en,
        "Developing 训练, 变更 and communication plans to support the organization's 内容管理 practices. 定义 target audiences, required competencies, learning objectives, and delivery methods to ensure consistent understanding and adoption of 内容 standards, tools, and 工作流s. 创建 communication strategies to promote awareness of 内容 治理, reinforce expectations, and inform stakeholders of process updates, system 变更s, and best practices. 协调 with internal partners to design 训练 materials, schedule learning sessions, and disseminate communications that enable effective and compliant 内容 creation, storage, use, and lifecycle management. 监控 participation, evaluate effectiveness, and continuously improve based on feedback and evolving organizational needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.6" ;
    skos:prefLabel "Develop content management training and communication plans"@en,
        "开发 内容管理 训练 and communication plans"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.7" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Defining and implementing performance measures to assess the effectiveness and strategic value of content management practices. Align indicators with organizational goals, governance requirements, and user needs. Specify data sources, measurement methods, and reporting cadences to provide reliable insight into content quality, accessibility, utilization, and lifecycle compliance. Collaborate with stakeholders to validate metric definitions, integrate measures into dashboards, and set expectations for monitoring and improvement. Periodically review and refine measures in response to changing priorities and requirements."@en,
        "Defining and implementing 绩效 measures to assess the effectiveness and strategic value of 内容管理 practices. Align indicators with organizational goals, 治理 requirements, and user needs. Specify data sources, measurement methods, and reporting cadences to provide reliable insight into 内容 质量, accessibility, utilization, and lifecycle 合规. Collaborate with stakeholders to validate metric definitions, integrate measures into dashboards, and set expectations for 监控 and improvement. Periodically review and refine measures in response to changing priorities and requirements."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.7" ;
    skos:prefLabel "Develop strategic measures and indicators for content management"@en,
        "开发 strategic measures and indicators for 内容管理"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.8" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Monitor and analyze content ecosystem performance to understand search behavior, user intent, knowledge gaps, content effectiveness, and content lifecycle health. Use content usage patterns and derived insights to identify emerging needs, anticipate gaps, recommend updates or new content, and continuously optimize the relevance, quality, and accessibility of the content ecosystem. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)"@en,
        "监控 and analyze 内容 ecosystem 绩效 to understand search behavior, user intent, knowledge gaps, 内容 effectiveness, and 内容 lifecycle health. Use 内容 usage patterns and derived insights to identify emerging needs, anticipate gaps, recommend updates or new 内容, and continuously optimize the relevance, 质量, and accessibility of the 内容 ecosystem. This includes leveraging all forms of new and evolving technology such as 人工智能 (AI)"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.8" ;
    skos:prefLabel "Manage content intelligence and insights"@en,
        "管理 内容 intelligence and insights"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Identifying functional, operational, governance, and compliance requirements that content management practices and solutions must satisfy across the organization."@en,
        "Identifying functional, operational, 治理, and 合规 requirements that 内容管理 practices and solutions must satisfy across the organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.1" ;
    skos:prefLabel "Determine content management requirements"@en,
        "Determine 内容管理 requirements"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Establishing content metadata structures that function as a common classification language by defining hierarchical categories and attributes used to organize and relate content, ensuring consistency across formats, business areas, and locations and supporting discoverability and semantic enrichment."@en,
        "Establishing 内容 metadata structures that function as a common classification language by defining hierarchical categories and attributes used to organize and relate 内容, ensuring consistency across formats, business areas, and locations and supporting discoverability and semantic enrichment."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.2" ;
    skos:prefLabel "Define content taxonomies"@en,
        "定义 内容 taxonomies"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Defining standardized conventions for naming, versioning, and tagging digital files and content assets to support consistency, findability, and compliance across the organization. Establish required metadata elements and tagging structures aligned with enterprise taxonomies, information architecture, and regulatory or operational needs."@en,
        "Defining standardized conventions for naming, versioning, and tagging digital files and 内容 资产 to support consistency, findability, and 合规 across the organization. 建立 required metadata elements and tagging structures aligned with enterprise taxonomies, information architecture, and regulatory or operational needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.3" ;
    skos:prefLabel "Define file naming standards and tagging requirements"@en,
        "定义 file naming standards and tagging requirements"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.3.1" ;
