        opf:ProcessNode ;
    dcterms:source "PCF:7.1.1.9" ;
    skos:broader <https://oprocess.net/opf/node/7.1.1> ;
    skos:definition "Creating, maintaining and communicating company's reputation and values to keep current employees and attract potential hires."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.1.9" ;
