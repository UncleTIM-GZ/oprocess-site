    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "Defining sourcing strategies and plans for categories of materials or services to optimize cost, supply continuity, value, and alignment with organizational requirements and market conditions."@en,
        "针对不同物料或服务品类，制定并优化寻源策略与计划，兼顾成本、供应连续性、价值创造及组织需求与市场环境。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.2" ;
    skos:prefLabel "Develop category plan"@en,
        "制定品类计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

