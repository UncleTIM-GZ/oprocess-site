    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.3" ;
    skos:prefLabel "Construct new assets"@en,
        "Construct new 资产"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

