<https://oprocess.net/opf/node/4.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "AI-era activity: AI-Enabled Quality Inspection."@en,
        "人工智能时代活动：AI赋能的质量检验。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.8" ;
    skos:prefLabel "AI-Enabled Quality Inspection"@en,
        "AI驱动的质量检验"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Determining the requirements for managing the flow of things between the point of origin and the point of consumption by assessing the service requirements of the customers."@en,
        "基于客户服务水平要求，评估并确定从供应源头至消费终端的货物流动管理需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.1" ;
    skos:prefLabel "Translate customer service requirements into logistics requirements"@en,
        "将客户服务要求转化为物流需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Developing a network for logistical activities. Create a network of entities through which materials and information flow, encompassing all related activities associated with the flow of transformation of products."@en,
        "构建物流活动网络。设计涵盖物料与信息流动的实体网络，整合产品转化全过程相关联的所有活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.2" ;
    skos:prefLabel "Design logistics network"@en,
        "设计物流网络"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Conveying outsourcing needs within the organization, with the objective of sourcing the assistance required. Define the portion of logistical activities that can be transferred to outside suppliers. Assess third-party agencies to carefully select the most appropriate agencies for outsourcing. Convey these needs to management or the appropriate authority."@en,
        "在组织内部明确物流外包需求，以获取必要外部支持。界定可交由外部供应商承接的物流职能范围；审慎评估第三方机构，择优选择外包合作方；将外包方案提报管理层或授权部门审批。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.3" ;
    skos:prefLabel "Communicate outsourcing needs"@en,
        "沟通外包需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Establishing rules and regulations, as well as the terms and conditions regarding the delivery of service by the company. Develop a delivery plan that specifies what, how, when, and in which way to deliver services to the customer."@en,
        "制定公司服务交付的规章制度与条款条件。编制交付计划，明确交付内容、方式、时间及路径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.4" ;
    skos:prefLabel "Develop and maintain delivery service policy"@en,
        "制定并维护交付服务政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.5" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Optimizing the schedule and costs of transportation services. Design a logistics strategy by strategically creating delivery routes and systems, which optimizes the overall transportation schedules and costs. Evaluate different transportation sources in order to select the most appropriate and cost-effective sources."@en,
        "优化运输服务的排程与成本。通过战略性设计运输路线与系统，实现整体运输排程与成本最优化；评估多种运输资源，择取最具适配性与成本效益的方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.5" ;
    skos:prefLabel "Optimize transportation schedules and costs"@en,
        "优化运输计划与成本"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.6" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Establishing measures for evaluating the performance of the logistics strategy of the organization. Establish key performance indicators, including the logistics performance index, delivery in full, and delivery on time."@en,
        "建立物流战略绩效评估机制。设定关键绩效指标（KPI），包括物流绩效指数、齐套交付率、准时交付率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.6" ;
    skos:prefLabel "Define key performance measures"@en,
        "定义关键绩效指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1.7" ;
    skos:broader <https://oprocess.net/opf/node/4.4.1> ;
    skos:definition "Establish a strategy that includes rules and regulations for the physical handling, information processing, and disposition of product and packaging returned by the buyer to the seller or an intermediary. Include return approval, transportation coordination, advance communication, product tracking, receipt, disposition of the return, and processing warranty claims in the strategy."@en,
        "制定退货管理策略，涵盖实物处理、信息处理及退换货处置规则。策略应包括退货审批、运输协调、提前沟通、产品追踪、收货确认、退货处置及保修索赔处理等环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1.7" ;
    skos:prefLabel "Define reverse logistics strategy"@en,
        "制定逆向物流策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Make-to-Order Product'."@en,
        "SCOR DS 14.0《按订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.10.1" ;
    skos:prefLabel "Pick product"@en,
        "拣选产品"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Make-to-Order Product'."@en,
        "SCOR DS 14.0《按订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.10.2" ;
    skos:prefLabel "Pack product"@en,
        "包装产品"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Make-to-Order Product'."@en,
        "SCOR DS 14.0《按订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.10.3" ;
    skos:prefLabel "Ship product"@en,
        "发运产品"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.10.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Make-to-Order Product'."@en,
        "SCOR DS 14.0《按订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.10.4" ;
    skos:prefLabel "Confirm delivery"@en,
        "确认交付"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.11> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Engineer-to-Order Product'."@en,
        "SCOR DS 14.0《按设计订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.11.1" ;
    skos:prefLabel "Schedule installation"@en,
        "安排安装计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.11.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.11> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Engineer-to-Order Product'."@en,
        "SCOR DS 14.0《按设计订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.11.2" ;
    skos:prefLabel "Install product"@en,
        "安装产品"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.11.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.11> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Engineer-to-Order Product'."@en,
        "SCOR DS 14.0《按设计订单生产产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.11.3" ;
    skos:prefLabel "Confirm acceptance"@en,
        "确认验收"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.12.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Retail Product'."@en,
        "SCOR DS 14.0《零售产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12.1" ;
    skos:prefLabel "Generate stocking schedule"@en,
        "生成补货计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.12.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Retail Product'."@en,
        "SCOR DS 14.0《零售产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12.2" ;
    skos:prefLabel "Receive product at store"@en,
        "门店收货"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.12.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Retail Product'."@en,
        "SCOR DS 14.0《零售产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12.3" ;
    skos:prefLabel "Pick from backroom"@en,
        "从后台仓拣货"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.12.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Retail Product'."@en,
        "SCOR DS 14.0《零售产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12.4" ;
    skos:prefLabel "Stock shelf"@en,
        "上架陈列"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.12.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Fulfill Retail Product'."@en,
        "SCOR DS 14.0《零售产品交付》流程活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12.5" ;
    skos:prefLabel "Checkout"@en,
        "收银结算"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Managing the receipts of inbound materials. Create a plan accounting for the materials procured from the source of supply and the materials delivered to the distribution center or the warehouse."@en,
        "管理进厂物料收货。制定收货计划，覆盖从供应商采购的物料及送达配送中心或仓库的物料。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.1" ;
    skos:prefLabel "Plan inbound material receipts"@en,
        "规划入厂物料收货"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Managing all the internal activities related to the flow/transfer of materials. Manage materials being delivered to distribution center or warehouse. Gauge the time taken for delivery and if the delivery process is on time."@en,
        "统筹管理与物料流动/转移相关的全部内部活动。管控送达配送中心或仓库的物料；评估交付耗时及是否准时交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.2" ;
    skos:prefLabel "Manage inbound material flow"@en,
        "管理入厂物料流"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Overseeing the performance of an inbound delivery system. Check the present delivery system's efficiency, cost effectiveness, and adherence to a delivery schedule."@en,
        "监督进厂交付系统的运行绩效。评估当前交付系统在效率、成本效益及交付计划遵从度方面的表现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.3" ;
    skos:prefLabel "Monitor inbound delivery performance"@en,
        "监控入厂交付绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Tracking and taking care of the products that have been internally returned either because of their deficiency or in cases of incorrect delivery."@en,
        "跟踪并处置因缺陷或错发而产生的内部退货产品。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.4" ;
    skos:prefLabel "Manage flow of returned products"@en,
        "管理退货产品流向"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2.5> ;
    skos:definition "Implement a checks and balances system to verify that returned parts meet acceptable quality standards to determine appropriate disposition activity."@en,
        "建立核查与制衡机制，验证退货零部件是否符合可接受的质量标准，以确定恰当的处置方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.5.1" ;
    skos:prefLabel "Determine quality of controlled part"@en,
        "判定受控部件质量状态"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2.5> ;
    skos:definition "Executing activities for reinstating the returned products. Present the customer with additional incentives of compensation in case of any defective products delivery or any discrepancy in the product specifications in order to save the order from being permanently returned."@en,
        "执行退货产品复用活动。针对交付缺陷产品或规格不符情形，向客户提供补偿等额外激励措施，避免订单被永久退回。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.5.2" ;
    skos:prefLabel "Perform salvage activities"@en,
        "开展回收利用活动"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2.5> ;
    skos:definition "Administering the reinstatement of the returned product in order to return them back to customers. Repair or remanufacture the defective or ineffective products returned by the customer. Process the delivery of the repaired or remanufactured products back to the customer."@en,
        "处理退货产品的复位，以便重新交付给客户；对客户退回的缺陷或失效产品进行维修或再制造；将维修或再制造后的产品交付回客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.5.3" ;
    skos:prefLabel "Manage repair/refurbishment"@en,
        "管理维修与翻新"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2.5> ;
    skos:definition "Moving a returned product back to inventory or stock. Whether a product is sufficient as returned, repaired, or refurbished, moving that product back to inventory for resale or returning to customer is the fnal step in Manage disposition of returned products."@en,
        "将退货产品重新入库或入仓。无论产品以原状、维修后或翻新状态返回，将其重新纳入库存用于再销售或返还客户，是‘管理退货产品处置’流程的最终环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.5.4" ;
    skos:prefLabel "Return to finished goods inventory"@en,
        "退回产成品库存"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Tracking the logistical act of delivering or releasing an inventory item or entity to targeted end users. Track how much inventory has been deployed at all the distribution centers, individually."@en,
        "跟踪将库存物品或实体交付或释放至目标终端用户的物流过程；分别跟踪各配送中心已部署的库存数量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.1" ;
    skos:prefLabel "Manage and track inventory deployment"@en,
        "管理并跟踪库存部署"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Coordinating the incoming inbound materials/products. Accept the delivery of these materials and the subsequent storage. Track them at the warehouse/distribution center."@en,
        "统筹进货/入库物料/产品的接收协调工作。完成物料/产品的交付签收及后续仓储存放，并在仓库/配送中心全程跟踪其状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.2" ;
    skos:prefLabel "Receive, inspect, and store inbound deliveries"@en,
        "接收、检验并存储到货交付物"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Keeping track of the availability of different materials/products at the warehouse and distribution centers."@en,
        "持续监控仓库及配送中心各类物料/产品的可供应状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.3" ;
    skos:prefLabel "Track product availability"@en,
        "跟踪产品可供应性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Packing and shipping the product to deliver to the customer. Take care of the internal and external packaging of the products in order to ensure safe transportation of the products from the warehouse to delivery locations. Notify the ERP system and/or Accounts Receivable Dept."@en,
        "打包并发货至客户；负责产品内外包装，确保产品从仓库至交付地点的安全运输；同步通知 ERP 系统和/或应收账款部门。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.4" ;
    skos:prefLabel "Pick, pack, and ship product for delivery"@en,
        "拣选、包装及发货交付"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.5" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Monitoring any discrepancies between electronic records that represent the inventory and the physical state of the inventory. Look for discrepancies such as phantom inventory, which includes products that an inventory accounting system considers to be available at the storage location but are not actually available."@en,
        "监控电子库存记录与实物库存状态之间的差异；识别虚盘库存等异常情形（即库存会计系统显示某地有货，但实际不可用）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.5" ;
    skos:prefLabel "Track inventory accuracy"@en,
        "跟踪库存准确性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.6" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Keeping a track on the storage and shipping performance of third-party agencies. Monitor logistics storage and shipping performance for third-party agencies. Use measures such as a logistics scoreboard, activity-based costing, economic value analysis, and balanced scorecards."@en,
        "跟踪第三方机构的仓储与运输绩效；采用物流记分板、作业成本法、经济价值分析及平衡计分卡等工具开展监测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.6" ;
    skos:prefLabel "Track third-party logistics storage and shipping performance"@en,
        "跟踪第三方物流（3PL）仓储与运输绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.7" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Administering the movement of the finished products that are processed by the organization through its warehouses. Track goods through the use of systems such as barcodes in order to monitor the volumes available, quantity of out-flowing goods, remaining shelf life of the product, etc.--ultimately, to best manage the warehouse capacity."@en,
        "管理组织经由其仓库流转的产成品移动；通过条码等系统追踪货物，以监控可用库存量、出库数量、剩余保质期等——最终实现仓库容量的最优管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.7" ;
    skos:prefLabel "Manage physical finished goods inventory"@en,
        "管理实物产成品库存"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3.8" ;
    skos:broader <https://oprocess.net/opf/node/4.4.3> ;
    skos:definition "Shipping items from one warehouse to another in a multi-warehouse environment. A warehouse transfer is typically handled electronically in a system designed to replicate the physical processes involved with transferring items from one warehouse to another."@en,
        "在多仓库环境中执行仓库间调拨；该操作通常通过专设系统以电子方式完成，系统模拟并复现实物调拨全流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3.8" ;
    skos:prefLabel "Manage warehouse transfers"@en,
        "管理仓库间调拨"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.4.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.4> ;
    skos:definition "Organizing the transportation and delivery of outbound products. Plan and organize the transportation, shipping, and delivery of the end products. Create a plan that specifies dispatch and delivery of the product to its destination, as well the transportation."@en,
        "统筹出库/发运产品的运输与交付作业。规划并组织终端产品的运输、装运与交付全过程；制定涵盖产品发运、运输路径及最终送达目的地的详细执行计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.4.1" ;
    skos:prefLabel "Plan, transport, and deliver outbound product"@en,
        "规划、运输及交付出库产品"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.4> ;
    skos:definition "Monitoring delivery performance when carrying products from the warehouse/distribution centers to the retailers or end consumers. Create a performance metrics based on the key performance indicators."@en,
        "监控从仓库/配送中心向零售商或终端消费者运送产品的交付绩效；基于关键绩效指标（KPI）构建交付绩效度量体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.4.2" ;
    skos:prefLabel "Track carrier delivery performance"@en,
        "跟踪承运商交付绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.4.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.4> ;
    skos:definition "Taking care of a range of functions related to the means of transport used for delivering the end products. Manage vehicle financing, vehicle maintenance, vehicle telematics (tracking and diagnostics), driver management, speed management, fuel management, and health and safety management."@en,
        "统筹与终端产品交付所用运输工具相关的各项职能：包括车辆融资、维保、车载远程信息处理（追踪与诊断）、驾驶员管理、车速管控、燃油管理及健康安全管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.4.3" ;
    skos:prefLabel "Manage transportation fleet"@en,
        "管理运输车队"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.4.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.4> ;
    skos:definition "Organizing and inspecting all account statements and any other documentation for the carriers used in delivery. Create, manage, and inspect all documents related to the financial, regulatory, and administrative accounts of all the carriers/freights. Generate receipts for all freight transactions."@en,
        "统筹并审核所有承运商相关账单及其他文件；创建、管理并审核涉及承运商/货运方财务、监管及行政账户的全部文档；生成每笔货运交易的收据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.4.4" ;
    skos:prefLabel "Process and audit carrier invoices and documents"@en,
        "处理并审核承运商发票及单据"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.1> ;
    skos:definition "Soliciting or acquiring information using various sources such as databases, customer interactions, and customer request forms. Hand them further up the hierarchy to deal with them. Categorize the user's request, determining if the request is supportable and prioritizing the request."@en,
        "通过数据库、客户互动、客户申请表等多种渠道采集或征集客户需求信息；按需向上级传递；对用户请求分类，判断其可行性并排序优先级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.1.1" ;
    skos:prefLabel "Process customer request"@en,
        "处理客户请求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.1> ;
    skos:definition "Documenting the individual customer service requirements solicited, along with personal information of the customers, in order to generate customized profiles that hasten the delivery process."@en,
        "将所征集的单个客户服务需求及客户个人信息完整归档，构建定制化客户档案，以加速服务交付进程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.1.2" ;
    skos:prefLabel "Create customer profile"@en,
        "创建客户档案"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.1> ;
    skos:definition "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and customer service work."@en,
        "设计服务提供商与客户之间的短期协议；一次性服务由服务接受方下单，服务完成后进行资源关联计费；使用服务工单记录服务内容及客户服务工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.1.3" ;
    skos:prefLabel "Generate last mile delivery order"@en,
        "生成末端配送订单"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.2> ;
    skos:definition "Developing a plan for sourcing and deploying the resources required to fulfill customer service needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete customer service requests and procure these resources. Identify and assess various sources in order to effectively create a resourcing plan."@en,
        "制定资源获取与部署计划，以满足客户服务需求；详尽记录完成服务请求所需各类资源（设备、资金、人员、时间等），并完成采购；识别并评估多种资源渠道，科学制定资源配置方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.2.1" ;
    skos:prefLabel "Create resourcing plan and schedule"@en,
        "制定资源配置计划与排程"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.2> ;
    skos:definition "Designing a detailed summary of customer service order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. Monitor the services delivered."@en,
        "编制客户服务工单需求的详细摘要，明确服务时间窗口与时长；对客户需求分类；持续监控服务交付情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.2.2" ;
    skos:prefLabel "Create last mile delivery service order fulfillment schedule"@en,
        "制定末端配送服务订单履约排程"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.3> ;
    skos:definition "Laying out a daily plan of specific service orders that need to be fulfilled. Document and systematically order these activities to ensure high effectiveness and efficiency."@en,
        "制定每日须完成的具体服务工单计划；系统化记录并有序安排各项活动，确保高效率与高成效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.3.1" ;
    skos:prefLabel "Organize daily last mile delivery order fulfillment schedule"@en,
        "组织每日末端配送订单履约排程"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.3> ;
    skos:definition "Dispatching and delivering the resources needed for the specific service requirements from the source/warehouse. Manage the dispatch, transportation, and delivery of the services."@en,
        "从源头/仓库调度满足特定服务需求所需的资源；统筹资源的调度、运输与交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.3.2" ;
    skos:prefLabel "Execute product delivery"@en,
        "执行产品交付"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.3> ;
    skos:definition "Handling and managing orders fulfilled, along with the orders are not or partially fulfilled to track the order fulfillment progress. Use electronic devices such as trackers and GPS in order track and ensure delivery of the orders."@en,
        "处理已履约、未履约或部分履约的订单，以跟踪订单履约进度；利用追踪器、GPS 等电子设备实时定位并确保订单交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.3.3" ;
    skos:prefLabel "Manage last mile delivery order fulfillment"@en,
        "管理末端配送订单履约"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.4> ;
    skos:definition "Determining the service orders that have been successfully delivered. Identify the service orders completed and delivered to the customer. Leverage communication systems to ensure coordination with the customers in order to avoid mishaps."@en,
        "确认已成功交付的服务工单；识别已完成并送达客户的服务工单；借助通信系统与客户保持协同，规避交付失误。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4.1" ;
    skos:prefLabel "Identify completed last mile delivery orders for feedback"@en,
        "识别已完成的末端配送订单以收集反馈"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.4.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.4> ;
    skos:definition "Determining orders which have not been completed or delivered. Identify the service orders that are partially or entirely incomplete, as well as the orders that have not been delivered to the customer. Use techniques such as project trackers to recognize the progress of the service orders."@en,
        "识别未完成或未交付的订单；判定部分或全部未完成的服务工单，以及尚未送达客户的服务工单；运用项目追踪器等工具掌握服务工单进展。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4.2" ;
    skos:prefLabel "Identify incomplete last mile delivery orders and last mile delivery service failures"@en,
        "识别未完成的末端配送订单及末端配送服务失败情形"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.4.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.4> ;
    skos:definition "Obtaining and procuring customer reviews or feedback on the services delivered. Design a customer feedback form, or communicate with the customer through the phone or online."@en,
        "获取并采集客户对已交付服务的评价或反馈；设计客户反馈表单，或通过电话、在线渠道与客户沟通。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4.3" ;
    skos:prefLabel "Solicit customer feedback on last mile services delivered"@en,
        "就已提供的末端配送服务征询客户反馈"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.5.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.4.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5.4> ;
    skos:definition "Assessing and incorporating customer reviews/feedback into the service plan to ensure high quality of service."@en,
        "评估客户反馈并将其融入服务计划，以确保持续提供高质量服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4.4" ;
    skos:prefLabel "Process customer feedback on last mile services delivered"@en,
        "处理客户关于末端配送服务的反馈"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/4.4.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sO1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.6> ;
