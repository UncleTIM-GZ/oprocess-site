        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Preparing reports that detail balances due or what to collect from customers at a certain point in time."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.4" ;
    skos:prefLabel "Prepare AR reports"@en,
        "准备 AR reports"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.5> a skos:Concept,
        opf:ProcessNode ;
