    skos:notation "6.3.2.2" ;
    skos:prefLabel "Validate warranty claim"@en,
        "验证 warranty claim"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.3.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2.3> ;
    skos:definition "Defining the issue of the claim. The warranty team will look into the issue and understand whether it is covered by the claim code or if more detail is required. Field service will be scheduled to further qualify the definition of the issue and to collect more evidence."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3.1" ;
    skos:prefLabel "Define issue"@en,
        "定义 issue"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2.3> ;
    skos:definition "Scheduling additional investigative field service. This is performed for high priority claims or claims that require additional investigation. Field service engineers will gather additional information, perform further investigation, and qualify the definition of the issue."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3.2" ;
    skos:prefLabel "Schedule field service"@en,
        "调度 field service"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2.3> ;
    skos:definition "Requesting receipt of a defective part for further investigation."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3.3" ;
    skos:prefLabel "Request and receive defective part"@en ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2.3> ;
    skos:definition "Investigating claims by an appropriate functional representative. Once the issue has been clearly defined and diagnosed and a recommendation for corrective action is determined, it will be provided to the warranty management team."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3.4" ;
    skos:prefLabel "Investigate issue/perform root cause analysis"@en ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2.3> ;
    skos:definition "Receiving investigative results to assess claim approval or denial. The warranty team will assess the results of the investigation and the recommendations for corrective action."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3.5" ;
    skos:prefLabel "Receive investigation result/recommendation for corrective action"@en,
        "接收 investigation result/recommendation for corrective action"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
    skos:definition "Identifying responsible party for a claim. There is no negotiation with the supplier at this point. There can be multiple warranties applicable to the same part: a new part warranty, a new product warranty (for the product the part is installed on), and a supplier warranty from the company that last repaired the part. The information required for this decision would be the output of Receive component/part and analyze fault [19728].\""@en,
        "Identifying responsible party for a claim. There is no negotiation with the supplier at this point. There can be multiple warranties applicable to the same part: a new part warranty, a new product warranty (for the product the part is installed on), and a supplier warranty from the company that last repaired the part. The information required for this decision would be the output of 接收 component/part and analyze fault [19728].\""@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.4" ;
    skos:prefLabel "Determine responsible party"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.3.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.5" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
    skos:definition "Authorizing claims prior to submittal."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.5" ;
    skos:prefLabel "Manage pre-authorizations"@en,
        "管理 pre-authorizations"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.3.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.6" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
    skos:definition "Following Defining issue [20098], an approval or rejection with be made against the warranty claim. If it is deemed that the claim falls within the warranty parameters, the claim will be approved. If the claim is deemed to fall outside warranty parameters, the claim with be rejected."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.6" ;
    skos:prefLabel "Approve or reject warranty claim"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.3.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.7" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
