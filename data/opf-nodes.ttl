        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.3> ;
    skos:definition "AI activity: Monitor alignment metrics."@en,
        "AI活动：监测对齐度指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
