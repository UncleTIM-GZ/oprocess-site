    skos:broader <https://oprocess.net/opf/node/8.2.9> ;
    skos:definition "Activity within ITIL practice 'Architecture Management'."@en,
        "ITIL 实践‘架构管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.9.3" ;
    skos:prefLabel "Govern architecture compliance"@en,
        "治理架构合规性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Determining and evaluating IT regulatory and audit requirements. Train employees on regulatory and audit requirements. Records for the appropriate regulatory and audit agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization."@en,
        "识别并评估 IT 监管与审计要求；开展员工监管与审计要求培训；向相关监管与审计机构留存完整记录；新产品流程须经相应监管机构审批后方可发布至组织内部。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.1" ;
    skos:prefLabel "Determine and evaluate IT regulatory and audit requirements"@en,
        "识别并评估IT监管与审计要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.10.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1.10> ;
    skos:definition "Include alignment with established cybersecurity frameworks like NIST CSF, ISO 27001, and ENISA risk management guidelines."@en,
        "确保与 NIST 网络安全框架（NIST CSF）、ISO/IEC 27001 及 ENISA 风险管理指南等公认网络安全框架保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.10.1" ;
    skos:prefLabel "Align IT risk management with cybersecurity frameworks"@en,
        "对齐IT风险管理与网络安全框架（如NIST CSF、ISO/IEC 27001）"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.3.1.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.10.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1.10> ;
    skos:definition "Ensure risk management processes are extended to cover OT systems and environments."@en,
        "确保风险管理流程覆盖运营技术（OT）系统与环境。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.10.2" ;
    skos:prefLabel "Integrate IT and OT risk management strategies"@en,
        "融合IT与OT风险管理策略"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Understand the risk tolerance levels of individual business units, given risk-return trade-offs for one or more anticipated and predictable consequences."@en,
        "结合一项或多项可预期、可预测后果的风险-收益权衡，明确各业务单元的风险容忍度水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.2" ;
    skos:prefLabel "Understand business unit risk tolerance"@en,
        "理解业务单元风险容忍度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Determine the specific maximum risk to take in quantitative terms for each relevant risk sub-category, including strategic, operational, financial, and compliance risks."@en,
        "以量化方式确定各相关风险子类别的最大可接受风险值，包括战略风险、运营风险、财务风险及合规风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.3" ;
    skos:prefLabel "Establish IT risk tolerance"@en,
        "确立IT风险容忍度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Establish an individual or a group who is ultimately accountable for ensuring that IT risks are managed appropriately."@en,
        "指定一名责任人或责任团队，最终承担确保 IT 风险得到恰当管理的职责。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.4" ;
    skos:prefLabel "Establish risk ownership"@en,
        "明确风险责任人"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Determine and maintain roles that are specialized in each risk areas and coordinating all risk management activities for IT function with due escalation structure."@en,
        "设立各风险领域专职岗位，统筹协调 IT 职能范围内的全部风险管理活动，并建立适当的升级机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.5" ;
    skos:prefLabel "Establish and maintain risk management roles"@en,
        "设立并维护风险管理角色"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Establishing compliance objectives which ensures that the organization has systems of internal controls that adequately measure and manage IT risk."@en,
        "确立合规目标，确保组织具备充分的内部控制体系，以准确衡量并有效管理 IT 风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.6" ;
    skos:prefLabel "Establish compliance objectives"@en,
        "设定合规目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.7" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Identifying and adopting information technology solutions to support changing regulatory compliance. Safeguard compliance and manage risk by outlining the risk policies and procedures."@en,
        "识别并采用信息技术解决方案，以支持不断变化的监管合规要求；通过制定风险政策与程序，保障合规并管控风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.7" ;
    skos:prefLabel "Identify systems to support compliance"@en,
        "识别支撑合规的系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.8" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Developing a timely and continuous process to identify and evaluate activities that might hinder IT operations or an IT project's goals."@en,
        "建立及时、持续的流程，识别并评估可能阻碍 IT 运营或 IT 项目目标实现的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.8" ;
    skos:prefLabel "Identify and evaluate IT risk"@en,
        "识别并评估IT风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.9" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Assess IT-related risk resilience strategies to ensure that the organization effectively manages its risk."@en,
        "评估 IT 相关韧性策略，确保组织有效管理其风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.9" ;
    skos:prefLabel "Evaluate IT-related risks resiliency"@en,
        "评估IT相关风险的韧性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Continuity Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.10> ;
    skos:definition "Activity within ITIL practice 'Service Continuity Management'."@en,
        "ITIL 实践「服务连续性管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.10.1" ;
    skos:prefLabel "Develop continuity plans"@en,
        "制定连续性计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

