    skos:broader <https://oprocess.net/opf/node/4.4.6> ;
    skos:definition "SCOR DS 14.0 activity in 'Order Stocked Product'."@en,
        "SCOR DS 14.0 ‘订购现货产品’活动。"@zh ;
