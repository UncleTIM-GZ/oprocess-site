    skos:definition "SCOR DS 14.0: Fulfill Engineer-to-Order Product (sF3)."@en,
        "SCOR DS 14.0：按设计订单生产产品交付（sF3）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.11" ;
    skos:prefLabel "Fulfill Engineer-to-Order Product"@en,
        "工程定制产品（ETO）履约"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5> ;
    skos:definition "Acquiring or soliciting information about specific service requirements for individual customers through the customer service function. Obtain information about customer specific requests, process these requests, and create customer profiles to generate a service order."@en,
        "通过客户服务职能获取或征集单个客户的特定服务需求信息；收集客户个性化请求，处理请求并建立客户档案，生成服务工单。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.1" ;
    skos:prefLabel "Confirm specific last mile delivery service requirements for individual customer"@en,
        "确认单个客户的末端配送服务具体要求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5> ;
    skos:definition "Dispatching resources for managing and fulfilling daily service requirements. Manage the progress of order fulfillment. Complete order blocks."@en,
        "调度资源以支撑日常服务需求的管理与履行；管控订单履约进度；完成订单区块闭环。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.3" ;
    skos:prefLabel "Provide last mile delivery service to specific customers"@en,
        "向特定客户提供末端配送服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

