    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. Identify processes, gather information gathering, interview participants, map processes, and perform analysis."@en,
        "Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. 识别 processes, gather information gathering, interview participants, map processes, and perform analysis."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.4" ;
    skos:prefLabel "Model and document processes"@en,
        "模型 and document processes"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Disclosing the information available on business processes. Ensure the availability of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information."@en,
        "Disclosing the information available on business processes. Ensure the 可用性 of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.5" ;
    skos:prefLabel "Publish processes"@en,
        "发布 processes"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.4> ;
    skos:definition "Providing training for the employees and process owners that administer the business processes. Design internal training programs or source third party agencies to provide the skills and training necessary."@en,
