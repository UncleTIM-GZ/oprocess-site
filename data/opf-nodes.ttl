    skos:prefLabel "Deliver approved content"@en,
        "Deliver approved 内容"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.7" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Controlling the use, evaluation, retention, and disposition of delivered content to ensure continued relevance, compliance, and value over time. Includes monitoring content quality and semantic coherence."@en,
        "Controlling the use, evaluation, retention, and disposition of delivered 内容 to ensure continued relevance, 合规, and value over time. Includes 监控 内容 质量 and semantic coherence."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.7" ;
    skos:prefLabel "Control delivered content"@en,
