    skos:notation "6.3.4.4.3" ;
    skos:prefLabel "Solicit customer feedback on services delivered"@en ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.4.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.4.4" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4.4> ;
    skos:definition "Assessing and incorporating customer reviews/feedback into the service plan to ensure high quality of service."@en,
        "Assessing and incorporating customer reviews/feedback into the service plan to ensure high 质量 of service."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.4.4" ;
    skos:prefLabel "Process customer feedback on services delivered"@en,
        "处理 customer feedback on services delivered"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

