        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP4" ;
    skos:broader <https://oprocess.net/opf/node/4.1.12> ;
    skos:definition "SCOR DS 14.0 activity in 'Plan Order'."@en,
        "SCOR DS 14.0‘规划订单’流程中的活动。"@zh ;
