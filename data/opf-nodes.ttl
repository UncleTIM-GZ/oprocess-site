<https://oprocess.net/opf/node/7.1.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.8" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Identifying skills, knowledge, and attributes that need enhancement in order to perform a job. Develop the appropriate training programs. These programs can be computer-based, classroom, or on-the-job training, etc."@en,
        "Identifying skills, knowledge, and attributes that need enhancement in order to perform a job. 开发 the appropriate 训练 programs. These programs can be computer-based, classroom, or on-the-job 训练, etc."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.8" ;
    skos:prefLabel "Design talent development program"@en,
        "设计 talent development program"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.9" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Creating HR programs and services such as employee engagements programs to promote positive employee behavior. Create a variety of programs and services to support employees' professional and personal needs at work and at home."@en,
        "Creating HR programs and services such as employee engagements programs to promote positive employee behavior. 创建 a variety of programs and services to support employees' professional and personal needs at work and at home."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.9" ;
    skos:prefLabel "Develop other HR programs"@en,
        "开发 other HR programs"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.1.3> ;
    skos:definition "Determining the accomplishment of HR and workforce goals and objectives. Evaluate the effectiveness of the HR function by estimating the present rate of achievement of the established objectives. Use metrics to determine if the objectives are being realized. Leverage measures such as turnover, training, return on human capital, costs of labor, and expenses per employee."@en,
        "Determining the accomplishment of HR and workforce goals and objectives. 评估 the effectiveness of the HR function by estimating the present rate of achievement of the established objectives. Use metrics to determine if the objectives are being realized. Leverage measures such as turnover, 训练, return on 人力资本, costs of labor, and expenses per employee."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.3.1" ;
    skos:prefLabel "Measure realization of HR objectives"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/7.1.3> ;
    skos:definition "Determining the role of the HR function in implementing the organizational strategy. Measure the correlation between the HR and workforce performance and the overall business strategy. Calculate the amount of contribution of the HR function to the overall business growth."@en,
        "Determining the role of the HR function in implementing the organizational 战略. Measure the correlation between the HR and workforce 绩效 and the overall business 战略. Calculate the amount of contribution of the HR function to the overall business growth."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.3.2" ;
    skos:prefLabel "Measure contribution of HR to business strategy"@en,
        "Measure contribution of HR to business 战略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/7.1.3> ;
    skos:definition "Conveying the plans for HR function to stakeholders. Ensure that the HR plans and strategy are effectively communicated to the people who can affect or be affected by the organization's actions, objectives, and policies such as the creditors, shareholders, employees, and suppliers. Provide regular updates to these stakeholders to ensure effective communication."@en,
        "Conveying the plans for HR function to stakeholders. Ensure that the HR plans and 战略 are effectively communicated to the people who can affect or be affected by the organization's actions, objectives, and policies such as the creditors, shareholders, employees, and suppliers. 提供 regular updates to these stakeholders to ensure effective communication."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.3.3" ;
    skos:prefLabel "Communicate HR plans and provide updates to stakeholders"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/7.1.3> ;
    skos:definition "Reassessing the strategies, plans, and policies of the HR function, with the objective of revising them. Revisit the schematic plans for the HR function. Taking stock of any suggestions or feedback from the stakeholders, revamp the blueprint of HR strategies and plans."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.3.4" ;
    skos:prefLabel "Review and revise HR plans"@en,
        "审查 and revise HR plans"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.4" ;
    skos:broader <https://oprocess.net/opf/node/7.1> ;
    skos:definition "Creating and implementing the tools for managing the competency levels of HR. Design a model for integrating HR planning with business planning. Assess current HR capacity based on the competencies against the capacity needed to achieve the vision, mission, and business goals of the organization. Consider factors such as employee development, career path, compensation policies, and performance management."@en,
        "Creating and implementing the tools for managing the competency levels of HR. 设计 a 模型 for integrating HR planning with business planning. 评估 current HR 容量 based on the competencies against the 容量 needed to achieve the vision, mission, and business goals of the organization. Consider factors such as employee development, career path, compensation policies, and 绩效 management."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.4" ;
    skos:prefLabel "Develop competency management models"@en,
        "开发 competency management 模型s"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/7.1> ;
    skos:definition "AI-era activity: AI-Driven Talent Acquisition."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.5" ;
    skos:prefLabel "AI-Driven Talent Acquisition"@en ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Creating a correspondence between the plan for hiring new employees and the desired employee requirements. Staff an adequate amount of people with the appropriate skills to effectively accomplish its legislative, regulatory, service, and production requirements."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.1" ;
    skos:prefLabel "Align staffing plan to work force plan and business unit strategies/resource needs"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Developing specific job requisitions, and ensuring their accessibility. Create and open a job requisition to fill the vacant positions within the organization. Clearly describe the job title, department, fill date, and the requisite skills and qualifications for the job."@en,
        "Developing specific job requisitions, and ensuring their accessibility. 创建 and open a job requisition to fill the vacant positions within the organization. Clearly describe the job title, department, fill date, and the requisite skills and qualifications for the job."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.2" ;
    skos:prefLabel "Open job requisitions"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Reviewing and authorizing requests to fill positions to ensure alignment with workforce plans, budget constraints, and organizational approval requirements"@en,
        "Reviewing and authorizing requests to fill positions to ensure 对齐 with workforce plans, budget constraints, and organizational approval requirements"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.3" ;
    skos:prefLabel "Approve job requisition"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Posting and advertising job descriptions. Display open job descriptions internally and externally. Use public portals, online portals, and websites to upload these requisitions in order for applications to be received."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.4" ;
    skos:prefLabel "Post job requisitions"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.5" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Making the necessary alterations to job requisitions. Revamp or revise the job requisitions in case a position is filled or is not vacant anymore, as well as in case of any new openings. (It involves Manage the internal/external job posting websites [10449] to make the necessary changes.)"@en,
        "Making the necessary alterations to job requisitions. Revamp or revise the job requisitions in case a position is filled or is not vacant anymore, as well as in case of any new openings. (It involves 管理 the internal/external job posting websites [10449] to make the necessary 变更s.)"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.5" ;
    skos:prefLabel "Modify job requisitions"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.6" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Informing and communicating with the hiring manager. Notify the manager responsible for the hiring process in cases of any new position openings or changes."@en,
        "Informing and communicating with the hiring manager. Notify the manager responsible for the hiring process in cases of any new position openings or 变更s."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.6" ;
    skos:prefLabel "Notify hiring manager"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1.7" ;
    skos:broader <https://oprocess.net/opf/node/7.2.1> ;
    skos:definition "Determining and managing the dates for the employee requisition process."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1.7" ;
    skos:prefLabel "Manage requisition dates"@en,
        "管理 requisition dates"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Defining the methods and channels for recruitments in order to maximize the amount of candidate availability. Use channels such as headhunting, job postings, job portals, networking websites, and media advertising. Choose from the various methods of recruitment such as internal/external third-party sourcing."@en,
        "Defining the methods and channels for recruitments in order to maximize the amount of candidate 可用性. Use channels such as headhunting, job postings, job portals, networking websites, and media advertising. Choose from the various methods of recruitment such as internal/external third-party sourcing."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.1" ;
    skos:prefLabel "Determine recruitment methods and channels"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Organizing and executing recruiting activities and events. Activities and events include on-campus hiring, refresher courses, information sessions, career fairs, etc. to increase the coverage of the sourcing in order to ensure that the most deserving and appropriate candidates are hired."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.2" ;
    skos:prefLabel "Perform recruiting activities/events"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Cultivating relationships with potential job candidates even when there are no immediate openings. Building the talent pipeline for potential future hiring needs."@en,
        "Cultivating relationships with potential job candidates even when there are no immediate openings. Building the talent 流水线 for potential future hiring needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.3" ;
    skos:prefLabel "Develop and maintain candidate pool"@en,
        "开发 and maintain candidate pool"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Establishing and maintaining relationships with recruitment vendors (suppliers). Create and maintain relationships with third-party agencies such as staffing and firms to expand. Use these relationships to implement the sourcing process effectively."@en,
        "Establishing and maintaining relationships with recruitment vendors (suppliers). 创建 and maintain relationships with third-party agencies such as staffing and firms to expand. Use these relationships to implement the sourcing process effectively."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.4" ;
    skos:prefLabel "Manage recruitment vendors"@en,
        "管理 recruitment vendors"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Creating and managing a recruiting strategy where current employees are rewarded for referring qualified candidates for employment."@en,
        "Creating and managing a recruiting 战略 where current employees are rewarded for referring qualified candidates for employment."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.5" ;
    skos:prefLabel "Manage employee referral programs"@en,
        "管理 employee referral programs"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2.6" ;
    skos:broader <https://oprocess.net/opf/node/7.2.2> ;
    skos:definition "Establishing and maintaining internal and external channels for recruiting. Extract the best out of every recruitment channel. Manage all the processes related to all the sourcing channels including maintaining career pages on the organization website."@en,
        "Establishing and maintaining internal and external channels for recruiting. Extract the best out of every recruitment channel. 管理 all the processes related to all the sourcing channels including maintaining career pages on the organization website."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2.6" ;
    skos:prefLabel "Manage recruitment channels"@en,
        "管理 recruitment channels"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.3> ;
    skos:definition "Identifying and implementing tools for the selection of candidates. Recognize candidate selection tools such as screening, telephone interviews, hiring manager interviews, drug testing, and skills assessment. Effectively deploy these tools to check if the candidates fit in the workplace or not, as well as to ensure workplace safety."@en,
        "Identifying and implementing tools for the selection of candidates. Recognize candidate selection tools such as screening, telephone interviews, hiring manager interviews, drug testing, and skills assessment. Effectively deploy these tools to check if the candidates fit in the workplace or not, as well as to ensure workplace 安全."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.3.1" ;
    skos:prefLabel "Identify and deploy candidate selection tools"@en,
        "识别 and deploy candidate selection tools"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2.3> ;
    skos:definition "Assessing the candidates by their performance in the interviews. Conduct HR interview, technical interview, hiring manager interview, etc. Understand the mindset of the candidate, and comprehend his/her personal and professional lives."@en,
        "Assessing the candidates by their 绩效 in the interviews. 开展 HR interview, technical interview, hiring manager interview, etc. Understand the mindset of the candidate, and comprehend his/her personal and professional lives."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.3.2" ;
    skos:prefLabel "Interview candidates"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2.3> ;
    skos:definition "Examining the candidates through tests. Prepare tools such as aptitude, technical, and grammar tests. Test the skills of the candidate through a written, oral, or computerized test."@en,
        "Examining the candidates through tests. 准备 tools such as aptitude, technical, and grammar tests. 测试 the skills of the candidate through a written, oral, or computerized test."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.3.3" ;
    skos:prefLabel "Test candidates"@en,
        "测试 candidates"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/7.2.3> ;
    skos:definition "Approving the deserving candidates, and rejecting the others. Examining the performance of candidates. Ensure candidates would fit well with the organization. (Assess performance from Interview candidates [10457] and Test candidates [10458].)"@en,
        "Approving the deserving candidates, and rejecting the others. Examining the 绩效 of candidates. Ensure candidates would fit well with the organization. (评估 绩效 from Interview candidates [10457] and 测试 candidates [10458].)"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.3.4" ;
    skos:prefLabel "Select and reject candidates"@en,
        "选择 and reject candidates"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.4> ;
    skos:definition "Compiling job-related information for the selected candidates in order to make up a job. Include information about the job description, reporting relationship, salary, bonus potential, benefits, and vacation allotment."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.4.1" ;
    skos:prefLabel "Draw up and make offer"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2.4> ;
    skos:definition "Negotiating an offer with selected candidates. Discuss the job offer with the candidate to ensure a mutual understanding."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.4.2" ;
    skos:prefLabel "Negotiate offer"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.4.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2.4> ;
    skos:definition "Wrapping up the process for hiring candidates. Agree to all hiring terms and conditions. Have the candidate accept and sign the job offer."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.4.3" ;
    skos:prefLabel "Hire candidate"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.5> ;
    skos:definition "Conducting a background investigation on the candidates with the objective of gathering and compiling criminal, commercial, medical, and financial information."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5.1" ;
    skos:prefLabel "Obtain candidate background information"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2.5> ;
    skos:definition "Creating and documenting the records of all applicants. Manage all individual applicants, including hires and non-hires. Maintain records to avoid any duplication and promote efficiency."@en,
        "Creating and documenting the records of all applicants. 管理 all individual applicants, including hires and non-hires. 维护 records to avoid any duplication and promote efficiency."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5.2" ;
    skos:prefLabel "Create applicant record"@en,
        "创建 applicant record"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2.5.3> ;
    skos:definition "Identifying the requirements for the position to be filled. Determine the experience and skills necessary to perform the tasks outlined."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5.3.1" ;
    skos:prefLabel "Complete position classification and level of experience"@en ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/7.2.5> ;
    skos:definition "Retaining and storing the records of the candidates who were rejected and not hired to ensure future availability in case the need arises. Create a centralized repository of profiles. Label these records in order to readily identify them. Add remarks for any future consideration."@en,
        "Retaining and storing the records of the candidates who were rejected and not hired to ensure future 可用性 in case the need arises. 创建 a centralized repository of profiles. Label these records in order to readily identify them. Add remarks for any future consideration."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5.4" ;
    skos:prefLabel "Archive and retain records of non-hires"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.1> ;
    skos:definition "Creating and maintaining a mechanism through which new employees acquire the necessary knowledge, skills, and behaviors to become effective organizational members and insiders. Conduct formal meetings, lectures, videos, printed materials, and/or computer-based orientations to introduce newcomers to their new jobs and the organization."@en,
        "Creating and maintaining a mechanism through which new employees acquire the necessary knowledge, skills, and behaviors to become effective organizational members and insiders. 开展 formal meetings, lectures, videos, printed materials, and/or computer-based orientations to introduce newcomers to their new jobs and the organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.1.1" ;
    skos:prefLabel "Develop employee onboarding program"@en,
        "开发 employee onboarding program"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.1> ;
    skos:definition "Bringing the employee on-boarding program into effect. Implement Develop employee onboarding program [10474]. Conduct training sessions and employee engagement programs."@en,
        "Bringing the employee on-boarding program into effect. 实施 开发 employee onboarding program [10474]. 开展 训练 sessions and employee engagement programs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.1.2" ;
    skos:prefLabel "Implement employee onboarding program"@en,
        "实施 employee onboarding program"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.1> ;
    skos:definition "Assessing the performance and effectiveness of employee on-boarding program. Examine the performance of on-boarding program through feedback and reviews from the new employees. Create web and written forms. Obtain information through face-to-face discussions."@en,
        "Assessing the 绩效 and effectiveness of employee on-boarding program. Examine the 绩效 of on-boarding program through feedback and reviews from the new employees. 创建 web and written forms. Obtain information through face-to-face discussions."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.1.3" ;
    skos:prefLabel "Monitor and update employee onboarding program"@en,
        "监控 and update employee onboarding program"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.2> ;
    skos:definition "Outlining the objectives for employee performance. Establish key performance objectives and measures such as customer-focus objectives, financially focused objectives, and employee growth objectives."@en,
        "Outlining the objectives for employee 绩效. 建立 key 绩效 objectives and measures such as customer-focus objectives, financially focused objectives, and employee growth objectives."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.2.1" ;
    skos:prefLabel "Define employee performance objectives"@en,
        "定义 employee 绩效 objectives"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.2> ;
    skos:definition "Execution of employee reviews/performance on a frequent basis. May include ongoing feedback and coaching activities."@en,
        "Execution of employee reviews/绩效 on a frequent basis. May include ongoing feedback and coaching activities."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.2.2" ;
    skos:prefLabel "Review employee performance"@en,
        "审查 employee 绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.2> ;
    skos:definition "Document the results of both formal reviews to include both positive and negative feedback and commentary. May include acknowledgement by involved parties."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.2.3" ;
    skos:prefLabel "Document employee performance"@en,
        "Document employee 绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3.2> ;
    skos:definition "Assessing and revamping performance programs, including the instruments used to measure employee performance standards. Review and upgrade these performance programs to avoid any deprivations and ensure effectiveness."@en,
        "Assessing and revamping 绩效 programs, including the instruments used to measure employee 绩效 standards. 审查 and upgrade these 绩效 programs to avoid any deprivations and ensure effectiveness."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.2.4" ;
    skos:prefLabel "Monitor and update performance program"@en,
        "监控 and update 绩效 program"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3> ;
    skos:definition "Outlining the guidelines for development of employees. Design development policies and procedures to identify areas of growth for employees, either in their current position or in preparation for future roles. Include topics related to knowledge and skill development."@en,
        "Outlining the guidelines for development of employees. 设计 development policies and procedures to identify areas of growth for employees, either in their current position or in preparation for future roles. Include topics related to knowledge and skill development."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.1" ;
    skos:prefLabel "Define employee development guidelines"@en,
        "定义 employee development guidelines"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3> ;
    skos:definition "Designing a future career path for the employees that encourages them to explore and gather information."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.2" ;
    skos:prefLabel "Develop employee career plans and career paths"@en,
        "开发 employee career plans and career paths"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3> ;
    skos:definition "Administering the development of employee skills. Conduct training, coaching and mentoring, job-rotation and cross training, lateral moves, etc. Maintain records of employee skills and competencies."@en,
        "Administering the development of employee skills. 开展 训练, coaching and mentoring, job-rotation and cross 训练, lateral moves, etc. 维护 records of employee skills and competencies."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.3" ;
    skos:prefLabel "Manage employee skill and competency development"@en,
        "管理 employee skill and competency development"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3.4> ;
    skos:definition "Determining roles that are essential to organizational performance or continuity and that require succession planning."@en,
        "Determining roles that are essential to organizational 绩效 or continuity and that require succession planning."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.4.1" ;
    skos:prefLabel "Identify critical roles"@en,
        "识别 critical roles"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3.4> ;
    skos:definition "Identifying and selecting employees with the potential to assume critical roles based on defined criteria and future capability requirements."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.4.2" ;
    skos:prefLabel "Select potential successors"@en,
        "选择 potential successors"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3.4> ;
    skos:definition "Creating and executing development plans for identified successors to prepare them for future roles through targeted learning and experience opportunities."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.4.3" ;
    skos:prefLabel "Develop and implement individual succession plans"@en,
        "开发 and implement individual succession plans"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3.4> ;
    skos:definition "Reviewing succession plans on a regular basis and updating them to reflect changes in roles, talent, organizational priorities, and performance outcomes."@en,
        "Reviewing succession plans on a regular basis and updating them to reflect 变更s in roles, talent, organizational priorities, and 绩效 outcomes."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.4.4" ;
    skos:prefLabel "Review and update succession plans"@en,
        "审查 and update succession plans"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Identifying the skills, competencies, and knowledge required by the organization to achieve its strategic goals and ensuring employees' growth directly contributes to achieving those goals."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.1" ;
    skos:prefLabel "Align organizational development needs to employees"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Defining the skills, knowledge, abilities, and attributes needed to achieve the desired core capabilities and competencies of the organization."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.2" ;
    skos:prefLabel "Define employees competencies and skills"@en,
        "定义 employees competencies and skills"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Aligning the learning programs with the core capabilities and competencies of the organization. Contextualize the training programs so that employees can expand their knowledge base and add new skills in line with the core competencies of the organization."@en,
        "Aligning the learning programs with the core capabilities and competencies of the organization. Contextualize the 训练 programs so that employees can expand their knowledge base and add new skills in line with the core competencies of the organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.3" ;
    skos:prefLabel "Align learning programs with competencies and skills"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Determining the training necessitated by business processes, using an examination of skill sets that are needed by the organization and those already possessed. Examine the various skills required by individual employees. Design training in light of the availability of resources to provide specific segments of training."@en,
        "Determining the 训练 necessitated by business processes, using an examination of skill sets that are needed by the organization and those already possessed. Examine the various skills required by individual employees. 设计 训练 in light of the 可用性 of resources to provide specific segments of 训练."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.4" ;
    skos:prefLabel "Establish training needs by analysis of required and available skills"@en,
        "建立 训练 needs by analysis of required and available skills"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Creating, implementing, and managing the programs for training employees. Create and design sessions on the basis of the needs and the availability of the skills. Conduct the sessions in person or virtually. Manage all aspects related to the training programs. Consider including literacy training, interpersonal skills training, technical training, problem-solving training, diversity or sensitivity training, etc."@en,
        "Creating, implementing, and managing the programs for 训练 employees. 创建 and design sessions on the basis of the needs and the 可用性 of the skills. 开展 the sessions in person or virtually. 管理 all aspects related to the 训练 programs. Consider including literacy 训练, interpersonal skills 训练, technical 训练, 问题-solving 训练, diversity or sensitivity 训练, etc."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.5" ;
    skos:prefLabel "Develop, conduct, and manage employee training programs"@en,
        "开发, conduct, and manage employee 训练 programs"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.6.1" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4.6> ;
    skos:definition "Coordinating with third party certification authorities to provide training and certifications for necessary skills."@en,
        "Coordinating with third party certification authorities to provide 训练 and certifications for necessary skills."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.6.1" ;
    skos:prefLabel "Liaise with external certification authorities"@en ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.4.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.6.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4.6> ;
    skos:definition "Providing tests to the workforce that will satisfy completion of certifications."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.6.2" ;
    skos:prefLabel "Administer certification tests"@en ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.4.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.6.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4.6> ;
    skos:definition "Ascertaining the experience level needed to qualify for a specific job or certification within the organization. Some certificates require practical experience as well as training programs."@en,
        "Ascertaining the experience level needed to qualify for a specific job or certification within the organization. Some certificates require practical experience as well as 训练 programs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.6.3" ;
    skos:prefLabel "Appraise experience qualifications"@en ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.4.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.6.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4.6> ;
    skos:definition "Administering certificates to all candidates that have successfully met experience qualifications, and passed all tests necessary to obtain the certificate."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.6.4" ;
    skos:prefLabel "Administer certificate issue and maintenance"@en ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.3.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.7" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Oversight of the organization's learning programs.  This process also includes the effectiveness of these programs."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.7" ;
    skos:prefLabel "Monitor and evaluate learning programs"@en,
        "监控 and evaluate learning programs"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/7.3> ;
    skos:definition "AI-era activity: AI-Powered Employee Experience."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
