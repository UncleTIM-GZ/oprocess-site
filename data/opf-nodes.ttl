    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.9.2" ;
    skos:prefLabel "Maintain architecture repository"@en,
        "维护架构存储库"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

