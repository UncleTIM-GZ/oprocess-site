    dcterms:source "SCOR:DS14:sSR2" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Source Return MRO Product (sSR2)."@en,
        "SCOR DS 14.0：维修、保养与大修（MRO）产品退货采购（sSR2）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.6" ;
    skos:prefLabel "Source Return MRO Product"@en,
        "寻源退货（维修、保养及运营用品）"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sSR3" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Source Return Excess Product (sSR3)."@en,
        "SCOR DS 14.0：过剩产品退货采购（sSR3）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.7" ;
    skos:prefLabel "Source Return Excess Product"@en,
        "寻源退货（过剩产品）"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sFR1" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Fulfill Return Defective Product (sFR1)."@en,
        "SCOR DS 14.0：履行退回缺陷产品（sFR1）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.8" ;
    skos:prefLabel "Fulfill Return Defective Product"@en,
        "履行缺陷产品退货流程"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sFR2" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Fulfill Return MRO Product (sFR2)."@en,
        "SCOR DS 14.0：履行退回维护、维修与大修产品（sFR2）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.9" ;
    skos:prefLabel "Fulfill Return MRO Product"@en,
        "履行MRO产品退货流程"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/5.1> ;
    skos:definition "Establishing service delivery governance through a system that manages performance, development, and direction. Allow for customer feedback on delivery satisfaction."@en,
        "通过绩效、开发与方向管理体系，建立服务交付治理机制，并支持客户对交付满意度的反馈。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.1" ;
    skos:prefLabel "Establish service delivery governance"@en,
        "建立服务交付治理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/6.2> ;
    skos:definition "Creating and administering the workforce deployed for the customer service process. Forecast the customer workforce needs to correctly schedule the workforce. Track the utility of the workforce deployed. Examine the interactions between the customer and customer service representatives to achieve high quality."@en,
        "统筹客户服务人力的配置与运营：预测人力需求以科学排班；跟踪人力使用效能；分析客户与客服代表的交互质量，持续提升服务品质。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.2.1" ;
    skos:prefLabel "Plan and manage customer service workforce"@en,
        "规划与管理客户服务人力团队"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3" ;
    skos:broader <https://oprocess.net/opf/node/6.0> ;
    skos:definition "Assigning post-sales policies and paying claims on purchased products.  This is a process that is an administrative function focused on creating rules (claim codes). This group ensures that claims are valid and are processed quickly.  As well as to quickly determine responsibility for claim settlement."@en,
        "制定售后政策并支付已购产品理赔款项；属行政管理职能，聚焦理赔规则（理赔代码）制定；确保理赔有效性与快速处理，并迅速厘清理赔责任归属。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3" ;
    skos:prefLabel "Service products after sales"@en,
        "售后产品服务"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/6.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4" ;
    skos:broader <https://oprocess.net/opf/node/6.3> ;
    skos:definition "Validating specific service requirements for individual customers. Determine and schedule resource to fulfill these requirements. Provide service to specific individual customers. Ensure the quality of service delivery."@en,
        "校验个体客户的特定服务需求，统筹调度资源予以满足，面向特定客户提供定制化服务，并保障交付质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4" ;
    skos:prefLabel "Service products"@en,
        "提供产品服务"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4> ;
    skos:definition "Guaranteeing the quality of service provided to customers. Identify the successful and unsuccessful orders along with the service failures. Collect customer feedback. Process the feedback to ensure the quality of service in the future."@en,
        "保障面向客户的整体服务质量；识别成功与失败的服务工单及服务失效情形；收集客户反馈；分析反馈以持续提升未来服务质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.4" ;
    skos:prefLabel "Ensure quality of service"@en,
        "保障服务质量"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.3" ;
    skos:broader <https://oprocess.net/opf/node/7.1> ;
    skos:definition "Supervising the HR and workforce strategy, plans, and policies in order to refurbish them whenever needed. Determine the performance of HR and workforce plans and policies by measuring the objective achievement rate and its contribution to the overall business strategy. Ensure that information about these plans and strategies is effectively communicated to various stakeholders. Incorporate any suggestions by these stakeholders when revising HR and workforce plans and policies."@en,
        "监督人力资源（HR）与员工队伍战略、计划及政策的执行情况，并根据需要及时更新完善。通过衡量目标达成率及其对整体业务战略的贡献度，评估HR与员工队伍相关计划及政策的绩效表现。确保相关计划与战略信息有效传达至各利益相关方，并在修订HR与员工队伍计划及政策时充分吸纳各方建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.3" ;
    skos:prefLabel "Monitor and update HR strategies, plans, and policies"@en,
        "监控与更新人力资源战略、计划及政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2> ;
    skos:definition "Evaluating and selecting potential employees through interviews, tests, etc."@en,
        "通过面试、测评等方式评估与甄选候选人。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.3" ;
    skos:prefLabel "Screen and select candidates"@en,
        "候选人筛选与甄选"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5" ;
    skos:broader <https://oprocess.net/opf/node/7.2> ;
    skos:definition "Creating and maintaining a system for managing the information of applicants. Create records for all candidates who apply. Maintain and track information through the use applicant-tracking systems."@en,
        "构建并维护应聘者信息管理系统：为所有应聘者建立档案；依托申请人跟踪系统（ATS）实现信息集中化、全过程追踪管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5" ;
    skos:prefLabel "Manage applicant information"@en,
        "应聘者信息管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.2" ;
    skos:broader <https://oprocess.net/opf/node/7.3> ;
    skos:definition "Defining individual performance objectives. Review performance in order to provide appraisals. Evaluate the efficiency and effectiveness of the current performance program. Update it regularly."@en,
        "设定个人绩效目标；开展绩效回顾以提供绩效评价；评估现行绩效管理体系的效率与有效性，并定期更新优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.2" ;
    skos:prefLabel "Manage employee performance"@en,
        "管理员工绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3" ;
    skos:broader <https://oprocess.net/opf/node/7.3> ;
    skos:definition "Establishing employee development guidelines. Lay out career paths and plans for individual employees. Manage the development of their skills to enhance their skills, ability, and knowledge."@en,
        "制定员工发展指导方针；为个体员工规划职业路径与发展计划；统筹员工能力提升，增强其技能、能力与知识水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3" ;
    skos:prefLabel "Manage employee career development"@en,
        "管理员工职业发展"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3.3> ;
    skos:definition "Establishing plans to ensure continuity in critical roles by identifying potential successors and preparing them for future leadership or specialist positions."@en,
        "制定关键岗位继任计划，通过识别潜在接班人并开展针对性培养，保障核心岗位人才连续性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.3.4" ;
    skos:prefLabel "Establish succession plans"@en,
        "制定继任计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.3.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4.6" ;
    skos:broader <https://oprocess.net/opf/node/7.3.4> ;
    skos:definition "Managing identified training programs for employees. Engage with industries to provide certifications, administer certification test, and maintain active certification."@en,
        "统筹员工认证类培训项目的管理；对接行业机构开展认证合作，组织认证考试，维持证书有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4.6" ;
    skos:prefLabel "Manage examinations and certifications"@en,
        "管理考试与认证"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.2" ;
    skos:broader <https://oprocess.net/opf/node/7.5> ;
    skos:definition "Managing and ensuring benefits enrollment by the employees. Process any benefit claims made by the employees. Balance the estimated amount and entitled amount of benefits."@en,
        "管理员工福利登记，处理员工提出的福利申领请求，并平衡预估福利金额与应得福利金额。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.2" ;
    skos:prefLabel "Manage and administer benefits"@en,
        "管理与实施员工福利"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.2" ;
    skos:broader <https://oprocess.net/opf/node/7.6> ;
    skos:definition "Managing the process of employee separation, including leaves of absence, resignations, discharges, and layoffs. Inform the employee of the termination. Complete paperwork for continuation of benefits. Enter employment status change into system."@en,
        "管理员工离职全流程，涵盖各类休假、辞职、解雇及裁员；及时告知员工终止劳动关系决定；完成福利延续手续；在系统中更新就业状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.2" ;
    skos:prefLabel "Manage separation"@en,
        "管理员工离职"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Identifying changing needs of staff dependent on information technology based on continuous improvement to deliver results according to organizational goals. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "基于持续改进机制，识别依赖信息技术的员工不断变化的需求，确保 IT 能力持续匹配组织目标；涵盖人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.2" ;
    skos:prefLabel "Identify IT customer transformation needs"@en,
        "识别IT客户转型需求"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.7" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Proactively manage IT service levels against IT customer requirements."@en,
        "主动依据IT客户需求，开展IT服务水平管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.7" ;
    skos:prefLabel "Analyze service performance"@en,
        "分析服务绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage AIOps."@en,
        "AI 流程：管理人工智能运维（AIOps）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.3" ;
    skos:prefLabel "Manage AIOps"@en,
        "管理AI驱动运维（AIOps）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage Robotic Process Automation."@en,
        "AI 流程：管理机器人流程自动化（RPA）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.4" ;
    skos:prefLabel "Manage Robotic Process Automation"@en,
        "管理机器人流程自动化（RPA）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage Data Science Workflows."@en,
        "AI 流程：管理数据科学工作流"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.5" ;
    skos:prefLabel "Manage Data Science Workflows"@en,
        "管理数据科学工作流"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage AI Infrastructure."@en,
        "AI 流程：管理 AI 基础设施"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.6" ;
    skos:prefLabel "Manage AI Infrastructure"@en,
        "管理AI基础设施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Outlining and maintaining the organization's IT architecture. Establish the IT architecture definition and framework. Ensure the relevance of IT. Create and confirm the approach for IT maintenance. Create rules and regulations to guide IT architecture. Authenticate and finalize all IT related research and innovation that takes place within the organization."@en,
        "制定并持续维护组织的IT架构；确立IT架构定义与框架；确保IT的相关性；制定并确认IT运维方法；制定指导IT架构的规则与规范；审核并最终确认组织内部开展的所有IT相关研究与创新。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.3" ;
    skos:prefLabel "Define and maintain enterprise architecture"@en,
        "定义并维护企业架构"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Creating and establishing the value portfolio. Defining, analyzing, and examining the value of projects, investments, and activities of the IT function."@en,
        "构建并确立价值组合；定义、分析与评估IT职能所涉项目、投资与活动的价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.6" ;
    skos:prefLabel "Manage IT value portfolio"@en,
        "管理IT价值投资组合"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Developing resilience strategies across IT and cybersecurity functions to proactively avoid risks and disruptions. Identify critical risks, prioritize them based on business needs, and establish mitigation approaches to ensure the organization’s ability to adapt and recover from cyber and IT-related threats."@en,
        "在 IT 与网络安全职能范围内制定韧性策略，主动规避风险与中断；识别关键风险，依据业务需求进行优先级排序，并建立缓解措施，保障组织应对及恢复网络与 IT 相关威胁的能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.2" ;
    skos:prefLabel "Develop IT resilience strategy"@en,
        "制定IT韧性战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Information Security Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "ITIL V5 practice: Information Security Management. Mapped to Develop and manage IT resilience and risk."@en,
        "ITIL V5实践：信息安全管理体系（Information Security Management），映射至IT韧性与风险管理能力建设。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.9" ;
    skos:prefLabel "Information Security Management"@en,
        "信息安全管理体系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Creating strategies to manage the organization's information and content. Outline the architecture for information. Administer information resources. Administer the management of data and content."@en,
        "制定组织信息与内容管理战略；规划信息架构；管理信息资源；统筹数据与内容管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4" ;
    skos:prefLabel "Manage information"@en,
        "管理信息"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.4" ;
    skos:broader <https://oprocess.net/opf/node/8.4> ;
    skos:definition "Creating strategies to administer information and content. Understand the needs of the organization for information and content management. Realize the role of IT services for implementing the overall business strategy. Assess the implications of new technologies for managing information and content. Identify and prioritize the most effective and efficient actions for managing information and content."@en,
        "制定信息与内容管理策略；理解组织对信息与内容管理的需求；明确 IT 服务在落实整体业务战略中的作用；评估新技术对信息与内容管理的影响；识别并优先推进最高效、最有效的管理举措。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.4" ;
    skos:prefLabel "Manage business information"@en,
        "管理业务信息"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Change Enablement" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "ITIL V5 practice: Change Enablement. Mapped to Deploy services/solutions."@en,
        "ITIL V5实践：变更启用（Change Enablement），映射至服务/解决方案部署。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.6" ;
    skos:prefLabel "Change Enablement"@en,
        "变更赋能"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Release Management" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "ITIL V5 practice: Release Management. Mapped to Deploy services/solutions."@en,
        "ITIL V5实践：发布管理（Release Management），映射至服务/解决方案部署。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.7" ;
    skos:prefLabel "Release Management"@en,
        "发布管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Monitoring and Event Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "ITIL V5 practice: Monitoring and Event Management. Mapped to Create and manage support services/solutions."@en,
        "ITIL V5 实践：监控与事件管理。映射至「构建与管理支持服务/解决方案」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.12" ;
    skos:prefLabel "Monitoring and Event Management"@en,
        "监控与事件管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.14> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Problem Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "ITIL V5 practice: Problem Management. Mapped to Create and manage support services/solutions."@en,
        "ITIL V5 实践：问题管理。映射至「构建与管理支持服务/解决方案」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.14" ;
    skos:prefLabel "Problem Management"@en,
        "问题管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Level Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "ITIL V5 practice: Service Level Management. Mapped to Create and manage support services/solutions."@en,
        "ITIL V5实践：服务级别管理（Service Level Management），映射至“创建与管理支持服务/解决方案”。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.9" ;
    skos:prefLabel "Service Level Management"@en,
        "服务级别管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.1> ;
    skos:definition "Deciding which expenses can be avoided to reduce some costs and increase revenues. Plan and control the organization's budget to forecast future expenditures."@en,
        "识别可规避支出以降低成本、提升收入。统筹规划与管控组织预算，预测未来开支。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.4" ;
    skos:prefLabel "Perform cost management"@en,
        "开展成本管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.10" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Managing cash collections and disbursements made by operating units across the enterprise. When appropriate, transfer cash from the operating units to parent-level bank accounts managed by the organization's treasury team."@en,
        "统筹管理全集团各运营单元的现金收付；视情况将资金划转至由组织司库团队管理的母公司银行账户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.10" ;
    skos:prefLabel "Manage international funds/consolidation"@en,
        "管理国际资金／合并报表"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.4> ;
    skos:definition "Preparing a project finance report to solicit approvals in capital projects. Prepare budgets for projects that require heavy investments. Report on project finances to solicit approvals from management."@en,
        "编制项目融资报告以获取资本性项目审批。为重大投资项目编制预算，并向管理层汇报项目财务情况以争取审批。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.1" ;
    skos:prefLabel "Perform capital planning and project approval"@en,
        "开展资本规划与项目审批"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Handling risks arising from changes in the interest rate."@en,
        "管理因利率变动引发的风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.2" ;
    skos:prefLabel "Manage interest rate risk"@en,
        "管理利率风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Taking care of exposure risks. Maintain financial investments in particular investments or a portfolios that could be risky for the organization."@en,
        "管理敞口风险，持续持有特定投资或投资组合，该等投资可能对组织构成财务风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.4" ;
    skos:prefLabel "Manage exposure risk"@en,
        "管理风险敞口"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.3" ;
    skos:broader <https://oprocess.net/opf/node/9.8> ;
    skos:definition "Reporting on internal controls compliance to the appropriate authority, including IT regulations and pertinent data."@en,
        "向相关监管方报告内部控制合规情况，包括信息技术（IT）监管要求及相关数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.3" ;
    skos:prefLabel "Report on internal controls compliance"@en,
        "报告内部控制合规情况"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.0" ;
    skos:definition "Relating to the design, construction, acquisition, and management of both productive and non-productive assets."@en,
        "涵盖生产性与非生产性资产的设计、建设、购置及全生命周期管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.0" ;
    skos:prefLabel "Acquire, Construct, and Manage Assets"@en,
        "资产获取、建设与管理"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1" ;
    skos:broader <https://oprocess.net/opf/node/10.0> ;
    skos:definition "Planning, acquiring, and managing facilities, workspaces, and supporting assets. Acquire, configure, and manage facilities and workspaces, to include supporting equipment and materials."@en,
        "规划、获取并管理设施、办公空间及相关支撑性资产；完成设施与办公空间的采购、配置及运维，含配套设备与物料。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1" ;
    skos:prefLabel "Plan and acquire assets"@en,
        "规划与获取资产"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/10.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2" ;
    skos:broader <https://oprocess.net/opf/node/10.1> ;
    skos:definition "Recognizing the needs of facility users in order to construct a project proposal that meets those needs."@en,
        "识别设施使用者需求，据此编制满足需求的项目提案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2" ;
    skos:prefLabel "Plan facility"@en,
        "规划设施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2" ;
    skos:broader <https://oprocess.net/opf/node/10.2> ;
    skos:definition "Outlining the steps and strategies needed to construct assets. Verify that all regulations are adhered to and that all permissions have been granted. Organize and plan for resources to complete construction."@en,
        "明确资产建造所需步骤与策略。确保合规性，取得全部必要审批；统筹规划人力、物力等资源以保障建设顺利完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2" ;
    skos:prefLabel "Design and plan asset construction"@en,
        "开展资产建设的设计与规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3" ;
    skos:broader <https://oprocess.net/opf/node/10.2> ;
    skos:definition "Arranging a timetable for which to perform construction work. Schedule resources to contract assets for new or replacement assets. Reschedule or redesign assets if needed."@en,
        "制定建设工作实施时间表；统筹资源开展新资产建设或旧资产更新；必要时进行计划重排或方案再设计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3" ;
    skos:prefLabel "Schedule and perform construction work"@en,
        "安排并执行工程建设作业"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4" ;
    skos:broader <https://oprocess.net/opf/node/10.2> ;
    skos:definition "Overseeing the performance and quality of work. Assure that records are maintained throughout the construction process. Adhere to all safety, security, and access regulations set forth by the organization and all government standards."@en,
        "监督建设过程绩效与工程质量；全过程留存完整记录；严格遵守组织制定及政府颁布的各项安全、安保与访问管理规定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4" ;
    skos:prefLabel "Manage asset construction"@en,
        "管理资产建设过程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3" ;
    skos:broader <https://oprocess.net/opf/node/10.3> ;
    skos:definition "Engaging in all aspects of asset maintenance. Ensure that all assets are functioning properly and to all specified codes and regulations where applicable. Maintenance includes all preventative, routine, and corrective activates."@en,
        "全面开展资产维护工作，确保所有资产正常运行且符合适用的规范与法规要求；维护涵盖预防性、例行性及纠正性活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3" ;
    skos:prefLabel "Perform asset maintenance"@en,
        "开展资产维修"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1" ;
    skos:broader <https://oprocess.net/opf/node/11.1> ;
    skos:definition "Creating an agenda for the rules and regulations of enterprise risk that deal with hazardous, financial, operational, and strategic risks. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "制定企业风险管理制度与规范，涵盖危害性、财务、运营及战略风险；包括人工智能（AI）等新兴与演进技术带来的各类风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1" ;
    skos:prefLabel "Establish the enterprise risk framework and policies"@en,
        "建立企业风险框架与政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4" ;
    skos:broader <https://oprocess.net/opf/node/11.0> ;
    skos:definition "Including the processes required to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat. Develop a more dynamic, strategic, and integrated approach to managing compliance obligations."@en,
        "涵盖快速适应并响应内外部机遇、需求、干扰或威胁所需的相关流程，推动形成更动态、更具战略性和一体化的合规义务管理方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4" ;
    skos:prefLabel "Manage business resiliency"@en,
        "管理业务韧性"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/11.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.0> ;
    skos:definition "AI-era process group: AI Governance and Ethics."@en,
        "人工智能（AI）时代流程组：AI治理与伦理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5" ;
    skos:prefLabel "AI Governance and Ethics"@en,
        "人工智能治理与伦理"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "Managing a public relations programs through business and communications skills."@en,
        "运用商业与传播技能管理公共关系项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5" ;
    skos:prefLabel "Manage public relations program"@en,
        "管理公共关系项目"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Establishing and administering governance for management of the processes. Outline and manage the frameworks for management of the processes. Define the business processes. Administer the performance of the processes. Enhance the business processes."@en,
        "建立并实施流程治理机制。明确并管理流程治理框架；定义业务流程；监督流程绩效；持续优化业务流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1" ;
    skos:prefLabel "Manage business processes"@en,
        "管理业务流程"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.1> ;
    skos:definition "Outlining and establishing the business processes of the organization. Scope, analyze, map, and publish processes for the employees who may require it."@en,
        "梳理并确立组织的业务流程。界定流程适用范围，开展分析、建模与发布，面向有需要的员工提供流程信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3" ;
    skos:prefLabel "Define processes"@en,
        "定义流程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1" ;
    skos:broader <https://oprocess.net/opf/node/13.10> ;
    skos:definition "Developing sustainability (ESG) capabilities for the organization. Understand and communicate legal, regulatory, and social/environmental requirements. Establish policies, objectives, guidelines and approaches for ESG efforts and reporting."@en,
        "建设组织可持续发展（ESG）能力；理解并传达法律、监管及社会/环境要求；制定ESG工作与报告的政策、目标、指南与方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1" ;
    skos:prefLabel "Develop sustainability capability"@en,
        "构建可持续发展能力"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3> ;
    skos:definition "Determining essential activities, processes, and attributes for securing enterprise quality. Outline critical characteristics for quality. Outline activities encouraging the preservation of quality. Create quality controls. Confirm capabilities in accordance with quality requirements. Finalize the plan for quality maintenance."@en,
        "明确保障企业质量所需的关键活动、流程与属性：界定质量关键特征；规划支撑质量保持的活动；建立质量控制机制；确认能力满足质量要求；最终形成质量维持计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1" ;
    skos:prefLabel "Establish quality requirements"@en,
        "制定质量要求"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3> ;
    skos:definition "Handling any nonconformance activities or events. Assess the potential impact of the nonconformity. Decide the immediate actions to take. Identify the root causes. Take corrective or preventive action. Ensure future conformance."@en,
        "处理所有不符合项活动或事件：评估不符合项潜在影响；确定即时应对措施；识别根本原因；实施纠正或预防措施；确保未来持续符合要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3" ;
    skos:prefLabel "Manage non-conformance"@en,
        "管理不符合项"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Planning, designing, and implementing the change. Ensure improvement in the change process."@en,
        "规划、设计并实施变革，确保变革流程持续优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4" ;
    skos:prefLabel "Manage change"@en,
        "管理变更"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.4> ;
    skos:definition "Effectuating the change within the desired impact areas of the organization. Ensure adequate commitment from all corners of the organization for the desired change. Create support structures. Refashion all processes deemed necessary. Observe the progress."@en,
        "在组织预设影响范围内切实推进变革；确保组织各层面充分承诺与支持；构建变革支撑体系；重构必要业务流程；持续跟踪进展。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3" ;
    skos:prefLabel "Implement change"@en,
        "实施变更"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Creating and administering the capability of the organization's knowledge management function. Develop a strategy for knowledge management. Assess capabilities of the knowledge management function."@en,
        "构建并运营组织的知识管理（KM）能力；制定知识管理战略；评估知识管理职能的成熟度与能力水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5" ;
    skos:prefLabel "Develop and manage enterprise-wide knowledge management (KM) capability"@en,
        "构建并管理企业级知识管理（KM）能力"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3" ;
    skos:broader <https://oprocess.net/opf/node/13.5> ;
    skos:definition "Creating knowledge bases and other repositories to preserve and develop company expertise, and to train new employees."@en,
        "建设知识库及其他知识载体，固化组织专业能力，支撑新员工培养。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3" ;
    skos:prefLabel "Design and implement KM capabilities"@en,
        "设计并实施知识管理能力"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2" ;
    skos:broader <https://oprocess.net/opf/node/13.7> ;
    skos:definition "Comparing organizational performance internally or externally with other organizations."@en,
        "开展组织内部或跨组织的绩效基准比对。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2" ;
    skos:prefLabel "Benchmark performance"@en,
        "绩效对标"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.0" ;
    skos:definition "Detailing practices and procedures related to the concept of developing and managing products and services. These are reflected in the process groups Govern and manage product/service development program [19696], Generate and define new product/service ideas [19698], and Develop products and services [10062]."@en,
        "细化产品与服务开发及管理的相关实践与规程，体现于以下流程组：“治理与管理产品/服务开发项目”[19696]、“生成与定义新产品/服务创意”[19698]、“开发产品与服务”[10062]。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.0" ;
    skos:prefLabel "Develop and Manage Products and Services"@en,
        "产品和服务开发与管理"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

<https://oprocess.net/opf/node/2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1" ;
    skos:broader <https://oprocess.net/opf/node/2.0> ;
    skos:definition "Supervising the complete product/service program from innovation until its commercial success. Meeting the customer demand and expectations. Conduct further development and innovation pertaining to business goals."@en,
        "统筹产品/服务全生命周期管理，覆盖创新孵化至商业成功；精准响应客户需求与期望；围绕业务目标持续推进开发与创新。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1" ;
    skos:prefLabel "Govern and manage product/service development program"@en,
        "治理与管理产品/服务开发项目"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1> ;
    skos:definition "Manage the introduction and withdrawal of products/services. Administer associated changes, namely measuring the performance of new solution offerings and the revision of master files in the archives."@en,
        "管理产品和服务的引入与退出。统筹相关变更事项，包括评估新解决方案的市场表现，以及更新档案中的主数据文件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2" ;
    skos:prefLabel "Manage product and service life cycle"@en,
        "管理产品和服务生命周期"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1> ;
    skos:definition "Determining the attributes necessary to protect and safeguard intellectual assets, maximize the value of IP assets through streamlined process, and collaboration between departments. Focus on needs to safeguard, critical assets, and assets' value."@en,
        "明确保护知识产权资产所需的要素，通过流程精简与跨部门协作最大化知识产权（IP）资产价值。聚焦于保护需求、关键资产及其价值评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3" ;
    skos:prefLabel "Manage patents, copyrights, and regulatory requirements"@en,
        "管理专利、版权及监管要求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/2.2> ;
    skos:definition "Producing and defining ideologies for new product/service offerings."@en,
        "提出并界定新产品/服务的构想与理念。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2" ;
    skos:prefLabel "Generate new product/service concepts"@en,
        "生成新产品和服务概念"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3" ;
    skos:broader <https://oprocess.net/opf/node/2.0> ;
    skos:definition "Developing new products/services from scratch, including all activities associated with the design, prototyping, evaluation, and market testing of these planned offerings."@en,
        "从零启动新产品/服务开发，涵盖设计、原型制作、评估及市场测试等全部环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3" ;
    skos:prefLabel "Develop products and services"@en,
        "开发产品和服务"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3> ;
    skos:definition "Devising business plans and procedures for manufacturing/operations/production and delivery of services offered by the organization. Further in general terms the total amount of output that the manufacturing department is responsible to produce for each period."@en,
        "制定面向制造/运营/生产及服务交付的业务计划与规程，并总体界定制造部门各周期应完成的产出总量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3" ;
    skos:prefLabel "Prepare for production/service delivery"@en,
        "为量产/服务交付做准备"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3> ;
    skos:definition "Determining the exact terms and conditions under which specific warranties apply to certain goods or services."@en,
        "明确特定商品或服务适用保修条款的具体条件与范围。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4" ;
    skos:prefLabel "Define warranty claims"@en,
        "定义保修索赔管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Monitoring marketing and distribution efforts of all channels individually and as a network. Re-distribute or add resources to channels that perform better than expected. Purge or consolidate under-performing channels, and find more promising replacements."@en,
        "独立监测各渠道及渠道网络的营销与分销成效；对超预期表现渠道追加或重分配资源；淘汰或整合低效渠道，并引入更具潜力的替代渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5" ;
    skos:prefLabel "Analyze and manage channel performance"@en,
        "分析与管理渠道绩效"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Creating and managing a customer loyalty program. The loyalty program is a key part of marketing, with an elaborate strategy and process for acquiring, retaining, and engaging with members. Members are engaged and acquainted to the loyalty program, thus growing relationship and adding value through the program."@en,
        "创建并管理客户忠诚度计划；该计划是营销体系的核心组成部分，涵盖会员获取、留存与深度互动的完整策略与流程；通过持续触达与价值传递，深化客户关系并提升计划价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7" ;
    skos:prefLabel "Design and manage customer loyalty program"@en,
        "设计并管理客户忠诚度计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Collating all customer-centered metrics. The objective is to create a big-picture view of the customers' mindset and their behavior pertaining to the organization's offerings."@en,
        "整合全部以客户为中心的度量指标，构建客户心智模式与行为特征的全景视图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5" ;
    skos:prefLabel "Track customer management measures"@en,
        "跟踪客户管理措施"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Reviewing and responding to customer feedback. Create tickets to initiate bug fixes or to propose feature updates. Monitor and track progress."@en,
        "收集并响应客户反馈；创建工单以启动缺陷修复或功能更新提案；全程监控与跟踪处理进展。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6" ;
    skos:prefLabel "Analyze and respond to customer insight"@en,
        "分析并响应客户洞察"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.0> ;
    skos:definition "Developing concrete plans for guiding and providing support to the sales function. Chart a road map for the sales function, including an analysis of historical sales data to create forecasts for anticipated sales, forming sales targets, forging partnerships with other economic agents to boost sales, devising a budget for this function, and determining metrics to measure customer management activities as well as progress in achieving sales targets."@en,
        "制定支撑销售职能的具体规划；绘制销售职能发展路线图，包括基于历史销售数据分析预测未来业绩、设定销售目标、构建外部合作生态以扩大销售、编制销售职能预算、设计客户管理活动及销售目标达成进度的度量指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4" ;
    skos:prefLabel "Develop sales strategy"@en,
        "制定销售策略"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/3.5.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Managing the entire sales process, from using leads to open sales to closing sales and creating records. Govern all sales activities. Make sales calls based on leads and preparatory work (drafting terms of the sale, creating proposals, suggesting prices, etc.). Close the sale, along with any administrative activities related to data entry and the processing of the sale."@en,
        "全流程管理销售作业：从线索激活、商机推进到成交闭环及记录归档；统管所有销售活动；基于线索及前期准备（如拟定销售条款、编制提案、报价等）开展销售拜访；完成签约及配套数据录入、交易处理等行政事务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8" ;
    skos:prefLabel "Manage customer sales calls"@en,
        "管理客户销售拜访"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Managing the customer's expectations, with the intent of responsibly increasing the sale of the organization's products/services. Create a systematic method for governing sales, using sales forecasts and customer management measures. Develop a blueprint to manage relationships with customers and the data it holds on them, as well as the sale of its products/services to these customers. Devise a recipe for handling the organization's key customers in order to manage their expectations with tact and responsibility while maximizing revenue."@en,
        "系统化管理客户期望，在负责任前提下促进产品/服务销售增长；构建以销售预测与客户管理指标为基础的销售治理体系；制定客户关系与客户数据管理蓝图，统筹产品/服务销售全流程；设计重点客户精细化管理方案，兼顾期望管理的审慎性与营收最大化目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2" ;
    skos:prefLabel "Manage customers and accounts"@en,
        "管理客户与客户账户"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sT2" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "SCOR DS 14.0: Transform Make-to-Order (sT2)."@en,
        "SCOR DS 14.0：转型按订单生产（sT2）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.6" ;
    skos:prefLabel "Transform Make-to-Order"@en,
        "执行按订单生产（Make-to-Order）转型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sT3" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "SCOR DS 14.0: Transform Engineer-to-Order (sT3)."@en,
        "SCOR DS 14.0：转型按订单设计（sT3）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.7" ;
    skos:prefLabel "Transform Engineer-to-Order"@en,
        "执行按订单设计（Engineer-to-Order）转型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF4" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "SCOR DS 14.0: Fulfill Retail Product (sF4)."@en,
        "SCOR DS 14.0：零售产品交付（sF4）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.12" ;
    skos:prefLabel "Fulfill Retail Product"@en,
        "零售产品履约"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Creating and executing a strategy for all the internal activities related to the flow/transfer of inbound materials. This process includes planning inbound material receipts, managing inbound material flow, monitoring inbound delivery performance, managing the flow of returned products, controlling the quality of returned parts, and salvaging or repairing returned products."@en,
        "制定并执行所有与进厂物料流动/转移相关的内部活动策略。该流程包括：进厂物料收货计划、进厂物料流管控、进厂交付绩效监控、退货产品流转管理、退货零部件质量控制，以及退货产品的修复或再利用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2" ;
    skos:prefLabel "Plan and manage inbound material flow"@en,
        "规划与管理入厂物料流"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF1" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "SCOR DS 14.0: Fulfill Stocked Product (sF1)."@en,
        "SCOR DS 14.0：备货型产品交付（sF1）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.9" ;
    skos:prefLabel "Fulfill Stocked Product"@en,
        "现货产品履约"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.0" ;
    skos:definition "Offering services to customers. This is the act of providing service delivery as a core business practice and covers identifying strategies for performing service delivery, managing resources, and delivering services to the customer."@en,
        "面向客户交付服务。指将服务交付作为核心业务实践，涵盖制定服务交付策略、管理资源及向客户提供服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.0" ;
    skos:prefLabel "Deliver Services"@en,
        "交付服务"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

<https://oprocess.net/opf/node/6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/6.2> ;
    skos:definition "Obtaining customer complaints online or by phone. Direct these complaints to higher-level representatives as appropriate. Resolve them. Respond to customers."@en,
        "在线上或电话渠道接收客户投诉，并视情升级至高级别代表处理、闭环解决并及时反馈客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.2.3" ;
    skos:prefLabel "Manage customer complaints"@en,
        "管理客户投诉"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/6.3.2> ;
    skos:definition "Executing investigational and analysis of warranty claims. This involves notification and definition of a warranty issue, includes the scheduling of a field service agent to perform further investigation; the request and receipt of defective parts; and diagnosis/root cause analysis. This concludes with the receipt of the result and recommendation for corrective action."@en,
        "开展保修索赔的调查与分析，包括：保修问题通报与界定；安排现场服务工程师进一步核查；缺陷部件申领与接收；根因诊断与分析；最终形成调查结果及纠正措施建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2.3" ;
    skos:prefLabel "Investigate warranty issues"@en,
        "调查保修问题"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5" ;
    skos:broader <https://oprocess.net/opf/node/6.0> ;
    skos:definition "Calculating and assessing the operational activities of the customer service function. Evaluation is achieved through the customer requests/inquiries handling process, the customer complaint handling process, and product and services quality. Examine activities to ensure high levels of customer service."@en,
        "核算与评估客户服务职能的运营活动；评估涵盖客户咨询/请求处理流程、客户投诉处理流程，以及产品和服务质量；检视各项活动，确保客户服务高水平运行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5" ;
    skos:prefLabel "Evaluate customer service operations and customer satisfaction"@en,
        "评估客户服务运营与客户满意度"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/6.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.3" ;
    skos:broader <https://oprocess.net/opf/node/6.5> ;
    skos:definition "Calculating satisfaction levels of customers with products/services. Obtain customer feedback on products/services, as well as the effectiveness of the advertising campaigns. Examine this information to reach meaningful conclusions, which could then be used to enhance the customer service operations."@en,
        "测算客户对产品和服务的满意度；收集客户对产品/服务及广告推广效果的反馈；分析上述信息形成有效结论，用于优化客户服务运营。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.3" ;
    skos:prefLabel "Measure customer satisfaction with products and services"@en,
        "衡量客户对产品和服务的满意度"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.4" ;
    skos:broader <https://oprocess.net/opf/node/6.5> ;
    skos:definition "Assessing the cost and effectiveness of warranties."@en,
        "评估保修服务的成本效益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.4" ;
    skos:prefLabel "Evaluate and manage warranty performance"@en,
        "评估与管理保修绩效"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Creating strategies for the HR function. Create and implement strategies for managing the work force. Supervise and enhance the strategies, plans, and policies supporting the HR function. Developing models for managing competency levels of the HR of the organization."@en,
        "制定人力资源（HR）职能发展战略。制定并落实员工队伍管理战略；监督并持续优化支撑HR职能的战略、计划与政策；构建组织HR胜任力水平管理体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1" ;
    skos:prefLabel "Develop and manage human resources (HR) planning, policies, and strategies"@en,
        "制定并管理人力资本规划、政策与战略"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Evaluating the current and future skill requirements of the organization with regard to the overall corporate strategy of the organization and market conditions. Identify and establish the minimum skills needed for the requisite HR needs."@en,
        "结合组织整体战略与市场环境，评估当前及未来技能需求；识别并确立满足人力资源需求所需的最低技能标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.1" ;
    skos:prefLabel "Perform strategic workforce planning"@en,
        "开展战略性员工队伍规划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Determining and handling employee requirements. Recruit or source the candidates as per the requirements. Screen and select the most appropriate candidates. Take care of the newly hired and re-hired employees. Maintain records of information for all applicants."@en,
        "识别并满足员工需求：按需开展人才招募或寻源；筛选并甄选最适配候选人；妥善办理新员工入职及返聘手续；完整归档所有应聘者信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2" ;
    skos:prefLabel "Recruit, source, and select employees"@en,
        "员工招聘、寻源与甄选"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Assisting employees in developing their capabilities, and providing them counseling services. Handle the orientation and deployment of the employees. Administer the performance of employees. Administer the development and enhancement of the employees. Provide training and development programs for employees."@en,
        "支持员工能力发展并提供职业辅导：组织实施新员工入职引导与岗位部署；开展员工绩效管理；推动员工成长与能力提升；提供系统化培训与发展项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3" ;
    skos:prefLabel "Manage employee onboarding, training, and development"@en,
        "员工入职、培训与发展管理"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Assisting general management in developing, maintaining, and improving employee relationships. This is accomplished through communication, performance management, processing grievances, and/or dispute. Interpret and convey organizational policies."@en,
        "协助高层管理构建、维护与优化员工关系，具体通过沟通协调、绩效管理、申诉处理与争议调解等方式实现；准确解读并传达组织政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4" ;
    skos:prefLabel "Manage employee relations"@en,
        "管理员工关系"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Creating frameworks for rewarding and recognizing employees with the objective of retaining them. Create and manage programs for provision of rewards, recognition, and motivation. Manage and administer the benefits for employees. Help assist and retain employees. Administer payroll to employees."@en,
        "构建员工激励与认可框架，以提升留任率；策划并管理奖励、认可与激励项目；统筹员工福利管理；支持员工保留；负责薪酬发放。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5" ;
    skos:prefLabel "Reward and retain employees"@en,
        "激励与保留员工"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.7.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.7.7" ;
    skos:broader <https://oprocess.net/opf/node/7.7> ;
    skos:definition "Understand, develop, and gather workforce data in support of stakeholder requirements."@en,
        "理解、设计并采集人力资本数据，以满足各利益相关方需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.7.7" ;
    skos:prefLabel "Develop workforce analytics"@en,
        "开展人力资本分析（workforce analytics）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization. Maintain and convey information about deliverables, prices, contact points, and processes for requesting an information technology service."@en,
        "构建并维护一套结构化、标准化的组织 IT 服务目录，涵盖可由组织内部、为组织或在组织内提供的全部 IT 相关服务；持续更新并发布服务交付物、定价、联络方式及服务申请流程等信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.3" ;
    skos:prefLabel "Plan and communicate IT services"@en,
        "规划与传达IT服务"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Managing the IT relationship with its customers by systematically coordinating interactions over multiple touch points on a regular basis. Coordinate the IT's efforts to reach out to its customers, which include emails, social-media interactions, newsletters, and direct conversations."@en,
        "系统化协调多触点交互，常态化开展IT与客户的客户关系管理；统筹IT部门通过邮件、社交媒体、简报及面对面交流等方式主动触达客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.6" ;
    skos:prefLabel "Manage IT customer relationships"@en,
        "管理IT客户关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage LLMOps."@en,
        "AI 流程：管理大语言模型运维（LLMOps）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.2" ;
    skos:prefLabel "Manage LLMOps"@en,
        "管理大语言模型运维（LLMOps）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Evaluate and analyze the IT environment for the compliance of industry regulations and government legislation. Ensure that IT capability and resources meet the set standards."@en,
        "评估与分析IT环境对行业监管要求及政府法律法规的合规性，确保IT能力与资源满足既定标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6" ;
    skos:prefLabel "Conduct and analyze IT compliance assessments"@en,
        "开展并分析IT合规性评估"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.4> ;
    skos:definition "Creating strategies to manage the organization's information and content. Outline the architecture for information collection and communication. Administer information resources, data management and content."@en,
        "制定组织信息与内容管理战略；规划信息采集与沟通架构；统筹信息资源、数据管理与内容管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2" ;
    skos:prefLabel "Define and maintain business information architecture"@en,
        "定义并维护业务信息架构"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5> ;
    skos:definition "Executing life-cycle planning for IT services and solutions. Develop new requirements and feature-function enhancements. Create and design a life cycle plan that addresses the current and future state of IT services and solutions."@en,
        "执行 IT 服务与解决方案的全生命周期规划；提出新需求与功能增强方案；制定兼顾当前与未来状态的生命周期计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2" ;
    skos:prefLabel "Manage service/solution lifecycle planning"@en,
        "管理服务/解决方案生命周期规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5> ;
    skos:definition "Executing IT service/solution maintenance lifecycle in order to reduce maintenance costs and increase reliability of IT infrastructure concerning service/solution related problems."@en,
        "执行IT服务/解决方案运维生命周期管理，以降低运维成本、提升IT基础设施在服务/解决方案相关问题上的可靠性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1" ;
    skos:prefLabel "Execute IT service/solution maintenance lifecycle"@en,
        "执行IT服务/解决方案维护生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Defining and establishing strategy for delivering IT services and solutions to the users. Design an IT service delivery model that defines the processes and procedures needed to deliver the IT services and solutions."@en,
        "制定并确立面向 IT 服务与解决方案用户的交付策略；设计定义交付流程与规程的 IT 服务交付模型。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.1" ;
    skos:prefLabel "Define and establish service delivery strategy"@en,
        "定义并建立服务交付策略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.13> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Incident Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "ITIL V5 practice: Incident Management. Mapped to Create and manage support services/solutions."@en,
        "ITIL V5 实践：事件管理。映射至「构建与管理支持服务/解决方案」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.13" ;
    skos:prefLabel "Incident Management"@en,
        "事件管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Developing and managing the resources required for administration of infrastructure. Manage the IT inventory and assets to meet organization's IT resource capacity."@en,
        "开发并管理基础设施运维所需资源；统筹管理 IT 资产与库存，满足组织 IT 资源容量需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4" ;
    skos:prefLabel "Develop and manage infrastructure resource planning"@en,
        "制定与管理基础设施资源规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Determining different stages of the planning process and accounting. Classify, determine, analyze, interpret, and communicate information to make up-to-date business decisions for better management and control functions."@en,
        "界定规划与会计各阶段，开展分类、判定、分析、解读与沟通，为提升管理与控制职能提供及时、可靠的业务决策支持"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1" ;
    skos:prefLabel "Perform planning and management accounting"@en,
        "开展规划与管理会计"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.1> ;
    skos:definition "Allocating funds to meet future and current financial goals. Led by the chief financial officer, have the finance function plan, budget, and forecast in order to determine and describe long and short-term financial goals."@en,
        "统筹资金配置以实现当前及未来的财务目标。由首席财务官牵头，组织财务职能开展规划、预算编制与财务预测，明确并阐述长期与短期财务目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2" ;
    skos:prefLabel "Perform planning/budgeting/forecasting"@en,
        "开展规划／预算／预测"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "Preparing detailed reports of customer purchases. Prepare a commercial document between the seller and customer with details about transaction. Detail the quantity purchased, price of products/services, date, parties involved, unique invoice number, and tax information."@en,
        "编制客户采购明细报告。向客户开具商业发票，列明交易详情，包括采购数量、产品或服务价格、日期、交易双方、唯一发票编号及税务信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2" ;
    skos:prefLabel "Invoice customer"@en,
        "向客户开具发票"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "Processing payments due from customers. This includes all processing of funds received, whether by check or electronically. This does not include the generation of invoices."@en,
        "处理客户应付账款，包括以支票或电子方式收到的所有资金处理；不包含发票开具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3" ;
    skos:prefLabel "Process accounts receivable (AR)"@en,
        "管理应收账款（AR）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Making statements about business activities and functions. Prepare financial statements (balance sheet, income statement, statement of cash flows, and statement of stockholders' equity) according to accounting concepts and principles."@en,
        "编制关于企业经营活动与职能的说明文件，依据会计概念与原则编制财务报表（资产负债表、利润表、现金流量表及股东权益变动表）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3" ;
    skos:prefLabel "Perform general accounting and reporting"@en,
        "执行通用会计与报告"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.3> ;
    skos:definition "Creating procedures to perform general accounting and reporting. Follow the rules and regulations made for a particular process in the business. Publish accounting policies."@en,
        "制定通用会计与报告操作规程，遵照企业既定流程的规章制度执行，并对外发布会计政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1" ;
    skos:prefLabel "Manage financial policies and procedures"@en,
        "管理财务政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.4> ;
    skos:definition "Accounting for large-scale and large-cost investments. Manage and account for ongoing activities related to capital projects, including setting up new projects, recording project transactions, monitoring and tracking spending, closing and capitalizing projects, and measuring the financial returns on completed projects."@en,
        "核算大规模、高成本投资。管理并核算资本性项目全过程财务活动，包括新项目立项、项目交易记账、支出监控与追踪、项目关账与资本化，以及已完成项目投资回报测算。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2" ;
    skos:prefLabel "Perform capital project accounting"@en,
        "开展资本项目会计核算"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.5> ;
    skos:definition "Recording the reporting time of employees on-site. Track working days, salary calculations, holidays taken, number of hours spend in the office, billing hours, etc."@en,
        "记录员工现场出勤工时。统计工作日、薪资计算依据、休假天数、办公室驻留时长、计费工时等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1" ;
    skos:prefLabel "Report time"@en,
        "工时申报"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.5> ;
    skos:definition "Deducting and paying taxes from employees' salaries."@en,
        "代扣代缴员工个人所得税。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3" ;
    skos:prefLabel "Manage and process payroll taxes"@en,
        "管理与处理薪酬税"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2" ;
    skos:broader <https://oprocess.net/opf/node/9.6> ;
    skos:definition "Processing reimbursements to employees for the expenses incurred during the course of business. Approve and process advancements and reimbursements for employee expenses on the organization's behalf. Capture and report relevant tax data and manage personal accounts."@en,
        "处理员工因公产生的费用报销。代表组织审批及执行预支款与报销款项，同步采集报告相关税务数据，并管理员工个人账户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2" ;
    skos:prefLabel "Process expense reimbursements"@en,
        "处理费用报销"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Taking care of foreign-exchange risks."@en,
        "管理外汇风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3" ;
    skos:prefLabel "Manage foreign exchange risk"@en,
        "管理外汇风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Implementing hedging strategy in attempt to alleviate risk. This will include all options, depravities, and futures contracts agreed upon in Develop risk management/hedging strategy [12974]."@en,
        "实施对冲策略以缓释风险，涵盖所有在‘制定风险管理/对冲策略 [12974]’中约定的期权、衍生品及期货合约。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5" ;
    skos:prefLabel "Execute hedging transactions"@en,
        "执行套期保值交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1" ;
    skos:broader <https://oprocess.net/opf/node/9.8> ;
    skos:definition "Forming rules and regulations to ensure the achievement of effectiveness, proficiency of operations, and reliability of financial reporting."@en,
        "制定规章制度，确保实现运营效率、效果及财务报告可靠性目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1" ;
    skos:prefLabel "Establish internal controls, policies, and procedures"@en,
        "建立健全内部控制、政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.0" ;
    skos:definition "Establishing a direction and vision for an organization. This involves defining the business concept and long-term vision, as well as developing the business strategy and managing strategic initiatives. Processes in this category focus on creating a vision, a mission, and strategic objectives, and culminate in creating measures to ensure that the organization is moving in the desired direction."@en,
        "为组织确立发展方向与远景。包括定义业务概念与长期愿景、制定业务战略及管理战略性举措。本类流程聚焦于构建组织愿景、使命与战略目标，并最终形成衡量机制，确保组织持续朝既定方向推进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.0" ;
    skos:prefLabel "Develop Vision and Strategy"@en,
        "制定愿景与战略"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

<https://oprocess.net/opf/node/1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.0> ;
    skos:definition "Creating a conceptual framework of the organization's business activity and strategic vision with long-term applicability. Scout the organization's internal capabilities, as well as the customer's needs and desires, to identify a fit that can be used to advance a conceptual structure of the organization's business activity. Conduct analysis in light of relevant externalities and large-scale shifts in the market landscape."@en,
        "构建具有长期适用性的组织业务活动与战略愿景的概念框架。审视组织内部能力，同时洞察客户需求与期望，识别契合点以支撑组织业务活动的概念化建构。结合相关外部环境因素及市场格局的重大变迁开展分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1" ;
    skos:prefLabel "Define the business concept and long-term vision"@en,
        "定义业务概念与长期愿景"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "Undertaking a review of the organization's in-house skills and resources in order to create a big-picture understanding of internal capacities. Assess the organization's capabilities in order to advance the advantageous and weed out the detrimental aspects. Identify synergic associations within the backdrop of the forces and players active in the market, and take into account all externalities."@en,
        "系统梳理组织内部技能与资源，形成对组织内在能力的全局性认知；评估组织各项能力，以强化优势、消除短板；在市场活跃力量与参与主体背景下识别协同关系，并统筹考量全部外部影响因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3" ;
    skos:prefLabel "Assess the internal environment"@en,
        "评估内部环境"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.0" ;
    skos:definition "Ensuring that an organization effectively manages its risk. Process groups are aligned with traditional risk management activities."@en,
        "确保组织有效管理企业风险，各流程组对应传统风险管理活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.0" ;
    skos:prefLabel "Manage Enterprise Risk, Compliance, Remediation, and Resiliency"@en,
        "管理企业风险、合规、整改与韧性"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/11.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3" ;
    skos:broader <https://oprocess.net/opf/node/11.0> ;
    skos:definition "Administering the efforts and activities for remediation. This process element requires the organization to create plans for corrective action in collaboration with government agencies and pertinent professional services agencies which specialize in remediation efforts relevant to the organization's operations. Additionally, the organization needs to consult experts to validate the plan, determine resources allocation, resolve any legal concerns, and formulate a company-wide policy for remediation."@en,
        "统筹整改工作与行动。该流程要求组织协同政府机构及相关专业服务机构（专精于本组织业务领域的整改事务），制定纠正行动计划；同时需咨询专家，对计划进行验证、确定资源分配方案、解决法律疑点，并制定覆盖全公司的整改政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3" ;
    skos:prefLabel "Manage remediation efforts"@en,
        "管理整改工作"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1" ;
    skos:broader <https://oprocess.net/opf/node/12.2> ;
    skos:definition "Persuading public and government policy at the local, regional, national, and global level (subject to government regulations)."@en,
        "在地方、区域、国家及全球层面影响公共政策与政府决策（须遵守政府监管规定）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1" ;
    skos:prefLabel "Manage government relations"@en,
        "管理政府关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Managing professionals, sought externally for assistance over legal and ethical concerns. Administer and oversee assistance from subject matter experts and professionals for sourcing expert opinion and counseling over legal and ethical matters."@en,
        "聘请外部专业人士，就法律与伦理问题提供咨询支持；统筹并监督来自领域专家及专业人员的意见征询与咨询服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5" ;
    skos:prefLabel "Manage outside counsel"@en,
        "管理外部法律顾问"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2> ;
    skos:definition "Establishing the scope of the projects. Create plans for implementing the projects. Initiate projects. Review and report project performance to management. Close projects."@en,
        "界定项目范围；制定项目实施计划；启动项目；向管理层评审并汇报项目绩效；收尾项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3" ;
    skos:prefLabel "Manage projects"@en,
        "管理项目"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Establishing the horizons of business projects. Identify the objectives of the program, along with the resource requirements. Assess the readiness for the project management approach. Identify methodologies for project management. Obtain funding. Develop performance measures and indicators."@en,
        "明确业务项目边界：识别项目所属组合的目标及资源需求；评估组织项目管理方法的适用性与准备度；甄选适用的项目管理方法论；落实项目资金；制定绩效衡量措施与指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1" ;
    skos:prefLabel "Establish project scope"@en,
        "确立项目范围"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3> ;
    skos:definition "Establishing and administering the software that manages content and business processes for quality and compliance across the value chain. Define the quality strategy. Plan and deploy the EQMS scope, targets, and goals. Identify core process controls and metric. Develop EQMS governance. Assess the performance of EQMS. Encourage improvements in EQMS."@en,
        "建立并运维覆盖价值链的质量与合规内容及业务流程管理软件：定义质量战略；规划并部署企业质量管理体系（EQMS）的范围、目标与指标；识别核心流程控制点与度量指标；构建EQMS治理机制；评估EQMS运行绩效；推动EQMS持续改进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4" ;
    skos:prefLabel "Implement and maintain the enterprise quality management system (EQMS)"@en,
        "实施并维护企业质量管理体系（EQMS）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.3.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Rewarding excellence in quality. Create and maintain quality partnerships. Maintain talent capabilities and competencies. Incorporate EQMS messaging into communication channels. Transfer proven EQMS methods. Consider factors such as EQMS reviews and gap assessments and the alignment and compatibility of business processes and quality. Adopt Lean principles."@en,
        "表彰质量卓越表现；构建并维系质量合作伙伴关系；夯实人才能力与胜任力；将EQMS理念融入组织各沟通渠道；推广已验证的EQMS方法；统筹考虑EQMS评审与差距评估，以及业务流程与质量体系的协同性与兼容性；贯彻精益（Lean）原则。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6" ;
    skos:prefLabel "Create environment and capability for EQMS improvement(s)"@en,
        "构建支持企业质量管理体系（EQMS）持续改进的环境与能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Managing the systems, tools, and repositories that support content storage, access, administration, and control across the content lifecycle. Consider AI supported content services (e.g., auto classification, semantic enrichment, embeddings stores, and knowledge graph infrastructure)."@en,
        "管理支撑内容全生命周期存储、访问、管理与控制的系统、工具与知识库；考虑人工智能（AI）赋能的内容服务（如自动分类、语义增强、嵌入式存储、知识图谱基础设施）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4" ;
    skos:prefLabel "Manage content infrastructure"@en,
        "管理内容基础设施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.9.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3" ;
    skos:broader <https://oprocess.net/opf/node/13.9> ;
    skos:definition "Managing the performance, costs and benefits of EHS. Measure and report the performance of EHS. Implement plans for emergency response and pollution prevention. Train and educate employees. Provide EHS support."@en,
        "管理环境、健康与安全（EHS）的绩效、成本与收益；测量并报告EHS绩效；实施应急响应与污染预防计划；开展员工培训与教育；提供EHS支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3" ;
    skos:prefLabel "Monitor and manage EHS program"@en,
        "监控与管理环境、健康与安全（EHS）计划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1> ;
    skos:definition "Managing a portfolio of product/service offerings to take advantage of shifts in the market expectations, all the while coordinating with the overall business strategy. Revisit the product/service portfolio in light of market opportunities, and overhaul it to capture value created by these opportunities. Identify gaps between current offerings and the market expectations to direct the organization's R&D activity. Create new solutions, and revise or retire existing ones so that the revamped portfolio aligns with Develop a business strategy [10015]."@en,
        "管理产品/服务组合，主动把握市场预期变化，并与整体业务战略协同；结合市场机遇重新审视组合，重构以捕获新增价值；识别当前供给与市场预期间的差距，引导组织R&D投入方向；开发新解决方案，迭代或淘汰现有方案，确保优化后的组合契合“制定业务战略”[10015]。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1" ;
    skos:prefLabel "Manage product and service portfolio"@en,
        "管理产品与服务组合"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.3.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Creating a sketch of the customer focused product/service in Develop and Manage Products and Services [10003]."@en,
        "在“开发与管理产品和服务[10003]”流程中，绘制以客户为中心的产品/服务草图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8" ;
    skos:prefLabel "Design products/services"@en,
        "开展产品/服务设计"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.0" ;
    skos:definition "Outlining process groups related to understanding markets, customers, and capabilities; developing marketing strategies; executing marketing plans; developing sales strategies; developing and managing marketing plans; and managing sales partners and alliances."@en,
        "界定与市场与客户洞察、能力评估、营销策略制定、营销计划执行、销售策略制定、营销计划开发与管理、销售伙伴及联盟管理相关的流程组。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.0" ;
    skos:prefLabel "Market and Sell Products and Services"@en,
        "市场推广与销售产品和服务"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

<https://oprocess.net/opf/node/3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1> ;
    skos:definition "Gathering intelligence on the market and customers. Closely examine the inherent attributes and collective behavior of the various market and customer segments. Track trends in the market. Determine what drives the customers to make purchasing decisions in order to identify opportunities in the market."@en,
        "开展市场与客户情报采集。深入分析各类市场与客户细分的内在属性及群体行为特征；追踪市场趋势；探究驱动客户购买决策的关键因素，以识别潜在市场机会。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1" ;
    skos:prefLabel "Perform customer and market intelligence analysis"@en,
        "开展客户与市场情报分析"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/3.4> ;
    skos:definition "Setting up a financial plan for the sales function. Calculate the estimated sales revenue and costs, which helps in calculating the overall net profit. Create a sound plan for resource outlay by comparing the forecast with historical data."@en,
        "为销售职能编制财务计划：测算预计销售收入与成本，支撑净收益核算；结合历史数据比对预测结果，制定科学合理的资源投入方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3" ;
    skos:prefLabel "Establish overall sales budgets"@en,
        "制定整体销售预算"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/4.1> ;
    skos:definition "Developing a scheme that allows for advance planning for the availability of raw materials and spares. Start with an unconstrained plan, and refine based on supply chain realities by identifying critical materials required for production, checking material specifications, and collaborating with all vendors over the supply."@en,
        "制定原材料与备件的前置供应规划：先制定无约束计划，再结合供应链实际，识别关键生产物料、核查物料规格，并协同全链供应商优化完善。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.3" ;
    skos:prefLabel "Create materials plan"@en,
        "制定物料计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3.2" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "Manufacturing the product. Convert the raw materials to develop consumer-ready products. Manage the raw materials to implement the detailed production schedule. Reproduce defectives to establish and remediate cause. Ensure production optimization and benchmark performance."@en,
        "产品制造：将原材料转化为面向消费者的成品；依据详细生产排程管理原材料；复现缺陷品以定位并整改根本原因；确保生产优化并开展绩效对标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.2" ;
    skos:prefLabel "Produce/Assemble product"@en,
        "生产／装配产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3.3" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "Executing tests to evaluate the quality of the products manufactured. Calibrate the test equipment. Conduct the actual tests. Record the results and outcomes of the quality test conducted."@en,
        "执行产品质量检验：校准检测设备；开展实际测试；记录并归档质检结果与结论。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.3" ;
    skos:prefLabel "Perform quality testing"@en,
        "执行质量检测"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sT1" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "SCOR DS 14.0: Transform Make-to-Stock (sT1)."@en,
        "SCOR DS 14.0：转型按库存生产（sT1）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.5" ;
    skos:prefLabel "Transform Make-to-Stock"@en,
        "执行按库存生产（Make-to-Stock）转型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/5.2> ;
    skos:definition "Identifying the need for and creating a resource plan. Understand resource demand and align with capacity, skills, and capabilities. Enlist suppliers and partners to supplement needed skills and capabilities. Monitor and manage capabilities and skills with an eye on critical resources and supplier capacity."@en,
        "识别资源缺口并制定资源计划；统筹资源需求与容量、技能及业务能力；引入供应商与合作伙伴弥补能力短板；持续监控关键资源及供应商承载能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2" ;
    skos:prefLabel "Create and manage resource plan"@en,
        "制定并管理资源计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.3" ;
    skos:broader <https://oprocess.net/opf/node/5.0> ;
    skos:definition "Managing and operating the systems, resources, and processes used to deliver services to customers, including planning, startup, ongoing operations, and service assurance."@en,
        "统筹管理服务交付所依赖的系统、资源与流程，涵盖规划、启动、日常运营及服务保障全过程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.3" ;
    skos:prefLabel "Manage and Operate Service Delivery System"@en,
        "管理与运行服务交付系统"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/6.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.0" ;
    skos:definition "Managing interactions with current customers after the delivery of products and services. This includes developing and planning customer service practices with a focus on handling inquiries after sales, feedback, warranties, recalls, and other related processes."@en,
        "在产品和服务交付后，持续管理与现有客户的互动关系，包括制定与规划客户服务实践，重点覆盖售后咨询、客户反馈、保修、召回及其他相关流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.0" ;
    skos:prefLabel "Manage Customer Service"@en,
        "管理客户服务"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

<https://oprocess.net/opf/node/6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.2" ;
    skos:broader <https://oprocess.net/opf/node/6.0> ;
    skos:definition "Planning and administering workforce operations for customer service provision by taking care of customer services requests/inquiries, as well as the complaints."@en,
        "统筹规划与执行客户服务人力运营，高效响应客户咨询、请求及投诉。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.2" ;
    skos:prefLabel "Plan and manage customer service contacts"@en,
        "规划与管理客户服务接触"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/6.2> ;
    skos:definition "Handling the requests and inquiries from customers that seek information regarding the organization's products/services. Obtain the customer requests online and by phone. Direct these requests to higher-level representatives. Approve requests, and respond to customers."@en,
        "受理客户关于组织产品与服务的信息咨询请求：通过线上与电话渠道接收请求，按需升级至高阶支持人员；完成审批并及时响应客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.2.2" ;
    skos:prefLabel "Manage customer service problems, requests, and inquiries"@en,
        "管理客户服务问题、请求与咨询"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.4" ;
    skos:broader <https://oprocess.net/opf/node/6.0> ;
    skos:definition "Removing defective products from the distribution chain. Participate in audits from watchdog agencies."@en,
        "从分销链中撤回缺陷产品；配合监管机构开展审计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.4" ;
    skos:prefLabel "Manage product recalls and regulatory audits"@en,
        "管理产品召回与监管审计"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.2> ;
    skos:definition "Recruiting new candidates for deployment across various functional areas inside the organization. Select methods for sourcing new employees. Manage relationships with third-party agencies. Stage recruitment fairs and drives. Manage employee referral programs."@en,
        "面向组织内各职能领域开展人才招募与部署：选择多元化招聘方式；管理第三方机构合作关系；组织校园招聘、专场宣讲会、招聘会等活动；运营员工内推计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.2" ;
    skos:prefLabel "Recruit/Source candidates"@en,
        "候选人招聘与寻源"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "AI-era process group: AI and Intelligent Operations."@en,
        "AI 时代流程组：人工智能与智能运维"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10" ;
    skos:prefLabel "AI and Intelligent Operations"@en,
        "人工智能与智能运维（AIOps）"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/8.10> ;
    skos:definition "AI process: Manage MLOps Lifecycle."@en,
        "AI 流程：管理机器学习运维（MLOps）生命周期"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.10.1" ;
    skos:prefLabel "Manage MLOps Lifecycle"@en,
        "管理机器学习运维（MLOps）生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Defining the need of technology in business and systematic implementation of IT investments. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). It comprises of assessing competitive technology components to ensure structural analysis, development, usage and security of technology for efficient business operations."@en,
        "明确业务对技术的需求，系统化实施IT投资，涵盖人工智能（AI）等新兴与演进技术；通过竞争性技术组件评估，保障技术在结构分析、开发、应用及安全等方面的高效支撑业务运营。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1" ;
    skos:prefLabel "Define business technology and governance strategy"@en,
        "制定业务技术与治理战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Strategy for systematic management of IT investments, projects, and activities. Analyze and examine the value of the IT portfolio and allocate resources based on business objectives."@en,
        "制定IT投资、项目与活动的系统化管理策略；分析评估IT投资组合价值，并依据业务目标统筹资源配置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2" ;
    skos:prefLabel "Manage IT portfolio strategy"@en,
        "管理IT投资组合战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Create and execute a process to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat in IT. Maintain continuous IT operations to protect employees, assets, and overall brand equity."@en,
        "建立并执行快速适应与响应IT领域内外部机遇、需求、中断或威胁的流程；持续保障IT运营，以保护员工、资产及整体品牌价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7" ;
    skos:prefLabel "Develop and execute IT resilience and continuity operations"@en,
        "制定并执行IT韧性与连续性运营"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.1" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "Creating and implementing a strategy for the deployment of IT service/solution. Define all of the activities that make the IT function available for use. Establish the change policies for IT services and solutions. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process."@en,
        "制定并落实IT服务/解决方案部署策略；明确定义使IT功能可投入使用的全部活动；建立IT服务与解决方案变更政策；界定部署流程、规程与工具；选择最可行、最实用的部署方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.1" ;
    skos:prefLabel "Develop and manage service/solution deployment strategy"@en,
        "制定并管理服务/解决方案部署策略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Defining and creating a strategy for provision of support to users of IT services and solutions."@en,
        "制定并构建面向 IT 服务与解决方案用户的支撑服务策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.2" ;
    skos:prefLabel "Define and develop service support strategy"@en,
        "定义并开发服务支持策略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3> ;
    skos:definition "Planning different delivery services for operational activities within the IT function. Use service delivery systems to manage the IT service delivery services."@en,
        "规划 IT 部门内运营活动所需的服务交付；利用服务交付系统管理 IT 服务交付工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1" ;
    skos:prefLabel "Plan operational activities for IT service delivery"@en,
        "规划IT服务交付的运营活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Managing the resources required for administration of IT infrastructure. Manage the IT inventory and assets. Take care of the organization's IT resource capacity."@en,
        "统筹管理IT基础设施行政资源；开展IT资产与库存管理；保障组织IT资源容量供给。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7" ;
    skos:prefLabel "Manage infrastructure resource administration"@en,
        "管理基础设施资源配置"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Managing systematic user support functionality and capability through defined procedures. Determine, record, and monitor user requests. Execute issue/request resolution. Utilize escalation path when needed. Resolve issue/request."@en,
        "通过标准化流程，系统化管理用户支持功能与能力；受理、记录并监控用户请求；执行问题/请求解决；必要时启用升级路径；闭环解决用户问题/请求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8" ;
    skos:prefLabel "Operate IT user support"@en,
        "运营IT用户支持"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.1> ;
    skos:definition "Defining costs to be incurred and methods for optimum utilization. Determine the costs of products, processes, projects, etc. to compile in the financial statements, as well as to assist management in making decisions regarding planning and control. Control costs by managing and reducing business expenses."@en,
        "界定各项成本发生范围及最优利用方式。确定产品、流程、项目等的成本，用于编制财务报表，并支持管理层在规划与控制方面的决策；通过管控与削减经营费用实现成本控制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3" ;
    skos:prefLabel "Perform cost accounting and control"@en,
        "开展成本核算与控制"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Comparing revenue targets to reality. Review all transactions and entries passed in final accounts in a year in order to examine profits."@en,
        "比对实际收入与目标收入。全面复核年度终账中所有交易与记账凭证，以检验盈利情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2" ;
    skos:prefLabel "Perform revenue accounting"@en,
        "开展收入核算"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "Creating and providing funds for necessary adjustments and deductions, including all expenses that were required for the business at certain point in time."@en,
        "设立并拨付必要调整与扣减所需资金，涵盖企业在特定时点所发生的全部经营性支出。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5" ;
    skos:prefLabel "Manage and process adjustments/deductions"@en,
        "管理与处理账务调整/扣减项"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3" ;
    skos:broader <https://oprocess.net/opf/node/9.6> ;
    skos:definition "Handling and authoring credit cards to business entities or for corporate purchases."@en,
        "为企业实体或公务采购配发及管理信用卡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3" ;
    skos:prefLabel "Manage corporate credit cards"@en,
        "管理企业信用卡"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Managing business's investments in trading in bonds, currencies, financial derivatives, etc. Manage the financial assets and holdings of the organization. Optimize the organization's liquidity. Invest excess cash. Reduce financial risks."@en,
        "管理企业对债券、外汇、金融衍生品等交易的投资；管理组织的金融资产与持仓；优化组织流动性；投资闲置资金；降低财务风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7" ;
    skos:prefLabel "Manage treasury operations"@en,
        "管理资金运营"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Performing transactions that limit investment risk with the help of derivatives, such as options and futures contracts. Manage interest rates, foreign exchange, and exposure risks. Develop and execute hedging transactions. Evaluate and refine hedging positions. Produce hedge accounting transactions and reports. Monitor credit."@en,
        "运用期权、期货合约等衍生工具开展交易，以限制投资风险；管理利率风险、外汇风险及风险敞口；制定并执行套期保值策略；评估与优化套期头寸；生成套期会计分录与报告；持续监控信用风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5" ;
    skos:prefLabel "Monitor and execute risk and hedging transactions"@en,
        "监控与执行风险及套期保值交易"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Developing a strategy for the achievement of business goals over the distant future. Adopt one of the strategic options for realizing its mission over the long term. Enlist senior management executives, comprising strategy and/or business unit personnel."@en,
        "制定面向远期的业务目标实现战略。选定一项长期使命实现路径作为组织战略方向；由高管层（含战略与业务单元负责人）共同制定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3" ;
    skos:prefLabel "Set/Develop long-term enterprise strategy"@en,
        "制定/设定企业长期战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8> ;
    skos:definition "Creating a design of how customers interact with the business by analyzing data captured through various customer interaction and customer involvement. These will be captured through various channels such as customer satisfaction surveys, feedback forms, product reviews, targeted studies, observational studies, or voice of customer research."@en,
        "通过分析多渠道采集的客户互动与参与数据，设计客户与企业的交互模式；数据来源包括客户满意度调查、反馈表单、产品评论、定向研究、观察研究及客户之声（VoC）研究等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2" ;
    skos:prefLabel "Design customer experience"@en,
        "设计客户体验"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.0> ;
    skos:definition "Managing strategic initiatives, from development through selection, execution, and evaluation. Conduct and oversee strategic projects supporting long-term objectives. Administer programs of strategic significance by developing such initiatives, select the most appropriate projects, and formulate measures to assess their impact."@en,
        "统筹战略举措的全生命周期管理，涵盖开发、遴选、执行与评估；主导支撑长期目标的战略项目；通过策划战略级项目、优选关键项目、制定影响评估机制，统筹实施具有战略意义的项目组合。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3" ;
    skos:prefLabel "Develop and measure strategic initiatives"@en,
        "制定与衡量战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/10.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1" ;
    skos:broader <https://oprocess.net/opf/node/10.3> ;
    skos:definition "Ensuring that necessary resources are available and tasks are prioritized accordingly through planning. Provide strategies and policies that identify tasks that need to be completed, and the resources necessary to fulfill those tasks."@en,
        "通过科学规划，确保维护所需资源到位并合理排序任务优先级；制定策略与政策，明确待执行任务清单及对应资源需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1" ;
    skos:prefLabel "Plan asset maintenance"@en,
        "规划资产维护"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2" ;
    skos:broader <https://oprocess.net/opf/node/10.3> ;
    skos:definition "Ensuring that asset maintenance is conducted in a timely manner and successfully. Schedule work with the required resources with an eye on quality control and safety. Verify that contracted maintenance meets performance targets."@en,
        "保障资产维护作业及时、高质量完成；统筹调度资源，兼顾质量控制与作业安全；验证外包维护服务是否达成约定绩效指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2" ;
    skos:prefLabel "Manage asset maintenance"@en,
        "管理资产维护作业"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3" ;
    skos:broader <https://oprocess.net/opf/node/11.1> ;
    skos:definition "Analyzing the threats a business unit/function faces to prioritize the controls it implements.."@en,
        "分析业务单元/职能面临的风险，以确定控制措施的优先级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3" ;
    skos:prefLabel "Manage business unit and function risk"@en,
        "管理业务单元与职能风险"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.0" ;
    skos:definition "Fostering external relationships with stakeholders of the entity, including investors, government and industry, the board of directors, and the general public. This is not related to customer management."@en,
        "构建并维系与企业外部利益相关方的关系，包括投资者、政府与行业机构、董事会及社会公众（不涉及客户管理）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.0" ;
    skos:prefLabel "Manage External Relationships"@en,
        "管理外部关系"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/13.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Defining the resources and their roles. Identify IT requirements. Create plans for effective training and communication. Design reward approaches. Plan the launch of project. Deploy the project."@en,
        "界定资源及其角色：识别信息技术（IT）需求；制定高效培训与沟通计划；设计激励机制；规划项目启动；部署项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3" ;
    skos:prefLabel "Develop project plans"@en,
        "制定项目计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Implementing the business projects of the organization. Evaluate the impact of project management. Record and report the status of the project. Manage the project scope. Promote and sustain activities and involvement. Realign and revamp the project management strategy and approach."@en,
        "实施组织业务项目：评估项目管理成效；记录并报告项目状态；管控项目范围；促进并维系各方参与和行动；动态调整与优化项目管理策略与方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4" ;
    skos:prefLabel "Execute projects"@en,
        "执行项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Storing, managing, curating and delivering enterprise content and knowledge assets to enable consistent reuse and informed decision making.  Establish structures and governance that support classification, semantic enrichment, and lifecycle management of content across formats and repositories.  This includes all forms of emerging technologies such as artificial intelligence (AI), machine learning assisted tagging, automated classification, and semantic content processing."@en,
        "企业内容与知识资产的存储、管理、策展与交付，以支持一致复用和科学决策；建立支撑内容分类、语义增强及跨格式、跨库全生命周期管理的结构与治理机制；涵盖人工智能（AI）、机器学习辅助打标、自动分类、语义内容处理等新兴技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6" ;
    skos:prefLabel "Manage Content"@en,
        "内容管理"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2> ;
    skos:definition "Learning from either a test or a full production run within the consumer market. Companies use this as an opportunity to both test and react to new products, ideas, or innovations based on the initial reaction of consumers on an individual level. Within this process, analytics are used to determine the relative success of a new product offering. Within this process, companies will launch key analytics to test a products acceptance. They will also review market performance and compare to similar products and against the business case or the financial plan. Companies can also measure the effectiveness of their supply chain network, and can apply what is learned from the post launch review to other new products, processes, and procedures to ensure and enhance the product quality."@en,
        "基于消费者市场的试运行或全量投产开展复盘学习。企业借此机会，依据个体消费者的初步反馈，对新产品、创意或创新进行测试与响应；运用分析工具评估新解决方案的相对成功度；启动关键分析手段检验市场接受度；比对实际市场表现与同类产品、商业案例或财务计划；评估供应链网络效能；并将上市后复盘所得经验，应用于其他新产品、流程与制度优化，持续提升产品质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5" ;
    skos:prefLabel "Conduct post launch review"@en,
        "开展上市后评审"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.0> ;
    skos:definition "Charting a strategic course for marketing products/services. This will include defining the value proposition, creating a mechanism for pricing, and determining the right mix of marketing channels. Create a specific positioning and branding for the organization's offerings. Enlist marketing head to lead, with inputs from the business development and sales functions."@en,
        "制定产品/服务的市场营销战略路径，包括定义价值主张、构建定价机制、确定最优营销渠道组合；明确组织产品的定位与品牌策略；由市场负责人牵头，协同业务拓展与销售部门共同推进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2" ;
    skos:prefLabel "Develop marketing strategy"@en,
        "制定营销策略"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/3.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Taking, receiving, processing, and acknowledging new customer orders or amendments to outstanding customer orders. Monitoring status from order receipt to customer delivery/customer invoicing."@en,
        "接收、处理并确认新客户订单，或处理现有客户订单的变更；全程监控订单状态，从接单至客户交付或开票"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4" ;
    skos:prefLabel "Manage sales orders"@en,
        "销售订单管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/4.1> ;
    skos:definition "Forecasting demand for products using secondary research and customer feedback. Refine these forecasts. Inspect the approach used in creating forecasts, and determine its accuracy."@en,
        "基于二手研究与客户反馈开展产品需求预测；持续优化预测结果；审查预测方法并评估其准确性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.2" ;
    skos:prefLabel "Manage demand for products"@en,
        "管理产品需求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "Creating and approving requisitions and distributing purchase orders accordingly. Hasten the procurement process to satisfy internal needs."@en,
        "创建并审批请购单，据此下达采购订单；加速采购流程以满足内部需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.4" ;
    skos:prefLabel "Order materials and services"@en,
        "下达物料与服务订单"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "Scheduling the production of final products. Generate a detailed schedule plan. Create and release production orders and lots. Schedule the planned and unplanned maintenance orders."@en,
        "最终产品生产排程：生成详细排程计划；创建并下达生产工单与批次；统筹计划性与非计划性设备维护工单排程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.1" ;
    skos:prefLabel "Schedule production"@en,
        "制定生产计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.1" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Outlining the strategy for managing logistics. Translate customer requirements logistic requirements. Create an efficient logistic network and outsourcing portions of logistics activities. Design a logistics strategy that optimizes transportation costs and schedule. Define key performance indicators."@en,
        "制定物流管理战略。将客户需求转化为物流需求；构建高效物流网络，外包部分物流职能；设计兼顾运输成本与交付时效的物流策略；定义关键绩效指标（KPI）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.1" ;
    skos:prefLabel "Provide logistics governance"@en,
        "提供物流治理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/5.1> ;
    skos:definition "Constructing strategies that identify goals, policies, processes, and procedures in relation to service delivery. Review and validate strategies. Define the workplace layout and infrastructure."@en,
        "制定服务交付相关目标、政策、流程与规程策略，并开展评审与验证；明确工作场所布局与基础设施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.2" ;
    skos:prefLabel "Develop service delivery strategies"@en,
        "制定服务交付战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/5.2> ;
    skos:definition "Instituting training to enable resources to provide service delivery to the customer. Develop a training plan. Create materials that provide for operation and technical training. Schedule, perform, and evaluate training."@en,
        "实施培训赋能，提升资源服务交付能力；制定培训计划；开发运营与技术类培训材料；统筹安排、执行并评估培训效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3" ;
    skos:prefLabel "Enable service delivery resources"@en,
        "赋能服务交付资源"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/5.4> ;
    skos:definition "Collaborating with the customer to understand service needs. Review, understand, and modify the delivery scope with the organization needs of the customer in mind. Confirm readiness and identify, select, and assign resources. Plan for service delivery."@en,
        "协同客户明确服务需求；结合客户组织目标，评审、理解并优化交付范围；确认就绪状态，识别、遴选并指派资源；制定服务交付计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.4.1" ;
    skos:prefLabel "Initiate service delivery"@en,
        "启动服务交付"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.4.2" ;
    skos:broader <https://oprocess.net/opf/node/5.4> ;
    skos:definition "Carrying out service delivery to the customer by creating and deploying the necessary solution. Analyze need and create a solution. Validate the solution and make changes if needed. Obtain approval to build/buy solution and then deploy solution to customer."@en,
        "通过构建与部署必要解决方案开展客户服务交付：分析需求、设计解决方案、验证方案有效性并按需优化；获取建设/采购方案的审批后，向客户部署解决方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.4.2" ;
    skos:prefLabel "Execute service delivery"@en,
        "执行服务交付"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.4.3" ;
    skos:broader <https://oprocess.net/opf/node/5.4> ;
    skos:definition "Implementing final steps to complete service delivery to the customer. Evaluate success through project review, complete finance activities, and confirm delivery. Release resources and manage completion by harvesting knowledge and systems by archiving records."@en,
        "执行服务交付收尾工作：通过项目复盘评估成效、完成财务结算、确认交付完成；释放资源，并通过归档记录、知识沉淀与系统固化实现闭环管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.4.3" ;
    skos:prefLabel "Complete service delivery"@en,
        "完成服务交付"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.1" ;
    skos:broader <https://oprocess.net/opf/node/6.0> ;
    skos:definition "Defining a plan that removes customer obstacles by gathering operational insight and competitive insight, as well as improving soft skills and forward resolution for employees. Develop customer segmentation. Define rules and regulations for customer service. Establish service levels for customers."@en,
        "制定消除客户障碍的客户服务规划：整合运营洞察与竞争洞察，提升员工软技能与前置问题解决能力；开展客户分群；明确客户服务规则与规范；设定差异化服务等级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.1" ;
    skos:prefLabel "Develop customer service strategy"@en,
        "制定客户服务战略"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.2> ;
    skos:definition "Handling the requirements for new employees. Create and open job requisitions by clearly defining the job descriptions. Post these requirements internally and externally, and modify them as appropriate. Manage the dates of the whole requisition process."@en,
        "管理新员工需求：明确定义岗位职责，创建并发布职位申请；内外部同步发布需求，并依实际情况动态调整；全程管控职位申请流程时间节点。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.1" ;
    skos:prefLabel "Manage employee requisitions"@en,
        "管理员工岗位需求申请"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.3.4" ;
    skos:broader <https://oprocess.net/opf/node/7.3> ;
    skos:definition "Establish organizational development needs for employees. Creating a link between employee and organizational development needs."@en,
        "识别组织层面的员工发展需求；建立员工发展需求与组织发展需求之间的协同关联。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.3.4" ;
    skos:prefLabel "Develop and train employees"@en,
        "员工培养与培训"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Establishing and maintaining service levels for the provision of IT services and solutions. Design and maintain the IT services and solution catalogue, as well as service level agreements. Evaluate the performance of IT service level agreements. Communicate the results to the management."@en,
        "建立并维护信息技术（IT）服务与解决方案的服务水平；设计和维护IT服务与解决方案目录及服务水平协议（SLA）；评估IT服务水平协议执行绩效，并向管理层通报结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.5" ;
    skos:prefLabel "Develop and manage IT service levels"@en,
        "制定并管理IT服务级别"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Defining perspective, position, plans, and patterns needed to execute designing, delivering, managing, and improving the way information technology is used within an organization."@en,
        "明确视角、定位、计划与模式，以支撑组织内信息技术应用的设计、交付、管理与持续改进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4" ;
    skos:prefLabel "Define IT service management strategy"@en,
        "定义IT服务管理战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Outline and manage the innovation of technology within the organization. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Research and understand emerging future technological concepts and capabilities. Plan for IT innovation investments. Plan and execute viable innovation projects."@en,
        "规划并管理组织内部的技术创新，涵盖人工智能（AI）等所有新型与演进中的技术；研究并理解未来新兴技术概念与能力；规划IT创新投资；策划并执行可行的创新项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7" ;
    skos:prefLabel "Define and manage technology innovation"@en,
        "定义并管理技术创新"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Creating and deploying an architecture for securing and ensuring the privacy of data flows throughout the organization. Develop and implement protocols and policies to protect IT and OT environments, aligned with global standards. Incorporate modern security paradigms, such as Zero Trust Architecture, to ensure the safe use of IT services and solutions."@en,
        "构建并部署端到端数据流安全与隐私保护架构；制定并实施保护IT与OT环境的协议和政策，符合全球标准；融入零信任架构（Zero Trust Architecture）等现代安全范式，保障IT服务与解决方案的安全使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5" ;
    skos:prefLabel "Develop and manage IT security, privacy, and data protection"@en,
        "制定并管理IT安全、隐私与数据保护"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Designing and maintaining the IT services/solutions catalogue. Evaluate the performance of IT services/solutions. Communicate the results to the management."@en,
        "设计并维护 IT 服务/解决方案目录；评估 IT 服务/解决方案绩效；向管理层汇报结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5" ;
    skos:prefLabel "Develop and manage services/solutions"@en,
        "开发与管理服务/解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5> ;
    skos:definition "Developing service/solution along with creating a strategy that provides a base for delivering service/solution aligned with overall business needs. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct research within the services/solutions field for development and integration."@en,
        "开发 IT 服务/解决方案，并制定支撑其交付的战略，确保与整体业务需求对齐；涵盖人工智能（AI）等各类新兴与演进技术；开展服务/解决方案领域的研发与集成研究。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1" ;
    skos:prefLabel "Develop service/solution and integration strategy"@en,
        "制定服务/解决方案及集成战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4> ;
    skos:definition "Executing an information system, aiming to produce a high quality system that meets or exceeds customer expectations, reaches completion within time and cost estimates, and is inexpensive to maintain and cost-effective to enhance."@en,
        "实施信息系统，目标是交付高质量系统：满足或超越客户期望、按时按预算完成、易于维护且增强成本可控。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1" ;
    skos:prefLabel "Execute IT service/solution development lifecycle"@en,
        "执行IT服务/解决方案开发生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.2" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect."@en,
        "IT解决方案与服务的变更规划与执行：制定变更部署计划；向相关方沟通变更内容；管理并实施变更；对受变更影响的人员开展培训；安装变更并验证其效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.2" ;
    skos:prefLabel "Plan service and solution implementation"@en,
        "规划服务与解决方案实施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.3" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "Creating and deploying an architecture for securing the changes deployed in the organization. Create and develop protocols that ensure proper and efficient use of deployed IT services and solutions. Test, evaluate, and implement the policies and protocols."@en,
        "构建并部署保障已实施变更安全性的架构；制定并完善确保IT服务与解决方案高效、合规使用的规程；对政策与规程开展测试、评估与落地实施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.3" ;
    skos:prefLabel "Manage change deployment control"@en,
        "管理变更与发布部署控制"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.5" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect."@en,
        "IT解决方案与服务的变更规划与执行：制定变更部署计划；向相关方沟通变更内容；管理并实施变更；对受变更影响的人员开展培训；安装变更并验证其效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.5" ;
    skos:prefLabel "Perform service and solution rollout"@en,
        "开展服务与解决方案上线"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.1> ;
    skos:definition "Checking and achieving predetermined financial targets and timelines. Assess and manage the profitability, feasibility, and consistency of a business or project. Study the revenues generated."@en,
        "核查并达成既定财务目标与时间节点。评估与管理业务或项目的盈利能力、可行性与持续性，并分析收入构成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5" ;
    skos:prefLabel "Evaluate and manage financial performance"@en,
        "评估与管理财务绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "Evaluating and processing requests for advances. Evaluate credit requests by customers requiring loans to buy products/services."@en,
        "审核与处理预付款申请。评估客户为采购产品或服务而提出的信贷申请。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1" ;
    skos:prefLabel "Process customer credit"@en,
        "处理客户信用管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "Posting entries to respective accounts, and preparing accounts for receivables. Manage the cash collected by the business from its debtors. Record it in the books of accounts to provide clear information about the availability of the cash."@en,
        "将会计分录过账至对应账户，建立并管理应收账款明细账；统筹管理企业从债务人处收回的现金，并在账簿中准确记录，以清晰反映现金可用状况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4" ;
    skos:prefLabel "Manage and process collections"@en,
        "管理与处理催收"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Managing financial services provided by an in-house bank structure in the corporation that is operating like a commercial bank."@en,
        "管理集团内部银行架构所提供的金融服务，该架构按商业银行模式运作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3" ;
    skos:prefLabel "Manage in-house bank accounts"@en,
        "管理内部银行账户"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2" ;
    skos:broader <https://oprocess.net/opf/node/9.9> ;
    skos:definition "Processing the taxes of the organization in line with the regional taxation structure, including corporate, property, excise, and service taxes."@en,
        "依据区域税收体系处理组织各项税款，包括企业所得税、房产税、消费税及服务税。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2" ;
    skos:prefLabel "Process taxes"@en,
        "处理税务事项"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Formulating a design for the organization's resources that allow it to meet its objectives. Develop a new framework for molding the organization's various processes into a coherent and seamless whole."@en,
        "设计组织资源配置方案，确保目标达成；构建新型框架，将组织各项流程整合为协调、无缝的整体。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5" ;
    skos:prefLabel "Create organizational design"@en,
        "设计组织架构"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Planning and performing waste and hazardous goods management. In compliance with all legal, regulatory, and social/environmental requirements, plan, document, and conduct hazardous material handling, disposal, and reporting."@en,
        "规划、执行并追踪废弃物及危险品管理，严格遵循法律、法规及社会责任与生态环境要求，落实危险物质的全过程管理、记录、处置与报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11" ;
    skos:prefLabel "Perform waste and hazardous goods management"@en,
        "开展废弃物及危险品管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Establishing a foundational plan that guides how an organization manages its content through the content lifecycle. Outlining the strategy for organizing, delivering, and facilitating access to enterprise content."@en,
        "制定指导企业内容全生命周期管理的基础性规划，明确内容组织、交付与访问支持策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1" ;
    skos:prefLabel "Define content management strategy"@en,
        "制定内容管理战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Creating, acquiring, refining, and maintaining content to ensure it is accurate, relevant, consistent, and aligned with organizational standards and intended use. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI). Apply metadata, tags, and semantic relationships to improve findability, compliance, and reuse."@en,
        "创建、获取、精炼与维护内容，确保其准确、相关、一致且符合组织标准与预期用途；包括应用人工智能（AI）等各类新兴与演进技术；通过元数据、标签与语义关系提升可发现性、合规性与复用性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5" ;
    skos:prefLabel "Develop and manage content"@en,
        "内容开发与管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3" ;
    skos:broader <https://oprocess.net/opf/node/13.7> ;
    skos:definition "Assessing process data, measures, and trends in an effort to evaluate process performance and identify possible improvements."@en,
        "分析流程数据、度量指标及趋势，以评估流程绩效并识别改进机会。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3" ;
    skos:prefLabel "Evaluate performance"@en,
        "评估绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3> ;
    skos:definition "Determining requirements related to the creation of the product/service. Explain potential achievements that could be made."@en,
        "明确产品/服务创建相关的需求，并说明其潜在达成效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1" ;
    skos:prefLabel "Define product/service requirements"@en,
        "定义产品和服务需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Establishing marketing communications that deliver promotional messages, in a coordinated way, through multiple marketing channels, such as print, radio, television, direct mail, online or mobile advertising, email, social media or personal selling."@en,
        "建立整合型营销传播体系，通过印刷、广播、电视、直邮、线上或移动端广告、电子邮件、社交媒体及人员销售等多种渠道，协同传递促销信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6" ;
    skos:prefLabel "Develop marketing communication strategy"@en,
        "制定营销传播策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Conceptualizing, testing, and executing product/service/brand promotions. Once a promotion has launched, this process continues as the organization tweaks parts of the promotion or chooses to use ideas or lessons learned during the promotion in future activities. The promotion's performance according to organizational measures is also evaluated in this process. Determine early on whether you need third party help with promotion. Purchase lists, consult with social media experts, hire seasonal staff, or pay for additional research."@en,
        "策划、测试并执行产品/服务/品牌促销活动；活动上线后持续优化局部环节，并将经验教训应用于后续活动；同步依据组织指标评估促销成效；初期即判断是否需引入第三方支持（如购买客户名单、咨询社交媒体专家、雇佣季节性人员或追加专项调研）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4" ;
    skos:prefLabel "Develop and manage promotional activities"@en,
        "制定并管理促销活动"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5" ;
    skos:broader <https://oprocess.net/opf/node/3.0> ;
    skos:definition "Selling products/services. Set appropriate customer expectations. Work with customers using the same schedule that product/service development, production, and customer service functions follow. Manage sales personnel and sales partnerships/alliances."@en,
        "开展产品/服务销售工作；合理设定客户期望；协同产品研发、生产与客户服务职能，执行统一运营节奏；统筹销售团队及销售合作伙伴/联盟管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5" ;
    skos:prefLabel "Develop and manage sales plans"@en,
        "制定并管理销售计划"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/3.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Generating leads of prospective customers to grow the organization's business. Identify viable customers based on customer and market research. Discover leads through IT applications, cold calling, reference/network development, or other sales and business development techniques. Employ a scoring model qualify the prospective customers into leads, and prioritize them."@en,
        "开拓潜在客户线索以驱动业务增长：基于客户与市场研究识别高潜力客户；通过IT应用、陌生拜访、推荐/网络拓展或其他销售与业务拓展手段获取线索；运用评分模型对潜在客户进行线索分级与优先级排序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1" ;
    skos:prefLabel "Manage leads/opportunities"@en,
        "管理销售线索/商机"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Collecting and maintaining all account information. Collect information about the purchase, servicing, return, and/or commitment of any products/services on part of the organization to its customers. Bring together information from various organizational divisions, and update periodically."@en,
        "收集并维护全部客户账户信息；汇总组织向客户提供的产品/服务的采购、维保、退换及承诺等相关信息；整合跨部门数据并定期更新"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2" ;
    skos:prefLabel "Collect and maintain account information"@en,
        "收集与维护客户账户信息"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.2" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "Creating a plan for procuring materials and services. Develop strategies for sourcing materials and services. Choose the most appropriate suppliers, and develop contracts with them. Order the materials and services as per the requirements. Manage relationships with suppliers."@en,
        "制定物料与服务采购计划；制定采购策略；遴选最合适的供应商并签订合同；按需下达采购订单；管理供应商关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2" ;
    skos:prefLabel "Procure materials and services"@en,
        "采购物料与服务"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "Creating strategies for procuring materials and services from various sources, and for managing and evaluating categories. Establish a procurement process that describes the approach for obtaining products and purchasing activities. Evaluate the sources. Create sourcing relationships in order to continuously improve. Re-evaluate purchasing activities."@en,
        "制定多源采购物料与服务的策略及品类管理策略；建立明确采购路径与采购活动流程；评估供应来源；构建持续改进的采购合作关系；定期复评采购活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.1" ;
    skos:prefLabel "Provide sourcing governance"@en,
        "实施采购治理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "Processing and delivering the finished goods manufactured by the organization. Schedule the production of products. Execute the product production activities. Perform tests to oversee and ensure quality of production. Maintain records of the production process. Track lots."@en,
        "加工并交付组织自主制造的产成品；制定产品生产计划；执行产品生产作业；开展质量检验以监督和保障生产质量；维护生产过程记录；追踪批次信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3" ;
    skos:prefLabel "Produce/Assemble/Test product"@en,
        "生产／装配／测试产品"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.3" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Tracking the inventory deployment. Accept and store products. Ship the products. Measure the accuracy of the inventory. Assess the performance of the outsourced logistics activities."@en,
        "跟踪库存部署：接收并存储产品；发运产品；衡量库存准确性；评估外包物流活动绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.3" ;
    skos:prefLabel "Operate warehousing"@en,
        "开展仓储运营"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/5.2> ;
    skos:definition "Ensuring necessary resources are maintained through monitoring pipeline, developing forecasts, and collaborating with customers. Determine skills needed for service deliver and forecast customer orders. Monitor forecasted orders and modify if where needed. Measure forecast accuracy."@en,
        "通过监控销售管线、开展需求预测及与客户协同，保障必要资源持续可用；明确服务交付所需技能，预测客户订单；持续监控预测订单并按需调整；评估预测准确率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1" ;
    skos:prefLabel "Manage service delivery resource demand"@en,
        "管理服务交付资源需求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.7" ;
    skos:broader <https://oprocess.net/opf/node/7.0> ;
    skos:definition "Managing the employee reporting processes, employee inquiry process, employee information and data, and the HR information systems. Create and administer the employee metrics. Develop and handle the time and attendance systems. Refurbish the indicators for employee retention and motivation."@en,
        "管理员工报告机制、员工咨询流程、员工信息与数据，以及人力资源（HR）信息系统；建立并运营员工绩效指标体系；开发并维护考勤与工时管理系统；优化员工留任与激励指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.7" ;
    skos:prefLabel "Manage employee information and analytics"@en,
        "管理员工信息与人力分析"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "The process of identifying, authenticating, and authorizing IT users to have access to applications, systems, IT components, or networks by associating user rights and restrictions with established identities."@en,
        "通过将用户权限与限制关联至已确立的身份标识，实现IT用户的识别、身份认证与授权，使其获得对应用、系统、IT组件或网络的访问权限。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8" ;
    skos:prefLabel "Manage IT user identity and authorization"@en,
        "管理IT用户身份与授权"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5> ;
    skos:definition "Creating the architecture for the IT services and solutions. Assess architecture and business constraints in order to understand integration requirements. Promote existing architecture. Manage exceptions."@en,
        "构建 IT 服务与解决方案架构；评估架构与业务约束，明确集成需求；推广现有架构；管理例外情形。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3" ;
    skos:prefLabel "Develop and manage service/solution architecture"@en,
        "开发与管理服务/解决方案架构"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Developing and managing different delivery services using service delivery systems for operational activities within the IT function in order to achieve organizations goal."@en,
        "依托服务交付系统，开发并管理多样化交付服务，支撑IT职能日常运营，助力组织目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6" ;
    skos:prefLabel "Develop and manage service delivery operations"@en,
        "开发与管理服务交付运营"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.3> ;
    skos:definition "Reporting on the organization's financial status to stakeholders. Include balance sheets, income statements, cash flow statements, and statements of shareholders' equity."@en,
        "向利益相关方报告组织财务状况。涵盖资产负债表、利润表、现金流量表及股东权益变动表。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4" ;
    skos:prefLabel "Perform financial reporting"@en,
        "开展财务报告"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.5> ;
    skos:definition "Managing the total payments made in employees payroll, including bonuses and compensation."@en,
        "管理员工薪酬总额支付，包括奖金与各类补偿。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2" ;
    skos:prefLabel "Manage pay"@en,
        "薪酬管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Managing rules and regulations for investments in trading in bonds, currencies, financial derivatives, etc. Establish policies and procedures for investments made. Optimize liquidity in treasury operations."@en,
        "制定并管理债券、外汇、金融衍生品等交易投资所适用的规则与监管要求；建立投资政策与流程；优化司库运营中的流动性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1" ;
    skos:prefLabel "Manage treasury policies and procedures"@en,
        "管理资金政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Taking care of all cash-related activities in the business. Manage and reconcile cash positions. Manage cash equivalents. Process and oversee electronic fund transfers. Develop cash flow forecasts. Manage cash flows. Produce cash management accounting transactions and reports. Manage and oversee banking relationships. Analyze, negotiate, resolve, and confirm bank fees."@en,
        "统筹管理企业全部现金相关活动；管理与核对现金头寸；管理现金等价物；处理并监督电子资金划转；编制现金流预测；管理现金流；生成现金管理会计分录与报告；管理并维护银企关系；分析、协商、解决及确认银行收费。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2" ;
    skos:prefLabel "Manage cash"@en,
        "管理现金"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Taking care of the organization's financial position. Manage its loans or debts from different sources and investments. Leverage the most profitable options to balance the financial position in the market."@en,
        "统筹管理组织整体财务状况；管理来自不同渠道的贷款或债务及各项投资；综合运用最具盈利性的融资与投资工具，实现市场财务结构的动态平衡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4" ;
    skos:prefLabel "Manage debt and investment"@en,
        "管理债务与投资"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2" ;
    skos:broader <https://oprocess.net/opf/node/11.1> ;
    skos:definition "Coordinating to plan, organize, lead, and control the activities of an organization in order to minimize the special effects of risk on capital and earnings."@en,
        "统筹规划、组织、领导与控制组织活动，以最小化风险对资本与盈利的特殊影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2" ;
    skos:prefLabel "Oversee and coordinate enterprise risk management activities"@en,
        "监督与协调企业风险管理活动"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2" ;
    skos:broader <https://oprocess.net/opf/node/11.2> ;
    skos:definition "Obeying laws, guidelines, strategies, and stipulations related to the business."@en,
        "遵守与业务相关的法律法规、指南、策略及规定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2" ;
    skos:prefLabel "Manage regulatory compliance"@en,
        "管理监管合规"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "Managing legal practices to abide by the law, as well as ethical practices."@en,
        "规范法律实践，确保依法合规运营，同时践行商业伦理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4" ;
    skos:prefLabel "Manage legal and ethical issues"@en,
        "管理法律与伦理事务"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.4> ;
    skos:definition "Developing plans for change management, training, communication, and rewards/incentives. Establish metrics for measuring the change adoption. Clarify new roles for employees. Identify budgets."@en,
        "制定变革管理、培训、沟通及激励方案；建立变革采纳成效衡量指标；厘清新岗位职责；明确预算安排。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2" ;
    skos:prefLabel "Design the change"@en,
        "设计变更方案"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1" ;
    skos:broader <https://oprocess.net/opf/node/13.5> ;
    skos:definition "Creating a plan for managing the organization's knowledge base. Determine what kind of specialized knowledge the organization possesses, which elements of this collective knowledge can prove beneficial, how to capture and maintain this knowledge, how to grant access to this library of information, and how the organization should proceed."@en,
        "制定组织知识库管理计划；明确组织所拥有的专业领域知识类型、其中可复用的关键知识要素、知识采集与维护方式、知识库访问机制，以及整体推进路径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1" ;
    skos:prefLabel "Develop KM strategy"@en,
        "制定知识管理战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Establishing all the activities needed to identify the appropriate channels to market to different customer segments as defined in Determine target segments [10117]. This involves finding channel partners, ensuring that the channels align with organizational strategy for each segment, and the final channel selection process."@en,
        "开展所有必要活动，识别面向不同客户细分（参见确定目标细分［10117］）的适配营销渠道，包括遴选渠道合作伙伴、确保渠道与各细分市场的组织战略一致，以及最终完成渠道选择。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4" ;
    skos:prefLabel "Define and manage channel strategy"@en,
        "定义并管理渠道策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/4.1> ;
    skos:definition "Creating strategies for production processes, as well as the process of managing materials. Define production and supply constraints. Design a blueprint of the workplace. Establish rules and regulations regarding the employees, outsourcing of services, and the expenditure to be incurred on the manufacturing capital."@en,
        "制定生产流程及物料管理战略：界定生产与供应约束；设计工作场所蓝图；制定关于员工、服务外包及制造资本投入的规章制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1" ;
    skos:prefLabel "Develop production and materials strategies"@en,
        "制定生产与物料战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1" ;
    skos:broader <https://oprocess.net/opf/node/7.5> ;
    skos:definition "Developing a salary/compensation structure and plan; developing a benefits and reward plan; develop commission plan; performing competitive analyses of benefits and rewards; identifying compensation requirements based on compensation, benefits, and HR policies; administering compensation, commission, and rewards to employees; and rewarding and motivating employees."@en,
        "制定薪酬结构与方案；设计福利与奖励计划；制定佣金方案；开展福利与奖励市场对标分析；依据薪酬、福利及人力资源政策明确薪酬需求；执行薪酬、佣金与奖励发放；实施员工激励与认可。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1" ;
    skos:prefLabel "Develop and manage reward, recognition, and motivation programs"@en,
        "制定并管理薪酬、认可与激励计划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Creating and administering relationships with IT customers. Understanding customer needs including high-level business requirements for IT transformation. Plan for and communicate IT services along with establishing IT service levels, providing transformation guidance, and performance analysis that foster IT customer relationships."@en,
        "建立并维护与 IT 客户的关系：理解客户高层级业务需求（含 IT 转型需求）；规划并宣贯 IT 服务，设定 IT 服务级别，提供转型指导，并开展绩效分析以持续强化客户关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1" ;
    skos:prefLabel "Develop and manage IT customer relationships"@en,
        "开发与管理IT客户关系"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Understanding the necessity of IT transformation for the business. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Collect and analyze customer requirements. Identify opportunities and prioritize outcomes. Develop and support business case for transformation. Develop transformation plan and roadmap."@en,
        "研判业务对 IT 转型的必要性（涵盖人工智能（AI）等各类新兴与演进技术）；收集并分析客户需求；识别机会并排序优先级；构建并支撑转型商业论证；制定转型计划与路线图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.4" ;
    skos:prefLabel "Provide IT transformation guidance"@en,
        "提供IT转型指导"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2> ;
    skos:definition "Regulating the IT management system through performance measures, governance, analysis, and monitoring through a variety of analytic tools. Evaluate IT finances, resource, services, projects, and value for report out."@en,
        "通过绩效度量、治理、分析与监控等多种分析工具，对IT管理体系实施管控；评估IT财务、资源、服务、项目及价值，并形成报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5" ;
    skos:prefLabel "Control IT management system"@en,
        "管控IT管理体系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6.4" ;
    skos:broader <https://oprocess.net/opf/node/8.6> ;
    skos:definition "Deploy the identified solutions for information technology important for healthy business operations. Confirm status and operational availability of IT resources. Perform testing and distribution of change. Execute roll-back protocol if necessary."@en,
        "部署支撑企业健康运营的关键IT解决方案；确认IT资源的状态与运行可用性；开展变更测试与分发；必要时执行回退预案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6.4" ;
    skos:prefLabel "Implement technology solutions"@en,
        "实施技术解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.3> ;
    skos:definition "Applying basic principles, concepts, and accounting practices in recording and preparing final accounts, and using accounting information in management."@en,
        "在账务记录与决算报表编制中贯彻基本会计原则、概念与实务，并将会计信息运用于管理决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2" ;
    skos:prefLabel "Perform general accounting"@en,
        "执行通用会计核算"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.3> ;
    skos:definition "Accounting for long-term and fixed assets. Record purchased, fixed assets that are not easily convertible into cash. Account for costs, useful life, resale value, depreciation, and amortization."@en,
        "长期资产与固定资产核算。记录购置的、不易变现的固定资产；核算其成本、使用寿命、残值、折旧及摊销。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3" ;
    skos:prefLabel "Perform fixed-asset accounting"@en,
        "开展固定资产会计核算"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "Assessing all forces, entities, and systems that are external to an organization but can affect its operation. Analyze far-reaching currents in the macroeconomic situation, assess the competition, evaluate technological changes, and identify societal as well as ecological issues of concern. Create a big-picture understanding of externalities, with sufficient depth across individual aspects."@en,
        "评估所有存在于组织外部但可能影响其运营的力量、实体与系统。分析宏观经济形势的深远趋势，评估竞争对手，研判技术变革，识别社会及生态领域的重要议题。构建对外部环境的全局性认知，并在各关键维度上具备足够深度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1" ;
    skos:prefLabel "Assess the external environment"@en,
        "评估外部环境"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.0> ;
    skos:definition "Developing an organization's mission statement, strategy, and business design. Create a concise statement that clearly articulates the mission of the organization, outlining practicable targets to Establish a strategic vision [10020]. Delineate strategic options by matching these alternatives with the organization's internal capabilities. Create an organizational design, and identify goals by developing strategies at the functional and process levels."@en,
        "制定组织使命陈述、战略及业务设计。编制简洁有力的使命陈述，清晰阐明组织使命，并设定切实可行的目标以支撑‘确立战略愿景’[10020]；通过匹配组织内部能力，厘清各项战略选项；构建组织架构，并在职能与流程层面制定策略以明确发展目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2" ;
    skos:prefLabel "Develop business strategy"@en,
        "制定业务战略"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1> ;
    skos:definition "Controlling/authorizing to enable services' and products' data and other critical data of these functions through a well secured storage and accessibility processes backed by siloed applications/IT systems."@en,
        "通过安全可靠的存储与访问机制，依托隔离式应用/IT 系统，对产品与服务数据及其他关键职能数据实施管控与授权。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4" ;
    skos:prefLabel "Manage product and service master data"@en,
        "管理产品和服务主数据"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.0> ;
    skos:definition "Creating specific plans to market offerings to customers. This process group includes processes for making budgets, identifying and developing media, pricing products and services, managing packaging, managing marketing content and promotional activities, tracking and responding to customer insight and monitoring measures established within \"develop marketing strategy\". Additionally, in this process group, organizations take action on plans made in earlier processes. Here, marketing and customers are managed and measured along with any supporting materials."@en,
        "制定面向客户的特定营销实施计划；本过程组涵盖预算编制、媒体识别与开发、产品与服务定价、包装管理、营销内容与促销活动管理、客户洞察跟踪与响应，以及“制定营销战略”环节所设定指标的监测；同时，组织在此阶段执行前期制定的计划，并对营销活动、客户及配套物料进行统筹管理与效果衡量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3" ;
    skos:prefLabel "Develop and manage marketing plans"@en,
        "制定并管理营销计划"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/6.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.2" ;
    skos:broader <https://oprocess.net/opf/node/6.3> ;
    skos:definition "Identifying, investigating, and processes warranty claims. This process includes: receipt and validation of a warranty claim; definition and diagnosis /root cause analysis of an issue and recommendation for corrective action; the determination of responsibility for settlement of the claim; the transaction being approved or denied; and the originator being notified and payment authorized. In the case of a recurring event, further investigation (definition and diagnosis or root cause analysis) is performed, and a recommendation for corrective action is made and implemented in production/design. It ends when the claim is closed."@en,
        "识别、调查与处理保修索赔，涵盖：索赔受理与有效性验证；问题界定、根因诊断与纠正措施建议；理赔责任归属判定；索赔审批或否决；通知发起方并授权付款。若属重复性事件，则开展深入根因分析，制定并落地生产/设计层面的纠正措施；最终以索赔结案为终点。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.2" ;
    skos:prefLabel "Process warranty claims"@en,
        "处理保修索赔"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.0" ;
    skos:definition "Delivering processes traditionally defined as \"human resources\". Process groups include those related to developing and maintaining workforce strategy, recruiting employees, developing and counseling employees, managing employee relations, rewarding and retaining employees, redeploying and retiring employees, managing employee information, and managing employee communications."@en,
        "履行传统定义为“人力资源”的各项流程。流程组涵盖：制定与维护人力资本战略、员工招聘、员工培养与辅导、员工关系管理、员工激励与保留、员工转岗与退休、员工信息管理、员工沟通管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.0" ;
    skos:prefLabel "Develop and Manage Human Resources"@en,
        "人力资本开发与管理"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/7.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.1" ;
    skos:broader <https://oprocess.net/opf/node/7.1> ;
    skos:definition "Creating a long-term plan that strategically aligns human resources with the company's goals. The HR function's focus is to ensure the organization has the necessary talent and capabilities to achieve its objectives, sustain its competitive advantage, and reduce employee turnover."@en,
        "制定长期人力资源战略规划，确保人力资本与公司目标战略对齐。人力资源职能聚焦于保障组织具备实现目标所需的人才与能力，维持竞争优势，并降低员工流失率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.1" ;
    skos:prefLabel "Develop human resources strategy"@en,
        "制定人力资本战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Handling the business of IT. Create a organization-wide strategy for the IT function. Define the organization's IT architecture. Manage the IT portfolio. Research and innovate in the field of IT. Assess and convey the performance and the value of the IT function."@en,
        "统筹IT业务运营：制定全组织IT职能战略；定义企业IT架构；管理IT投资组合；开展IT领域研究与创新；评估并传达IT职能绩效与价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2" ;
    skos:prefLabel "Develop and manage IT business strategy"@en,
        "制定并管理IT业务战略"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Develop and include the processes required to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat to IT and cybersecurity. Build a dynamic, strategic, and integrated approach to managing IT and cyber risks, compliance obligations, and resilience, while ensuring alignment with global standards and frameworks."@en,
        "制定并纳入必要流程，以快速适应和响应任何内部或外部的机遇、需求、干扰或对 IT 与网络安全的威胁；构建动态化、战略性、一体化的 IT 与网络风险、合规义务及韧性的管理方法，并确保与全球标准及框架保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3" ;
    skos:prefLabel "Develop and manage IT resilience and risk"@en,
        "构建并管理IT韧性与风险"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Ensuring that the organization effectively manages IT and cybersecurity risks by developing rules, standards, and strategies that safeguard the confidentiality, integrity, and availability of IT and OT assets. Establish compliance objectives, align with recognized cybersecurity frameworks, and integrate IT and OT risk management to create a unified approach."@en,
        "通过制定规则、标准与策略，有效管理 IT 与网络安全风险，保障 IT 与运营技术（OT）资产的机密性、完整性与可用性；确立合规目标，对标公认的网络安全框架，并融合 IT 与 OT 风险管理，形成统一方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1" ;
    skos:prefLabel "Develop IT compliance, risk, and security strategy"@en,
        "制定IT合规、风险与安全战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Ensuring effective control over IT and cybersecurity risks, compliance obligations, and security measures. Formulate and execute guidelines in line with regulatory bodies and organizational security objectives. Implement proactive measures such as threat intelligence, vulnerability management, and OT-specific controls to safeguard the organization’s IT and OT environments. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "确保对 IT 与网络安全风险、合规义务及安全措施实施有效管控；制定并执行符合监管机构要求及组织安全目标的指导方针；实施威胁情报、漏洞管理及面向 OT 的专项控制等主动防护措施，全面保护组织的 IT 与 OT 环境；涵盖人工智能（AI）等所有新兴及演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3" ;
    skos:prefLabel "Control IT risk, compliance, and security"@en,
        "管控IT风险、合规与安全"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.6" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Executing IT services/solutions by creating a strategy for deployment. Plan and execute the changes. Plan and administer the release of its IT services and solutions."@en,
        "通过制定部署策略执行IT服务/解决方案；规划并实施变更；规划并统筹IT服务与解决方案的发布。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.6" ;
    skos:prefLabel "Deploy services/solutions"@en,
        "部署服务/解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Develop strategies and methodologies to provide service support. Examine service levels, support complexity, stakeholder requirements to offer service support."@en,
        "制定服务支持策略与方法论；结合服务水平、支持复杂度及利益相关方需求，提供服务支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5" ;
    skos:prefLabel "Define service support planning"@en,
        "定义服务支持规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Making and collecting payments for transactions in products/services, and transporting them to interested markets."@en,
        "执行产品和服务交易的付款与收款，并将其运抵目标市场。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11" ;
    skos:prefLabel "Perform global trade services"@en,
        "提供全球贸易服务"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Assessing sets of strategic decisions designed to drive the organization's long-term objectives. Identify various strategies concerning core functional areas. Appraise strategic options in light of auxiliary decision frameworks that ensure smooth functioning, the advancement of functional efficiencies, and vitality. Involve senior management executives, especially strategy and/or business unit personnel, with need-based consultative assistance from professional services providers."@en,
        "评估一系列旨在驱动组织长期目标达成的战略决策。识别覆盖核心职能领域的各类战略；结合辅助性决策框架，评估各战略选项对保障平稳运行、提升职能效率及增强组织活力的影响；由高管层（尤其是战略与业务单元负责人）主导，按需引入专业服务机构提供咨询支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2" ;
    skos:prefLabel "Define and evaluate strategic options to achieve the mission"@en,
        "定义并评估实现使命的战略选项"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4" ;
    skos:broader <https://oprocess.net/opf/node/10.0> ;
    skos:definition "Managing the disposition of assets at their end-of-life. End-of-life for an asset may be due to obsolescence, replacement, excess capacity, or disrepair among other potential factors. Steps may include decommissioning, disassembly, recycling, etc. Tracking and reporting may also be appropriate for some or all asset types due to law, regulation, or social/environmental responsibility."@en,
        "管理资产全生命周期末期处置工作。资产退役原因可能包括技术淘汰、更新替换、冗余产能或严重损毁等；处置方式包括停用、拆解、回收等；部分或全部资产类型需依法律、法规及社会责任要求开展追踪与报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4" ;
    skos:prefLabel "Manage asset end-of-life"@en,
        "管理资产生命周期终结"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Creating new and improving existing analytical capabilities to enhance data management pipeline."@en,
        "构建新型分析能力并优化现有能力，以增强数据管理流水线效能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8" ;
    skos:prefLabel "Develop, Manage, and Deliver Analytics"@en,
        "开发、管理与交付分析服务"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/8.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.0" ;
    skos:definition "Managing process groups relevant to the business of information technology within an organization. The process groups include \"Develop and manage IT customer relationships\", \"Develop and manage IT business strategy\", \" Develop and manage IT resilience and risk\", \" Manage information\", \" Develop and manage services/solutions\", \"Deploy services/solutions\", and \" Create and manage support services/solutions\"."@en,
        "统筹管理组织内信息技术相关的过程组，包括：开发与管理 IT 客户关系、开发与管理 IT 业务战略、开发与管理 IT 韧性与风险、信息管理、服务/解决方案开发与管理、服务/解决方案部署、支持服务/解决方案创建与管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.0" ;
    skos:prefLabel "Manage Information Technology (IT)"@en,
        "管理信息技术（IT）"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/9.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1" ;
    skos:broader <https://oprocess.net/opf/node/9.6> ;
    skos:definition "Processing payments of operating expenses and other supplier charges. This includes the development of policies and procedures around processing of accounts payable and all operations. This process is often supported by key technology enablers."@en,
        "处理运营费用及其他供应商应付款项。包括制定应付账款及相关业务操作的政策与流程，通常依托关键信息技术支撑。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1" ;
    skos:prefLabel "Process accounts payable (AP)"@en,
        "处理应付账款（AP）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Determining and maintaining a pricing mechanism based on forecasted sales and that enables a pricing equilibrium for the lifecycles of products/services. Create a pricing mechanism, factoring in attributes relating to the market, customers, sales, and the cost of production. Implement this pricing mechanism over all products/services. Analyze its performance, and adjust accordingly."@en,
        "构建基于销量预测的动态定价机制，实现产品/服务全生命周期的价格均衡；综合考量市场、客户、销售及生产成本等因素制定定价规则；覆盖全部产品/服务；持续评估执行效果并动态调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3" ;
    skos:prefLabel "Develop and manage pricing"@en,
        "制定并管理定价策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/3.4> ;
    skos:definition "Cultivating an alliance of partners by identifying, analyzing, negotiating, and managing partnerships with other economic agents."@en,
        "构建合作伙伴联盟体系，涵盖伙伴识别、分析、谈判与关系管理全流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2" ;
    skos:prefLabel "Develop sales partner/alliance relationships"@en,
        "建立并管理销售合作伙伴/联盟关系"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.5" ;
    skos:broader <https://oprocess.net/opf/node/4.1> ;
    skos:definition "Maintaining master data of finished products and inventory. Identify the requirements of finished products at the destination, as well as partner requirements. Calculate the consolidation at source. Manage replenishment planning. Create and administer a dispatch plan. Calculate load plans for destinations and partners. Manage the cost of supplying these products. Ensure effective utilization of capacity."@en,
        "维护成品与库存主数据；识别终端客户及合作伙伴需求；计算源头集货量；管理补货计划；制定并执行发货计划；测算终端客户与合作伙伴的装载计划；管控产品供应成本；确保产能高效利用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.5" ;
    skos:prefLabel "Plan distribution requirements"@en,
        "规划分销需求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "Administering and overseeing all activities related to logistics and warehousing. Outline and establish a strategy for the logistics function. Plan and administer the flow of inbound materials. Administer the operational activities of warehousing and outbound transportation. Manage reverse logistics including returns and exchanges."@en,
        "统筹管理与物流及仓储相关的全部活动。制定并确立物流职能战略；规划并管控进厂物料流动；执行仓储及出厂运输的日常运营；管理逆向物流，包括退货与换货。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4" ;
    skos:prefLabel "Manage logistics and warehousing"@en,
        "管理物流与仓储"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.0" ;
    skos:definition "Overseeing key back-office processes for organizations. This category includes process groups related to planning and management accounting, revenue accounting, general accounting and reporting, fixed-asset project accounting, payroll, accounts payable and expense reimbursements, treasury operations, internal controls, tax management, international funds/consolidation, and global trade services."@en,
        "统筹组织关键后台流程，涵盖规划与管理会计、收入会计、总账会计与报告、固定资产项目会计、薪酬管理、应付账款与费用报销、资金运营、内部控制、税务管理、国际资金/合并报表、全球贸易服务等领域"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.0" ;
    skos:prefLabel "Manage Financial Resources"@en,
        "管理财务资源"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/13.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.0" ;
    skos:definition "Performing activities by an organization that are fundamental to the successful operation of the organization, even across functions in a business. Capabilities defined in the PCF include business process management; portfolio, program, and project management; quality management; change management; benchmarking; environmental health and safety management; and knowledge management."@en,
        "组织为保障高效运转而开展的基础性跨职能活动。PCF 定义的能力包括：业务流程管理；投资组合、项目集与项目管理；质量管理；变更管理；标杆管理；环境、健康与安全管理；知识管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.0" ;
    skos:prefLabel "Develop and Manage Business Capabilities"@en,
        "开发与管理业务能力"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "management_support" ;
    opf:level 1 .

<https://oprocess.net/opf/node/2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3> ;
    skos:definition "Sketching and standardizing product and service based on the market. Analyze the data market competitiveness and innovation attained for the product and service development."@en,
        "基于市场需求开展产品与服务的草图绘制与标准化；分析产品与服务开发所达成的市场竞争力与创新水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1" ;
    skos:prefLabel "Design and prototype products and services"@en,
        "设计并构建产品和服务原型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.4> ;
    skos:definition "Evaluating impact and planning change activities. Spanning the lifecycle of change from initial concept, to designing, implementing, and sustaining the change, change planning identifies the activities to enage and enable the stakeholders and all impacted by the change. Change plans should address the interplay between people, process, technology, and knowledge to guide the transition, or tranformation, from current state to the future state."@en,
        "评估变革影响并统筹变革活动；覆盖从初始构想到设计、实施及持续维持的全生命周期；变革规划需明确利益相关方参与路径与赋能机制；统筹人员、流程、技术与知识四大维度，引导组织由现状平稳迈向目标状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1" ;
    skos:prefLabel "Plan for change"@en,
        "变更规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Understanding and refining the customer requirements as provided in a RFP (Request for Proposal) or RFI (Request for Information).  When compiling the response, they must take into consideration whether the requirements are a match with the strategic or tactical plans of the organization and whether they are able to submit a bid/proposal that is competitive based on an understanding of the offerings of other competing organizations. The next step will be to define the pricing and scheduling of the proposed solution and determine whether the proposal will be profitable for the company if accepted. The bid is then submitted and a notification of whether or not it was successful is received."@en,
        "理解并优化客户在招标文件（RFP）或信息征询函（RFI）中提出的需求。编制响应方案时，需评估该需求是否契合组织的愿景与战略或战术规划，并判断能否基于对竞争对手产品和服务的了解，提交具备竞争力的投标/提案。后续需明确拟议解决方案的定价与实施计划，并评估若中标，该提案是否能为公司带来盈利。完成投标后提交方案，并接收中标或落标通知。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3" ;
    skos:prefLabel "Develop and manage sales proposals, bids, and quotes"@en,
        "销售方案、投标与报价的制定与管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "Creating strategies for production and materials. Handle the demand for the products of the organization. Develop plans for handling materials. Develop and administer the schedule for master production. Plan for distribution requirements and its constraints by reviewing and assessing distribution policies and performance and by establishing quality standards and procedures."@en,
        "制定生产与物料战略：应对组织产品需求；编制物料管理计划；制定并执行主生产计划；通过审查评估分销政策与绩效、设定质量标准与程序，规划分销需求及其约束条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1" ;
    skos:prefLabel "Plan for and align supply chain resources"@en,
        "规划并统筹供应链资源"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/7.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2" ;
    skos:broader <https://oprocess.net/opf/node/7.1> ;
    skos:definition "Creating and executing strategies and policies for smooth administration of workforce. Determine and gather skill requirements. Plan the requirements for employee resourcing per unit. Create compensation, succession, HR program, and employee diversity plans. Develop and administer policies for HR. Develop benefits for employees. Create models for work force strategies."@en,
        "制定并执行保障人力资本高效运营的战略与政策；识别并汇总技能需求；按业务单元规划人力配置需求；制定薪酬、继任、人力资源项目及员工多元化计划；制定并推行人力资源政策；设计员工福利方案；构建人力资本战略模型。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2" ;
    skos:prefLabel "Develop and implement workforce planning, policies, and strategies"@en,
        "制定并实施员工队伍规划、政策与战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7" ;
    skos:broader <https://oprocess.net/opf/node/8.0> ;
    skos:definition "Establishing and managing services for providing support to users of IT services and solutions. Define the plethora of services by which the organization assists users of computers, software products, or other information technology products."@en,
        "建立并管理面向 IT 服务与解决方案用户的支撑服务，明确组织为计算机、软件产品及其他信息技术产品用户提供支持的各类服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7" ;
    skos:prefLabel "Create and manage support services/solutions"@en,
        "创建与管理支持服务/解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.0> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.0" ;
    skos:definition "Performing supply chain activities include planning supply chain, procuring materials and services, and managing logistics."@en,
        "开展供应链活动，包括供应链规划、物资与服务采购、物流管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.0" ;
    skos:prefLabel "Manage Supply Chain for Physical Products"@en,
        "管理实物产品供应链"@zh ;
    skos:topConceptOf <https://oprocess.net/opf> ;
    opf:domain "operating" ;
    opf:level 1 .

