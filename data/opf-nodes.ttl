        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Determining if a returned product can be salvaged or repaired. Salvage or repair is dependent upon the product, the condition of the product, or the availability of a like item."@en,
        "Determining if a returned product can be salvaged or repaired. Salvage or repair is dependent upon the product, the condition of the product, or the 可用性 of a like item."@zh ;
