<https://oprocess.net/opf/node/4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Creating and executing a strategy for all the internal activities related to the flow/transfer of inbound materials. This process includes planning inbound material receipts, managing inbound material flow, monitoring inbound delivery performance, managing the flow of returned products, controlling the quality of returned parts, and salvaging or repairing returned products."@en,
        "Creating and executing a 战略 for all the internal activities related to the flow/transfer of inbound materials. This process includes planning inbound material receipts, managing inbound material flow, 监控 inbound delivery 绩效, managing the flow of returned products, controlling the 质量 of returned parts, and salvaging or repairing returned products."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2" ;
    skos:prefLabel "Plan and manage inbound material flow"@en,
        "规划 and manage inbound material flow"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF1" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "SCOR DS 14.0: Fulfill Stocked Product (sF1)."@en,
        "SCOR DS 14.0: 履约 Stocked Product (sF1)."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.9" ;
    skos:prefLabel "Fulfill Stocked Product"@en,
        "履约 Stocked Product"@zh ;
    opf:domain "operating" ;
