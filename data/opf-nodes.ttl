        "ITIL V5 实践：服务财务管理。映射至‘制定并管理 IT 业务战略’。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.10" ;
    skos:prefLabel "Service Financial Management"@en,
        "IT服务财务管理"@zh ;
    opf:domain "management_support" ;
