    skos:notation "9.2.2.5" ;
    skos:prefLabel "Resolve customer billing inquiries"@en,
        "解决 customer billing inquiries"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.1> a skos:Concept,
