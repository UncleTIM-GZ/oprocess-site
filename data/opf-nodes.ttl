        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sSR1" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Source Return Defective Product (sSR1)."@en,
        "SCOR DS 14.0：缺陷产品退货采购（sSR1）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.5" ;
    skos:prefLabel "Source Return Defective Product"@en,
        "寻源退货（缺陷产品）"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

