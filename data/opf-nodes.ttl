        "Scheduling and performing commissioning activities to verify that constructed 资产 operate as intended, meet specified requirements, and are ready for handover, use, or operational acceptance."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.5" ;
    skos:prefLabel "Schedule and perform commissioning"@en,
        "调度 and perform commissioning"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

