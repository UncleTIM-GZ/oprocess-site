    skos:notation "6.5.3.3" ;
    skos:prefLabel "Solicit customer feedback on cross-channel experience"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/6.5.3> ;
    skos:definition "Assessing the information collected on customer satisfaction levels with products/services in order to determine areas for improvement. Examine the data and information extracted from the customer feedback and reviews to measure the satisfaction levels of the customers. Identify opportunities that could enhance the customer satisfaction levels and the overall customer service strategy."@en,
        "Assessing the information collected on customer satisfaction levels with products/services in order to determine areas for improvement. Examine the data and information extracted from the customer feedback and reviews to measure the satisfaction levels of the customers. 识别 opportunities that could enhance the customer satisfaction levels and the overall 客户服务 战略."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.3.4" ;
    skos:prefLabel "Analyze product and service satisfaction data and identify improvement opportunities"@en,
        "分析 product and service satisfaction data and identify improvement opportunities"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/6.5.3> ;
    skos:definition "Providing feedback from customers on products/services to the product management team. Analyze information collected through Gather and solicit post-sale customer feedback on products/services [11238]. Share with the product management team for consideration while improving existing offerings or developing new products/services."@en,
        "Providing feedback from customers on products/services to the product management team. 分析 information collected through Gather and solicit post-sale customer feedback on products/services [11238]. Share with the product management team for consideration while improving existing offerings or developing new products/services."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.3.5" ;
    skos:prefLabel "Provide feedback and insights to appropriate teams (product design/development, marketing, manufacturing)"@en,
        "提供 feedback and insights to appropriate teams (product design/development, marketing, manufacturing)"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

