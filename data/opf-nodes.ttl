<https://oprocess.net/opf/node/7.1.2.16> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.16" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Creating descriptions for job requisitions. Define the normal components of a job description, such as the overall position description with general areas of responsibility listed, essential functions of the job described with a couple of examples of each, required knowledge, skills, abilities, required education and experience, a description of the physical demands, and a description of the work environment."@en,
        "Creating descriptions for job requisitions. 定义 the normal components of a job description, such as the overall position description with general areas of responsibility listed, essential functions of the job described with a couple of examples of each, required knowledge, skills, abilities, required education and experience, a description of the physical demands, and a description of the work environment."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.16" ;
    skos:prefLabel "Develop and maintain job descriptions"@en,
        "开发 and maintain job descriptions"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2.2> ;
    skos:definition "Defining the strategic approach for wages, salaries, and benefits to support workforce attraction, retention, performance, and alignment with organizational objectives and market conditions."@en,
        "Defining the strategic approach for wages, salaries, and benefits to support workforce attraction, retention, 绩效, and 对齐 with organizational objectives and market conditions."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.2.2.1" ;
