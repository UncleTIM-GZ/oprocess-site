    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1.8" ;
    skos:prefLabel "Measure forecast accuracy"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Analyzing the skills needed to perform services to be delivered. Classify and organize these skills requirements."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.1" ;
    skos:prefLabel "Define and manage skills taxonomy"@en,
        "定义 and manage skills taxonomy"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Creating a plan to ensure that all resources are available to carry out services required for the customer. This can include physical resources and personnel."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.2" ;
    skos:prefLabel "Create resource plan"@en,
        "创建 resource plan"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Matching demand with skills and capability. Enlisting suppliers and partners to help with demand when needed."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.3" ;
    skos:prefLabel "Match resource demand with capacity, skills, and capabilities"@en,
        "Match resource demand with 容量, skills, and capabilities"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Understanding organizational need to enlist suppliers to provide resources for gaps in skills and capabilities. Identify where additional skills are needed and collaborate with third parties to fill those demands."@en,
        "Understanding organizational need to enlist suppliers to provide resources for gaps in skills and capabilities. 识别 where additional skills are needed and collaborate with third parties to fill those demands."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.4" ;
    skos:prefLabel "Collaborate with suppliers and partners to supplement skills and capabilities"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Realizing critical resources required to perform and carry out customer needs. Engage with suppliers to fulfill those needs, if necessary. Identify supplier threshold for performing those needs."@en,
        "Realizing critical resources required to perform and carry out customer needs. Engage with suppliers to 履约 those needs, if necessary. 识别 supplier threshold for performing those needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.5" ;
    skos:prefLabel "Identify critical resources and supplier capacity"@en,
        "识别 critical resources and supplier 容量"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.2.6" ;
    skos:broader <https://oprocess.net/opf/node/5.2.2> ;
    skos:definition "Directing and managing workforce needs. Ensure that resources are at full capacity. Monitor that all resources are able to skilled in their respective rolls. Make sure that necessary resources are available to provide the needed services."@en,
        "Directing and managing workforce needs. Ensure that resources are at full 容量. 监控 that all resources are able to skilled in their respective rolls. Make sure that necessary resources are available to provide the needed services."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.2.6" ;
    skos:prefLabel "Monitor and manage resource capacity and availability"@en,
        "监控 and manage resource 容量 and 可用性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training."@en,
        "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the 训练. Determine when and where the apprentice or trainee needs to go to receive the structured component of the 训练."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.1" ;
    skos:prefLabel "Develop service delivery training plan"@en,
        "开发 service delivery 训练 plan"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Developing materials necessary to provide comprehensive training for the skills or behavior needed to deliver services. This can be any number for formats such as classroom or computer based training."@en,
        "Developing materials necessary to provide comprehensive 训练 for the skills or behavior needed to deliver services. This can be any number for formats such as classroom or computer based 训练."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.2" ;
    skos:prefLabel "Develop training materials"@en,
        "开发 训练 materials"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Providing training to the employee within a manageable timeframe to meet the needs of both the individual and the organization."@en,
        "Providing 训练 to the employee within a manageable timeframe to meet the needs of both the individual and the organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.3" ;
    skos:prefLabel "Manage training schedule"@en,
        "管理 训练 schedule"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Educating service delivery personnel on all aspects of the operations process of the organization."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.4" ;
    skos:prefLabel "Deliver operations training"@en,
        "Deliver operations 训练"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Ensuring that all personnel are trained on all technical aspects of service delivery to include compliance with constraints on how advanced technologies including artificial intelligence (AI) are used."@en,
        "Ensuring that all personnel are trained on all technical aspects of service delivery to include 合规 with constraints on how advanced technologies including 人工智能 (AI) are used."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.5" ;
    skos:prefLabel "Deliver technical training"@en,
        "Deliver technical 训练"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.6" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Verifying that training provided to the person was successful through the administration testing and the application of skills for practical use."@en,
        "Verifying that 训练 provided to the person was successful through the administration testing and the application of skills for practical use."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.6" ;
    skos:prefLabel "Perform skill and capability testing"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.3.7" ;
    skos:broader <https://oprocess.net/opf/node/5.2.3> ;
    skos:definition "Eliciting feedback from various sources to evaluate the training provided. This can be achieved through testing and the practical application of skills. Additionally, manager or student feedback can be garnered to evaluate training effectiveness."@en,
        "Eliciting feedback from various sources to evaluate the 训练 provided. This can be achieved through testing and the practical application of skills. Additionally, manager or student feedback can be garnered to evaluate 训练 effectiveness."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.3.7" ;
    skos:prefLabel "Evaluate training effectiveness"@en,
        "评估 训练 effectiveness"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/5.3> ;
    skos:definition "Planning the service delivery system by defining service requirements, capacity, resources, and delivery approaches needed to support effective and reliable service provision."@en,
        "Planning the 服务交付系统 by defining service requirements, 容量, resources, and delivery approaches needed to support effective and reliable service provision."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.3.1" ;
    skos:prefLabel "Perform service delivery system planning"@en,
        "Perform 服务交付系统 planning"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/5.3> ;
    skos:definition "Establishing and activating the service delivery system, including preparing resources, processes, and controls required to begin delivering services."@en,
        "Establishing and activating the 服务交付系统, including preparing resources, processes, and controls required to begin delivering services."@zh ;
