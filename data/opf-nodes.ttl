        "AI流程：管理AI监管合规。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.2" ;
    skos:prefLabel "Manage AI Regulatory Compliance"@en,
        "管理人工智能监管合规"@zh ;
