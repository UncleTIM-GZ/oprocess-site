<https://oprocess.net/opf/node/9.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Handling reporting time, managing pay, and processing taxes from salaries. Pay employees. Withhold taxes. Confirm the correct funds are paid to the correct government agency."@en,
        "工时管理、薪酬发放与薪资税务处理。向员工支付薪酬，代扣代缴税款，并确保税款准确划付至对应政府主管部门。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5" ;
    skos:prefLabel "Process payroll"@en,
        "处理薪酬发放"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Handling bills and reimbursements to be made. Make payments for goods or services taken or used on behalf of the organization."@en,
        "处理应付账款及员工费用报销。代表组织支付所采购商品或服务的相关款项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6" ;
    skos:prefLabel "Process accounts payable and expense reimbursements"@en,
        "处理应付账款及费用报销"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Administering internal controls. This process requires the organization to manage entity's board of trustees, management, and other personnel in order to offer judicious assurance about the achievement of effectiveness, proficiency of operations, and reliability of financial reporting."@en,
        "管理内部控制体系。该流程要求组织通过董事会、管理层及其他人员协同运作，为运营效率、效果及财务报告可靠性提供合理保证。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8" ;
    skos:prefLabel "Manage internal controls"@en,
        "管理内部控制"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.1" ;
    skos:broader <https://oprocess.net/opf/node/9.9> ;
    skos:definition "Setting targets for periodic tax liabilities. Assess the tax impact of various activities such as the acquisition or disposal of fixed assets or a deliberate change in number of employee."@en,
        "设定周期性税务负债目标，评估固定资产购置或处置、员工数量主动调整等各类活动的税务影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.1" ;
    skos:prefLabel "Develop tax strategy and plan"@en,
        "制定税务战略与规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.1.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5> ;
    skos:definition "Examining various options shortlisted for assimilating new entities into the organization or dissociating from it. Undertake a piecemeal and comprehensive consideration of each option identified for acquisition, merger, de-merger, and divestment. Consider intangible and non-material aspects of the entities involved and synergic aspects. Consider the assistance of specialist professional services."@en,
        "对拟纳入组织或剥离的实体选项开展多维度综合评估。逐项审慎分析收购、合并、分拆与剥离等已筛选方案；兼顾相关实体的无形资产、非财务因素及协同效应；必要时引入专业服务机构提供支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.3" ;
    skos:prefLabel "Analyze deal options"@en,
        "分析交易方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Defining a roadmap to meet customer expectations while considering how it will affect the business."@en,
        "制定满足客户期望的战略路线图，并同步评估其对业务的影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8" ;
    skos:prefLabel "Develop customer experience strategy"@en,
        "制定客户体验战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/1.4> ;
    skos:definition "Creating an economic model that describes the goals of an organization and the business processes needed to achieve those goals. This involves information gathering, securing necessary approvals and authorizations, integrating with preexisting models, including the general business concept [10002] and business strategy [10015], and formally accepting the model as the basis for organization's day-to-day operations."@en,
        "构建描述组织目标及其实现所需业务流程的经济模型；涵盖信息收集、获取必要审批与授权、与既有模型（含通用业务概念[10002]及业务战略[10015]）集成，并正式确认该模型作为组织日常运营的基础依据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.1" ;
    skos:prefLabel "Develop business models"@en,
        "开发业务模型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/1.4> ;
    skos:definition "Revising and updating business models to reflect the changes in the marketed services, product inventory, market behavior, available resources or accrued expenses. Determine how and when to modify the accepted business model in response to incoming feedback."@en,
        "根据市场化服务调整、产品库存变化、市场行为演变、可用资源变动或累计成本变化，持续修订与更新业务模型；明确响应外部反馈时业务模型的优化方式与时点。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.2" ;
    skos:prefLabel "Maintain business models"@en,
        "维护业务模型"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2" ;
    skos:broader <https://oprocess.net/opf/node/10.0> ;
    skos:definition "Designing and constructing assets such as machines, tools, factories, etc. Manage steps to acquire assets including managing capital, as well as planning, scheduling, and overseeing acquisition/construction."@en,
        "资产的设计与建造，如机器、工装、厂房等。统筹资产获取全过程，包括资本管理，以及规划、排程与建设/采购监督。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2" ;
    skos:prefLabel "Design and construct assets"@en,
        "资产设计与建设"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/10.4.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.10" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Planning and performing abandonment activities. Whether facilities  or equipment, ensure assets to be abandoned are safe, secure, and meet all legal, regulatory, and social/environmental responsibilities."@en,
        "规划并执行废弃活动（含设施或设备），确保拟废弃资产处于安全、受控状态，并满足全部法律、法规及社会责任与生态环境要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.10" ;
    skos:prefLabel "Perform abandonment"@en,
        "执行废弃处置"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1" ;
    skos:broader <https://oprocess.net/opf/node/11.0> ;
    skos:definition "Creating requisite frameworks and coordinating all risk management activities for the entire organization and each function. Manage the enterprise risk by outlining the risk policies and procedures. Monitor and communicate all risk management activities. Encourage correspondence among the business units. Manage the risk of all business units and functions."@en,
        "构建必要风险管理框架，统筹组织整体及各职能单元的风险管理活动；通过制定风险政策与程序实施企业风险管理；持续监测、通报各项风险管理活动；促进业务单元间协同沟通；统一管控各业务单元与职能领域的风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1" ;
    skos:prefLabel "Manage enterprise risk"@en,
        "管理企业风险"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/11.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.1" ;
    skos:broader <https://oprocess.net/opf/node/11.2> ;
    skos:definition "Developing a set of procedures detailing an organization's progress in complying with established guidelines, provisions, and legislation."@en,
        "制定一套程序，系统记录组织在遵循既定准则、条款及法规方面的进展。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.1" ;
    skos:prefLabel "Establish compliance framework and policies"@en,
        "建立合规框架与政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5> ;
    skos:definition "AI process: Manage AI Ethics Framework."@en,
        "AI流程：管理AI伦理框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.1" ;
    skos:prefLabel "Manage AI Ethics Framework"@en,
        "管理人工智能伦理框架"@zh ;
