    skos:prefLabel "Establish credit policies"@en,
        "建立 credit policies"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Checking and accepting new requests based on eligibility criteria. Analyze the status of applicants and requirements to be met for a new account."@en,
        "Checking and accepting new requests based on eligibility criteria. 分析 the status of applicants and requirements to be met for a new account."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.2" ;
    skos:prefLabel "Analyze/Approve new account applications"@en,
        "分析/Approve new account applications"@zh ;
    opf:domain "management_support" ;
