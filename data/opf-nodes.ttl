        "ITIL实践‘软件开发与管理’中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.7.1" ;
    skos:prefLabel "Manage development lifecycle"@en,
        "管理开发生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

