    skos:definition "SCOR DS 14.0 activity in 'Plan Transform'."@en,
        "SCOR DS 14.0‘规划制造’流程中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.11.1" ;
    skos:prefLabel "Identify transformation requirements"@en,
        "识别制造（转化）需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

