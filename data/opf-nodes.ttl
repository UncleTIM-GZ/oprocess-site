<https://oprocess.net/opf/node/9.2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Evaluating existing account holders and their past performance. Regularly review existing accounts to get the required information about the status at present."@en,
