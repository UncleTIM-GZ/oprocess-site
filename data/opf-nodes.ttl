    skos:definition "Activity within ITIL practice 'Portfolio Management'."@en,
        "ITIL 实践‘投资组合管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.8.3" ;
    skos:prefLabel "Balance portfolio risk and value"@en,
        "平衡项目组合的风险与价值"@zh ;
    opf:domain "management_support" ;
