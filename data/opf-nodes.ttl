        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Registering transactions and their scheduled payments."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.4" ;
    skos:prefLabel "Post receivable entries"@en ;
    opf:domain "management_support" ;
