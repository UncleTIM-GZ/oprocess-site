<https://oprocess.net/opf/node/8.3.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Continuity Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "ITIL V5 practice: Service Continuity Management. Mapped to Develop and manage IT resilience and risk."@en,
        "ITIL V5 实践：服务连续性管理。对应「构建与管理 IT 韧性及风险」能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.10" ;
    skos:prefLabel "Service Continuity Management"@en,
        "服务连续性管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3> ;
    skos:definition "Planning and managing the organization’s ability to recover from exposure to internal and external threats, with a focus on IT and cybersecurity. Ensure that continuity plans address cyber-specific scenarios, including ransomware attacks and other evolving threats, while maintaining uninterrupted operations of critical IT and OT services."@en,
        "规划并管理组织应对内外部威胁的恢复能力，重点聚焦信息技术（IT）与网络安全；确保业务连续性计划涵盖勒索软件攻击等特定网络威胁场景，同时保障关键IT与运营技术（OT）服务持续稳定运行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.4" ;
    skos:prefLabel "Plan and manage IT continuity"@en,
        "规划与管理IT连续性"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.4> ;
    skos:definition "Create an organization-wide strategy for the IT function by combining skills, technologies, applications, and processes in order to attain organizations objectives. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "整合技能、技术、应用与流程，制定覆盖全组织的 IT 职能战略，以支撑组织目标实现；涵盖人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.1" ;
    skos:prefLabel "Define business information and analytics strategy"@en,
        "定义业务信息与分析战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

