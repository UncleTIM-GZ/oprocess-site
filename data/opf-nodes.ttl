    skos:notation "8.3.10.2" ;
    skos:prefLabel "Test continuity procedures"@en,
        "测试连续性流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Continuity Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.10> ;
    skos:definition "Activity within ITIL practice 'Service Continuity Management'."@en,
        "ITIL 实践「服务连续性管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.10.3" ;
    skos:prefLabel "Maintain recovery capabilities"@en,
        "维护恢复能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.2> ;
    skos:definition "Determining resilience strategies to ensure that IT effectively manages it's delivery process to mitigate risk."@en,
        "制定韧性策略，确保 IT 有效管理其交付流程以缓释风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.2.1" ;
    skos:prefLabel "Determine IT delivery resiliency"@en,
        "评估IT交付韧性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.2> ;
    skos:definition "Determining risks that could disrupt objectives of IT including physical, security, data, network, and cybersecurity."@en,
        "识别可能影响 IT 目标的各类风险，包括物理风险、安全风险、数据风险、网络风险及网络安全风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.2.2" ;
    skos:prefLabel "Determine critical IT risks"@en,
        "识别关键IT风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.2> ;
    skos:definition "Prioritize potential IT risks based on business need to ensure overall IT stability."@en,
        "依据业务需求对潜在 IT 风险进行优先级排序，以保障整体 IT 稳定性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.2.3" ;
    skos:prefLabel "Prioritize IT risks"@en,
        "对IT风险进行优先级排序"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.2> ;
    skos:definition "Establishing activities to improve opportunities and lessen threats for IT."@en,
        "开展活动以提升 IT 机会、降低威胁。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.2.4" ;
    skos:prefLabel "Establish mitigation approaches for IT risks"@en,
        "建立IT风险缓解方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Evaluation of dynamic, strategic, and integrated approach to manage regulatory requirements and compliance obligations."@en,
        "评估动态化、战略性、一体化的监管要求与合规义务管理方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.1" ;
    skos:prefLabel "Evaluate enterprise regulatory and compliance obligations"@en,
        "评估企业监管与合规义务"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.10" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Identifying and supervising a blueprint of measures for managing risk in IT. Monitor actions to enhance opportunities and reduce threats to project objectives."@en,
        "识别并监督一套 IT 风险管理措施蓝图；跟踪行动进展，以增强机会、降低对项目目标的威胁。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.10" ;
    skos:prefLabel "Identify, supervise and monitor IT risk mitigation measures"@en,
        "识别、监督与监控IT风险缓解措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Analyzing the impact of threats to critical IT assets across different departments and functions in the organization in terms of quantifiable results."@en,
        "分析各类威胁对跨部门、跨职能关键 IT 资产的影响，并以可量化结果呈现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.2" ;
    skos:prefLabel "Analyze IT security threat impact"@en,
        "分析IT安全威胁影响"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Develop and maintain IT compliance standards. Maintaining requirements set forth by such directives as GRCP, PMI RMP, CGRC, CGEIT, CRMA."@en,
        "制定并维护 IT 合规标准；持续落实 GRCP、PMI RMP、CGRC、CGEIT、CRMA 等权威指引所规定的要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.3" ;
    skos:prefLabel "Create and maintain IT compliance requirements"@en,
        "制定并维护IT合规要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Develop and maintain an architecture for securing and ensuring the privacy of data flows throughout the organization. Create, test, evaluate, and implement IT security policies to ensure the safe use of IT services and solutions."@en,
        "构建保障数据流安全与隐私的架构；制定、测试、评估并实施 IT 安全政策，确保 IT 服务与解决方案的安全使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.4" ;
    skos:prefLabel "Create and maintain IT security policies, standards, and procedures"@en,
        "制定并维护IT安全政策、标准与规程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Develop and implement training in regard to managing IT risks, understanding criticality, impact, and opportunities associated with business objectives."@en,
        "开展 IT 风险管理培训，提升员工对业务目标关联的关键性、影响及机会的理解能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.5" ;
    skos:prefLabel "Develop and deploy risk management training"@en,
        "开发并部署风险管理培训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Establishing processes to communicate IT risk to the organization."@en,
        "建立向组织内部传达 IT 风险的流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.6" ;
    skos:prefLabel "Establish risk reporting capabilities and responsibilities"@en,
        "建立风险报告能力与职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.7" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Establishing standards for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and information technology services."@en,
        "制定组织内部沟通标准，为业务单元与信息技术服务共同理解战略举措提供路线图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.7" ;
    skos:prefLabel "Establish communication standards"@en,
        "建立沟通标准"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.8" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Evaluate IT risk and threat assessments by way of IT assets, information security, and breach points within the organization."@en,
        "基于组织内的 IT 资产、信息安全及薄弱环节，开展 IT 风险与威胁评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.8" ;
    skos:prefLabel "Conduct IT risk and threat assessments"@en,
        "开展IT风险与威胁评估"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.3.9" ;
    skos:broader <https://oprocess.net/opf/node/8.3.3> ;
    skos:definition "Monitoring and managing risks related to IT adoption within the organization."@en,
        "监控并管理组织内 IT 采纳过程中的相关风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.3.9" ;
    skos:prefLabel "Monitor and manage IT activity risk"@en,
        "监控与管理IT活动风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.4> ;
    skos:definition "Evaluating IT business needs and IT's ability to recover from internal or external threat exposure."@en,
        "评估IT业务需求及IT系统在遭遇内外部威胁暴露后的恢复能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.4.1" ;
    skos:prefLabel "Evaluate IT continuity"@en,
        "评估IT连续性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.4> ;
    skos:definition "Identifying the limitations of the IT organization's ability to remediate disruptions in IT services."@en,
        "识别IT部门在修复IT服务中断方面的能力局限。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.4.2" ;
    skos:prefLabel "Identify IT continuity gaps"@en,
        "识别IT连续性差距"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.4> ;
    skos:definition "Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT."@en,
        "整合应急响应、危机管理、灾难恢复（技术连续性）与IT业务连续性管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.4.3" ;
    skos:prefLabel "Manage IT business continuity"@en,
        "管理IT业务连续性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Evaluate principles or rules employed in controlling, directing, or managing IT services. Assessing requirements and policies related to confidentiality."@en,
        "评估用于管控、指导或管理IT服务的原则或规则；审查与保密性相关的合规要求及政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.1" ;
    skos:prefLabel "Assess IT regulatory and confidentiality requirements and policies"@en,
        "评估IT监管与保密性要求及政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Defining and managing organization's approach to governing IT security and ensuring the privacy of data flows throughout the organization. Establish and manage tools to support the governance process in order to avoid misuse of information and breach of organizational privacy."@en,
        "定义并管理组织的IT安全治理方法，确保全组织数据流的隐私保护；建立并管理支撑治理流程的工具，防范信息滥用与组织隐私泄露。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.2" ;
    skos:prefLabel "Create IT security, privacy, and data protection risk governance"@en,
        "构建IT安全、隐私与数据保护风险治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Outlining and establishing policies, regulations, standards, and procedures for IT data security and privacy."@en,
        "制定并确立IT数据安全与隐私相关的政策、法规、标准及操作规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.3" ;
    skos:prefLabel "Define IT data security and privacy policies, standards, and procedures"@en,
        "制定IT数据安全与隐私政策、标准及规程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Identifying, examining, and reviewing physical and logical IT data security measures such as hardware security (smart cards), cryptographic protocols, and access control."@en,
        "识别、检查并评审物理与逻辑层面的IT数据安全措施，如智能卡等硬件安全、密码学协议及访问控制机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.4" ;
    skos:prefLabel "Review and monitor physical and logical IT data security measures"@en,
        "审查与监控物理及逻辑IT数据安全措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Identifying, examining, and reviewing security control for IT applications. Test, analyze, and implement security protocols in order to safeguard IT applications."@en,
        "识别、检查并评审IT应用系统的安全控制措施；测试、分析并实施安全协议，以保障IT应用系统安全。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.5" ;
    skos:prefLabel "Review and monitor application security controls"@en,
        "审查与监控应用安全控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Identifying and examining security controls for physical environment of information technology such as business facilities, equipment, and resources."@en,
        "识别、检查并评审IT物理环境（如办公场所、设备及资源）的安全控制措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.6" ;
    skos:prefLabel "Review and monitor IT physical environment security controls"@en,
        "审查与监控IT物理环境安全控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.5.7" ;
    skos:broader <https://oprocess.net/opf/node/8.3.5> ;
    skos:definition "Monitoring and evaluating network intrusion detection for any malicious activity or policy violations. Identify the gaps in order to resolve threats and enhance existing network security."@en,
        "监控与评估网络入侵检测系统，识别恶意活动或策略违规行为；定位安全短板，以消除威胁并强化现有网络安全防护。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.5.7" ;
    skos:prefLabel "Monitor/analyze network intrusion detection data and resolve threats"@en,
        "监控/分析网络入侵检测数据并处置威胁"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.6> ;
    skos:definition "Conducting projects in order to enhance set standards, established guidelines, and risk preventive measures for IT risk and resilience."@en,
        "开展项目以提升IT风险与韧性领域的既定标准、既定指南及风险预防措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6.1" ;
    skos:prefLabel "Conduct projects to enhance IT compliance and remediate risk"@en,
        "开展提升IT合规性及整改风险的项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.6> ;
    skos:definition "Examine compliance control systems and tools implemented for internal and external IT services."@en,
        "审查为内外部IT服务所部署的合规管控系统与工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6.2" ;
    skos:prefLabel "Conduct IT compliance control auditing of internal and external services"@en,
        "对内部与外部服务开展IT合规性控制审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.6> ;
    skos:definition "Execute IT compliance reporting in order to review processes, standards, regulations, and laws are followed as laid out by the regulatory bodies."@en,
        "执行IT合规报告工作，以验证流程、标准、法规及法律是否严格遵循监管机构要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6.3" ;
    skos:prefLabel "Perform IT compliance reporting"@en,
        "执行IT合规性报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.6> ;
    skos:definition "Identify and escalate issues related to IT compliance to ensure that corrective measures are taken."@en,
        "识别并上报IT合规相关问题，确保及时采取整改措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6.4" ;
    skos:prefLabel "Identify and escalate IT compliance issues and remediation requirements"@en,
        "识别并上报IT合规性问题及整改要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.6.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.6> ;
    skos:definition "Supporting audits and reports through external resources. This process requires the organization to follow all the regulations set forth by external auditors."@en,
        "借助外部资源支持审计与报告工作；组织须全面遵守外部审计机构提出的各项监管要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.6.5" ;
    skos:prefLabel "Support external audits and reports"@en,
        "支持外部审计与报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Conducting projects to improve the strategy and process for rapidly adapting to any threat in IT."@en,
        "开展项目以优化IT领域快速应对威胁的战略与流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.1" ;
    skos:prefLabel "Conduct IT resilience improvement projects"@en,
        "开展IT韧性提升项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Develop, document, and maintain plans to ensure uninterrupted operations of critical IT services (for example, ransomware recovery). Determine resources such as specialized personnel, equipment, support infrastructure, third-party access, legal and financial aspects."@en,
        "制定、记录并维护关键IT服务不间断运行保障计划（例如勒索软件恢复方案），明确所需资源，包括专业人员、设备、支撑基础设施、第三方接入权限，以及法律与财务要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.2" ;
    skos:prefLabel "Develop, document, and maintain IT business continuity planning"@en,
        "制定、记录并维护IT业务连续性计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Implement and enforce procedures and policies in order to control changes in IT services and solutions. Manage changes in a rational and predictable manner for optimum resource utilization."@en,
        "制定并落实IT服务与解决方案变更管控的流程与政策，以理性、可预测的方式管理变更，实现资源最优配置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.3" ;
    skos:prefLabel "Implement and enforce change control procedures"@en,
        "实施并落实变更控制流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Review and implement resources (including external parties) necessary to support uninterrupted operations of critical IT services."@en,
        "评审并落实支撑关键IT服务不间断运行所需的资源（含外部合作方）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.4" ;
    skos:prefLabel "Execute recurring IT service provider business continuity"@en,
        "执行IT服务提供商业务连续性的周期性演练"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Conduct and manage employee training programs on IT resilience so that prospective risks can be avoided."@en,
        "开展并管理面向员工的IT韧性培训项目，前瞻性规避潜在风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.5" ;
    skos:prefLabel "Provide IT resilience training"@en,
        "开展IT韧性培训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.7.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.7.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3.7> ;
    skos:definition "Implement regular resources supporting uninterrupted operations of critical IT services."@en,
        "定期部署并维护支撑关键IT服务不间断运行的资源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.7.6" ;
    skos:prefLabel "Execute recurring IT business operations continuity"@en,
        "执行IT业务运营连续性的周期性演练"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Create and implement policies that integrate authorization policies with authorized profiles of users meant to access network resources."@en,
        "制定并实施将授权策略与用户网络资源访问权限画像相集成的政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.1" ;
    skos:prefLabel "Support integration of identity and authorization policies"@en,
        "支持身份与授权政策的集成"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Managing directory of user profiles and access requirements across different levels in the organization's IT network."@en,
        "统一管理组织IT网络中各层级的用户画像目录及访问权限要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.2" ;
    skos:prefLabel "Manage IT user directory"@en,
        "管理IT用户目录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.3" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Managing the process of authorizing IT users to access applications, systems, IT components, or networks by associating user rights."@en,
        "管理IT用户授权流程，通过绑定用户权限，授予其对应用、系统、IT组件或网络的访问权。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.3" ;
    skos:prefLabel "Manage IT user authorization"@en,
        "管理IT用户授权"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8.4> ;
    skos:definition "Adopting MFA to ensure secure user authentication across all systems."@en,
        "采用多因素认证（MFA），确保所有系统用户身份认证的安全性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.4.1" ;
    skos:prefLabel "Implement multi-factor authentication (MFA)"@en,
        "实施多因素认证（MFA）"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.3.8.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8.4> ;
    skos:definition "Integrating identity federation and SSO solutions to enhance user experience and security."@en,
        "集成身份联合（identity federation）与单点登录（SSO）解决方案，兼顾用户体验与安全性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.4.2" ;
    skos:prefLabel "Implement identity federation and single sign-on (SSO)"@en,
        "实施身份联合与单点登录（SSO）"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.3.8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.5" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Examine the processes responsible for reviewing IT user identity and authorization."@en,
        "审查负责IT用户身份与授权审核的流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.5" ;
    skos:prefLabel "Audit IT user identity and authorization systems"@en,
        "审计IT用户身份与授权系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.6" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Address any form of unauthorized network breach such as unauthorized access or usage of data, applications, services, networks, and/or devices. Identify the root cause and take corrective measures to resolve the breach."@en,
        "处置各类未授权网络入侵事件，包括数据、应用、服务、网络和/或设备的未授权访问或使用；查明根本原因并采取整改措施予以解决。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.6" ;
    skos:prefLabel "Respond to IT information security and network breaches"@en,
        "响应IT信息安全与网络攻击事件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.7" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Conduct penetration testing (pen test) through an authorized stimulated attack to identify security weakness in an IT environment by evaluating the system or network with various harmful techniques."@en,
        "通过经授权的模拟攻击开展渗透测试（pen test），运用多种攻击技术评估系统或网络，识别IT环境中的安全薄弱环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.7" ;
    skos:prefLabel "Conduct penetration testing"@en,
        "开展渗透测试"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.8" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Reviewing the processes responsible for integration of user identity and access authorization in order to confirm that all the required regulations are followed."@en,
        "审查用户身份与访问授权集成流程，确认其全面符合各项监管要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.8" ;
    skos:prefLabel "Audit integration of user identity and authorization systems"@en,
        "审计用户身份与授权系统的集成情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Information Security Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.9> ;
    skos:definition "Activity within ITIL practice 'Information Security Management'."@en,
        "ITIL信息安全管理体系实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.9.1" ;
    skos:prefLabel "Define security policies"@en,
        "制定安全政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Information Security Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.9> ;
    skos:definition "Activity within ITIL practice 'Information Security Management'."@en,
        "ITIL信息安全管理体系实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.9.2" ;
    skos:prefLabel "Manage security incidents"@en,
        "管理安全事件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.9.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Information Security Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.9> ;
    skos:definition "Activity within ITIL practice 'Information Security Management'."@en,
        "ITIL信息安全管理体系实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.9.3" ;
    skos:prefLabel "Conduct security assessments"@en,
        "开展安全评估"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.9.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Information Security Management" ;
    skos:broader <https://oprocess.net/opf/node/8.3.9> ;
    skos:definition "Activity within ITIL practice 'Information Security Management'."@en,
        "ITIL 实践「信息安全管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.9.4" ;
    skos:prefLabel "Manage access controls"@en,
        "管理访问控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.4.1> ;
    skos:definition "Implementing strategies for securing and ensuring the privacy of data flows throughout the organization. Create protocols and guidelines for individual IT components. Outline analytic objectives in order to avoid misuse of information."@en,
        "实施保障数据流动安全与隐私的策略；为各 IT 组件制定协议与规范；明确分析目标，防范信息滥用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.1.1" ;
    skos:prefLabel "Establish data, information, and analytic objectives"@en,
        "确立数据、信息与分析目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.4.1> ;
    skos:definition "Creating a set of guidelines that ensure effective and efficient use of IT. Define data, information, and analytic governance to reach the organization's goal."@en,
        "制定确保 IT 高效、有效使用的指导方针；界定数据、信息与分析治理框架，支撑组织目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.1.2" ;
    skos:prefLabel "Establish data, information, and analytic governance"@en,
        "建立数据、信息与分析治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.4.1> ;
    skos:definition "Determining the request for data accessibility and analysis. Review the details based on internal data security policies and permit data access only if internal policies and data access parameters are met."@en,
        "评估数据可访问性与分析需求；依据内部数据安全政策审核申请细节，仅在符合内部政策及数据访问参数时批准访问。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.1.3" ;
    skos:prefLabel "Access IT data/analytic capabilities"@en,
        "接入IT数据/分析能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.4.2> ;
    skos:definition "Determining strategies to manage the enterprise wide flow of business information and content. Outline the required architecture for information resources."@en,
        "制定覆盖全企业的业务信息与内容流动管理策略；明确信息资源所需架构。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2.1" ;
    skos:prefLabel "Determine enterprise business information requirements"@en,
        "识别企业级业务信息需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.4.2> ;
    skos:definition "Define different ways of representation, usage, and identification of data with independent or interdependent sources across the organization."@en,
        "定义组织内独立或关联数据源的数据表示、使用与识别方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2.2" ;
    skos:prefLabel "Define enterprise data models"@en,
        "定义企业级数据模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.4.2> ;
    skos:definition "Identifying and understanding external sources of data in relevance of reliability, security, and authenticity."@en,
        "识别并评估外部数据源的可靠性、安全性与真实性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2.3" ;
    skos:prefLabel "Identify and understand external data sources"@en,
        "识别并理解外部数据源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.4.2> ;
    skos:definition "Establishing entities responsible for data accuracy, integrity, and timeliness that can authorize or deny access to certain data. Develop data utilizing governance processes to ensure fitness of data elements."@en,
        "明确对数据准确性、完整性与时效性负主体责任的实体，并授权或否决特定数据访问；通过数据治理流程确保数据要素适用性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2.4" ;
    skos:prefLabel "Establish data ownership and stewardship responsibilities"@en,
        "明确数据所有权与数据管家职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.4.2> ;
    skos:definition "Creating and maintaining the process of designing, creating, deploying, and managing strategies to maintain enterprise data and information architecture."@en,
        "建立并持续优化企业数据与信息架构的设计、构建、部署与管理策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.2.5" ;
    skos:prefLabel "Maintain and evolve enterprise data and information architecture"@en,
        "持续维护与演进企业级数据与信息架构"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.4.3> ;
    skos:definition "Outlining and establishing policies for information and setting information standards and procedures. Establish policies to regulate the creation, use, storage, access, communication, and dissemination of information."@en,
        "制定信息政策，确立信息标准与规程；规范信息的创建、使用、存储、访问、沟通与分发。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.3.1" ;
    skos:prefLabel "Define and maintain enterprise information policies, standards, and procedures"@en,
        "制定并维护企业级信息政策、标准与规程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.4.3> ;
    skos:definition "Implementing and executing strategies for processes and technologies that support the collection, managing, and storing of data."@en,
        "实施并执行支撑数据采集、管理与存储的流程与技术策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.3.2" ;
    skos:prefLabel "Implement and execute data administration responsibilities"@en,
        "实施并履行数据管理职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.4.4> ;
    skos:definition "Defining the rules, diction, and logic that make up the framework of the organization's information architecture. Monitoring and controlling information attributes that flow through the IT framework."@en,
        "定义构成组织信息架构基础的规则、术语与逻辑；监控并管控流经 IT 框架的信息属性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.4.1" ;
    skos:prefLabel "Monitor and control business information"@en,
        "监控与管控业务信息"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.4.4> ;
    skos:definition "Maintain information feedstock along with IT hardware and software needed for storage, access, and retrieval of business information."@en,
        "维护信息基础资源，以及支撑业务信息存储、访问与检索所需的 IT 硬件与软件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.4.2" ;
    skos:prefLabel "Maintain business information feeds and repositories"@en,
        "维护业务信息数据流与存储库"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.4.4> ;
    skos:definition "Verification of information access and usage through regular reports on organizational performance."@en,
        "通过定期组织绩效报告，验证信息访问与使用情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.4.3" ;
    skos:prefLabel "Perform internal usage audits"@en,
        "开展内部使用审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.4.4" ;
    skos:broader <https://oprocess.net/opf/node/8.4.4> ;
    skos:definition "Implement and manage the process for accessing information including issues related to copyright, open source, privacy, and security."@en,
        "实施并管理信息访问流程，涵盖版权、开源、隐私与安全等相关问题。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.4.4" ;
    skos:prefLabel "Implement and administer business information access"@en,
        "实施并管理业务信息访问控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Determining the development of IT service/solution. Analyze the pros and cons of IT service/solution and it's methods on the basis of their cost effectiveness and development value."@en,
        "确定 IT 服务/解决方案的开发方向；基于成本效益与开发价值，分析其优劣及实施方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.1" ;
    skos:prefLabel "Determine IT service/solution development"@en,
        "确定IT服务/解决方案开发方向"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Establishing the methods and processes as the foundation for developing new IT platforms, components, software, and explore new standards for better IT usage in the organization."@en,
        "建立新 IT 平台、组件与软件开发的方法与流程基础；探索提升组织 IT 应用效能的新标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.2" ;
    skos:prefLabel "Define IT service/solution development processes/standards"@en,
        "定义IT服务/解决方案开发流程与标准"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Identifying and implementing techniques and tools for development based on overall value addition to the IT environment."@en,
        "识别并落地可为 IT 环境整体增值的技术与工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.3" ;
    skos:prefLabel "Identify, deploy, and support development methodologies and tools"@en,
        "识别、部署并支持开发方法论与工具"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Establishing standards for selection of IT service components."@en,
        "制定 IT 服务组件选型标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.4" ;
    skos:prefLabel "Establish service component criteria"@en,
        "确立服务组件评估准则"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Understanding and selecting reusable service components so that they can be cost-effective and efficient."@en,
        "理解并遴选可复用的服务组件，以实现成本效益与运行效率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.5" ;
    skos:prefLabel "Understand and select reusable service components"@en,
        "理解并遴选可复用服务组件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Creating and establishing service component portfolio by defining investments, and activities. Analyze and examine the value of the service component portfolio, and allocate resources towards it."@en,
        "通过界定投资与活动，构建并确立服务组件组合；分析评估其价值，并合理配置资源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.6" ;
    skos:prefLabel "Maintain service component portfolio"@en,
        "维护服务组件组合"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.1.7" ;
    skos:broader <https://oprocess.net/opf/node/8.5.1> ;
    skos:definition "Creating standards and procedures for developing IT services/solutions outside of defined business parameters."@en,
        "制定在既定业务边界之外开发 IT 服务/解决方案的标准与规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.1.7" ;
    skos:prefLabel "Establish development standards exception governance"@en,
        "建立开发标准例外治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.2> ;
    skos:definition "Perform a systematic investigation to new and future technology capabilities for future upgrades."@en,
        "系统性调研新兴与未来技术能力，支撑后续升级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2.1" ;
    skos:prefLabel "Monitor and track emerging technology capabilities"@en,
        "监测与跟踪新兴技术能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5.2> ;
    skos:definition "Identifying processes and supporting procedures that are performed by an organization to design, plan, deliver, operate, and control information technology services/solutions offered to customers."@en,
        "识别组织为设计、规划、交付、运营与管控面向客户的 IT 服务/解决方案所执行的流程及配套程序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2.2" ;
    skos:prefLabel "Identify IT services/solutions"@en,
        "识别IT服务/解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5.2> ;
    skos:definition "Determining an approach to create a base for delivering IT service/solution aligned with overall business needs while maintaining a tight control on delivery and costs."@en,
        "制定兼顾业务需求对齐、交付可控与成本可控的 IT 服务/解决方案交付基础方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2.3" ;
    skos:prefLabel "Determine IT service/solution approach"@en,
        "确定IT服务/解决方案实施路径"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5.2> ;
    skos:definition "Defining solutions to satisfy business needs. IT solution lifecycle provides a means to address the full life cycle of an information technology solution and addresses the current and future state of IT services and solutions."@en,
        "定义满足业务需求的解决方案；IT 解决方案生命周期提供覆盖其全生命周期的管理路径，并统筹当前与未来状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2.4" ;
    skos:prefLabel "Define IT solution lifecycle"@en,
        "定义IT解决方案生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5.2> ;
    skos:definition "Developing plans to retire IT service/solution resources when the service/solution is no longer feasible."@en,
        "制定 IT 服务/解决方案资源退役计划，于其不再可行时有序退出。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.2.5" ;
    skos:prefLabel "Develop IT service/solution \"sunset\" plans"@en,
        "制定IT服务/解决方案退出计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Assessing limitations in IT application and infrastructure architecture that may hinder expected performance."@en,
        "评估信息技术应用与基础设施架构中存在的限制，识别可能阻碍预期性能的因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.1" ;
    skos:prefLabel "Assess IT application and infrastructure architecture constraints"@en,
        "评估IT应用与基础设施架构约束"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Evaluate business limitations that may hinder IT service/solution performance."@en,
        "评估可能制约IT服务/解决方案性能的业务限制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.2" ;
    skos:prefLabel "Assess business constraints on IT service/solution"@en,
        "评估业务对IT服务/解决方案的约束"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Determining the requirements to integrate IT components such as hardware, software, database, telecommunication, and network."@en,
        "明确集成IT组件（包括硬件、软件、数据库、电信及网络）所需的要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.3" ;
    skos:prefLabel "Determine IT component integration requirements"@en,
        "确定IT组件集成需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Identification of opportunities for reusing IT components so that they can be cost-effective and efficient."@en,
        "识别IT组件复用机会，以提升成本效益与运行效率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.4" ;
    skos:prefLabel "Identify opportunities for IT component reuse"@en,
        "识别IT组件复用机会"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Encouraging acceptance of existing IT service/solution architecture in the organization."@en,
        "推动组织内部对现有IT服务/解决方案架构的接受与采纳。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.5" ;
    skos:prefLabel "Promote adoption of existing service/solution architecture"@en,
        "推动现有服务/解决方案架构的采用"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.6" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Creating and maintaining a services and solutions architecture over a network that can be revised as needed or even eliminated in case of inefficiencies."@en,
        "构建并维护基于网络的服务与解决方案架构，支持按需修订或在低效时予以淘汰。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.6" ;
    skos:prefLabel "Develop and maintain service/solution architectures"@en,
        "开发并维护服务/解决方案架构"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.7" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Assessing functional compliance of the IT service/solution architecture. Safeguard compliance with guidelines for the architecture."@en,
        "评估IT服务/解决方案架构的功能合规性，保障其符合架构相关规范要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.7" ;
    skos:prefLabel "Assess IT service/solution architecture conformance"@en,
        "评估IT服务/解决方案架构合规性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.3.8" ;
    skos:broader <https://oprocess.net/opf/node/8.5.3> ;
    skos:definition "Identifying and resolving any architectural exceptions. Address the internal inquiries related to architecture that cannot be addressed immediately. Research inquiries that require the need of exceptional methods."@en,
        "识别并解决架构异常；处理无法即时响应的内部架构类咨询；针对需采用特殊方法的咨询开展专项研究。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.3.8" ;
    skos:prefLabel "Manage architectural exceptions"@en,
        "管理架构例外事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Evaluating and validating the requirements and needs of IT service/solution."@en,
        "评估与验证IT服务/解决方案的需求与要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.1" ;
    skos:prefLabel "Assess and validate IT service/solution requirements"@en,
        "评估并验证IT服务/解决方案需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Formulating a design for service/solution that helps an organization to meet its objectives. Develop a new framework for molding the service/solution processes into a coherent and structured form."@en,
        "制定支撑组织目标实现的服务/解决方案设计方案；构建新框架，将服务/解决方案流程整合为连贯、结构化体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.2" ;
    skos:prefLabel "Create service/solution design"@en,
        "制定服务/解决方案设计"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Building and testing new components required for the development of IT services and solutions."@en,
        "构建并测试IT服务与解决方案开发所需的新增组件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.3" ;
    skos:prefLabel "Build and test IT service/solution components"@en,
        "构建并测试IT服务/解决方案组件"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Combining the newly built IT component along with IT services in order to gain optimum output."@en,
        "将新建IT组件与既有IT服务集成，以实现最优输出。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.4" ;
    skos:prefLabel "Integrate IT components and services"@en,
        "集成IT组件与服务"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Validating that the proposed IT service/solution is feasible and provides the needed services for the customer."@en,
        "验证所提议的IT服务/解决方案具备可行性，并能为客户交付所需功能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.5" ;
    skos:prefLabel "Execute IT service/solution validation"@en,
        "执行IT服务/解决方案验证"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Creating and implementing a strategy for the deployment of IT service/solution by defining all of the activities that make the IT function available for use. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process."@en,
        "制定并落实IT服务/解决方案部署策略，明确定义使IT功能可投入使用的全部活动；界定部署流程、规程与工具；选择最可行、最实用的部署方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.6" ;
    skos:prefLabel "Bundle service/solution deployment packaging"@en,
        "打包服务/解决方案部署包"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.4.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4.1.7" ;
    skos:broader <https://oprocess.net/opf/node/8.5.4.1> ;
    skos:definition "Identifying and resolving internal needs/inquiries for service/solution that cannot be resolved immediately. Research inquiries that require the need of exceptional solutions."@en,
        "识别并处理无法即时解决的内部服务/解决方案类需求或咨询；针对需采用特殊方案的咨询开展专项研究。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4.1.7" ;
    skos:prefLabel "Manage service/solution process exceptions"@en,
        "管理服务/解决方案流程例外事项"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5.1> ;
    skos:definition "Evaluate plans to address information technology environmental adulteration for rectification efforts."@en,
        "评估应对信息技术环境劣化的整改计划，支撑纠偏行动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1.1" ;
    skos:prefLabel "Assess IT remediation"@en,
        "评估IT整改需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5.1> ;
    skos:definition "Redesign the roadmap to seek solution or service with an overall process flow and impact timeframe."@en,
        "重构实施路线图，统筹解决方案或服务的整体流程与影响周期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1.2" ;
    skos:prefLabel "Modify service/solution design"@en,
        "修改服务/解决方案设计"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5.1> ;
    skos:definition "Administering the efforts and activities for IT service/solution remediation. This process element requires the organization to create plans for corrective action in collaboration with government agencies and pertinent professional services agencies which specialize in remediation efforts relevant to the organization's service/solution. Additionally, the organization needs to consult experts to validate the plan, determine resources allocation, resolve any legal concerns, and formulate a company-wide policy for IT service/solution remediation."@en,
        "统筹IT服务/解决方案整改工作的实施与活动。该环节要求组织协同政府机构及相关专业服务机构共同制定整改行动计划；同时须咨询专家，以验证计划可行性、确定资源投入、解决法律风险，并制定全公司范围的IT服务/解决方案整改政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1.3" ;
    skos:prefLabel "Perform IT service/solution remediation"@en,
        "实施IT服务/解决方案整改"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5.1> ;
    skos:definition "Understanding customer requirements. Managing services/solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Confirm the customer experience post-sale. Evaluate the performance of service/solution. Communicate the results to the management."@en,
        "理解客户需求；依据需求开展服务/解决方案管理；开发满足需求的组件；培训支持人员；售后确认客户体验；评估服务/解决方案绩效；向管理层汇报结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1.4" ;
    skos:prefLabel "Manage service/solution operations"@en,
        "管理服务/解决方案运维"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5.5.1> ;
    skos:definition "Developing packaging for fixed/enhanced service/solution based on the standalone or bundled offerings to be used by the organization."@en,
        "基于独立提供或组合打包模式，开发面向组织使用的已修复/增强型服务/解决方案交付包。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5.1.5" ;
    skos:prefLabel "Prepare fixed/enhanced service/solution packaging"@en,
        "准备修复版/增强版服务/解决方案部署包"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.5.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Design" ;
