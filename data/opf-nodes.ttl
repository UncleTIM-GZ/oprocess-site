<https://oprocess.net/opf/node/7.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4.1" ;
    skos:broader <https://oprocess.net/opf/node/7.4> ;
    skos:definition "Managing labor relations, the collective bargaining process, and the relationships between the labor and management. Take care of employee grievances."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4.1" ;
    skos:prefLabel "Manage labor relations"@en,
        "管理 labor relations"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4.2" ;
    skos:broader <https://oprocess.net/opf/node/7.4> ;
    skos:definition "Managing any negotiations between an employer and a group of employees that determine the conditions of employment. Engage employees to reach agreements in regulating working conditions."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4.2" ;
    skos:prefLabel "Manage collective bargaining process"@en,
        "管理 collective bargaining process"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4.3" ;
    skos:broader <https://oprocess.net/opf/node/7.4> ;
    skos:definition "Handling partnerships between labor and management. Develop a lasting two-way relationship that is beneficial for the labor, management, and the organization."@en,
        "Handling partnerships between labor and management. 开发 a lasting two-way relationship that is beneficial for the labor, management, and the organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4.3" ;
    skos:prefLabel "Manage labor management partnerships"@en,
        "管理 labor management partnerships"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4.4" ;
    skos:broader <https://oprocess.net/opf/node/7.4> ;
    skos:definition "Taking care or resolving any complaint raised by an employee by procedures provided for in a collective agreement, an employment contract, or by other mechanisms established by an employer."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4.4" ;
    skos:prefLabel "Manage employee grievances"@en,
        "管理 employee grievances"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.4.5" ;
    skos:broader <https://oprocess.net/opf/node/7.4> ;
    skos:definition "Awareness of the employee legislature that is in place for the organization.  The regulatory environment could include areas, regions, countries, or technologies (around AI, for example)."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.4.5" ;
    skos:prefLabel "Monitor legal and regulatory environment"@en,
        "监控 legal and regulatory environment"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Creating the framework for the provision of salary/compensation to employees. Break down the salary structure into different components such as fixed pay, variable pay, bonus, and allowances such medical allowance, and rent allowance, etc. Develop, adjust, and maintain a pay structure."@en,
        "Creating the framework for the provision of salary/compensation to employees. Break down the salary structure into different components such as fixed pay, variable pay, bonus, and allowances such medical allowance, and rent allowance, etc. 开发, adjust, and maintain a pay structure."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.1" ;
    skos:prefLabel "Develop salary/compensation structure and plan"@en,
        "开发 salary/compensation structure and plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Developing a plan for provision of rewards, commission, and benefits to employees. Plan health benefits, retirement benefits, wellness plans, and non-monetary benefits, etc."@en,
        "Developing a plan for provision of rewards, commission, and benefits to employees. 规划 health benefits, retirement benefits, wellness plans, and non-monetary benefits, etc."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.2" ;
    skos:prefLabel "Develop benefits and rewards plan"@en,
        "开发 benefits and rewards plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Analyzing and evaluating the organization's benefits and rewards plan. Compare/Benchmark the benefits and employees plan with other organizations to adhere to industry standard practices."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.3" ;
    skos:prefLabel "Perform competitive analysis of benefits and rewards"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Recognizing the employee requirements for compensation on the basis of the financial, benefits, and HR policies of the organization. Recognize individual compensation requirements regarding the financial policies of the organization. Consider the benefits plan and overall HR policies while selecting compensation requirements."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.4" ;
    skos:prefLabel "Identify compensation requirements based on financial, benefits, and HR policies"@en,
        "识别 compensation requirements based on financial, benefits, and HR policies"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Managing the provision of compensations and rewards to the employees while maintaining consistency with the compensation and benefits plan. Follow the compensation and benefits plan rigorously in order to avoid any discrepancies."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.5" ;
    skos:prefLabel "Administer compensation and rewards to employees"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.6" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Rewarding and stimulating the performance efforts of employees. Create methods for motivating employees. Spur extrinsic and intrinsic motivation."@en,
        "Rewarding and stimulating the 绩效 efforts of employees. 创建 methods for motivating employees. Spur extrinsic and intrinsic motivation."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.6" ;
    skos:prefLabel "Reward and motivate employees"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.7" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Reassessing the indicators for retention and motivation of employees. Monitor the indicators that signal the levels of motivation and retention. Regularly update and upgrade indicators to avoid depreciation and ensure high efficiency."@en,
        "Reassessing the indicators for retention and motivation of employees. 监控 the indicators that signal the levels of motivation and retention. Regularly update and upgrade indicators to avoid depreciation and ensure high efficiency."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.7" ;
    skos:prefLabel "Review engagement and retention indicators"@en,
        "审查 engagement and retention indicators"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.8" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Analyzing existing compensation plans and making changes necessary to continue to retain employees."@en,
        "Analyzing existing compensation plans and making 变更s necessary to continue to retain employees."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.8" ;
    skos:prefLabel "Review compensation plan"@en,
        "审查 compensation plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.1.9" ;
    skos:broader <https://oprocess.net/opf/node/7.5.1> ;
    skos:definition "Evaluating benefits and rewards plans to assess effectiveness, alignment with workforce needs, and consistency with organizational reward and recognition objectives."@en,
        "Evaluating benefits and rewards plans to assess effectiveness, 对齐 with workforce needs, and consistency with organizational reward and recognition objectives."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.1.9" ;
    skos:prefLabel "Review benefits and rewards plan"@en,
        "审查 benefits and rewards plan"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.5.2> ;
    skos:definition "Implementing the programs that specify employee benefits, other than salary provided, such as those concerning medical care, death, and disability."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.2.1" ;
    skos:prefLabel "Deliver employee benefits program"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.5.2> ;
    skos:definition "Handling the employee enrollment for obtaining benefits. Manage employee enrollment and eligibility, including work and life status/event changes. Encourage employees to enroll for benefits."@en,
        "Handling the employee enrollment for obtaining benefits. 管理 employee enrollment and eligibility, including work and life status/event 变更s. Encourage employees to enroll for benefits."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.2.2" ;
    skos:prefLabel "Administer benefit enrollment"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.5.2> ;
    skos:definition "Processing any formal requests or demands made by the employees claiming that they have earned some benefits. Includes escalation to management."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.2.3" ;
    skos:prefLabel "Process benefits claims"@en,
        "处理 benefits claims"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.2.4" ;
    skos:broader <https://oprocess.net/opf/node/7.5.2> ;
    skos:definition "Carrying out reconciliation of benefits delivered to employees. Compare the estimated benefit requirement made by the employee and the actual amount of benefits the employee is entitled to receive."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.2.4" ;
    skos:prefLabel "Perform benefit reconciliation"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/7.5.3.1> ;
    skos:definition "Creation and execution of a plan that might allow for work from home days, or alternate hours."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.3.1.1" ;
    skos:prefLabel "Manage flexible working"@en,
        "管理 flexible working"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.5.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/7.5.3.1> ;
    skos:definition "Managing transportation-related programs and services provided to employees to support commuting, mobility, and work/life balance objectives."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.3.1.2" ;
    skos:prefLabel "Manage transportation programs and services"@en,
        "管理 transportation programs and services"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/7.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/7.5.3> ;
    skos:definition "Creating a support structure that aligns with local and federal laws that allow for support for families. This could include things like maternity leave, care for a family member, or in some cases, extended sick leave."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.3.2" ;
    skos:prefLabel "Develop employee and family support systems"@en,
        "开发 employee and family support systems"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.4" ;
    skos:broader <https://oprocess.net/opf/node/7.5> ;
    skos:definition "Managing the sum of all financial records of salaries for an employee, including wages, bonuses, and deductions. Use a payroll management system to deal with the financial aspects of employees' salaries, allowances, deductions, gross pay, net pay, etc. Generate pay slips for a specific period."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.4" ;
    skos:prefLabel "Administer Payroll"@en ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.5" ;
    skos:broader <https://oprocess.net/opf/node/7.5> ;
    skos:definition "Procuring and handling suggestions from employees, and performing research on employees. Manage and analyze the programs that help the organization to tap into employee ideas for improving the organization's processes and/or products. Use surveys, focus groups, and other data-gathering methods to find out the attitudes, opinions, and feelings of members of an organization."@en,
        "Procuring and handling suggestions from employees, and performing research on employees. 管理 and analyze the programs that help the organization to tap into employee ideas for improving the organization's processes and/or products. Use surveys, focus groups, and other data-gathering methods to find out the attitudes, opinions, and feelings of members of an organization."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.5" ;
    skos:prefLabel "Manage/Collect employee suggestions and perform employee research"@en,
        "管理/收集 employee suggestions and perform employee research"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.1" ;
    skos:broader <https://oprocess.net/opf/node/7.6> ;
    skos:definition "Administering the process of promoting and demoting employees. Design a system for advancing or demoting an employee's rank or position. Leverage techniques such as horizontal promotion, vertical promotion, dry promotion, and involuntary/voluntary demotion."@en,
        "Administering the process of promoting and demoting employees. 设计 a system for advancing or demoting an employee's rank or position. Leverage techniques such as horizontal promotion, vertical promotion, dry promotion, and involuntary/voluntary demotion."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.1" ;
    skos:prefLabel "Manage promotion and demotion process"@en,
        "管理 promotion and demotion process"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/7.6.2> ;
    skos:definition "Managing and administering instances where a person stops employment completely."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.2.1" ;
    skos:prefLabel "Manage retirement"@en,
        "管理 retirement"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/7.6.2> ;
    skos:definition "Managing the period of time that an employee must be away from their primary job, while maintaining the status of employee (i.e., paid and unpaid leave of absence but not vacations, holidays, hiatuses, sabbaticals, and work-from-home programs)."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.2.2" ;
    skos:prefLabel "Manage leave of absence"@en,
        "管理 leave of absence"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/7.6.2> ;
    skos:definition "Coordinating activities related to employee departures, including transitions, knowledge transfer, and administrative actions, to support orderly and compliant workforce exits."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.2.3" ;
    skos:prefLabel "Manage offboarding"@en,
        "管理 offboarding"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.6.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.2.4" ;
    skos:broader <https://oprocess.net/opf/node/7.6.2> ;
    skos:definition "Helping former employees transition to new jobs or to re-orient themselves in the job market. Deliver help through one-on-one sessions or in a group format. Provide guidance in career evaluation, resume writing, interview preparation, developing networks, and job searching."@en,
        "Helping former employees transition to new jobs or to re-orient themselves in the job market. Deliver help through one-on-one sessions or in a group format. 提供 guidance in career evaluation, resume writing, interview preparation, developing networks, and job searching."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.2.4" ;
    skos:prefLabel "Develop and implement employee outplacement"@en,
        "开发 and implement employee outplacement"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.6.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.6.3> ;
    skos:definition "Manage employees who are sent to live abroad or hired from abroad for a defined time period."@en,
        "管理 employees who are sent to live abroad or hired from abroad for a defined time period."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.3.1" ;
    skos:prefLabel "Manage expatriates"@en,
        "管理 expatriates"@zh ;
