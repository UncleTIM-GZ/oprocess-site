    skos:broader <https://oprocess.net/opf/node/5.2.1> ;
    skos:definition "Identifying the demand anticipated for the organization's services. Estimate future demand for services using historical data, analysis of the market environment, and external data."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1.2" ;
    skos:prefLabel "Develop baseline forecasts"@en,
        "开发 baseline forecasts"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/5.2.1> ;
    skos:definition "Providing a collaborative meeting in which to engage the customer to understand the scope of their needs and constructing solutions based on need and constraints."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1.3" ;
    skos:prefLabel "Collaborate with customers"@en ;
    opf:domain "operating" ;
    opf:level 4 .

