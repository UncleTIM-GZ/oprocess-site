    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Creating rules and regulations to be followed in case of credit sales to customers. Create rules and procedures to follow at the time of sale (e.g., the allowable number of installments)."@en,
        "Creating rules and regulations to be followed in case of credit sales to customers. 创建 rules and procedures to follow at the time of sale (e.g., the allowable number of installments)."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.1" ;
    skos:prefLabel "Establish AR policies"@en,
        "建立 AR policies"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.2> a skos:Concept,
