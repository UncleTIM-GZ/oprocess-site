    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Using existing technologies to improve organization's knowledge management processes. Research available third-party offerings. Develop proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel."@en,
        "Using existing technologies to improve organization's 知识管理 processes. Research available third-party offerings. 开发 proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.4" ;
    skos:prefLabel "Leverage and enhance IT for KM approaches"@en ;
