    skos:broader <https://oprocess.net/opf/node/11.5.1> ;
    skos:definition "AI activity: Monitor ethical compliance."@en,
        "AI活动：监测伦理合规情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.1.4" ;
    skos:prefLabel "Monitor ethical compliance"@en,
        "监控伦理合规情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.2> ;
    skos:definition "AI activity: Monitor AI regulations (EU AI Act, etc.)."@en,
        "AI活动：监测AI监管法规（如欧盟《人工智能法案》等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.2.1" ;
    skos:prefLabel "Monitor AI regulations (EU AI Act, etc.)"@en,
        "跟踪人工智能监管法规（如欧盟《人工智能法案》等）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.2> ;
    skos:definition "AI activity: Classify AI systems by risk level."@en,
        "AI活动：按风险等级对AI系统进行分类。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.2.2" ;
    skos:prefLabel "Classify AI systems by risk level"@en,
        "按风险等级对人工智能系统进行分类"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.2> ;
    skos:definition "AI activity: Maintain AI compliance documentation."@en,
        "AI活动：维护AI合规文档。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.2.3" ;
    skos:prefLabel "Maintain AI compliance documentation"@en,
        "维护人工智能合规文档"@zh ;
    opf:domain "management_support" ;
