    skos:notation "8.5.7.2" ;
    skos:prefLabel "Implement coding standards"@en,
        "实施编码规范"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.5.7.3> a skos:Concept,
