    skos:definition "SCOR DS 14.0: Order Make-to-Order Product (sO2)."@en,
        "SCOR DS 14.0：订购按订单生产产品（sO2）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.7" ;
    skos:prefLabel "Order Make-to-Order Product"@en,
        "订购按订单生产（MTO）产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

