        "Determine HR delivery 模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/7.1.1> ;
    skos:definition "Ascertaining the costs and expenses of the HR function. Identify and report HR investments using, for example, a cost approach or a present value of future earnings approach."@en,
