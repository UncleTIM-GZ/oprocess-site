<https://oprocess.net/opf/node/11.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5> ;
    skos:definition "AI process: Manage AI Safety and Alignment."@en,
        "AI流程：管理AI安全与对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.3" ;
    skos:prefLabel "Manage AI Safety and Alignment"@en,
        "管理人工智能安全与对齐"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5> ;
    skos:definition "AI process: Manage AI Bias and Fairness."@en,
        "AI流程：管理AI偏见与公平性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.4" ;
    skos:prefLabel "Manage AI Bias and Fairness"@en,
        "管理人工智能偏见与公平性"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5> ;
    skos:definition "AI process: Manage AI Transparency and Explainability."@en,
        "AI流程：管理人工智能透明度与可解释性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.5" ;
    skos:prefLabel "Manage AI Transparency and Explainability"@en,
        "管理人工智能（AI）透明度与可解释性"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.1" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "Creating a strategic management responsibility for integrating finance, communication, marketing, and securities law compliance. Allow the most effective two-way communication among the organization, the financial community, and other constituencies. Enlist the investor relations function to provide market intelligence to corporate management."@en,
        "设立战略管理职责，统筹财务、传播、营销及证券法规合规工作；促进组织、金融界及其他利益相关方之间最有效的双向沟通；借助投资者关系职能，向企业管理层提供市场情报。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.1" ;
    skos:prefLabel "Build investor relationships"@en,
        "构建投资者关系"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "Creating and maintaining relationships with government and industry representatives."@en,
        "建立并维系与政府及行业代表的关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2" ;
    skos:prefLabel "Manage government and industry relationships"@en,
        "管理政府与行业关系"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.2" ;
    skos:broader <https://oprocess.net/opf/node/12.2> ;
    skos:definition "Managing relations with quasi-governmental organizations, corporations, businesses, or any other agency that is treated by national laws and principles to be under the supervision of the government but also distinct and self-directed from the government."@en,
        "管理与准政府组织、企业、商业实体或其他依法受政府监督但又保持独立自主运作的机构的关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.2" ;
    skos:prefLabel "Manage relations with quasi-government bodies"@en,
        "管理与准政府机构的关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.6" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Safeguarding the intellectual property of the organization. This process requires the organization to protect a wide variety of intellectual property created by it. This includes leveraging artificial intelligence(AI) to identify potential infringement of intellectual property and making sure employees are adhering to company policies around use of artificial intelligence(AI). It involves creating and managing non-disclosure agreements (NDAs), following up on current developments in the areas where the organization holds patents, tracking the use of the organization's copyrighted material, creating and upholding licensing terms, and administering policies for safeguarding intellectual property."@en,
        "保护组织的知识产权。该流程要求组织全面保护自身创造的各类知识产权，包括：运用人工智能（AI）识别潜在侵权行为；确保员工遵守公司关于人工智能（AI）使用的政策；制定并管理保密协议（NDA）；跟进组织持有专利的相关技术发展动态；追踪组织版权材料的使用情况；制定并执行许可条款；建立并落实知识产权保护政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.6" ;
    skos:prefLabel "Protect intellectual property"@en,
        "保护知识产权"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1> ;
    skos:definition "Defining and managing the organization's approach to governing business process management. Establish and manage tools to support the governance process. Assign ownership for all business processes. Perform activities to administer the governing process."@en,
        "定义并管理组织在业务流程管理（BPM）领域的治理方法。建立并管理支撑治理过程的工具；明确所有业务流程的责任归属；开展治理过程的日常管理工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.1" ;
    skos:prefLabel "Establish and maintain process management governance"@en,
        "建立并维护流程治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.1> ;
    skos:definition "Identifying, selecting, and managing improvements. Based on the type and scope of the improvement, determination of the appropriate improvement methodology (e.g., Lean, Six Sigma, etc.) should guide the effort. This includes continuous improvement, process redesign, process reengineering, and application of the organizations approaches for Manage projects."@en,
        "识别、遴选与管理流程改进：依据改进类型与范围，选用适宜的改进方法论（如精益管理、六西格玛等）予以指导，涵盖持续改进、流程优化、流程再造，以及组织既定的项目管理方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.5" ;
    skos:prefLabel "Improve processes"@en,
        "改进流程"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Continual Improvement" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "ITIL V5 practice: Continual Improvement. Mapped to Develop and Manage Business Capabilities."@en,
        "ITIL V5实践：持续改进。映射至‘开发与管理业务能力’。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.11" ;
    skos:prefLabel "Continual Improvement"@en,
        "持续改进"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

