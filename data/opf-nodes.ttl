    dcterms:source "PCF:5.4.3.7" ;
    skos:broader <https://oprocess.net/opf/node/5.4.3> ;
    skos:definition "Completing and archiving all records associated with requested services. Update all necessary systems to reflect those changes."@en,
        "Completing and archiving all records associated with requested services. Update all necessary systems to reflect those 变更s."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.4.3.7" ;
    skos:prefLabel "Archive records and update systems"@en ;
