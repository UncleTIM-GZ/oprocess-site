    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.6.3" ;
    skos:prefLabel "Reserve inventory"@en,
        "预留库存"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.6.4> a skos:Concept,
