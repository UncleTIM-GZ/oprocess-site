<https://oprocess.net/opf/node/6.3.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4.1> ;
    skos:definition "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and customer service work."@en,
        "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and 客户服务 work."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.1.3" ;
    skos:prefLabel "Generate service order"@en ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4.2> ;
    skos:definition "Developing a plan for sourcing and deploying the resources required to fulfill customer service needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete customer service requests and procure these resources. Identify and assess various sources in order to effectively create a resourcing plan."@en,
        "Developing a plan for sourcing and deploying the resources required to 履约 客户服务 needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete 客户服务 requests and procure these resources. 识别 and assess various sources in order to effectively create a resourcing plan."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.2.1" ;
    skos:prefLabel "Create resourcing plan and schedule"@en,
        "创建 resourcing plan and schedule"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4.2> ;
    skos:definition "Designing a detailed summary of customer service order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. Monitor the services delivered."@en,
        "Designing a detailed summary of 客户服务 order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. 监控 the services delivered."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.2.2" ;
    skos:prefLabel "Create service order fulfillment schedule"@en,
        "创建 service order 履约ment schedule"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/6.3.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4.3> ;
    skos:definition "Laying out a daily plan of specific service orders that need to be fulfilled. Document and systematically order these activities to ensure high effectiveness and efficiency."@en,
        "Laying out a daily plan of specific service orders that need to be 履约ed. Document and systematically order these activities to ensure high effectiveness and efficiency."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.3.1" ;
    skos:prefLabel "Organize daily service order fulfillment schedule"@en,
