    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.5> ;
    skos:definition "AI activity: Document AI decision processes."@en,
        "AI活动：记录人工智能决策流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.5.2" ;
    skos:prefLabel "Document AI decision processes"@en,
        "记录人工智能决策流程"@zh ;
    opf:domain "management_support" ;
