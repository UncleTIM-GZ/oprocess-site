    skos:notation "6.5.1.3" ;
    skos:prefLabel "Provide customer feedback to product management on customer service experience"@en,
        "提供 customer feedback to product management on 客户服务 experience"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/6.5.2> ;
    skos:definition "Requesting customer feedback on the process of handling and resolving customer complaints. Obtain information about the effectiveness and performance of the customer complaint handling process from the customers through various means (e.g., online and by phone)."@en,
        "Requesting customer feedback on the process of handling and resolving customer complaints. Obtain information about the effectiveness and 绩效 of the customer complaint handling process from the customers through various means (e.g., online and by phone)."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.2.1" ;
    skos:prefLabel "Solicit customer feedback on complaint handling and resolution"@en ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/6.5.2> ;
    skos:definition "Examining the information obtained through handling and resolving complaints for development/improvement opportunities. Categorize the customer complaints data on the basis of speed, accuracy, courtesy, price, product choice, availability, hours, location, etc. Determine complaint patterns in order to diagnose areas needing enhancement."@en,
        "Examining the information obtained through handling and resolving complaints for development/improvement opportunities. Categorize the customer complaints data on the basis of speed, accuracy, courtesy, price, product choice, 可用性, hours, location, etc. Determine complaint patterns in order to diagnose areas needing enhancement."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.2.2" ;
    skos:prefLabel "Analyze customer complaint data and identify improvement opportunities"@en,
        "分析 customer complaint data and identify improvement opportunities"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/6.5.2> ;
    skos:definition "Determining complaint patterns in order to identify common issues. Document common problems for correction."@en,
        "Determining complaint patterns in order to identify common issues. Document common 问题s for correction."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.2.3" ;
    skos:prefLabel "Identify common customer complaints"@en,
        "识别 common customer complaints"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/6.5.3> ;
    skos:definition "Obtaining customer feedback/review on the quality and utility derived from the products/services after the sale is complete. Use techniques such as surveys, feedback boxes, and user activity and usability tests."@en,
        "Obtaining customer feedback/review on the 质量 and utility derived from the products/services after the sale is complete. Use techniques such as surveys, feedback boxes, and user activity and usability tests."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.3.1" ;
    skos:prefLabel "Gather and solicit post-sale customer feedback on products and services"@en,
        "Gather and solicit post-sale customer feedback on 产品和服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/6.5.3> ;
    skos:definition "Assessing the influence of promotions on purchasing behavior. Use techniques such as surveys and product recognition tests, questionnaires or feedback flyers, and toll-free numbers in order to encourage customer interaction after the sale."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.5.3.2" ;
    skos:prefLabel "Solicit post-sale customer feedback on promotion effectiveness"@en ;
    opf:domain "operating" ;
    opf:level 4 .

