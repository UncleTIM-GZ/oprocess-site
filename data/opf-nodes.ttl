    skos:definition "SCOR DS 14.0: Plan Service Operations (sP-SVC)."@en,
        "SCOR DS 14.0：规划服务运营（sP-SVC）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.3" ;
    skos:prefLabel "Plan Service Operations"@en,
        "规划服务运营"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2" ;
    skos:broader <https://oprocess.net/opf/node/5.0> ;
    skos:definition "Understanding the demands on resources and creating a plan to enable the delivery of services via those resources."@en,
        "识别资源需求并制定计划，以确保通过可用资源交付服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2" ;
    skos:prefLabel "Manage service delivery resources"@en,
        "管理服务交付资源"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

