    skos:broader <https://oprocess.net/opf/node/11.5.4> ;
    skos:definition "AI activity: Assess training data bias."@en,
        "AI活动：评估训练数据偏见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
