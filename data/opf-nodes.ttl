<https://oprocess.net/opf/node/13.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.1> ;
    skos:definition "Instituting the strategy for managing business portfolio. Create a systematic plan that defines the strategy for managing investments, holdings, products, businesses, and brands."@en,
        "建立业务组合管理战略：制定系统性计划，明确投资、持股、产品、业务单元及品牌等要素的管理策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.1.1" ;
    skos:prefLabel "Establish portfolio strategy"@en,
        "制定项目组合战略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.1> ;
    skos:definition "Outlining the administration of business portfolio of the organization. Create and manage the rules and regulations regarding the business processes in order to identify, select, prioritize, and monitor portfolio components. Include a set of metrics to indicate the health and progress of the portfolio in the most vital area."@en,
        "界定业务组合管理机制：制定并维护相关规则与制度，规范组合组件的识别、遴选、优先级排序与监控；配套设定关键健康度与进展指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.1.2" ;
    skos:prefLabel "Define portfolio governance"@en,
        "定义项目组合治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.1> ;
    skos:definition "Overseeing and administering the business portfolio of the organization. Monitor all activities related to investments, holdings, products, businesses, and brands by effectively monitoring and supervising these activities."@en,
        "监督与运营业务组合：通过有效监控与督导，全面跟踪投资、持股、产品、业务单元及品牌相关各项活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.1.3" ;
    skos:prefLabel "Monitor and control portfolio"@en,
        "监控与控制项目组合"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.2> ;
    skos:definition "Constructing and instituting the framework and approach to manage business programs. Monitor key factors such as governance, alignment with the overall business vision, assurance, and management."@en,
        "构建并落地业务项目组合管理框架与方法：重点监控治理机制、与组织愿景的战略对齐度、保障机制及管理效能等关键要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.2.1" ;
    skos:prefLabel "Establish program structure and approach"@en,
        "建立项目集结构与实施路径"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.2> ;
    skos:definition "Managing relationships with stakeholders and partners of the business programs."@en,
        "管理业务项目组合的干系人与合作伙伴关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.2.2" ;
    skos:prefLabel "Manage program stakeholders and partners"@en,
        "管理项目集干系人与合作伙伴"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.2> ;
    skos:definition "Administering and implementing business programs. Implement and execute programs with the intention of improving an organization's performance. Execute all the individual projects of the program to ensure the desired success."@en,
        "运营与实施业务项目组合：以提升组织绩效为目标推进组合实施；全面落实组合内各子项目，确保整体成功交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.2.3" ;
    skos:prefLabel "Manage program execution"@en,
        "管理项目集执行"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/13.2.2> ;
    skos:definition "Evaluating and documenting the performance of business programs. Evaluate the performance of the programs. Create reports on the basis of the analysis. Use performance indicators and metrics such as desired/achieved goals, completion dates, issues and defects, and cost effectiveness."@en,
        "评估并记录业务项目组合绩效：开展绩效评估；基于分析结果编制报告；运用目标达成率、计划完成时间、问题与缺陷数、成本效益等绩效指标与度量数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.2.4" ;
    skos:prefLabel "Review and report program performance"@en,
        "评审并报告项目集绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Recognizing and defining what the project is ultimately supposed to do. Specify the capabilities, features, or attributes of the project's deliverables, as well as any kind of formal documentation."@en,
        "识别并定义项目最终交付价值：明确项目可交付成果的能力、功能或属性，并形成正式文档。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.1" ;
    skos:prefLabel "Identify project requirements and objectives"@en,
        "识别项目需求与目标"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Identifying the prerequisites of business projects. Identify the people with appropriate and applicable skills and competencies. Locate resources such as capital, facilities, equipment, material, and information required to accomplish the objectives of a specific project."@en,
        "识别业务项目的先决条件：匹配具备相应技能与胜任力的人员；落实资本、场地、设备、物料及信息等必要资源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.2" ;
    skos:prefLabel "Identify project resource requirements"@en,
        "识别项目资源需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Evaluating the culture and readiness of the organizational environment is order to implement the project management approach."@en,
        "评估组织文化与环境对实施项目管理方法的适配性与成熟度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.3" ;
    skos:prefLabel "Assess culture and readiness for project management approach"@en,
        "评估组织文化及项目管理方法的就绪度"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Creating a document that includes the current situation, proposed solution, financial analysis, conclusion, etc. Convince a decision maker and investors to approve the project. Obtain funding."@en,
        "编制立项建议书：涵盖现状分析、拟议解决方案、财务分析、结论等内容，用于说服决策者与投资者批准项目并获取资金。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.4" ;
    skos:prefLabel "Create business case"@en,
        "编制商业论证"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Developing procedures and indictors to assess performance of business projects. Design and develop metrics and indicators--such as cost, schedule, resources, risk, and quality--that exhibit the performance of the business projects."@en,
        "制定业务项目绩效评估程序与指标：设计并开发反映项目绩效的成本、进度、资源、风险与质量等维度的度量指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.5" ;
    skos:prefLabel "Develop project measures and indicators"@en,
        "制定项目度量指标与关键绩效指标（KPI）"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.1> ;
    skos:definition "Stack ranking of projects in the portfolio based upon preestablished criteria."@en,
        "依据预设标准对组合内项目进行优先级排序（堆栈式排名）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.1.6" ;
    skos:prefLabel "Prioritize and select projects for the portfolio"@en,
        "对项目组合中的项目进行优先级排序与遴选"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Identifying and implementing the techniques and procedures for managing business projects. Identify the most appropriate models, which are to be employed by the project managers for the purpose of designing, planning, implementing, and achieving project objectives. Examine and assess various project management methodologies such as adaptive project framework, agile development, crystal methods, and feature-driven development."@en,
        "识别并应用业务项目管理技术与规程：甄选最适合项目管理者在设计、规划、实施与达成目标过程中采用的方法模型；评估自适应项目框架（APF）、敏捷开发、水晶方法、特性驱动开发（FDD）等各类项目管理方法论。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.2" ;
    skos:prefLabel "Identify appropriate project management methodologies"@en,
        "识别适用的项目管理方法论"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Outlining the resources and their roles in the business projects."@en,
        "明确业务项目中各类资源及其职责分工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.1" ;
    skos:prefLabel "Define roles and resources"@en,
        "明确角色与资源"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Procuring the necessary resources outlined in Define roles and resources [11123]"@en,
        "采购《界定角色与资源》[11123]中所列明的必要资源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.2" ;
    skos:prefLabel "Acquire/secure project resources"@en,
        "获取/落实项目资源"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Determining the IT requirements for specific business projects. Identify the requirements of computers and telecommunications equipment to store, retrieve, transmit, and manipulate data related to the project. Consider factors such as functional requirements, design requirements, project phases, and project schedule."@en,
        "确定特定业务项目的IT需求：识别支撑项目数据存储、检索、传输与处理所需的计算机及通信设备要求；综合考虑功能需求、设计需求、项目阶段与进度安排等因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.3" ;
    skos:prefLabel "Identify specific IT requirements"@en,
        "识别具体信息技术（IT）需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Designing a plan for equipping the project team with the necessary skills and abilities to fulfill their roles and responsibilities in the project effectively and efficiently. Offer formal training, mentoring, or coaching. Initiate informal conversations. Communicate messages during the project."@en,
        "制定赋能计划：通过正式培训、导师制或教练辅导等方式，提升项目团队履职所需技能与能力；辅以非正式交流与全过程信息沟通。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.4" ;
    skos:prefLabel "Create training and communication plans"@en,
        "制定培训与沟通计划"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Creating a plan for recognizing and rewarding extraordinary performances within the business projects. Use incentives, bonuses, and certificates for recognition and rewarding purposes."@en,
        "制定项目卓越绩效认可与激励计划：采用奖金、津贴、荣誉证书等形式予以表彰与激励。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.5" ;
    skos:prefLabel "Design recognition and reward approaches"@en,
        "设计认可与激励机制"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.6" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Creating a plan specifying when to initiate the project, and introducing it to the target audience. Clearly define the project team, objectives, timelines, and milestone."@en,
        "制定项目启动计划：明确启动时点与目标受众；清晰界定项目团队、目标、时间表及关键里程碑。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.6" ;
    skos:prefLabel "Design and plan launch of project"@en,
        "设计并规划项目启动"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.3.7" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.3> ;
    skos:definition "Putting the project into position by effectively bringing it into action."@en,
        "推动项目落地实施：高效推动项目进入实际运行状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.3.7" ;
    skos:prefLabel "Deploy the project"@en,
        "部署项目"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Assessing the impact of business project management on the measures and outcomes of the projects. Gauge non-financial measures, frequency of measurement, action plan, etc."@en,
        "评估业务项目管理对项目指标与成果的影响：衡量非财务指标、测量频次、改进举措等维度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.1" ;
    skos:prefLabel "Evaluate impact of project management (strategy and projects) on measures and outcomes"@en,
        "评估项目管理（战略与项目）对度量指标与成果的影响"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Recording and documenting the current status and position of the project. Record and report items such as completed tasks, incomplete tasks, planned tasks, and problems faced."@en,
        "记录并归档项目当前状态与进展，包括已完成任务、未完成任务、计划任务及所遇问题。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.2" ;
    skos:prefLabel "Report the status of project"@en,
        "报告项目状态"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Determining and documenting a list of specific project goals, deliverables, tasks, costs, and deadlines. Use the scope statement to explain the boundaries of the project. Assign responsibilities for team members. Set up procedures for verifying and approving the completed tasks."@en,
        "明确并文档化具体项目目标、可交付成果、任务、成本及截止日期；利用范围说明书界定项目边界；分配团队成员职责；建立任务完成后的验证与审批流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.3" ;
    skos:prefLabel "Manage project scope"@en,
        "管理项目范围"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Encouraging and sustaining the activities and involvement while executing projects. Promote the execution activities of the projects. Encourage employee involvement in project implementation."@en,
        "在项目执行过程中持续激发并维持团队活动与参与度，推动项目执行工作，鼓励员工积极参与项目实施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.4" ;
    skos:prefLabel "Promote and sustain activity and involvement"@en,
        "促进并持续推动活动参与"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Hold post project reviews, lessons learned, or After Action Reviews (AARs) at the end of each project to understand what could be improved during future projects."@en,
        "在每个项目结束时开展项目后评审、经验总结或行动后复盘（AAR），以识别未来项目可改进之处。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.5" ;
    skos:prefLabel "Conduct Project Reviews with Program Managers and other stakeholders"@en,
        "与项目集经理及其他相关方开展项目评审"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.6" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Reorganizing and stimulating the approach and strategy for managing business projects. Make improvements based on the project scope and on findings from Evaluate the impact of project management (strategy and projects) on measures and outcomes [11131]."@en,
        "重构并优化业务项目管理的方法与策略，基于项目范围及‘评估项目管理（战略与项目）对指标与成果的影响’[11131]的分析结果实施改进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.6" ;
    skos:prefLabel "Realign and refresh project management strategy and approaches"@en,
        "调整并更新项目管理策略与方法"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.4.7" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3.4> ;
    skos:definition "Changes to project plans based upon internal and or external influences on the project.  This would include the update to the project plan file, as well as the communication to the team."@en,
        "依据内外部影响因素调整项目计划，包括更新项目计划文件并向团队沟通变更内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.4.7" ;
    skos:prefLabel "Adjust project plan as needed"@en,
        "按需调整项目计划"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Measuring the performance of a business project against key performance indicators including the project scope, schedule, quality, cost, and risk criteria. Identify any deviations from the plan. Assess the impact of these deviations on the project, as well as on the overall program. Report results to key stakeholders."@en,
        "依据关键绩效指标（KPI）——包括项目范围、进度、质量、成本与风险等维度——衡量业务项目绩效；识别偏离计划的情况；评估其对项目及整体项目集的影响；向关键干系人报告结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.5" ;
    skos:prefLabel "Review and report project performance"@en,
        "评审并报告项目绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.3.6" ;
    skos:broader <https://oprocess.net/opf/node/13.2.3> ;
    skos:definition "Settling each contract. Close each contract applicable to the project or project phase. Finalize all activities across all of the process groups in order to formally close the project or a project phase."@en,
        "完成每份合同的收尾工作；关闭适用于项目或项目阶段的所有合同；全面终结各过程组中的全部活动，以正式结束项目或项目阶段。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.3.6" ;
    skos:prefLabel "Close projects"@en,
        "收尾项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Project Management" ;
    skos:broader <https://oprocess.net/opf/node/13.2.4> ;
    skos:definition "Activity within ITIL practice 'Project Management'."@en,
        "ITIL 实践‘项目管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.4.1" ;
    skos:prefLabel "Initiate IT projects"@en,
        "启动IT项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Project Management" ;
    skos:broader <https://oprocess.net/opf/node/13.2.4> ;
    skos:definition "Activity within ITIL practice 'Project Management'."@en,
        "ITIL 实践‘项目管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.4.2" ;
    skos:prefLabel "Plan and execute IT projects"@en,
        "规划并执行IT项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Project Management" ;
    skos:broader <https://oprocess.net/opf/node/13.2.4> ;
    skos:definition "Activity within ITIL practice 'Project Management'."@en,
        "ITIL 实践‘项目管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.4.3" ;
    skos:prefLabel "Monitor and control IT projects"@en,
        "监控与控制IT项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1> ;
    skos:definition "Outlining characteristics crucial for managing enterprise quality. Translate broad customer needs into specific, actionable, measurable performance requirements. Define the key measurable characteristics of key products and processes."@en,
        "界定企业质量管理的关键特征；将宽泛的客户需求转化为具体、可操作、可测量的性能要求；定义核心产品与流程的关键可测特性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.1" ;
    skos:prefLabel "Define critical-to-quality characteristics"@en,
        "界定关键质量特性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1> ;
    skos:definition "Identifying gaps in customer requirements and determining whether the gap will be mitigated through preventive Quality activities or deemed as acceptable risk. The goal of any preventive quality activities is to create provisions to prevent, control, or reduce the risk of not meeting the CtQCs. In addition, any standard methodology that will be used to design or conduct preventive Quality activities are defined and documented."@en,
        "识别客户需求缺口，并判定该缺口将通过预防性质量活动予以弥补，抑或被接受为可容忍风险；预防性质量活动的目标是制定措施以预防、控制或降低未能满足关键质量特性（CtQCs）的风险；同时明确定义并文档化拟采用的标准方法，用于设计或执行预防性质量活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.2" ;
    skos:prefLabel "Define preventive quality activities"@en,
        "界定预防性质量活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1.3> ;
    skos:definition "Establishing the steps for developing quality controls. Conduct Alpha testing. Have the product team conduct rework. Send the product/service for Beta testing, and carry on rework as needed."@en,
        "建立质量控制开发步骤：开展Alpha测试；由产品团队实施返工；将产品/服务送入Beta测试，并按需持续返工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.3.1" ;
    skos:prefLabel "Define process steps for controls (or integration points)"@en,
        "界定控制流程步骤（或集成点）"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1.3> ;
    skos:definition "Establishing a detailed summary including measures, on which material, in what manner, and by whom. Identify the parameters to be measured, the range of possible values, and the required resolution. Provide a sampling scheme that details how and when samples will be taken. Select sample sizes. Assign roles and responsibilities."@en,
        "编制含测量要素的详细说明，明确测量对象、方式与责任人；确定待测参数、允许取值范围及所需精度；制定详尽的抽样方案，说明抽样时机与方法；确定样本量；明确角色与职责。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.3.2" ;
    skos:prefLabel "Define sampling plan"@en,
        "界定抽样方案"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1.3> ;
    skos:definition "Using tools to measure quality. Use tools such as quality improvement oversight system tool, performance measurement tools, consumer information models/guides, and validation tools to effectively determine the quality levels."@en,
        "运用工具开展质量测量：使用质量改进监督系统工具、绩效测量工具、消费者信息模型/指南及验证工具等，有效判定质量水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.3.3" ;
    skos:prefLabel "Identify measurement methods"@en,
        "识别测量方法"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1.3> ;
    skos:definition "Defining the competencies required for developing quality controls. Define the required competencies including compliance management, audit management, and document control and document management."@en,
        "界定质量控制开发所需的胜任力：包括合规管理、审计管理、文件控制与文档管理等能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.3.4" ;
    skos:prefLabel "Define required competencies"@en,
        "界定所需能力"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1> ;
    skos:definition "Demonstrating the ability and capability to confirm and fulfill the quality requirements in front of customers, managers, employees, board members, associations, regulatory bodies, and creditors. Leverage tools and techniques such as process behavior or control charts, statistical process control, measurement system analysis, gage calibration management, and process capability analysis."@en,
        "面向客户、管理者、员工、董事会成员、行业协会、监管机构及债权人，展示组织确认并满足质量要求的能力与实力；运用过程行为图/控制图、统计过程控制（SPC）、测量系统分析（MSA）、量具校准管理、过程能力分析等工具与技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.4" ;
    skos:prefLabel "Prove capability to assess compliance with requirements"@en,
        "验证评估合规性要求的能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1> ;
    skos:definition "Establishing how the critical-to-quality characteristics will be achieved, controlled, ensured, and managed throughout the lifecycle of a product/service. Address quality requirements and critical-to-quality characteristics. Conduct a preventive quality assessment. Describe how to verify the product/service, verification criteria, and response to nonconformance. Keep records to demonstrate conformity."@en,
        "明确关键质量特性（CtQCs）在产品/服务全生命周期内如何实现、受控、保障与管理；响应质量要求与关键质量特性；开展预防性质量评估；说明产品/服务验证方式、验证标准及不符合项响应机制；保留记录以证明符合性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.5" ;
    skos:prefLabel "Finalize quality plan"@en,
        "定稿质量计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.1> ;
    skos:definition "Evaluating quality performance through periodic or episodic testing against the established standards for quality characteristics. For periodic testing, design a schedule with sufficient time to make any required adjustments to the process or system to maintain the desired level of quality. For episodic testing, conduct a test whenever a known non-conformance or fault occurs, which results in outputs or outcomes known to be unsatisfactory to performance requirements."@en,
        "通过周期性或事件驱动型测试，对照既定质量特性标准评估质量绩效：周期性测试需设计合理时间表，预留足够时间对流程或系统进行必要调整以维持期望质量水平；事件驱动型测试则在已知不符合项或故障发生、导致输出/结果明显不满足性能要求时立即开展。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.1.1" ;
    skos:prefLabel "Conduct test and collect data"@en,
        "开展测试并采集数据"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.1> ;
    skos:definition "Maintaining and recording the results of Test against the quality plan [17483] electronically and in standard formats. Assign ownership to a designated function or role."@en,
        "以电子化及标准格式维护并记录‘对照质量计划开展的测试’[17483]结果；指定职能或角色承担该项工作所有权。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.1.2" ;
    skos:prefLabel "Record result(s)"@en,
        "记录结果"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.1> ;
    skos:definition "Deciding whether to take any additional actions based on the results of quality tests. Initiate a quarantine disposition and relocated inventory, scrap workflow item and scrap transaction, rework operation, net-able and nonnet-able items, and the activity list."@en,
        "基于质量测试结果决定是否采取进一步措施：启动隔离处置并转移库存、报废工作项与交易、执行返工操作、区分可冲销与不可冲销项，以及更新活动清单。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.1.3" ;
    skos:prefLabel "Determine disposition of result(s)"@en,
        "判定结果处置方式"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.2> ;
    skos:definition "Assessing the significance of the sample chosen for the test in order to determine whether or not the sample is representative of the larger output or outcome. Determine if the sample meets or does not meet the requirements. Identify the conditions for acceptance, rejection, remediation, and prevention."@en,
        "评估所选测试样本的代表性，判断其能否反映整体输出或结果；判定样本是否符合要求；明确接收、拒收、整改与预防的判定条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.2.1" ;
    skos:prefLabel "Assess sample significance"@en,
        "评估样本代表性"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.2> ;
    skos:definition "Outlining the major facts and figures of the quality test results in order to provide insights and information. Use charts, tables, statistical test results, and written findings and conclusions in a summary of results."@en,
        "以图表、表格、统计检验结果及文字形式的发现与结论，归纳质量测试结果的核心事实与数据，提供洞察与决策支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.2.2" ;
    skos:prefLabel "Summarize result(s)"@en,
        "汇总结果"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.2> ;
    skos:definition "Recommending measures for improvement. Assess the summarized results to identify areas which can be improved. Suggest actions to management for improving the quality plan basis on the results of the tests."@en,
        "提出改进建议：基于汇总结果识别可提升领域；向管理层建议基于测试结果优化质量计划的具体措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.2.3" ;
    skos:prefLabel "Recommend actions"@en,
        "提出改进建议"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2.2> ;
    skos:definition "Selecting the subsequent actions that the organization can adopt for improving the enterprise quality. Select measures and recommended actions for managing the enterprise quality."@en,
        "选择组织可采纳的后续行动以提升企业质量：筛选并确定质量管控措施及推荐行动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.2.4" ;
    skos:prefLabel "Decide next steps"@en,
        "确定后续步骤"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.3> ;
    skos:definition "Analyzing any nonconformance events. Determine the need for corrective and/or preventative action(s). Leverage root-cause analysis, risk exposure, and other evaluations to properly review and approve/reject subsequent actions."@en,
        "分析不符合项事件：判定是否需采取纠正和/或预防措施；借助根本原因分析、风险暴露评估及其他评价手段，审慎评审并批准/否决后续行动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3.1" ;
    skos:prefLabel "Assess potential impact"@en,
        "评估潜在影响"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.3> ;
    skos:definition "Initiating immediate corrective, preventative, or no action based upon the impact and likelihood of reoccurrence. Consider cost/benefit, risk exposure, timing, the assignment of responsibility, and other pertinent factors ."@en,
        "依据不符合项影响程度与复发可能性，立即启动纠正、预防或不采取行动；综合考量成本效益、风险暴露、时效性、责任归属及其他相关因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3.2" ;
    skos:prefLabel "Determine immediate action(s)"@en,
        "确定即时应对措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.3> ;
    skos:definition "Recognizing the reasons that have triggered the nonconformance events or activities. Perform a root-cause analysis through documentary evidence and interviews. Involve the appropriate individuals. Leverage cause analysis and risk assessment."@en,
        "识别触发不符合项事件或活动的深层原因：通过文档证据与访谈开展根本原因分析；邀请相关人员参与；结合因果分析与风险评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3.3" ;
    skos:prefLabel "Identify root cause(s)"@en,
        "识别根本原因"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.3> ;
    skos:definition "Pursuing corrective and preventative activities to eliminate the cause of a detected nonconformity. Define the nonconformity. Communicate and assign responsibility. Identify the appropriate corrective and preventive action. Implement and monitor for reoccurrence."@en,
        "开展纠正与预防活动以消除已识别不符合项的根本原因：明确定义不符合项；传达并落实责任；识别适配的纠正与预防措施；实施并监控以防复发。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3.4" ;
    skos:prefLabel "Take corrective or preventative action"@en,
        "实施纠正或预防措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.3.3> ;
    skos:definition "Closing nonconformance. Perform all the final processes related to the nonconformance, including documenting root causes. Document corrective and preventive actions."@en,
        "关闭不符合项：完成所有相关收尾工作，包括记录根本原因，以及纠正与预防措施的文档化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.3.5" ;
    skos:prefLabel "Close non-conformance"@en,
        "关闭不符合项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Outlining the strategy for managing enterprise quality. Define and formalize quality techniques and standards. Assign responsibilities for achieving the required quality levels. Standardize the quality maintenance procedure, tools and techniques, recording and reporting, the timing of quality maintenance activities, and the roles and responsibilities for the quality management team."@en,
        "制定企业质量管理战略，明确定义并正式化质量技术与标准；明确达成所需质量水平的责任分工；统一质量维护流程、工具与技术、记录与报告机制、质量维护活动的时间安排，以及质量管理团队的职责分工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.1" ;
    skos:prefLabel "Define the quality strategy"@en,
        "制定质量战略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Establishing and effectively deploying the scope, targets, and goals of EQMS. Define the role of EQMS through nonconformance/corrective and preventive action, compliance/audit management, risk management, failure mode and effects analysis, and statistical process control. Implement EQMS into operational activities. Define the goals and objectives that are to be achieved by the EQMS."@en,
        "确立并有效部署企业质量管理体系（EQMS）的范围、目标与宗旨；通过不符合项管理／纠正与预防措施、合规／审计管理、风险管理、失效模式与影响分析（FMEA）、统计过程控制（SPC）等明确EQMS职能；将EQMS嵌入日常运营活动；定义EQMS需达成的具体目标与成果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.2" ;
    skos:prefLabel "Plan and deploy the EQMS scope, targets, and goals"@en,
        "规划并部署企业质量管理体系（EQMS）范围、目标与宗旨"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Recognizing and implementing the processes, controls, and metrics for maintenance of EQMS. Define the role of EQMS in failure mode and effects analysis, complaint handling, and advanced product quality planning. Establish the role of EQMS in evaluating metrics such as cost of quality, overall equipment effectiveness, on-time and complete shipments, percentage of products in compliance, and new product introductions."@en,
        "识别并落实支撑EQMS持续运行的流程、管控机制与衡量指标；明确EQMS在失效模式与影响分析（FMEA）、客户投诉处理、先进产品质量策划（APQP）中的作用；建立EQMS对质量成本、设备综合效率（OEE）、准时齐套交付率、合规产品占比、新产品导入数量等关键指标的评估机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.3" ;
    skos:prefLabel "Identify core EQMS processes, controls, and metrics"@en,
        "识别企业质量管理体系（EQMS）核心流程、控制措施与指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Setting the process limits. Gather required information. Align with other documents and processes. Define the document structure."@en,
        "设定流程边界；收集必要信息；与其他文档及流程保持协同；定义文档结构。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.4" ;
    skos:prefLabel "Develop and document EQMS policies, procedures, standards, and measures"@en,
        "制定并记录企业质量管理体系（EQMS）政策、程序、标准与度量方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4> ;
    skos:definition "Benchmarking current performance in quality metrics that span across the value chain. Identify gaps in performance as compared to industry peers. Identify and implement complementary EQMS capabilities. Enable a continuous improvement environment."@en,
        "对标贯穿价值链的质量绩效指标；识别与行业标杆相比的绩效差距；识别并引入互补性EQMS能力；营造持续改进环境。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.5" ;
    skos:prefLabel "Assess the EQMS performance"@en,
        "评估企业质量管理体系（EQMS）绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.4.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Provisioning rewards for achieving quality excellence. Provide monetary and nonmonetary rewards such as compensation, vacations, gift cards, and reimbursements to employees in in recognition of their services, efforts, and achievements in quality excellence."@en,
        "设立质量卓越奖励机制；向员工提供货币性与非货币性激励，包括薪酬调整、带薪休假、礼品卡、费用报销等，以表彰其在质量卓越实践中的服务、努力与成就。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.1" ;
    skos:prefLabel "Reward quality excellence"@en,
        "表彰质量卓越表现"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.4.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Establishing and maintaining partnerships with third-party sources to achieve quality excellence. Source and evaluate third-party sources both public and private to ensure that the most effective and efficient partnerships are formed."@en,
        "建立并维系第三方质量合作伙伴关系；甄选并评估公共与私营第三方资源，确保构建高效、高质的合作关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.2" ;
    skos:prefLabel "Create and maintain quality partnerships"@en,
        "建立并维系质量合作伙伴关系"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.4.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Maintaining a common denominator for the competency level within the organization's talent circle. Conduct training sessions, skill development activities, and quality excellence activities to ensure that the resources of the organization are competent enough and have the capabilities to achieve the required level of quality."@en,
        "统一组织内人才梯队的质量胜任力基准；开展培训、技能提升及质量卓越专项活动，确保组织资源具备达成既定质量目标所需的能力与资质。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.3" ;
    skos:prefLabel "Maintain talent capabilities and competencies"@en,
        "持续提升人才能力与胜任力"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.4.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.4" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Assimilating all the communication related to the EQMS into the organization's already established communication channels."@en,
        "将所有EQMS相关信息整合至组织既有沟通渠道中。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.4" ;
    skos:prefLabel "Incorporate EQMS messaging into communication channels"@en,
        "将企业质量管理体系（EQMS）信息融入各类沟通渠道"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.4.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.5" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Ensuring EQMS access to the person in charge of the quality management process. Establish who has the authority to manage the EQMS. Ensure access of EQMS to only the person(s) in authority."@en,
        "确保质量管理人员对EQMS系统的专属访问权限；明确EQMS管理权责归属；仅授权指定责任人访问EQMS。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.5" ;
    skos:prefLabel "Assure independent EQMS management access to appropriate authority in the organization"@en,
        "确保企业质量管理体系（EQMS）管理层具备组织内相应权限的独立访问权"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.3.4.6.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.4.6.6" ;
    skos:broader <https://oprocess.net/opf/node/13.3.4.6> ;
    skos:definition "Recording and transferring the best practices and proven methods associated with enterprise quality management systems (EQMS) that can be leveraged in improving the organization's framework. Record proven methodologies and approaches with the objective of communicating them for upgrading, refining, and enhancing the organization's systems."@en,
        "记录并推广企业质量管理体系（EQMS）中经实践验证的最佳实践与成熟方法，用于优化组织整体框架；系统归档已验证的方法论与实施路径，旨在推动体系升级、精进与强化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.4.6.6" ;
    skos:prefLabel "Transfer proven EQMS methods"@en,
        "推广已验证的企业质量管理体系（EQMS）方法"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Identifying and communicating with shareholders affected by the change. Consider internal and external stakeholders that will be affected by the change. Determine the amount of influence the change will have on them. Ensure the involvement of these stakeholders in the change process by effectively communicating with them."@en,
        "识别并沟通受变革影响的利益相关方；兼顾内部与外部相关方；评估变革对其影响程度；通过高效沟通确保其全程深度参与变革进程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.1" ;
    skos:prefLabel "Determine stakeholders"@en,
        "识别相关方"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.10" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Recognizing the impact of threats to critical assets. Determine what groups are impacted by this impact."@en,
        "识别关键资产受威胁所产生的影响；明确受影响的群体。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.10" ;
    skos:prefLabel "Identify impacted groups"@en,
        "识别受影响群体"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.11" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Evaluating the impact of threats to critical assets. Determine what assets will be impacted by the change."@en,
        "评估关键资产受威胁的影响；明确变革将波及的具体资产。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.11" ;
    skos:prefLabel "Determine degree/extent of impact"@en,
        "判定影响程度与范围"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.12" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Identifying and assigning the people accountable for effective change management. Hold managers accountable for ensuring change happens systematically and rigorously. Ensure that certain behaviors are rewarded or reprimanded accordingly."@en,
        "明确对有效变革管理负有直接责任的人员；压实管理者责任，确保变革系统化、规范化推进；对契合变革导向的行为予以激励，对阻碍行为及时纠偏。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.12" ;
    skos:prefLabel "Establish accountability for change management"@en,
        "明确变更管理责任主体"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.13> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.13" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Recognizing the circumstances or obstacles that keep the organization from progressing. Identify who and what are the resources resisting change. Identify integration failures, threats by competitive forces, and complexity failures."@en,
        "识别制约组织发展的现实障碍与阻力因素；定位抵制变革的主体与动因；识别集成失败、竞争力量冲击及复杂性失效等根源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.13" ;
    skos:prefLabel "Identify barriers to change"@en,
        "识别变更阻力因素"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.14> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.14" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Identifying the person(s) or thing(s)responsible for making the change possible. Consider factors such as interdependence of efforts, reward to the integrators, sharing of power and responsibility, and employee understanding of why change is essential."@en,
        "识别并赋权促成变革落地的关键角色；统筹考量协作依存关系、整合者激励机制、权责共享安排，以及员工对变革必要性的理解程度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.14" ;
    skos:prefLabel "Determine change enablers"@en,
        "识别变更促进因素"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.15> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.15" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Recognizing the resource requirements, and developing measures for change. Identify the financial, material, human, and informational resources needed to successfully implement the change. Develop programs, campaigns, etc. for establishing the change within the organization."@en,
        "识别变革所需的各类资源，并制定配套举措；明确财务、物资、人力与信息资源投入需求；设计变革宣贯计划、专项活动等组织落地方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.15" ;
    skos:prefLabel "Identify resources and develop measures"@en,
        "识别所需资源并制定衡量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Determining the level of preparedness of the conditions, attitudes, and resources at all levels in the organization needed for change to happen successfully. Define scope of the proposed change. Select the tools for a change readiness assessment."@en,
        "评估组织各层级在条件、态度与资源方面对变革成功的准备度；界定拟议变革的范围；选定变革准备度评估工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.2" ;
    skos:prefLabel "Assess readiness for change"@en,
        "评估组织变更准备度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Identifying people exhibit an extraordinary interest in the adoption, implementation, and success of the change. Engage champions in each division or team. Define the roles and responsibilities for the change champions. Determine criteria for selecting change champions. Provide training sessions to champions. Reward and recognize champions."@en,
        "识别对变革采纳、实施与成功抱有高度热情的关键人员；在各部门或团队中遴选变革倡导者；明确其角色与职责；制定倡导者遴选标准；为其提供专项培训；给予表彰与激励。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.3" ;
    skos:prefLabel "Identify change champion(s)"@en,
        "确定变更倡导者"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Preparing a design team for implementing change throughout the organization."@en,
        "组建覆盖全组织的变革实施设计团队。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.4" ;
    skos:prefLabel "Form design team"@en,
        "组建设计团队"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Defining the extent of the area or subject matter that the change process deals with or to which it is relevant. Establish a set of tools, processes, skills, and principles for managing the people side of change to achieve the required outcomes of the change process."@en,
        "界定变革流程所涉领域或主题范围；建立一套涵盖工具、流程、技能与原则的体系，用以管理变革中的人因要素，确保达成预期变革成效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.5" ;
    skos:prefLabel "Define scope"@en,
        "界定变更范围"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.6" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Using graphical and statistical tools such as pareto diagrams, process flow diagrams, cause-and-effect diagrams, check sheets, histograms, run charts, and scatter diagrams."@en,
        "运用帕累托图、流程图、因果图、检查表、直方图、运行图、散点图等图形与统计分析工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.6" ;
    skos:prefLabel "Understand current state"@en,
        "梳理现状"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.7" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Determining the state or position that the organization wants to be in after the implementation of the change. Gather necessary information about the processes, structures, and cultures. Define resource requirements."@en,
        "明确变革实施后组织期望达成的目标状态；收集有关流程、组织架构与文化的必要信息；界定资源需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.7" ;
    skos:prefLabel "Define future state"@en,
        "定义未来状态"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.8" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Looking beyond the immediate consequences of the threat to a critical asset and placing it in the context of what is important to the organization. Identify the impact of threats to critical assets. Create risk evaluation criteria. Evaluate the impact of threats to critical assets. Incorporate probability into the risk analysis."@en,
        "超越对关键资产威胁的即时后果，将其置于组织核心价值框架下审视；识别关键资产受威胁的影响；制定风险评估准则；将发生概率纳入风险分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.8" ;
    skos:prefLabel "Conduct organizational risk analysis"@en,
        "开展组织风险分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.1.9" ;
    skos:broader <https://oprocess.net/opf/node/13.4.1> ;
    skos:definition "Evaluating the culture within the organization. Adopt a quantitative, multidimensional measurement approach of an organization's culture and the aspirations for it. Diagnose cultural activities, enhance leadership sections. Integrate cultures."@en,
        "评估组织文化现状；采用定量、多维度测量方法评估当前文化及理想文化愿景；诊断文化实践短板，强化领导力模块；推动文化融合。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.1.9" ;
    skos:prefLabel "Assess cultural context"@en,
        "评估组织文化背景"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Correlating the change initiative with the other initiatives. Create an alignment between the goals and objectives of the change process and that of the other initiatives."@en,
        "统筹协调变革项目与其他战略举措；确保变革目标与组织其他重点工作的目标保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.1" ;
    skos:prefLabel "Assess connection to other initiatives"@en,
        "评估变更与其他举措的关联性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Creating a detailed structure summary for the purposes of managing the change. Demonstrate the reasons for the change. Define the type and scope of change. Form a change management team. Create a communication plan."@en,
        "构建结构清晰的变革管理概要框架；阐明变革动因；界定变革类型与范围；组建变革管理团队；制定沟通计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.2" ;
    skos:prefLabel "Develop change management plans"@en,
        "制定变更管理计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training."@en,
        "编制详尽的培训行动纲要，明确特定技能或行为的传授路径；确定培训实施主体；明确受训人员接受结构化培训的时间、地点与方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.3" ;
    skos:prefLabel "Develop training plan"@en,
        "制定培训计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Developing a plan for imparting or exchanging information relevant the to change. Define goals, objectives, and audience. Gather tools for all communications."@en,
        "制定变革相关信息传递与共享计划；明确沟通目标、对象与核心内容；统筹配置各类沟通工具与渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.4" ;
    skos:prefLabel "Develop communication plan"@en,
        "制定沟通计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Utilizing champions that have been trained to carry out needed changes. Engage champions to communicate roles and responsibilities for the change."@en,
        "启用经培训认证的变革倡导者推动变革落地；由倡导者传达变革相关的角色与职责要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.5" ;
    skos:prefLabel "Assign change champion(s)"@en,
        "指派变更倡导者"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.6" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Creating and designing the plan for rewarding the employees exhibiting the desired behavior. Specify rewards in recognition of service, effort, or achievement regarding the change, including bonuses, compensation, stock options, profit sharing, vacations, and flexible time."@en,
        "设计员工行为激励方案，对践行变革期望行为者予以奖励；明确奖励形式，包括绩效奖金、薪酬调整、股票期权、利润分享、带薪休假及弹性工作时间等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.6" ;
    skos:prefLabel "Develop rewards/incentives plan"@en,
        "制定激励与奖励方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.7" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Establishing a system or standard of measurement for measuring the adoption of the change. Consider activities such as the number of people who have adopted the change, how quickly have they adopted, number of unique adopters, and adopters by teams/divisions."@en,
        "建立变革采纳成效量化评估体系；关注采纳人数、采纳速度、唯一采纳者数量、按部门／团队划分的采纳者分布等指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.7" ;
    skos:prefLabel "Establish change adoption measures"@en,
        "建立变更采纳度衡量机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.8" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Establishing and explaining the new roles to employees. Assign roles and responsibilities to resources."@en,
        "向员工清晰阐释新岗位职责；为相关人员分配具体角色与任务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.8" ;
    skos:prefLabel "Establish/Clarify new roles"@en,
        "确立或厘清新角色职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.2.9" ;
    skos:broader <https://oprocess.net/opf/node/13.4.2> ;
    skos:definition "Creating a plan of financial outlay for the newly defined roles. Determine the amount of capital the organization is willing to invest in effectuating these new roles, how would the roles be financed, and what would comprise the ROI from these flows. Coordinate personnel responsible for change management and the finance division."@en,
        "制定新设岗位的财务投入计划；明确组织愿为新岗位配置的资本规模、融资方式及投资回报构成；协同变革管理负责人与财务部门共同推进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.2.9" ;
    skos:prefLabel "Identify budget/roles"@en,
        "明确预算与角色配置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.4.3> ;
    skos:definition "Kindling an organization wide commitment for effectuating the change. Effectively communicate the advantages of the desired change. Personalize the pitch for change."@en,
        "激发全员对变革的认同与承诺；清晰传达预期变革带来的优势；针对不同受众定制化宣导内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3.1" ;
    skos:prefLabel "Create commitment for improvement/change"@en,
        "制定改进/变更承诺"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.4.3> ;
    skos:definition "Restructuring, redesigning, repurposing, and/or retrofitting existing business processes, activities, and frameworks in order to effectuate the desired change. Review pertinent processes from the ground up by starting with the desired result. (Build on Select a process improvement methodology [11138] to create business processes that perfectly fit with the road map for change.)"@en,
        "重构、重新设计、调整用途或改造现有业务流程、活动及框架，以推动预期变革落地；以期望结果为起点，自下而上全面审视相关流程；（依托「选择一种流程改进方法论 [11138]」，构建与变革路线图高度契合的业务流程。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3.2" ;
    skos:prefLabel "Reengineer business processes and systems"@en,
        "重构业务流程与系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.4.3> ;
    skos:definition "Supporting the transition of personnel to new roles and the dismissal of any existing employees, necessitated for the desired change. Create an on-boarding process for seamlessly transitioning personnel to new roles. Offer orientation and training. Address any concerns. Create a structured procedure for the discharge of incumbents from their positions."@en,
        "支持人员向新岗位平稳过渡，并依变革需要规范开展人员退出工作；建立无缝衔接的入职流程；提供岗前引导与专项培训；及时回应各类疑虑；制定结构化的在岗人员退出机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3.3" ;
    skos:prefLabel "Support transition to new roles or exit strategies for incumbents"@en,
        "支持岗位转型或在任者退出安排"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.4.3> ;
    skos:definition "Monitoring activities in the change process in order to assess the performance of individual agents and the process as a whole. Oversee the implementation of activities needed for effectuating the change. Track the pace, impact, enthusiasm, reaction, and feedback over the change process."@en,
        "监控变革过程中的各项活动，评估个体执行者及整体流程绩效；督导变革所需各项活动的实施；跟踪变革进程中的推进节奏、影响程度、员工热情度、响应情况及反馈意见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3.4" ;
    skos:prefLabel "Monitor change"@en,
        "监控变更"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.4.3> ;
    skos:definition "Reporting on the outcome of the change. Document changes and the impact those changes had on critical assets. Share findings with those within the target audience: those impacted by the change, change champions, stakeholders, etc."@en,
        "汇报变革成果；记录所实施的变更及其对关键资产的影响；面向目标受众（包括受变革影响人员、变革倡导者、利益相关方等）共享分析结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.3.5" ;
    skos:prefLabel "Report on change"@en,
        "报告变更情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.4.4> ;
    skos:definition "Monitoring the performance of improved business processes. Track the key performance indicators of the upgraded processes in order to gauge its contribution to the desired change. Expedite through the use of business process management software."@en,
        "监测优化后业务流程的运行绩效；跟踪升级流程的关键绩效指标（KPI），评估其对预期变革的贡献度；借助业务流程管理（BPM）软件提升监测效率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.4.1" ;
    skos:prefLabel "Monitor improved process performance"@en,
        "监控优化后流程的绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.4.4> ;
    skos:definition "Documenting and standardizing insights gleaned and the knowledge acquired from studying the change process already implemented. Create case studies/best practices guides from the process of implementing change. Include experienced personnel."@en,
        "系统化沉淀并标准化变革实施过程中获取的洞见与知识；基于变革实践编制案例集与最佳实践指南；纳入具备实战经验的人员参与编写。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.4.2" ;
    skos:prefLabel "Capture and reuse lessons learned from change process"@en,
        "沉淀并复用变更过程中的经验教训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.4.4> ;
    skos:definition "Implement corrective action to adjust the re-engineered processes for maximizing the desired impact. Adjust business processes and systems to implement the desired change."@en,
        "实施纠偏措施，动态调优再造后的业务流程，以最大化预期成效；同步调整业务流程与支撑系统，确保变革意图全面落地。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.4.3" ;
    skos:prefLabel "Take corrective action as necessary"@en,
        "视需采取纠正措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Organizational Change Management" ;
    skos:broader <https://oprocess.net/opf/node/13.4.5> ;
    skos:definition "Activity within ITIL practice 'Organizational Change Management'."@en,
        "ITIL「组织变革管理」实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.5.1" ;
    skos:prefLabel "Assess change readiness"@en,
        "评估变革准备度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Organizational Change Management" ;
    skos:broader <https://oprocess.net/opf/node/13.4.5> ;
    skos:definition "Activity within ITIL practice 'Organizational Change Management'."@en,
        "ITIL「组织变革管理」实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.5.2" ;
    skos:prefLabel "Plan organizational changes"@en,
        "规划组织变革"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Organizational Change Management" ;
    skos:broader <https://oprocess.net/opf/node/13.4.5> ;
    skos:definition "Activity within ITIL practice 'Organizational Change Management'."@en,
        "ITIL「组织变革管理」实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.5.3" ;
    skos:prefLabel "Manage stakeholder engagement"@en,
        "管理相关方参与"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Developing a structure for the governance of the organization's collective knowledge. Gather, maintain, and make accessible the collective knowledge base. Develop a standard procedure for the conservation and perpetuation of the organization's knowledge. Create policies for the usage and maintenance of this knowledge. Establish specialized roles."@en,
        "构建组织集体知识治理架构；统筹开展知识的采集、维护与开放共享；制定知识保全与传承的标准规程；明确知识使用与维护政策；设立专业化知识管理角色。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.1" ;
    skos:prefLabel "Develop governance model with roles and accountability"@en,
        "建立含角色与责任的治理模式"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Clearly determining the roles and responsibilities of all personnel involved in the management of the organization's corpus of knowledge. Flesh out the roles and responsibilities of the KM core group, as well as the operational staff involved in the upkeep of the knowledge management program."@en,
        "清晰界定所有参与知识管理工作的人员职责；细化知识管理核心团队及日常运维人员的具体角色与责任。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.2" ;
    skos:prefLabel "Define roles and accountability of core group versus operating units"@en,
        "明确核心团队与运营单元的角色与责任划分"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Analyze the organization's current approach to funding. Learn from the funding approaches of peer organizations. Evaluate the revenue potential and costs of those short-list funding models. Select funding models to implement."@en,
        "分析组织当前知识管理投入模式；借鉴同业组织的筹资机制；评估候选筹资模式的收益潜力与实施成本；选定并落地适配的筹资方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.3" ;
    skos:prefLabel "Develop funding models"@en,
        "设计资金投入模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Identifying any links that exist between the strategy for knowledge management and any other functional areas. Determine any correlations that exist between the strategic road map for the knowledge management and any other functional areas. Study each function's/unit's attributes."@en,
        "识别知识管理战略与其他职能领域的关联关系；研判知识管理战略路线图与各职能/业务单元之间的协同点；深入分析各职能/单元的特性与需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.4" ;
    skos:prefLabel "Identify links to key initiatives"@en,
        "识别与关键举措的关联关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Creating core knowledge management procedures and methodologies. Initiate developing a strategy, planning, execution, and improvement."@en,
        "构建核心知识管理流程与方法论体系；覆盖战略制定、规划、执行与持续改进全周期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.5" ;
    skos:prefLabel "Develop core KM methodologies"@en,
        "开发核心知识管理方法论"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.6" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Determining the IT needs for developing the knowledge management strategy, and collaborating with the IT function to implement the strategy. Assess requirements for technologies such as computer hardware, software, electronics, semiconductors, internet, and telecommunications equipment in order to effectively build and implement the strategy for knowledge management."@en,
        "明确知识管理战略落地所需的IT支撑需求，协同信息技术（IT）职能共同实施；评估计算机硬件、软件、电子设备、半导体、互联网及电信设备等技术资源需求，保障知识管理战略高效构建与部署。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.6" ;
    skos:prefLabel "Assess IT needs and engage IT function"@en,
        "评估信息技术（IT）需求并协同IT职能"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.7" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Creating plans for KM training plans and conveying the knowledge management strategy within the organization. Create training programs, sessions, and activities in order to familiarize employees and management with the concept of knowledge management."@en,
        "制定知识管理内部宣贯与培训计划；设计培训课程、专题研讨及互动活动，帮助员工与管理层深入理解知识管理理念与价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.7" ;
    skos:prefLabel "Develop training and communication plans"@en,
        "制定培训与沟通计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.8" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Creating approaches for effectively administering the changes in knowledge management. Design an approach that transforms individuals, teams, and the organization to a desired future state represented by the change."@en,
        "构建知识管理变革的有效推行路径；设计覆盖个体、团队及组织层级的转型方案，推动整体迈向知识驱动的未来状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.8" ;
    skos:prefLabel "Develop change management approaches"@en,
        "制定变革管理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.1.9" ;
    skos:broader <https://oprocess.net/opf/node/13.5.1> ;
    skos:definition "Establishing measures and indicators for evaluating the performance of the knowledge management function. Define key performance indicators such as the amount of knowledge assets created and number of knowledge projects undertaken."@en,
        "建立知识管理职能绩效评估指标体系；定义关键绩效指标（KPI），如知识资产新增数量、知识项目启动数量等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.1.9" ;
    skos:prefLabel "Develop strategic measures and indicators"@en,
        "制定战略性衡量指标与监测指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.5.2> ;
    skos:definition "Evaluating if initiatives are effective or should be discarded. Design a framework for assessing maturity, typically from Level 1 (undefined), Level 2 (repeatable), Level 3 (defined), and Level 4 (managed) through Level 5 (optimized)."@en,
        "评估现有举措有效性，决定保留或终止；构建典型成熟度评估框架，通常涵盖第1级（未定义）、第2级（可重复）、第3级（已定义）、第4级（已管理）至第5级（已优化）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.2.1" ;
    skos:prefLabel "Assess maturity of existing KM initiatives"@en,
        "评估现有知识管理举措的成熟度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.5.2> ;
    skos:definition "Evaluating existing procedures, policies, and guidelines for knowledge management. Study and examine the organization's approach against industry best practices by benchmarking, competitive analysis, etc."@en,
        "评估现行知识管理政策、流程与指南；通过标杆比对、竞品分析等方式，将组织实践与行业最佳实践进行对照分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.2.2" ;
    skos:prefLabel "Evaluate existing KM approaches"@en,
        "评估现有知识管理方法的有效性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.5.2> ;
    skos:definition "Assessing the KM approach evaluations in order to identify any gaps or needs. Compare the performance of the KM approach against the desired or expected performance, as well as against the standard knowledge management industry approach."@en,
        "基于知识管理方法评估结果，识别能力缺口与改进需求；将实际绩效与预期目标、行业标准知识管理方法进行多维度对标分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.2.3" ;
    skos:prefLabel "Identify gaps and needs"@en,
        "识别能力差距与需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Designing new policies, procedures, and guidelines to support knowledge management."@en,
        "制定支撑知识管理的新政策、流程与指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.1" ;
    skos:prefLabel "Develop new KM approaches"@en,
        "开发新型知识管理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Creating a model to describe resources and approaches to organization's knowledge management. Establish standards and guidelines to be followed."@en,
        "构建组织知识管理资源与方法模型；确立统一遵循的标准与实施指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.2" ;
    skos:prefLabel "Design resource model for KM approaches"@en,
        "设计知识管理方法的资源投入模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Implementing new policies, procedures, and guidelines to support knowledge management."@en,
        "落地执行支撑知识管理的新政策、流程与指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.3" ;
    skos:prefLabel "Implement new KM approaches"@en,
        "实施新型知识管理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Using existing technologies to improve organization's knowledge management processes. Research available third-party offerings. Develop proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel."@en,
        "利用现有技术手段提升知识管理效能；调研第三方成熟解决方案；自主研发定制化工具；配备知识工程师、数据科学家等相关专业人员。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.4" ;
    skos:prefLabel "Leverage and enhance IT for KM approaches"@en,
        "依托并增强信息技术（IT）支撑知识管理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.5.3> ;
    skos:definition "Creating metrics that can be used to systematically describe KM approaches and capabilities. Choose applicable scales, benchmarks and units of measure. Determine required precision and error rates."@en,
        "构建可量化描述知识管理方法与能力的指标体系；选取适用的量纲、基准值与计量单位；明确所需精度与容许误差范围。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.3.5" ;
    skos:prefLabel "Develop measures"@en,
        "制定衡量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.5.4> ;
    skos:definition "Leveraging KM evaluations and identified gap to enhance existing approaches."@en,
        "依托知识管理评估结果与识别的能力缺口，持续优化现有知识管理方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.4.1" ;
    skos:prefLabel "Enhance/Modify existing KM approaches"@en,
        "优化或调整现有知识管理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.5.4> ;
    skos:definition "Developing awareness about available knowledge bases and promoting their use to maximize their impact."@en,
        "提升组织内对现有知识库的认知度，积极推广使用，最大化知识资产价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.4.2" ;
    skos:prefLabel "Sustain awareness and engagement"@en,
        "持续提升认知度与参与度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.5.4> ;
    skos:definition "Augmenting available resources to better leverage the offerings of the organization to serve existing clients and to expand the client base."@en,
        "扩充知识管理资源，更好赋能现有客户服务，并拓展新客户群体。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.4.3" ;
    skos:prefLabel "Expand KM infrastructure to meet demand"@en,
        "扩展知识管理基础设施以满足业务增长需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Knowledge Management" ;
    skos:broader <https://oprocess.net/opf/node/13.5.5> ;
    skos:definition "Activity within ITIL practice 'Knowledge Management'."@en,
        "ITIL「知识管理」实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.5.1" ;
    skos:prefLabel "Capture and share knowledge"@en,
        "知识的捕获与共享"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Knowledge Management" ;
    skos:broader <https://oprocess.net/opf/node/13.5.5> ;
    skos:definition "Activity within ITIL practice 'Knowledge Management'."@en,
        "ITIL知识管理（Knowledge Management）实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.5.2" ;
    skos:prefLabel "Maintain knowledge base"@en,
        "维护知识库"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.5.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Knowledge Management" ;
    skos:broader <https://oprocess.net/opf/node/13.5.5> ;
    skos:definition "Activity within ITIL practice 'Knowledge Management'."@en,
        "ITIL知识管理（Knowledge Management）实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.5.3" ;
    skos:prefLabel "Improve knowledge practices"@en,
        "优化知识管理实践"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Establishing objectives for content management that enhance the organization and accessibility of enterprise content. Objectives can include curation, findability, consistency, user-centric design, lifecycle management, governance and roles, quality assurance, and measurement and evaluation."@en,
        "设定提升企业内容组织性与可访问性的内容管理目标，包括策展、可发现性、一致性、以用户为中心的设计、全生命周期管理、治理与角色分工、质量保证，以及度量与评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.1" ;
    skos:prefLabel "Establish content management objectives"@en,
        "确立内容管理目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Establishing a structured framework with roles and responsibilities to oversee and guide content management practices within an organization to ensure content is managed consistently, remains high-quality, meets the needs of users, and enhances the overall content management strategy."@en,
        "构建含明确角色与职责的结构化框架，统筹指导组织内内容管理实践，确保内容管理的一致性、高质量、用户适配性，并强化整体内容管理战略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.2" ;
    skos:prefLabel "Develop content management governance model"@en,
        "构建内容管理治理模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Defining funding approaches for content management activities, capabilities, and infrastructure to support sustainable operations, investment prioritization, and alignment with organizational objectives."@en,
        "明确内容管理活动、能力及基础设施的资金投入方式，以支撑可持续运营、投资优先级排序及与组织目标的对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.3" ;
    skos:prefLabel "Develop content management funding models"@en,
        "制定内容管理资金投入模式"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Identifying and implementing content management methodologies to effectively store, deliver, and facilitate access to enterprise content. Core methodologies may include prioritization of critical or high-value content, findability to ensure ease of locating relevant content, content lifecycle management, standardization of content creation, review and access, collaboration, and technology integration."@en,
        "识别并实施内容管理方法论，高效实现企业内容的存储、交付与访问支持；核心方法包括：关键或高价值内容优先管理、提升可发现性、内容全生命周期管理、内容创建/评审/访问标准化、协同协作及技术集成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.4" ;
    skos:prefLabel "Develop core content management methodologies"@en,
        "建立核心内容管理方法论"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Assessing technology requirements for content management and collaborating with the IT function to align systems, integration, security, and support with content management needs. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "评估内容管理的技术需求，协同信息技术（IT）职能，确保系统、集成、安全与支持能力与内容管理需求对齐；包括应用人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.5" ;
    skos:prefLabel "Assess content management IT needs and engage IT function"@en,
        "评估内容管理信息技术（IT）需求并协同IT部门"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.6" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Developing training, change and communication plans to support the organization's content management practices. Define target audiences, required competencies, learning objectives, and delivery methods to ensure consistent understanding and adoption of content standards, tools, and workflows. Create communication strategies to promote awareness of content governance, reinforce expectations, and inform stakeholders of process updates, system changes, and best practices. Coordinate with internal partners to design training materials, schedule learning sessions, and disseminate communications that enable effective and compliant content creation, storage, use, and lifecycle management. Monitor participation, evaluate effectiveness, and continuously improve based on feedback and evolving organizational needs."@en,
        "制定培训、变革与沟通计划，支撑组织内容管理实践；明确目标受众、所需胜任力、学习目标与交付方式，确保内容标准、工具与工作流的统一理解与落地；制定沟通策略，提升内容治理认知度、强化各方预期，并及时向利益相关方通报流程更新、系统变更与最佳实践；协同内部伙伴设计培训材料、安排学习活动、发布沟通信息，推动内容创建、存储、使用与全生命周期管理的有效性与合规性；监测参与情况、评估成效，并基于反馈与组织演进需求持续优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.6" ;
    skos:prefLabel "Develop content management training and communication plans"@en,
        "制定内容管理培训与沟通计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.7" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Defining and implementing performance measures to assess the effectiveness and strategic value of content management practices. Align indicators with organizational goals, governance requirements, and user needs. Specify data sources, measurement methods, and reporting cadences to provide reliable insight into content quality, accessibility, utilization, and lifecycle compliance. Collaborate with stakeholders to validate metric definitions, integrate measures into dashboards, and set expectations for monitoring and improvement. Periodically review and refine measures in response to changing priorities and requirements."@en,
        "定义并实施绩效度量指标，评估内容管理实践的有效性与战略价值；指标需与组织目标、治理要求及用户需求对齐；明确数据来源、测量方法与报告周期，为内容质量、可访问性、使用率及生命周期合规性提供可靠洞察；协同利益相关方验证指标定义，将度量纳入仪表盘，并设定监控与改进预期；定期审视并根据优先级与需求变化优化指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.7" ;
    skos:prefLabel "Develop strategic measures and indicators for content management"@en,
        "设定内容管理战略性度量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.1.8" ;
    skos:broader <https://oprocess.net/opf/node/13.6.1> ;
    skos:definition "Monitor and analyze content ecosystem performance to understand search behavior, user intent, knowledge gaps, content effectiveness, and content lifecycle health. Use content usage patterns and derived insights to identify emerging needs, anticipate gaps, recommend updates or new content, and continuously optimize the relevance, quality, and accessibility of the content ecosystem. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)"@en,
        "监测与分析内容生态绩效，理解搜索行为、用户意图、知识缺口、内容有效性及内容生命周期健康度；基于内容使用模式与衍生洞察，识别新兴需求、预判缺口、推荐内容更新或新增，持续优化内容生态的相关性、质量与可访问性；包括应用人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.1.8" ;
    skos:prefLabel "Manage content intelligence and insights"@en,
        "管理内容智能与洞察"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Identifying functional, operational, governance, and compliance requirements that content management practices and solutions must satisfy across the organization."@en,
        "识别内容管理实践与解决方案在全组织范围内需满足的功能性、运营性、治理性与合规性要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.1" ;
    skos:prefLabel "Determine content management requirements"@en,
        "明确内容管理需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Establishing content metadata structures that function as a common classification language by defining hierarchical categories and attributes used to organize and relate content, ensuring consistency across formats, business areas, and locations and supporting discoverability and semantic enrichment."@en,
        "构建内容元数据结构，作为通用分类语言，通过定义层级化类别与属性实现内容组织与关联，确保跨格式、跨业务领域及跨地域的一致性，并支撑可发现性与语义增强。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.2" ;
    skos:prefLabel "Define content taxonomies"@en,
        "定义内容分类体系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.2> ;
    skos:definition "Defining standardized conventions for naming, versioning, and tagging digital files and content assets to support consistency, findability, and compliance across the organization. Establish required metadata elements and tagging structures aligned with enterprise taxonomies, information architecture, and regulatory or operational needs."@en,
        "制定数字文件与内容资产的命名、版本控制与打标标准化规范，以保障组织内的一致性、可发现性与合规性；明确必需的元数据要素与打标结构，并与企业分类体系、信息架构及监管或运营需求保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2.3" ;
    skos:prefLabel "Define file naming standards and tagging requirements"@en,
        "制定文件命名规范与标签要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.3> ;
    skos:definition "Defining rules and permissions that govern who can create, view, modify, and distribute content to protect sensitive information and support appropriate access."@en,
        "制定内容创建、查看、修改与分发的权限规则，以保护敏感信息并支持恰当访问控制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.3.1" ;
    skos:prefLabel "Define content access controls"@en,
        "设定内容访问控制策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.3> ;
    skos:definition "Establishing audit and retention requirements to ensure content is reviewed, retained, archived, or disposed of in accordance with governance, legal, and operational obligations."@en,
        "建立审计与留存要求，确保内容按治理、法律及运营义务开展评审、留存、归档或处置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.3.2" ;
    skos:prefLabel "Develop content audit and retention requirements"@en,
        "制定内容审计与保留要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Establishing and maintaining content repositories and systems of record to support secure storage, organization, access, and lifecycle management."@en,
        "建设并维护内容知识库与权威数据源，支撑内容的安全存储、组织、访问与全生命周期管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.1" ;
    skos:prefLabel "Set up and maintain systems of record and storage locations"@en,
        "部署并维护权威系统与存储位置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Executing administrative activities required to manage content systems, permissions, structures, and configurations in accordance with defined standards and governance."@en,
        "执行内容系统管理所需的行政活动，包括权限、结构与配置管理，严格遵循既定标准与治理要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.2" ;
    skos:prefLabel "Implement and execute content administration responsibilities"@en,
        "落实并执行内容管理职责"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Overseeing activities to verify that content complies with established standards, policies, and requirements across its lifecycle."@en,
        "监督内容在其全生命周期中对既定标准、政策与要求的符合性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.3" ;
    skos:prefLabel "Audit content compliance"@en,
        "开展内容合规性审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.4" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Planning content audits by defining scope, criteria, timing, and responsibilities to assess compliance and effectiveness of content management practices."@en,
        "规划内容审计，明确范围、标准、时间安排与责任分工，以评估内容管理实践的合规性与有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.4" ;
    skos:prefLabel "Plan content audits"@en,
        "规划内容审计工作"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.5" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Conducting reviews of content to evaluate compliance with defined standards, controls, and retention requirements. Includes auditing for semantic accuracy, metadata completeness, and AI-readiness. Consider leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "开展内容审查，评估其对既定标准、管控措施与留存要求的符合性；包括语义准确性、元数据完整性及AI就绪度审计；可借助人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.5" ;
    skos:prefLabel "Perform content audits"@en,
        "执行内容审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.4.6" ;
    skos:broader <https://oprocess.net/opf/node/13.6.4> ;
    skos:definition "Tracking identified content non-compliance issues and monitoring corrective actions to ensure timely resolution and adherence to content standards."@en,
        "跟踪已识别的内容不合规问题，并监控整改行动，确保及时闭环与标准遵从。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.4.6" ;
    skos:prefLabel "Track content non-compliance resolution"@en,
        "跟踪内容不合规项整改情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Identifying content needs and existing content assets to support reuse, updates, and alignment with organizational requirements."@en,
        "识别内容需求与现有内容资产，以支持复用、更新及与组织要求的对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.1" ;
    skos:prefLabel "Identify new and existing content"@en,
        "识别新增及存量内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Identifying control requirements for content, including review, approval, access, and compliance needs across the content lifecycle."@en,
        "识别内容全生命周期内的管控要求，包括评审、审批、访问与合规需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.2" ;
    skos:prefLabel "Identify content control requirements"@en,
        "识别内容管控要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Preparing newly created content for use by applying required standards, structure, and controls prior to review and approval."@en,
        "对新创建内容应用必要标准、结构与管控措施，完成前置准备后进入评审与审批环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.3" ;
    skos:prefLabel "Prepare created content"@en,
        "完成原创内容编制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.4" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Preparing externally sourced or acquired content for organizational use by validating quality, applying standards, and aligning it with governance requirements."@en,
        "对外部引入或采购的内容进行质量验证，应用组织标准并对其治理要求进行对齐，以适配组织使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.4" ;
    skos:prefLabel "Prepare acquired content"@en,
        "完成采购内容整合"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.5" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Refining content to improve clarity, accuracy, consistency, and quality for its existing intended purpose and audience. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "优化内容以提升其清晰度、准确性、一致性与质量，适配既有目标用途与受众；包括应用人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.5" ;
    skos:prefLabel "Refine content"@en,
        "优化内容质量"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.6" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Enhancing and adapting content to support new or different audiences, formats, channels, or contexts while preserving core meaning and intent of the original content. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "增强与适配内容以支持新受众、新格式、新渠道或新场景，同时保留原始内容的核心含义与意图；包括应用人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.6" ;
    skos:prefLabel "Enhance and adapt content"@en,
        "增强并适配内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.7" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Applying branding elements and standards to content to ensure consistent identity, presentation, and alignment with organizational guidelines."@en,
        "为内容应用品牌元素与标准，确保身份统一、呈现一致，并符合组织指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.7" ;
    skos:prefLabel "Perform content branding"@en,
        "实施内容品牌化"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.5.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.5.8" ;
    skos:broader <https://oprocess.net/opf/node/13.6.5> ;
    skos:definition "Performing technical edits to ensure content meets formatting, accessibility, usability, and technical quality requirements. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "开展技术编辑，确保内容满足格式、可访问性、可用性与技术质量要求；包括应用人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.5.8" ;
    skos:prefLabel "Execute technical edits on content"@en,
        "执行内容技术性编辑"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.6.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.6> ;
    skos:definition "Reviewing content to confirm accuracy, quality, compliance, and readiness prior to approval for distribution or use."@en,
        "审核内容，确认其准确性、质量、合规性及发布就绪状态，方可批准分发或使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.6.1" ;
    skos:prefLabel "Assess and approve content"@en,
        "评估与审批内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.6.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.6> ;
    skos:definition "Publishing approved content to designated locations or channels to make it available to intended users."@en,
        "将已批准内容发布至指定位置或渠道，供目标用户使用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.6.2" ;
    skos:prefLabel "Publish approved content"@en,
        "发布已审批内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.6.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.6> ;
    skos:definition "Storing approved content in designated repositories to support controlled access, retrieval, and lifecycle management."@en,
        "将已批准内容存入指定知识库，以支持受控访问、检索与全生命周期管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.6.3" ;
    skos:prefLabel "Store approved content"@en,
        "归档已审批内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.7.1" ;
    skos:broader <https://oprocess.net/opf/node/13.6.7> ;
    skos:definition "Evaluating content usage, effectiveness, and relevance to inform updates, improvements, or retirement decisions."@en,
        "评估内容的使用情况、有效性及与业务目标的相关性，以支撑内容更新、优化或下线决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.7.1" ;
    skos:prefLabel "Evaluate content"@en,
        "评估内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.7.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6.7> ;
    skos:definition "Archiving content that is no longer actively used but must be retained to meet governance, legal, or historical requirements."@en,
        "归档不再活跃使用但须依据治理、法律或历史要求予以保留的内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.7.2" ;
    skos:prefLabel "Archive content"@en,
        "归档内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.6.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.7.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6.7> ;
    skos:definition "Deleting content that has reached the end of its retention period and is no longer required, in accordance with defined policies and controls."@en,
        "依据既定政策与管控要求，在内容达到保留期限且无继续留存必要时予以删除。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.7.3" ;
    skos:prefLabel "Delete content"@en,
        "删除内容"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.7.1> ;
    skos:definition "Developing a model for organization's management systems. Develop a high-level measurement system to track performance across the enterprise or in specific functions or business units. Determine which processes to measure, which measures to use, how often to measure, and measurement targets. Review strategic decisions about how to best measure an organization."@en,
        "构建组织管理体系的度量模型：设计高层级度量体系，用于跟踪企业整体或特定职能/业务单元的绩效；明确需度量的流程、选用的指标、度量频次及目标值；复审关于组织最优度量方式的战略决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.1.1" ;
    skos:prefLabel "Define enterprise measurement models"@en,
        "定义企业度量模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.7.1> ;
    skos:definition "Reviewing, evaluating, and updating enterprise measurement models. Align measurement models to current and future goals and performance targets, and make adjustments to support visibility and reporting needs across the organization."@en,
        "评审、评估并更新企业级度量模型：使模型与当前及未来战略目标、绩效目标保持一致，并调整以满足全组织范围内的可视性与报告需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.1.2" ;
    skos:prefLabel "Maintain enterprise measurement models"@en,
        "维护企业度量模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.7.2> ;
    skos:definition "Measuring, researching, and recording the performance of people, processes, mechanisms, or other areas of the business that the organization wants to benchmark or track."@en,
        "对人员、流程、机制或其他组织关注领域开展绩效度量、调研与记录，以支持基准比对或持续跟踪。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2.1" ;
    skos:prefLabel "Conduct performance assessments"@en,
        "开展绩效评估"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.7.2> ;
    skos:definition "Improving an organization's ability to compare its performance internally or externally, and maintaining benchmarking relationships with other organizations. Train staff in benchmarking. Develop technological solutions or other materials to aid benchmarking efforts. Consult with external entities to gain knowledge or tools to help benchmark."@en,
        "提升组织内外部绩效比对能力，维系与其他组织的基准比对合作关系；开展基准比对培训；开发技术解决方案或辅助材料以支持比对工作；联合外部机构获取知识或工具以增强比对能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2.2" ;
    skos:prefLabel "Develop benchmarking capabilities"@en,
        "构建对标能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.7.2> ;
    skos:definition "Benchmarking internal processes and against external competitors."@en,
        "开展内部流程基准比对，并与外部竞争对手对标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2.3" ;
    skos:prefLabel "Conduct internal and external benchmarking"@en,
        "开展内外部对标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2.4" ;
    skos:broader <https://oprocess.net/opf/node/13.7.2> ;
    skos:definition "Examining performance against benchmarked organizations or entities. Determine how much performance needs to change to meet expectations. Reach strategic goals."@en,
        "对照标杆组织或实体评估绩效表现；识别绩效差距，明确为达成预期需改进的程度；支撑战略目标实现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2.4" ;
    skos:prefLabel "Conduct gap analysis"@en,
        "开展差距分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.2.5" ;
    skos:broader <https://oprocess.net/opf/node/13.7.2> ;
    skos:definition "Establishing a need for changing the performance of the organization. Make use of the gap analysis results in order to define the need for change."@en,
        "识别组织绩效改进需求，基于差距分析结果界定变革必要性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.2.5" ;
    skos:prefLabel "Establish need for change"@en,
        "识别变革需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Designing key measures that analyze and interpret how effectively the business is achieving its objectives."@en,
        "设计关键绩效指标（KPI），用以分析和解读业务目标达成的有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.1" ;
    skos:prefLabel "Establish performance indicators (measures)"@en,
        "建立绩效指标（度量项）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Deciding on the appropriate amount of supervisions that are needed to effectively assess the performance of business plans."@en,
        "确定有效评估业务计划执行绩效所需的监督频次与强度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.2" ;
    skos:prefLabel "Establish monitoring frequency"@en,
        "确定监测频率"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Consolidating acquired metrics and trends. Provide data that can be benchmarked against historical data."@en,
        "整合采集的度量指标与趋势数据，提供可与历史数据进行比对的基准数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.3" ;
    skos:prefLabel "Collect performance data"@en,
        "采集绩效数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Measuring the performance of process planning. Quantify the performance, record results of the performance tests, and report them to the appropriate authority."@en,
        "度量流程规划绩效：量化绩效表现，记录测试结果，并向相关责任主体报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.4" ;
    skos:prefLabel "Calculate performance measures"@en,
        "计算绩效度量值"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Recognizing the trends in performance. Carefully and strategically assess the results in order to effectively spot the trends."@en,
        "识别绩效趋势：系统、战略性地评估结果，精准识别发展趋势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.5" ;
    skos:prefLabel "Identify performance trends"@en,
        "识别绩效趋势"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.6" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Evaluating the gaps between achieved and benchmarked performance. Analyze how performance differs from the optimal or expected performance."@en,
        "评估实际绩效与标杆绩效之间的差距，分析绩效偏离最优或预期水平的程度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.6" ;
    skos:prefLabel "Analyze performance"@en,
        "分析绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.7" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Creating reports that systematically record and represent the performance planning. Construct a detailed report specifying the performance, and include indicators such as the performance gaps, performance trends, and analysis."@en,
        "编制结构化绩效规划报告：详细呈现绩效表现，并包含绩效差距、绩效趋势及分析结论等关键指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.7" ;
    skos:prefLabel "Prepare performance reports"@en,
        "编制绩效报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.3.8" ;
    skos:broader <https://oprocess.net/opf/node/13.7.3> ;
    skos:definition "Using performance indicators to report, analyze, and create a detailed performance improvement plan to bridge the performance gaps."@en,
        "运用绩效指标开展报告、分析，并制定详尽的绩效改进计划，以弥合绩效差距。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.3.8" ;
    skos:prefLabel "Develop performance improvement plan"@en,
        "制定绩效改进计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Measurement and Reporting" ;
    skos:broader <https://oprocess.net/opf/node/13.7.4> ;
    skos:definition "Activity within ITIL practice 'Measurement and Reporting'."@en,
        "ITIL 度量与报告实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.4.1" ;
    skos:prefLabel "Define KPI frameworks"@en,
        "定义KPI框架"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Measurement and Reporting" ;
    skos:broader <https://oprocess.net/opf/node/13.7.4> ;
    skos:definition "Activity within ITIL practice 'Measurement and Reporting'."@en,
        "ITIL 度量与报告实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.4.2" ;
    skos:prefLabel "Collect and analyze metrics"@en,
        "采集并分析指标数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Measurement and Reporting" ;
    skos:broader <https://oprocess.net/opf/node/13.7.4> ;
    skos:definition "Activity within ITIL practice 'Measurement and Reporting'."@en,
        "ITIL 度量与报告实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.4.3" ;
    skos:prefLabel "Generate management reports"@en,
        "生成管理报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.1" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Gathering information from stakeholders prior to conducting analytics."@en,
        "开展分析前，面向相关方收集需求与背景信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.1" ;
    skos:prefLabel "Identify needs from stakeholders"@en,
        "识别干系人需求"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.10" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Summarizing and documenting the results of data analysis. Create graphs and visualizations to illustrate numerical findings to make them more accessible to readers."@en,
        "汇总并文档化数据分析结果；制作图表与可视化呈现，提升数值发现的可读性与可理解性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.10" ;
    skos:prefLabel "Report on analysis"@en,
        "输出分析报告"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.11" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Determining the steps that need to be taken to correct the shortcomings."@en,
        "明确弥补现存短板所需采取的具体改进步骤。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.11" ;
    skos:prefLabel "Identify remedial actions"@en,
        "识别整改行动"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.2" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Determining the size and scale of the project based upon the collected information and analytics."@en,
        "基于所收集信息与分析需求，确定项目规模与实施范围。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.2" ;
    skos:prefLabel "Scope analytics project"@en,
        "界定分析项目范围"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.3" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Creating theories that explain empirical data. Use the hypotheses to guide feature selection in the process of data collection."@en,
        "构建解释实证数据的理论假设，并以此指导数据采集过程中的特征选择。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.3" ;
    skos:prefLabel "Develop and manage hypotheses"@en,
        "构建并管理分析假设"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.4" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Gathering and harvesting structured and unstructured data from disparate sources. Clean and pre-process data. Remove duplicates. Convert to a uniform format to make records comparable."@en,
        "从异构来源采集与汇聚结构化及非结构化数据；清洗与预处理数据；剔除重复记录；统一数据格式以确保可比性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.4" ;
    skos:prefLabel "Collect data"@en,
        "采集数据"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.5" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Creation and validation of data in order to initiate the process of analysis."@en,
        "完成数据创建与验证，启动分析流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.5" ;
    skos:prefLabel "Prepare data"@en,
        "准备数据"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.6" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Conducting data analysis. Choose statistical algorithms that best reveal patterns and trends in the data. Compare with hypotheses and time series forecasts. Determine error rates and significant outliers."@en,
        "开展数据分析：选用最能揭示数据模式与趋势的统计算法；对照假设与时间序列预测结果；识别误差率与显著异常值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.6" ;
    skos:prefLabel "Analyze data"@en,
        "分析数据"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.7" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Creation of conceptual and physical data models as an outline for data structure and storage."@en,
        "构建概念模型与物理数据模型，作为数据结构与存储的设计蓝图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.7" ;
    skos:prefLabel "Create data models"@en,
        "构建数据模型"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.8" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Confirm data models represent the hypothesis supporting the original research question"@en,
        "确认数据模型能够有效支撑原始研究问题所对应的假设。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.8" ;
    skos:prefLabel "Review data models with stakeholders"@en,
        "与干系人评审数据模型"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.8.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.8.9" ;
    skos:broader <https://oprocess.net/opf/node/13.8> ;
    skos:definition "Make required changes to data model based upon review with stakeholders."@en,
        "根据与相关方的评审意见，对数据模型进行必要修订。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.8.9" ;
    skos:prefLabel "Refine data models"@en,
        "优化数据模型"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.9.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.9.1> ;
    skos:definition "Evaluating the impact of offerings and the auxiliary operations required to process them on the immediate ecosystem and the environment at large. Study the lifecycle of the products/services offered by the organization. Estimate any affect on the environment through metrics such as a calculation of carbon footprint."@en,
        "评估产品和服务及其配套运营活动对直接生态环境及整体环境的影响；研究组织所提供产品/服务的全生命周期；通过碳足迹测算等指标估算环境影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.1.1" ;
    skos:prefLabel "Evaluate environmental impact of products, services, and operations"@en,
        "评估产品、服务及运营的环境影响"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.9.1> ;
    skos:definition "Conducting an inspection to verify that the organization adequately complies with the environmental, health, and safety standards. Audit procedures and records regarding responsibility for the environment, health, and safety."@en,
        "开展检查，验证组织是否充分符合环境、健康与安全（EHS）标准；审计有关环境、健康与安全责任的流程和记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.1.2" ;
    skos:prefLabel "Conduct health and safety and environmental audits"@en,
        "开展健康安全与环境审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.9.2> ;
    skos:definition "Determining any protocols or standards to comply with, set by regulatory agencies or the organization's stakeholders. Closely examine all standards and matters of compliance relating to the environment, health, and safety."@en,
        "明确监管机构或组织利益相关方所规定的合规协议或标准；全面审查与环境、健康及安全相关的所有标准与合规事项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.2.1" ;
    skos:prefLabel "Identify regulatory and stakeholder requirements"@en,
        "识别法规与利益相关方要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.9.2> ;
    skos:definition "Evaluating any risks and opportunities that might affect the environmental, health, and safety of products/services. Leverage techniques such as cost-benefit analysis, trend extrapolation, systems analysis, social surveys, historical surveys, historical analogy, Delphi, conferences, workshops, briefings, hearings, advisory committees, moot courts, artistic judgment, on-site field investigation, scaling techniques, and scenario creation."@en,
        "评估可能影响产品/服务环境、健康与安全的风险与机遇；运用成本效益分析、趋势外推、系统分析、社会调查、历史调查、历史类比、德尔菲法、研讨会、简报会、听证会、咨询委员会、模拟法庭、专家判断、实地勘察、标度法、情景构建等技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.2.2" ;
    skos:prefLabel "Assess future risks and opportunities"@en,
        "评估未来风险与机遇"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.9.2> ;
    skos:definition "Creating a plan for managing the environmental, health, and safety impact of products/services. Establish minimum requirements for the organization regarding the environment at large and the health and safety of employees. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements."@en,
        "制定管理产品/服务环境、健康与安全影响的计划；确立组织在宏观环境及员工健康与安全方面的最低要求；制定政策、书面程序及配套工具，明确组织落实政策要求的具体方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.2.3" ;
    skos:prefLabel "Create EHS policy"@en,
        "制定环境、健康与安全（EHS）政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.2.4" ;
    skos:broader <https://oprocess.net/opf/node/13.9.2> ;
    skos:definition "Recording and managing all events and activities associated with complying with environmental, health and safety standards. Create event calendars. Assign funds. Educate employees. Conduct events."@en,
        "记录并管理所有与环境、健康与安全（EHS）标准合规相关的事件与活动；编制事件日历；分配资金；开展员工培训；组织实施相关活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.2.4" ;
    skos:prefLabel "Record and manage EHS events"@en,
        "记录并管理环境、健康与安全（EHS）事件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Administering the costs and benefits of EHS management program. Evaluate program costs to ensure that the benefits of the program always outweigh its costs."@en,
        "统筹管理EHS管理项目的成本与收益；评估项目投入，确保其收益始终高于成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.1" ;
    skos:prefLabel "Manage EHS costs and benefits"@en,
        "管理环境、健康与安全（EHS）成本与收益"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Using performance techniques and indicators. Utilize number of audits or inspections performed, safety committee meetings, the number and types of findings and observations, timely preventive maintenance tasks performed, etc."@en,
        "应用绩效技术与指标，例如：已完成的审核或检查次数、安全委员会会议次数、发现项与观察项的数量及类型、按时完成的预防性维护任务数量等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.2" ;
    skos:prefLabel "Measure and report EHS performance"@en,
        "衡量并报告环境、健康与安全（EHS）绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Implementing a program for organizing, coordinating, and directing available resources to respond to the event. Conduct a risk assessment to identify potential emergency scenarios in order to create a program that ensures that resources are on hand--or quickly available--in case of emergencies."@en,
        "实施应急响应资源统筹计划，即组织、协调与调度可用资源以应对突发事件；开展风险评估，识别潜在紧急场景，确保应急资源可即时调用或快速到位。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.3" ;
    skos:prefLabel "Implement emergency response program"@en,
        "实施应急响应计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Implementing a program that reduces or eliminates the creation of pollutants through increased efficiency in the use of raw materials, energy, water, or other resources. Implement a program to inspect facilities that store, manufacture, or use hazardous, toxic, or polluting materials."@en,
        "实施污染预防计划，通过提升原材料、能源、水资源及其他资源利用效率，减少或消除污染物产生；实施针对储存、制造或使用危险、有毒或污染性物料场所的巡检计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.4" ;
    skos:prefLabel "Implement pollution prevention program"@en,
        "实施污染预防计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Conducting programs such as on-the-job training sessions, group training workshops, and online training."@en,
        "开展在岗培训、小组工作坊、在线培训等形式的培训项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.5" ;
    skos:prefLabel "Train and educate functional employees"@en,
        "对职能员工开展环境、健康与安全（EHS）培训与教育"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.9.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.3.6" ;
    skos:broader <https://oprocess.net/opf/node/13.9.3> ;
    skos:definition "Supporting employees in light of the organization's environmental, health, and safety policies and standards. Provide medical insurance, maternity leave, environmental education, training over safety, etc."@en,
        "依据组织环境、健康与安全（EHS）政策与标准为员工提供支持，包括医疗保险、产假、环境教育、安全培训等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.3.6" ;
    skos:prefLabel "Provide EHS support"@en,
        "提供环境、健康与安全（EHS）支持"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Assessing the capabilities and performance of existing products/services, in light of market opportunities. Examine performance of the existing line of products/services, including measures of profitability, penetration, and value delivered. Identify gaps between existing solutions' portfolio or their performance levels, on the one hand, and the current market demand, available technologies, and/or customer expectations, on the other. Consider opportunities in the present market environment and any relation with the performance. Consider input from professional services providers."@en,
        "结合市场机遇，评估现有产品/服务的能力与绩效；考察产品/服务线的整体表现，包括盈利能力、市场渗透率及交付价值等维度；识别现有解决方案组合或其绩效水平与当前市场需求、可用技术及客户期望之间的差距；研判当前市场环境中的机会及其与绩效表现的关联性；参考专业服务提供商的意见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.1" ;
    skos:prefLabel "Evaluate performance of existing products/services against market opportunities"@en,
        "对照市场机会评估现有产品/服务绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Checking the alignment of product/service portfolio, and its individual offerings, with the organization's overall strategy and planning for the development of new or revised solutions. Conduct reality checks on new product/service concepts prior to committing significant investment to ensure that the revamped solutions' portfolio is in line with the overall business strategy, aligns organizational processes for their development, and creates a plan for assimilating these changes in the organization's offerings. Enlist senior management executives."@en,
        "检查产品/服务组合及其各单项产品/服务项目与组织整体战略及新解决方案或修订解决方案开发规划的一致性。在投入重大资金前，对新产品/服务概念开展可行性验证，确保重构后的解决方案组合符合整体业务战略、协同组织内相关开发流程，并制定将这些变更融入组织现有产品/服务项目的实施计划。邀请高管参与。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.2" ;
    skos:prefLabel "Confirm alignment of product/service concepts with business strategy"@en,
        "确认产品/服务概念与业务战略的一致性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Selecting from among the potential new/revised solutions and capitalizing on market opportunities so that they meet the cost and quality prerequisites. Create an index of product/service concepts, and arrange them in order of preference. Base prioritization on adherence to Plan and develop cost and quality targets [10073], and choose options that would comprise the revised solution portfolio."@en,
        "从潜在的新/修订解决方案中遴选最优选项，把握市场机遇，确保其满足成本与质量前提要求。建立产品/服务概念索引，并按优先级排序；优先级设定依据为对「制定并开发成本与质量目标 [10073]」的遵循程度，最终选定构成修订后解决方案组合的具体选项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.3" ;
    skos:prefLabel "Prioritize and select new product/service concepts"@en,
        "优先排序并遴选新产品/服务概念"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Setting prerequisites for the cost of development and quality standards for the new solutions' portfolio and/or its individual offerings. Set targets for the budget and quality standards for the revamped portfolio of solution offerings. Prepare a plan for the outlay required for revising and adding new product/services. Identify intended levels of quality for these, bearing in mind the existing standards of solutions offered by the organization and its competitors. Enlist senior management executives, particularly those responsible for finance and budgeting, product/service design, manufacturing/processing, delivery, and quality control."@en,
        "明确新解决方案组合及/或其各单项产品/服务项目的开发成本前提与质量标准。为重构后的解决方案产品/服务组合设定预算目标与质量标准目标。编制修订及新增产品/服务所需支出的计划。结合组织自身及竞争对手现行解决方案的质量标准，确定拟交付产品/服务的质量预期水平。邀请高管参与，尤其包括财务与预算、产品/服务设计、制造/加工、交付及质量控制等职能领域的负责人。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.4" ;
    skos:prefLabel "Plan and develop cost and quality targets"@en,
        "制定成本与质量目标计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Determining the individual and collective timeframe for realizing new/revised solutions. Create a schedule that clearly demarcates the timeframes designated for the development of every new solution and/or revising each of the existing ones. Create a timetable by setting deadlines for each step in overhauling the product/service portfolio."@en,
        "确定新/修订解决方案的个体及整体实现时限。制定清晰的时间表，明确每项新解决方案开发或现有方案修订的各阶段时间节点；通过为产品/服务组合重构全过程中的每个步骤设定截止日期，形成完整实施日程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.5" ;
    skos:prefLabel "Specify development timing targets"@en,
        "明确产品/服务开发时间节点目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.1.6" ;
    skos:broader <https://oprocess.net/opf/node/2.1.1> ;
    skos:definition "Developing a programmatic procedure for changing products/services while paying heed to all stakeholders involved and the prerequisites identified. Create a plan for changing the existing portfolio of solution offerings. Develop a systematic program for the design, processing, and delivery of the new product/service concepts. Construct project-flow diagrams. Identify the stakeholders involved and personnel responsible for each stage, as well as the necessary decisions. Earmark the budgetary outlay, and conduct any strategic planning required."@en,
        "构建系统化的产品/服务变更程序，兼顾所有相关方及已识别的前提要求。制定现有解决方案组合的变更计划；开发涵盖设计、加工与交付环节的新产品/服务概念系统化实施方案；绘制项目流程图；明确各阶段涉及的相关方与责任人，以及所需的关键决策点；划定预算投入，并开展必要的战略规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.1.6" ;
    skos:prefLabel "Plan for product/service offering modifications"@en,
        "规划产品/服务供给的优化调整"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2> ;
    skos:definition "Developing a program and managing a perspective for new product/service introduction and launch."@en,
        "制定并管理新产品/服务的引入与上市策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.1" ;
    skos:prefLabel "Develop plan for new product/service development and introduction/launch"@en,
        "制定新产品/服务开发及上市/发布计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2> ;
    skos:definition "Launching revamped product/service portfolio in to the market. Introduction in to the marketplace is done by deploying effective channels for marketing, sales, delivery, and after-sales servicing. Introduce new/revised solution offerings in a concerted effort. Coordinate a cross-functional effort."@en,
        "将重构后的产品/服务组合推向市场。通过高效整合营销、销售、交付及售后服务渠道实现上市；以跨职能协同方式统一推进新/修订解决方案的发布。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.2" ;
    skos:prefLabel "Introduce new products/services"@en,
        "推出新产品/服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2> ;
    skos:definition "Removing nonconforming products and services. Withdraw those products/services that do not conform to market realities and are not positioned to take advantage of prevailing opportunities. Coordinate with processing/delivery teams within the organization and key stakeholders in the supply chain. Create mechanisms for continued after-sales servicing, as well as deploy effective public relations efforts in order to preserve the image and goodwill of the organization through the process."@en,
        "淘汰不合规产品和服务。下架不符合市场实际、无法把握当前机遇的产品/服务；协同组织内部加工/交付团队及供应链关键相关方；建立持续性售后服务机制，并开展有效公关活动，维护组织形象与声誉。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.3" ;
    skos:prefLabel "Retire outdated products/services"@en,
        "淘汰过时产品/服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2> ;
    skos:definition "Attuning the performance measures of products/services to better reflect the revamped portfolio of solution offerings. Revise the parameters used to measure performance, apropos the organization's product/service offerings. (Modify these standards in consideration of the changes made to the portfolio by Introduce new products/services [10077] and Retire outdated products/services [10078].)"@en,
        "调优产品/服务绩效指标，使其更准确反映重构后的解决方案组合。依据组织产品/服务组合的实际变化，修订绩效衡量参数（需结合「引入新产品/服务 [10077]」与「淘汰过时产品/服务 [10078]」所引发的组合调整进行动态更新）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.4" ;
    skos:prefLabel "Identify and refine performance indicators"@en,
        "识别并优化绩效指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Measuring the performance of marketing once the product/services are launched. This broadly covers measuring user engagement and product's/service's performance in the market."@en,
        "产品/服务上市后评估营销成效，涵盖用户参与度及产品/服务在市场中的整体表现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.1" ;
    skos:prefLabel "Carry out post launch analytics to test the acceptability in the market"@en,
        "开展上市后分析以验证市场接受度"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Conducting customer and market analysis to review progress and identify opportunities for increasing market position. Track and review product/service response through sales reports, website statistics, direct response from customers, and survey reports."@en,
        "开展客户与市场分析，跟踪进展并识别提升市场地位的机会。通过销售报告、网站统计、客户直接反馈及调研报告等多渠道追踪和评估产品/服务市场响应。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.2" ;
    skos:prefLabel "Review market performance"@en,
        "评估市场表现"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Determining the performance of supply chain to all departments and logistics from input to shop floor. Seeking performance reviews at each intersection and communication channels. Review effectiveness of supply chain and distribution to check if it is meeting the demands of the various groups and organizations that are concerned with its activities (groups might include customers, partners, suppliers, and vendors)."@en,
        "评估供应链在各部门及物流环节（从输入至车间）的整体绩效。在各节点及沟通渠道开展绩效审查；检视供应链与分销体系的有效性，确认其是否满足客户、合作伙伴、供应商及厂商等各方关切需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.3" ;
    skos:prefLabel "Review effectiveness of supply chain and distribution network"@en,
        "评估供应链与分销网络效能"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Collecting and examining raw data with the purpose of drawing conclusions about that information and correlate gaps and efficiencies to the existing supply chain channels. Apply the information to make better business decisions to the related supply chain methodologies to meet efficiency."@en,
        "采集并分析原始数据，从中得出结论，识别现有供应链渠道中的缺口与效率瓶颈；将分析结果应用于优化相关供应链方法论，提升运营效率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.4" ;
    skos:prefLabel "Apply data and analytics to review supply chain methodologies"@en,
        "应用数据与分析方法评估供应链运作模式"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Identifying the quality and performance of the product/service delivered to customers. Analyze data from the customer feedback, audits, measures of customer satisfaction (such as product quality complaints and recalls), and organizational policies on delivery."@en,
        "评估交付给客户的最终产品/服务质量与性能。综合客户反馈、审计结果、客户满意度指标（如产品质量投诉、召回事件）及组织交付政策开展分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.5" ;
    skos:prefLabel "Review quality and performance of the product/service"@en,
        "评审产品/服务的质量与性能"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.6" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Evaluating organization's financial reports and financial reporting processes. Review and document the ROI catered by the product/service delivery to the customer in the market."@en,
        "评估组织财务报表及财务报告流程，审核并记录产品/服务在市场交付过程中所产生的投资回报率（ROI）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.6" ;
    skos:prefLabel "Conduct financial review"@en,
        "开展财务评审"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.2.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.2.5.7" ;
    skos:broader <https://oprocess.net/opf/node/2.1.2.5> ;
    skos:definition "Analyzing the steps involved in the development of new product, its effect on existing product, resources, and functions related to the development of the new product until its sale in the competitive market place."@en,
        "分析新产品开发全流程及其对现有产品、资源及关联职能的影响，直至其在竞争市场完成销售。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.2.5.7" ;
    skos:prefLabel "Conduct new product development process assessment"@en,
        "开展新产品开发流程评估"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3> ;
    skos:definition "Conducting necessary performance reviews on enforcement of processes and steps to ensure protection. Determine policies and reviews for Manage patents, copyrights, and regulatory requirements [19985]."@en,
        "开展必要绩效审查，确保知识产权保护流程与措施有效执行；制定并落实「管理专利、版权及监管要求 [19985]」相关政策与审查机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.1" ;
    skos:prefLabel "Conduct mandatory and elective reviews"@en,
        "开展强制性与自主性审查"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3> ;
    skos:definition "Reviewing activities in regards to patentability and infringement. The usage of Open Source in commercial product development will be reviewed in regard to licensing, community development, etc."@en,
        "审查专利性与侵权风险；针对商业产品开发中开源软件（Open Source）的使用，开展许可证合规性、社区协作等方面的专项评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.2" ;
    skos:prefLabel "Review infringement of patents and copyrights"@en,
        "审查专利与版权侵权风险"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3> ;
    skos:definition "Determining the business need for patents and copyrights. The patents and copyrights are managed by Manage copyrights and patents [11062]."@en,
        "研判专利与版权的业务必要性；相关管理工作由「管理版权与专利 [11062]」承接。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.3" ;
    skos:prefLabel "Determine patent and copyright needs"@en,
        "确定专利与版权需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3> ;
    skos:definition "Defining sourcing and procurement requirements for new product technical documentation management. Make sourcing-based decisions that identify the capabilities that will be required in order to launch the new product. This documentation will be used to support the product following entry into service. It is compiled and managed in Manage product and process related data [12082], but the capability to manage and maintain this documentation must be defined and established."@en,
        "定义新产品技术文档管理的寻源与采购需求。基于寻源决策，识别新产品上市所需具备的能力。该技术文档将在产品投入运行后持续用于支持产品全生命周期。其编制与管理归属「管理产品与工艺相关数据（12082）」流程，但须明确定义并建立文档管理与维护能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.4" ;
    skos:prefLabel "Define product technical documentation management requirements"@en,
        "定义产品技术文档管理要求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.3.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.5.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3.5> ;
    skos:definition "Conducting training and impart learning to existing and new employees. Training will relate to the most recent/enforced regulations of the business to meet Manage regulatory requirements [12771]."@en,
        "面向新老员工开展培训与知识传递，内容覆盖最新施行的业务监管要求，以支撑「管理监管要求 [12771]」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.5.1" ;
    skos:prefLabel "Train employees on appropriate regulatory requirements"@en,
        "面向员工开展相关监管要求培训"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.3.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.5.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3.5> ;
    skos:definition "Identifying steps and procedures to manage and regularly update the records for regulatory agencies. Updates will be made to safety procedures, identity and access management, software tools and applications, internal accessibility policies, internal quality parameters, etc."@en,
        "识别并规范监管机构记录的管理步骤与定期更新流程；更新范围包括安全规程、身份与访问管理、软件工具与应用、内部无障碍政策、内部质量参数等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.5.2" ;
    skos:prefLabel "Maintain records for regulatory agencies"@en,
        "维护监管机构所需记录"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.3.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.5.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3.5> ;
    skos:definition "Determine and follow the timely input and update of regulatory information by assessing reforms, regulatory policies, and guidelines."@en,
        "通过评估改革动向、监管政策及指南，及时开展监管信息的录入与更新。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.5.3" ;
    skos:prefLabel "Manage regulatory submission life cycle"@en,
        "管理监管申报全生命周期"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Controlling the details of materials' storage and utilization, supplier details linked to materials, in a defined sequential manner and ensuring regular updates with permissible accessibility."@en,
        "按既定顺序管控物料存储与使用细节，以及关联供应商信息，并确保信息定期更新且权限内可访问。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.1" ;
    skos:prefLabel "Manage materials master lists"@en,
        "管理物料主数据清单"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.10" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Determining the requests pertaining to data accessibility. Review the requester details based on internal data security policies and permit data access only if internal policies and data access parameters are met."@en,
        "审核数据访问请求；依据内部数据安全政策核查申请人信息，仅当符合内部政策及数据访问参数时，方可授予访问权限。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.10" ;
    skos:prefLabel "Review and approve data access requests"@en,
        "审核并批准数据访问申请"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Managing the purchase details/bills through regular and error free updates to applications. Create manual entries wherever necessary and ensure timely review of the laid processes and systems."@en,
        "通过应用程序实现采购明细/账单的定期、无误更新；确需人工录入时及时操作，并定期审查既有流程与系统。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.2" ;
    skos:prefLabel "Manage bills of material"@en,
        "管理物料清单（BOM）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Controlling and executing the flow of operations from raw form to finished product in a defined format using industry applications/routing sheets for the specific product/service layout."@en,
        "依托行业专用应用或工艺路线表，按既定格式管控从原材料到成品的全流程作业。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.3" ;
    skos:prefLabel "Manage routings"@en,
        "管理工艺路线"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.4" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Direct, supervise, and control the product/service details necessary to execute the process. Adhere to details and descriptions for product/service through identified or guided parameters towards final outcome in the market with due critical analysis formed on organizational objectives."@en,
        "统筹并管控产品/服务执行过程所需的关键细节；依据组织目标开展关键分析，严格遵循已识别或指导性参数，确保最终市场交付成果符合要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.4" ;
    skos:prefLabel "Manage specifications"@en,
        "管理技术规格"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.5" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Administering the specifications of the product/service and ensure accessibility for product alteration/new product development."@en,
        "管理产品/服务规格参数，并确保其对产品改进或新产品开发具备可访问性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.5" ;
    skos:prefLabel "Manage drawings"@en,
        "管理工程图纸"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.6" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Controlling the details of the product and the input materials. Manage classification throughout the production process, and for future accessibility to new product development or product enrichment."@en,
        "管控产品及投入物料的详细信息；在生产全过程实施分类管理，支撑未来新产品开发或产品增值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.6" ;
    skos:prefLabel "Manage product/material classification"@en,
        "管理产品/物料分类体系"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.7" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Determining procedures required to assess the sustainability of defined criterion for product/service delivery to customers. Retain results for further review as a procedural practice."@en,
        "制定评估产品/服务交付可持续性标准的程序；留存评估结果供后续复审，形成标准化操作实践。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.7" ;
    skos:prefLabel "Develop and maintain quality/inspection documents"@en,
        "编制并维护质量/检验文档"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.8" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Directing and handling data with respect to the procedures followed across different functions and mission critical applications."@en,
        "统筹不同职能及任务关键型应用所涉数据的处理与管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.8" ;
    skos:prefLabel "Maintain process specification data"@en,
        "维护工艺规范数据"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.4.9" ;
    skos:broader <https://oprocess.net/opf/node/2.1.4> ;
    skos:definition "Identifying and handling data accessed by the permitted touch points. Ensure that no data is accessible to any unnecessary recipient. Data flow should be controlled through secured access and free from unauthorized access."@en,
        "识别并管控经授权触点所访问的数据；确保无数据流向非必要接收方；通过受控访问机制保障数据流安全，杜绝未授权访问。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.4.9" ;
    skos:prefLabel "Manage traceability data"@en,
        "管理可追溯性数据"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/2.1> ;
    skos:definition "AI-era activity: AI-Powered Product Design."@en,
        "AI 时代专项活动：AI 驱动的产品设计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.5" ;
    skos:prefLabel "AI-Powered Product Design"@en,
        "AI驱动的产品设计"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.2.1> ;
    skos:definition "Determining new technologies to revise the portfolio of solution offerings. Identify recently developed technological advances that can be leveraged in the development or advancement of the organization's product/service portfolio. Enlist senior management in conjunction with personnel responsible for the design, processing, and delivery of products/services. Have the organization's research division(s) carry out the process."@en,
        "甄选新技术以更新解决方案组合；识别近期涌现的技术突破，评估其在组织产品和服务组合开发或升级中的应用潜力；联合高层管理者，以及负责产品和服务设计、加工与交付的相关人员共同推进；由组织内部研究部门具体执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.1.1" ;
    skos:prefLabel "Identify new technologies"@en,
        "识别新兴技术"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/2.2.1> ;
    skos:definition "Developing new technologies from scratch to integrate into a revised portfolio of solutions. Develop new technological processes, models, and/or implements in-house, with the objective of improving existing solutions or creating new ones. Consider market realities, as well as the portfolio of products/services. Assess the results in conjunction with senior executives and personnel responsible for the design, processing, and delivery of these solutions. Engage the R&D function, and consider external sources such as offshore providers, specialized research agencies, and crowdsourcing communities."@en,
        "从零开始自主研发新技术并集成至修订后的解决方案组合中；自主构建新型技术工艺、模型及工具，旨在优化现有解决方案或创造全新方案；兼顾市场现实与现有产品和服务组合；联合高管层及负责解决方案设计、加工与交付的人员共同评估成果；依托研发职能，并整合外部资源（如离岸服务商、专业研究机构、众包社区等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.1.2" ;
    skos:prefLabel "Develop new technologies"@en,
        "研发新技术"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/2.2.1> ;
    skos:definition "Appraising the feasibility of integrating new technologies, whether developed as a custom solution or adopted from an external source, into revised portfolio of solution offerings. Examine recently developed technological advances for suitability to incorporate them into the concept of revised and/or new solution offerings. Enlist senior management, in consultation with in-house personnel responsible for the design, processing, and delivery of these solutions, as well as key supply-chain stakeholders."@en,
        "评估新技术（含定制开发或外部引入）融入修订后解决方案组合的可行性；考察近期技术进展是否适配新/修订解决方案的概念设计；协同高层管理者、内部解决方案设计/加工/交付人员，以及关键供应链干系人共同研判。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.1.3" ;
    skos:prefLabel "Assess feasibility of integrating new leading technologies into product/service concepts"@en,
        "评估将前沿新技术整合至产品和服务概念的可行性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/2.2.2> ;
    skos:definition "Collecting necessary items, documents, regulatory requirements, etc., based on Generate and define new product/service ideas [19698]"@en,
        "依据“生成并界定新产品/服务创意[19698]”流程，收集所需物料、文档、监管要求等基础要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2.1" ;
    skos:prefLabel "Gather new product/service ideas and requirements"@en,
        "收集新产品和服务创意及需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/2.2.2> ;
    skos:definition "Assessing and reviewing the concepts and requirements of Generate and define new product/service ideas [19698]"@en,
        "对“生成并界定新产品/服务创意[19698]”所产出的概念与需求进行评估与评审。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2.2" ;
    skos:prefLabel "Analyze new product/service ideas and requirements"@en,
        "分析新产品和服务创意及需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/2.2.2> ;
    skos:definition "Assessing and reviewing the required inputs and necessary elements such as automation, technology, hardware installation, regulatory requirements, certifications, etc., for new products/services through defined process and analysis."@en,
        "通过既定流程与分析，评估新产品/服务所需的输入项与关键要素（如自动化、技术、硬件安装、监管要求、认证等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2.3" ;
    skos:prefLabel "Evaluate new product/service inputs and requirements"@en,
        "评估新产品和服务输入及需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/2.2.2> ;
    skos:definition "Devising ideas and elements necessary for thoughts on new product/service development."@en,
        "构思新产品/服务开发所需的核心创意与构成要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2.4" ;
    skos:prefLabel "Formulate new product/service concepts"@en,
        "制定新产品和服务概念"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/2.2.2> ;
    skos:definition "Defining potential enhancements to current products/services in order to take advantage of a shift in market expectations. Identify how the existing line of products/services may be revised--through enhancements to individual solutions or across-the-board renovations--in order to capitalize on present opportunities in the market."@en,
        "定义现有产品/服务的潜在增强方向，以响应市场预期变化；识别现有产品/服务线可通过单点优化或整体重构实现升级的具体路径，从而把握当前市场机遇。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.2.5" ;
    skos:prefLabel "Identify potential improvements to existing products and services"@en,
        "识别现有产品和服务的潜在改进点"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Determining the operations of functions related to the product/service in the marketing environment."@en,
        "界定产品/服务在营销环境中的功能运作方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.1" ;
    skos:prefLabel "Define basic functional requirements"@en,
        "定义基础功能需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Determining the ability of products and services to work together, exchange and use information in a multi-vendor, multi-network, and multi-service environment."@en,
        "评估产品和服务在多厂商、多网络、多业务环境下的互操作能力，即信息交换与协同使用能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.2" ;
    skos:prefLabel "Derive interoperability requirements for products and services"@en,
        "推导产品和服务的互操作性需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Developing safety requirements in line with environmental safety, occupational health and safety, and community health and safety guidelines."@en,
        "依据环境安全、职业健康与安全、社区健康与安全等指南，制定安全需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.3" ;
    skos:prefLabel "Derive safety requirements for products and services"@en,
        "推导产品和服务的安全需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Implementing security requirements through authentication and encryption of CE device data stream.  Utilize security measures such as cryptographic protocols and hardware security (smart cards)."@en,
        "通过CE设备数据流的身份认证与加密实施安全需求；采用密码学协议、硬件安全（如智能卡）等安全措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.4" ;
    skos:prefLabel "Derive security requirements for products and services"@en,
        "推导产品和服务的安全保障需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Meeting regulatory requirements set forth by such directives as RoHS, WEEE, ELV, and REACH."@en,
        "满足《限制有害物质指令》（RoHS）、《废弃电子电气设备指令》（WEEE）、《报废车辆指令》（ELV）、《化学品注册、评估、许可和限制法规》（REACH）等监管要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.5" ;
    skos:prefLabel "Derive regulatory compliance requirements"@en,
        "推导监管合规需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Complying with consumer electronic industry standards developed by the Consumer Technology Association (CTA)."@en,
        "符合美国消费者技术协会（CTA）制定的消费电子行业标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.6" ;
    skos:prefLabel "Derive requirements from industry standards"@en,
        "推导行业标准相关需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.7" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Identifying and creating steps and tools to develop the user experience."@en,
        "识别并构建提升用户体验的步骤与工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.7" ;
    skos:prefLabel "Develop user experience requirements"@en,
        "制定用户体验需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.1.8" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3.1> ;
    skos:definition "Productizing the service by defining the scope of the service/cost.  Target market for the service and make the service more tangible."@en,
        "通过界定服务范围与成本，实现服务产品化；明确目标市场，增强服务的可感知性与可交付性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.1.8" ;
    skos:prefLabel "Derive ‘services-as-a-product’ offering"@en,
        "推导“服务即产品”（Services-as-a-Product）方案"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3> ;
    skos:definition "Defining SLAs (Service Level Agreement) and service level KPIs (Key Performance Indicator)."@en,
        "定义服务等级协议（SLA）及服务级关键绩效指标（KPI）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.2" ;
    skos:prefLabel "Define post launch support model"@en,
        "定义产品/服务上市后支持模式"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/2.2.3> ;
    skos:definition "Establishing areas of growth and further development of product/service mix, customization, market based changes, etc., to further demonstrate value to the customer in the competition."@en,
        "规划产品/服务组合的增长方向与持续演进路径（如定制化、市场驱动型调整等），以在竞争中进一步彰显客户价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3.3" ;
    skos:prefLabel "Identify product/service bundling opportunities"@en,
        "识别产品和服务组合机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/2.2> ;
    skos:definition "AI-era activity: Generative AI for Content Creation."@en,
        "AI时代专项活动：利用生成式人工智能（Generative AI）开展内容创作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.4" ;
    skos:prefLabel "Generative AI for Content Creation"@en,
        "生成式人工智能（Generative AI）用于内容创作"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.3.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.1> ;
    skos:definition "Determining essential elements for collaborators involved in blueprint/development of product/service."@en,
        "明确参与产品/服务蓝图设计与开发的协作方所需核心要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.1.1" ;
    skos:prefLabel "Identify requirements for product/service design/development partners"@en,
        "明确产品/服务设计与开发合作伙伴的需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.10" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Creating the new manufacturing/delivery processes for the new products/services, and testing them to ensure proper functioning. Create the production/delivery process for the prototypes that have been built for the new products/services. Conduct trial-runs to test these processes and their integration with the organization's other processes."@en,
        "为新产品/服务建立并测试新的制造/交付流程。围绕已构建的新产品/服务原型，设计并验证其生产/交付流程；通过试运行检验流程功能及其与组织其他业务流程的集成效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.10" ;
    skos:prefLabel "Develop and test prototype production and/or service delivery process"@en,
        "开发并测试原型化生产及/或服务交付流程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.11" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Eliminating any problems relating to utility of the product/service over the course of its expected lifetime. Tweak the prototype in order to comply with the required quality and reliability standards. Further refine the prototype, so it may be subjected to testing."@en,
        "消除产品/服务在其预期生命周期内可能存在的实用性问题。优化原型以满足质量与可靠性标准；持续迭代完善原型，为后续测试做好准备。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.11" ;
    skos:prefLabel "Eliminate quality and reliability problems"@en,
        "消除质量与可靠性问题"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.12" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Carrying out an in-house appraisal of the prototypes in order to validate design and feasibility. Test the product/service prototypes to confirm their compliance with design and usability standards. Corroborate the viability of the design, and validate the feasibility of their production. Identify any areas for improvement."@en,
        "开展内部原型评估，验证设计方案与可行性。测试产品/服务原型，确认其符合设计规范与可用性标准；佐证设计方案的可行性，并验证量产可行性；识别待改进环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.12" ;
    skos:prefLabel "Conduct in-house product/service testing and evaluate feasibility"@en,
        "开展内部产品/服务测试并评估可行性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.13> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.13" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Identifying performance parameters. Determine the parameters to measure performance of the design and development of the product/service concepts into prototypes."@en,
        "明确性能参数。确定用于衡量产品/服务概念向原型转化过程中的设计与开发绩效的关键参数。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.13" ;
    skos:prefLabel "Identify design/development performance indicators"@en,
        "识别设计/开发绩效指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.14> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.14" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Interacting with suppliers and manufactures to determine design decisions. Collaborate with vendors, suppliers, contractors, and subcontractors to verify feasibility of co-producing the prototype's design. Ensure that efforts can be coordinated with other stakeholders in the organization's supply chain ecosystem at the time of manufacturing, producing, or packaging the finished product/service."@en,
        "协同供应商与制造商共同决策设计方案。联合供应商、承包商、分包商等验证原型协同开发的可行性；确保在成品/服务的制造、生产或包装阶段，可与供应链生态内其他相关方高效协同。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.14" ;
    skos:prefLabel "Collaborate on design with suppliers and external partners"@en,
        "与供应商及外部合作伙伴协同开展设计"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Preparing a business-level business case and a technical feasibility assessment in order to move the product/service projects forward. Weigh the costs and benefits of designing, developing, and evaluating the shortlisted product/service concepts. Prepare a business case to justify the product/service projects. Conduct a technical appraisal to ensure that the organization has the technical know-how and resources to further develop these concepts."@en,
        "编制业务层面商业论证与技术可行性评估报告，推动产品/服务项目落地；权衡短名单内产品/服务概念的设计、开发与评估成本与收益；形成商业论证以支持立项决策；开展技术评估，确认组织具备相应技术能力与资源支撑后续开发。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.2" ;
    skos:prefLabel "Prepare high-level business case and technical assessment"@en,
        "编制高层级商业论证与技术评估"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Creating design specifications. Create specifications for the design of new or revised product/service concepts as a measure to meet during development. Have the senior functional-level solutioning or design staff create a framework of compliance standards for these products/services."@en,
        "制定设计规范；明确新/修订产品/服务概念的设计规格，作为开发过程中的达标基准；由高级职能级解决方案或设计团队建立产品/服务合规标准框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.3" ;
    skos:prefLabel "Develop product/service design specifications"@en,
        "制定产品/服务设计规范"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Determining the usability and user experience of products and the business impact it creates."@en,
        "评估产品/服务的可用性与用户体验，及其带来的业务影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.4" ;
    skos:prefLabel "Develop user experience design specifications"@en,
        "制定用户体验设计规范"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Providing warranty plan and pricing specifications for recommendation."@en,
        "提供保修方案与定价规格建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.5" ;
    skos:prefLabel "Provide warranty-related recommendations"@en,
        "提供与保修相关的建议"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Documenting requirements to meet in the design of new or revised products/services. Specify technical, quality, and costing requirements, as well as ergonomic, safety, and servicing requirements for such products/services. Ensure the information presented can be understood by the personnel executing the design and includes examples, anecdotal references, and illustrations."@en,
        "记录新/修订产品/服务设计需满足的各项要求，包括技术、质量、成本，以及人机工学、安全、可维护性等维度；确保设计执行人员能清晰理解要求，并辅以示例、案例参考与图示说明。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.6" ;
    skos:prefLabel "Document design specifications"@en,
        "归档设计规范文档"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.7" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Conducting any mandatory and elective appraisals of the product/service design specifications in order to ensure compliance with external standards. Carry out external reviews of specifications created for the development of new product/service designs. Conduct mandatory appraisals such as legal and regulatory, as well as any optional assessments that, for instance, pitch the specifications against industrial benchmarks."@en,
        "开展产品/服务设计规范的强制性与可选性评审，确保符合外部标准；组织外部专家对新/修订产品/服务设计规范进行评审；执行法律与监管等强制性评审，并视需要开展对标行业基准等可选评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.7" ;
    skos:prefLabel "Conduct mandatory and elective external reviews"@en,
        "开展强制性与可选外部评审"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Carrying out the steps necessary to appropriately manufacture correct parts.  This includes designing application, product hardware, mold, casting, mechanical, and electrical aspects of the product."@en,
        "落实正确零部件的制造流程，涵盖应用设计、产品硬件、模具、铸造、机械及电气等各环节。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.1" ;
    skos:prefLabel "Design for manufacturing"@en,
        "面向制造的设计"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Creating product application service view to allow for product servicing and refurbishing."@en,
        "构建产品应用服务视图，支撑产品维修与翻新。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.2" ;
    skos:prefLabel "Design for product servicing"@en,
        "面向产品维修服务的设计"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Replacing core components and republishing."@en,
        "更换核心组件并重新发布。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.3" ;
    skos:prefLabel "Design for re-manufacturing"@en,
        "面向再制造的设计"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Reviewing the design and approach for troubleshooting the product."@en,
        "评审产品故障排查的设计思路与方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.4" ;
    skos:prefLabel "Review product troubleshooting methodology"@en,
        "评审产品故障排查方法论"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.5" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Designing the BOM-Bill of material, manufacturing BOM and Service BOMA bill of materials list for all the raw materials and components/parts used in the producing end product."@en,
        "设计物料清单（BOM）、制造用物料清单（Manufacturing BOM）及服务用物料清单（Service BOM），列明终端产品所用全部原材料、零部件/组件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.5" ;
    skos:prefLabel "Design and manage product data, design, and bill of materials"@en,
        "设计并管理产品数据、设计及物料清单（BOM）"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.8.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.8.6" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1.8> ;
    skos:definition "Designing hardware and software upgrade techniques."@en,
        "设计软硬件升级技术方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.8.6" ;
    skos:prefLabel "Design for product upgrades"@en,
        "面向产品升级的设计"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.9" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Building prototypes for shortlisted product/service concepts. Develop prototypes for those product/service concepts that have been identified for further development. Provide proof-of-concepts, and test any processes involved. Build prototypes in line with the design specifications already outlined. Enlist the solutioning and/or design staff."@en,
        "构建短名单内产品/服务概念的原型。针对已选定进入后续开发阶段的产品/服务概念，开展原型开发；提供概念验证（PoC），并对相关流程进行测试；严格依据既定设计规范开展原型构建；协调解决方案设计团队或设计人员参与。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.9" ;
    skos:prefLabel "Build prototypes/proof of concepts"@en,
        "构建原型/概念验证"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.2> ;
    skos:definition "Composing a detailed study of the market ecosystem in light of new products/services. Conduct a detailed analysis of the targeted market(s) in order to Introduce new products/services [10077]. Examine the competition, market size and growth rate, market trends, customer segments and their characteristics, market influencers, distribution channels, and profitability. Enlist in-house marketing and/or solutioning teams, or outsource to specialized professional services agencies."@en,
        "结合新产品/服务，开展市场生态系统专项研究。对目标市场开展深度分析，以支持新产品/服务上市（[10077]）；考察竞争格局、市场规模与增长率、市场趋势、客户细分及其特征、关键影响者、分销渠道与盈利水平；由内部营销或解决方案团队主导，或外包给专业服务机构执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.2.1" ;
    skos:prefLabel "Prepare detailed market study"@en,
        "编制详尽的市场调研报告"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3.2> ;
    skos:definition "Conducting both qualitative and quantitative studies to determine the fit between the newly developed products/services and the customers. Conduct external tests of the new product/service, and then refine them to maximize the customer uptake. Gather feedback from prospective customers and targeted populations by conducting surveys, focus groups, interviews, and detailed studies. Enlist professional services such as public relations or market research organizations."@en,
        "开展定性与定量研究，评估新产品/服务与客户需求的匹配度。对外开展新产品/服务实测，并基于反馈持续优化以提升客户采纳率；通过问卷调查、焦点小组、深度访谈及专项研究等方式，收集目标客户与特定人群反馈；可借助公关或市场调研等专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.2.2" ;
    skos:prefLabel "Conduct customer tests and interviews"@en,
        "开展客户测试与访谈"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3.2> ;
    skos:definition "Finalizing the characteristics of new products/services by appropriately weighing feedback from prospective customers against a cost-benefit analysis in order to produce a profitable business proposition. Refine the attributes of the newly developed products/services, in light of the feedback and insights collected during Conduct customer tests and interviews [10094]. Revisit the high-level business case to justify the resources assigned to the product/service project against the anticipated benefits."@en,
        "综合权衡客户反馈与成本效益分析，最终确定新产品/服务特性，形成盈利性商业方案。依据客户测试与访谈（[10094]）所获反馈与洞察，优化新产品/服务属性；重新审视高层级商业论证，以资源投入与预期收益匹配性支撑项目决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.2.3" ;
    skos:prefLabel "Finalize product/service characteristics and business cases"@en,
        "确定产品/服务特性及商业案例"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3.2> ;
    skos:definition "Reassessing the technical requirements in light of the final product/service attributes. Revisit the technical assessment to revalidate the organization's capacity for progressing with new product/service projects, in light of the revised product/service characteristics."@en,
        "基于最终确定的产品/服务特性，重新评估技术要求。复核技术评估结论，结合修订后的产品/服务特性，再次验证组织推进新项目的技术能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.2.4" ;
    skos:prefLabel "Finalize technical requirements"@en,
        "明确技术需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3> ;
    skos:definition "Developing and/or sourcing the essential machinery needed for creating purpose-built processes, as well as the raw materials, to produce the new products/services. Either design the equipment and materials needed internally, or source from external vendors. Obtain the feedstock or raw materials needed to prepare the finished products, as well as the machinery - hardware and software - needed to arrange production lines, factory operations, assemblies, and manufacturing processes. Revisit the technologies that underpin the new or revised products/services in order to source the right equipment and materials."@en,
        "开发或采购定制化制造流程所需的设备及原材料，以支撑新产品/服务生产。设备与材料可自主设计开发，亦可向外部供应商采购；获取成品生产所需原料/基础物料，以及产线布局、工厂运营、装配与制造流程所需的硬件与软件设备；同步复审支撑新产品/服务的技术基础，以精准选型配套设备与材料。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.1" ;
    skos:prefLabel "Design and obtain necessary capabilities/materials and equipment"@en,
        "设计并获取必要的能力、物料及设备"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3> ;
    skos:definition "Identifying any changes that need to be effectuated in the organization's internal processes for manufacturing, and delivering the newly developed products/services. Determine if any changes need to be made to the production and distribution processes, in light of the new products/services. Begin production process planning. Prepare for factory layout planning. Generate shop-floor instructions and changes to the supply chain."@en,
        "识别组织内部制造与交付流程需适配新产品/服务所做的调整。基于新产品/服务特性，研判生产与分销流程是否需优化；启动生产流程规划；筹备工厂布局设计；编制车间作业指令并更新供应链安排。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.2" ;
    skos:prefLabel "Identify requirements for changes to manufacturing/delivery processes"@en,
        "识别制造/交付流程变更所需的要求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3> ;
    skos:definition "Requesting changes in the production and/or delivery operations for processing the new or revised products/services. Rectify any problems identified in the manufacturing or delivery processes (through Monitor production runs [11417]). Seek changes in components, repair machinery, optimize production lines, and tweak factory assemblies through a formal notice to the concerned division, known as an engineering change order."@en,
        "提出生产与/或交付环节的变更请求，以适配新产品/服务。针对制造或交付流程中发现的问题（通过“监控生产运行”[11417]识别），发起工程变更单（ECO），正式通知相关部门开展零部件调整、设备维修、产线优化或工厂装配微调。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.3" ;
    skos:prefLabel "Request engineering/process change"@en,
        "提出工程/流程变更申请"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3.4> ;
    skos:definition "Regularly monitoring production runs of the production and/or delivery operations."@en,
        "持续监控生产与/或交付运行情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.4.1" ;
    skos:prefLabel "Monitor initial production runs"@en,
        "监控首批生产运行"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/2.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3> ;
    skos:definition "Verifying the measures/processes/techniques through systems and tools involved in the introduction of products and services."@en,
        "通过系统与工具验证产品/服务导入过程中所采用的措施、流程与技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.5" ;
    skos:prefLabel "Validate launch procedures"@en,
        "验证上线流程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.4> ;
    skos:definition "Establishing warranty policies to assure customers that the company will guarantee its warranties that it issues."@en,
        "制定保修政策，向客户承诺企业将切实履行所出具的保修义务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4.1" ;
    skos:prefLabel "Determine and document warranty policies"@en,
        "制定并记录保修政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3.4> ;
    skos:definition "Establishing and maintaining claims processing and routing rules. Establish and maintain claims processing and routing rules for product warranties, coverage lists, repair, fault, trouble codes, repair time setup, and warranty policy registration. This also includes rolling out the codes and rules, and the improvements/updates to these rules and codes via systematic updates."@en,
        "建立并维护保修索赔处理与路由规则。涵盖产品保修索赔处理规则、保障范围清单、维修流程、故障分类、报修代码、维修时效设定及保修政策登记等；同步推动代码与规则的发布、迭代更新及系统化升级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4.2" ;
    skos:prefLabel "Create and manage warranty rules/claim codes for products"@en,
        "为产品创建并管理保修规则/索赔代码"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/2.3.4> ;
    skos:definition "Negotiating with manufacturers and dealers the obligations of each party in upholding warranties."@en,
        "与制造商及经销商协商各方在保修履约中的责任与义务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4.3" ;
    skos:prefLabel "Agree on warranty responsibilities with suppliers"@en,
        "与供应商就保修责任达成一致"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3.4> ;
    skos:definition "Informing customers about warranties that apply to promoted products or services."@en,
        "向客户清晰传达促销产品或服务所适用的保修条款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4.4" ;
    skos:prefLabel "Define warranty related offerings for customers"@en,
        "为客户定义保修相关服务方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/2.3.4> ;
    skos:definition "Communicating rules and updates via training manuals for new products and training resources."@en,
        "通过新产品培训手册与培训资源，宣贯保修规则及更新内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.4.5" ;
    skos:prefLabel "Communicate warranty policies and offerings"@en,
        "向客户传达保修政策与服务方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/2.3> ;
    skos:definition "Establishing procedures to handle recalls of defective products."@en,
        "建立缺陷产品召回处理规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.5" ;
    skos:prefLabel "Develop recall strategy"@en,
        "制定召回策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Business Analysis" ;
    skos:broader <https://oprocess.net/opf/node/2.4> ;
    skos:definition "Activity within ITIL practice 'Business Analysis'."@en,
        "ITIL ‘业务分析’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.4.1" ;
    skos:prefLabel "Analyze business needs and requirements"@en,
        "分析业务需求与要求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Business Analysis" ;
    skos:broader <https://oprocess.net/opf/node/2.4> ;
    skos:definition "Activity within ITIL practice 'Business Analysis'."@en,
        "ITIL ‘业务分析’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.4.2" ;
    skos:prefLabel "Recommend solutions to business problems"@en,
        "针对业务问题提出解决方案建议"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Business Analysis" ;
    skos:broader <https://oprocess.net/opf/node/2.4> ;
    skos:definition "Activity within ITIL practice 'Business Analysis'."@en,
        "ITIL ‘业务分析’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.4.3" ;
    skos:prefLabel "Validate solution alignment with needs"@en,
        "验证解决方案与需求的一致性"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.1.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1.1> ;
    skos:definition "Identifying the factors that drive the targeted market segment. Model customer purchasing patterns, and forecast their future purchasing behavior."@en,
        "识别目标客户细分的关键驱动因素。建模客户购买行为模式，并预测其未来购买趋势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.1.1" ;
    skos:prefLabel "Understand consumer needs and historical behaviors"@en,
        "洞察消费者需求与历史行为"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1.1> ;
    skos:definition "Using customer segmentation tools to examine past customer behavior to predict future purchasing patterns."@en,
        "运用客户细分工具，基于历史客户行为预测未来购买模式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.1.2" ;
    skos:prefLabel "Predict customer purchasing behavior"@en,
        "预测客户购买行为"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1.2> ;
    skos:definition "Determining the increase or decrease of the company's sales volume in the targeted markets. Conduct an analysis to determine the factors and underlying causes that affect the changes in the demand for products or services offered. Consider changes in offerings or in the business strategy to regain or increase the market share."@en,
        "分析公司在目标市场的销量增减趋势。开展专项分析，识别影响产品/服务需求变动的因素与根本原因；必要时调整产品供给或业务策略，以重获或扩大市场份额。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.2.1" ;
    skos:prefLabel "Determine market share gain/loss"@en,
        "评估市场份额增减情况"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Examining large-scale shifts and trends, with relevance to the organization's products/services. Vet the industrial and larger market landscape to identify broad-based movements that could have a direct or tangential impact on the uptake of the organization's products/services. Examine, among other things, the market capitalization of similar products, the profitability of organizations offering competing products/services, the stock price of key vendors/suppliers in the organizational value-chain, the rate and scale of innovation activity in the organization's product/service category, the price and availability of raw materials, and the shelf-life of similar products/services. Conduct primary and secondary research, and consider enlisting professional services."@en,
        "研判与组织产品/服务相关的大规模市场变革与趋势。审视产业及宏观市场格局，识别可能直接影响或间接波及组织产品/服务市场接受度的广泛性动向；重点考察同类产品市值、竞品企业盈利能力、价值链关键供应商/厂商股价、本类产品/服务领域创新活跃度、原材料价格与供应稳定性、同类产品/服务保质期等；结合一手与二手研究，并可引入专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.3" ;
    skos:prefLabel "Analyze market and industry trends"@en,
        "分析市场与行业趋势"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Examining the strengths and weaknesses of competing organizations. Assess competing organizations for offerings, product strategy, marketing and delivery channels, etc. Analyze the usability experience, durability, USP, and other key attributes of competing and substitute products. Gather competitive intelligence, and consider enlisting professional services."@en,
        "评估竞争对手组织的优势与劣势。从产品供给、产品战略、营销与交付渠道等方面对标竞品组织；分析竞品与替代产品的用户体验、耐用性、独特卖点（USP）等核心属性；开展竞争情报收集，可引入专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.4" ;
    skos:prefLabel "Analyze competing organizations, competitive/substitute products/services"@en,
        "分析竞争组织及竞争性/替代性产品和服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Examining the brands owned and products offered in the market. Determine the relative position of the existing products/brands in the marketplace."@en,
        "分析市场中现有品牌与产品布局。评估组织既有产品/品牌在市场中的相对定位。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.5" ;
    skos:prefLabel "Evaluate existing products/services"@en,
        "评估现有产品和服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.6" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Understanding the culture and environment in which you're operating. Analyze how internal decision-making, thought processes, financial circumstances, and more affect the ability to bring new products to market. Survey or analyze the market into which the products would be introduced."@en,
        "理解所处的文化与经营环境。分析内部决策机制、思维模式、财务状况等因素如何影响新产品上市能力；开展目标市场调研，评估产品拟进入的市场。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.6" ;
    skos:prefLabel "Assess internal and external business environment"@en,
        "评估内外部商业环境"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2> ;
    skos:definition "Attaching quantifiable indicators to opportunities that have been identified in the market. Compute estimated figures of the approximate value that can be captured with the provision of existing products/services (i.e., the extent of financial benefits that can be reaped in the market)."@en,
        "为已识别的市场机会设定可量化的指标。测算依托现有产品和服务可获取的预期价值（即在市场中可实现的财务收益规模）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.1" ;
    skos:prefLabel "Quantify market opportunities"@en,
        "量化市场机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2.2> ;
    skos:definition "Determining which groups of potential customers do not yet, or already do have access to the product or a service that the company produces or markets. Use those findings to create specialized product offerings and differentiated marketing campaigns."@en,
        "判定哪些潜在客户群体尚未或已获得本公司生产或营销的产品或服务；据此设计差异化产品方案与定制化营销活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.2.1" ;
    skos:prefLabel "Identify under-served and saturated market segments"@en,
        "识别服务不足与饱和的细分市场"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2> ;
    skos:definition "Creating an index of market opportunities, and arrange them in order of preference. Prioritize based on the opportunities' adherence to the overall business strategy. Correlate with the competencies and capacities that the organization, as a whole, processes."@en,
        "构建市场机会指数，并按优先级排序；依据各机会与整体业务战略的契合度进行优先级排序，同时关联组织整体具备的核心能力与资源禀赋。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.3" ;
    skos:prefLabel "Prioritize opportunities consistent with capabilities and overall business strategy"@en,
        "依据业务能力与整体战略优先排序机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2.4> ;
    skos:definition "Validating identified market opportunities by testing company's offerings on limited-size samples of the consumer population that are hypothesized to be representative of the target market at large and to have similar purchasing behavior. The feedback gained through consumer testing can be used to modify or reject product offerings before their full scale launch, saving the company valuable resources, should the initial offering not be successful."@en,
        "通过小规模消费者抽样测试（样本需代表目标市场总体并具备相似购买行为）验证市场机会；利用测试反馈在全面上市前优化或终止产品方案，避免资源浪费。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.4.1" ;
    skos:prefLabel "Test with customers/consumers"@en,
        "面向客户/消费者开展测试"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2.4> ;
    skos:definition "Verifying that the company has sufficient infrastructure and resources to deliver their offerings in a timely and cost-effective manner, and that it is able to scale up from the small-scale market samples, used for consumer testing, to the entire identified market segment."@en,
        "核实企业是否具备及时、经济高效交付产品/服务所需的基础设施与资源，并能从小规模测试样本顺利扩展至全部目标市场细分。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.4.2" ;
    skos:prefLabel "Confirm internal capabilities"@en,
        "确认内部能力支撑情况"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/3.1> ;
    skos:definition "AI-era activity: AI-Driven Customer Segmentation."@en,
        "AI时代专项活动：人工智能驱动的客户细分。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.3" ;
    skos:prefLabel "AI-Driven Customer Segmentation"@en,
        "人工智能驱动的客户细分"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.1> ;
    skos:definition "Defining problem(s) that the organization's products/services solve for the customers, thereby determining how they are positioned in the market. Refine the product/service concepts from the perspective of customers. Succinctly outline the problem the organization's offerings solves for the customers, making a case for why the customer should buy a product or use a service. Define the offering's unique value."@en,
        "界定组织产品/服务为客户解决的核心问题，从而明确其市场定位；从客户视角持续优化产品/服务概念；简明扼要阐明产品/服务解决的具体问题，论证客户采购或使用该产品/服务的理由；定义产品/服务的独特价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.1.1" ;
    skos:prefLabel "Define offering and positioning"@en,
        "定义产品/服务及市场定位"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.1> ;
    skos:definition "Boosting the attractiveness of products/services to the targeted customers, and creating a unique brand projection around these features. Identify and enhance those product/service features that reinforce the attractiveness of these offerings, for these segment of customers. Underscore the perceived value delivered to the customers by clearly specifying the relevance and desirability of these products/services. Once it has been clarified how the organization's offerings meet the customer's expectations or deliver specific benefits, position the brands around these benefits."@en,
        "强化产品/服务对目标客户的吸引力，并围绕关键特性打造差异化品牌印象；识别并增强能提升该客户群吸引力的产品/服务特性；通过明确说明相关性与需求度，凸显客户感知价值；在厘清产品/服务如何满足客户期望或提供特定收益后，围绕这些收益开展品牌定位。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.1.2" ;
    skos:prefLabel "Develop value proposition including brand positioning for target segments"@en,
        "为目标细分市场制定价值主张（含品牌定位）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.1> ;
    skos:definition "Validating the desirability of the perceived value delivered by the organization's offerings, to the targeted customer segment. Substantiate the value of the benefits accrued to the customers through the organization's offerings. Justify the value proposition in light of the targeted segments by gathering feedback (using teaser demonstrations, surveys, interviews, primary research studies, and customer case studies). Corroborate the benefits of the organization's offerings."@en,
        "验证组织产品/服务向目标客户群传递的感知价值是否具有吸引力；通过客户反馈（如概念演示、问卷调查、深度访谈、一手研究及客户案例研究）实证客户获益价值；基于目标细分群体，论证价值主张合理性并佐证产品/服务收益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.1.3" ;
    skos:prefLabel "Validate value proposition with target segments"@en,
        "面向目标细分市场验证价值主张"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.2> ;
    skos:definition "Analyzing external social and digital feedback related to brands to assess public perception, sentiment trends, and emerging reputation risks or opportunities, and to inform brand positioning and management decisions."@en,
        "分析外部社交与数字平台上的品牌相关舆情，评估公众认知、情感趋势及新兴声誉风险或机遇，支撑品牌定位与管理决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.2.1" ;
    skos:prefLabel "Conduct brand level social sentiment analysis"@en,
        "开展品牌层级社交舆情分析"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.2> ;
    skos:definition "Defining brand-specific marketing direction, priorities, and strategic choices to support brand introduction, growth, positioning, and ongoing performance within the broader marketing strategy."@en,
        "制定品牌专属的营销方向、优先事项与战略选择，支撑品牌引入、成长、定位及持续绩效表现，并融入整体营销战略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.2.2" ;
    skos:prefLabel "Develop marketing strategy for new and existing brands"@en,
        "制定新旧品牌营销策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.2> ;
    skos:definition "Establishing the desired brand value, differentiation, and market perception relative to competitors and target audiences, including the attributes and associations the brand is intended to represent."@en,
        "确立品牌相对于竞争对手及目标受众所期望的价值、差异化特征与市场认知，明确品牌拟代表的核心属性与关联联想。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.2.3" ;
    skos:prefLabel "Define brand equity position"@en,
        "界定品牌资产定位"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.2> ;
    skos:definition "Evaluating brand performance against defined objectives and expectations to inform brand positioning adjustments, investment decisions, and ongoing brand management actions."@en,
        "对照既定目标与预期评估品牌绩效，为品牌定位调整、投资决策及持续品牌管理提供依据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.2.4" ;
    skos:prefLabel "Assess brand performance management"@en,
        "评估品牌绩效管理"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.3> ;
    skos:definition "Analyzing marketing objectives, consumer demand, product attributes, competitors' pricing, and economic trends to determine optimum prices for the set of products and services that the company offers or intends to offer by delivering maximum ROI."@en,
        "综合分析营销目标、消费需求、产品属性、竞品定价及经济趋势，确定公司当前或拟推出产品/服务组合的最优价格，以实现ROI最大化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.3.1" ;
    skos:prefLabel "Conduct pricing analysis"@en,
        "开展定价分析"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.3> ;
    skos:definition "Creating a framework that allows for a uniform methodology while determining the price of individual offerings. Devise a blueprint for establishing the pricing of specific products/services. Create guidelines that factor in the cost of production/servicing, price sensitivity, product lifecycle, and the price of competing/substitute products."@en,
        "构建统一的定价方法论框架；制定具体产品/服务的定价蓝图；制定涵盖生产/服务成本、价格敏感度、产品生命周期及竞品/替代品价格等要素的定价指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.3.2" ;
    skos:prefLabel "Establish guidelines for applying pricing and discounting of products/services"@en,
        "制定产品/服务定价与折扣应用规范"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.3> ;
    skos:definition "Determining optimum prices for individual products or services on the basis of the cost of producing, distributing and marketing the offerings, pricing analysis and general pricing strategy."@en,
        "基于产品/服务的生产、分销与营销成本，结合定价分析及整体定价策略，确定单个产品/服务的最优价格。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.3.3" ;
    skos:prefLabel "Establish pricing targets"@en,
        "设定定价目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.3> ;
    skos:definition "Confirming the strategy and specifications developed for pricing the organization's products/services. Approve pricing guidelines by vetting the soundness of the methodology and the guidelines' alignment with the value proposition."@en,
        "确认组织产品/服务定价策略与细则；通过审核定价方法论的科学性及与价值主张的一致性，批准定价指南。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.3.4" ;
    skos:prefLabel "Approve pricing strategies/policies and targets"@en,
        "审批定价策略/政策及目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Deciding which distributors, wholesalers and retailers the company will use to promote its offerings and to distribute its products and services to the target market. Narrowing down which intermediaries the company will use will affect retail prices of individual products, and should therefore be included in the pricing analysis."@en,
        "确定公司将采用的分销商、批发商与零售商，用于推广产品/服务并触达目标市场；中间商的选择将影响单品零售价格，须纳入定价分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.1" ;
    skos:prefLabel "Determine channels to be supported"@en,
        "确定拟支持的渠道类型"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Identifying the role that each chosen marketing channels plays in the larger distribution network with respect to the organizational marketing strategy. Determine intermediary costs for shipping, handling, transporting, warehousing, insurance and marketing that incur and accumulate in the distribution channel."@en,
        "明确各选定营销渠道在整体分销网络中所承担的角色及其与组织营销战略的关联；核算分销渠道中产生的运输、装卸、仓储、保险及营销等中间环节成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.2" ;
    skos:prefLabel "Establish channel objectives"@en,
        "设定渠道目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Analyze the various channels for their relevance to the targeted segments. Identify the channel that can effectively market to the targeted customers in regard to the drives, desires, and characteristics of these populations, their uptake, extent of engagement, frequency of use, and effectiveness in communicating."@en,
        "分析各渠道对目标细分的相关性；识别最契合目标客户驱动力、需求特征、采纳意愿、参与程度、使用频次及传播效能的渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.3" ;
    skos:prefLabel "Determine channel role and fit with target segments"@en,
        "明确渠道角色及其与目标细分市场的匹配度"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Choose the most pertinent marketing channel for the targeted segments (based on Determine channel fit with target segments [10127])."@en,
        "依据确定渠道与目标细分的匹配度［10127］，选择最适配目标细分的营销渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.4" ;
    skos:prefLabel "Select channels for target segments"@en,
        "为目标细分市场遴选渠道"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.5" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Determining the maximum output rate required from a distribution channel to optimally market and deliver the products and services the company offers or would like to offer. Ideally, a channel should be able to adapt to a certain degree of variability in the demand for the offerings, and able scale up if needed."@en,
        "确定分销渠道所需达到的最大输出速率，以最优支持产品/服务的营销与交付；理想渠道应具备一定需求波动适应能力，并可按需扩容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.5" ;
    skos:prefLabel "Identify required channel capabilities"@en,
        "识别所需渠道能力"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.6" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Assessing the attributes of all marketing channels, and evaluating the key partners in those channels. Closely examine the various characteristics of all available marketing channels such as the cost of using them, durability of impact, applicability to the organization's products/services, turn-around time, involvement of middlemen, and conversion rate. Analyze key partners in the marketing channels including those who have been associated with the organization; evaluate their capabilities, the scale and scope of their operations, quality of support provided, etc."@en,
        "全面评估所有营销渠道属性，并对关键渠道伙伴开展评价；深入考察各渠道的成本、影响持久性、与组织产品/服务的适配性、响应时效、中间环节数量及转化率等特征；分析渠道关键伙伴（含既有合作方）的运营规模与范围、能力水平、支持力度等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.6" ;
    skos:prefLabel "Evaluate channel attributes and potential partners"@en,
        "评估渠道属性及潜在合作伙伴"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.7.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4.7> ;
    skos:definition "Devising a strategy to market company's products or services seamlessly through all or most channels that are in widespread use among the target market. This may mean cross-channel access to customer preferences and purchasing history to accept returned merchandise, provide refunds, resolve payment issues or to provide technical support."@en,
        "制定全渠道或主流渠道无缝营销策略；例如打通客户偏好与购买历史数据，支持退换货、退款、支付问题处理及技术支援等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.7.1" ;
    skos:prefLabel "Define omni-channel strategy"@en,
        "定义全渠道策略"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.2.4.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.7.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4.7> ;
    skos:definition "Identifying necessary preconditions that a channel should fulfill in order to be included as one of the adopted channels, such as required throughput capacities, service capabilities, competitive pricing, and alignment with organizational marketing strategies."@en,
        "明确渠道纳入标准，包括必需吞吐能力、服务能力、竞争性定价及与组织营销战略的一致性等前提条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.7.2" ;
    skos:prefLabel "Define omni-channel requirements"@en,
        "定义全渠道需求"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.2.4.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.7.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4.7> ;
    skos:definition "Determining the detailed policies and procedures that each of the channels needs to follow in order to conform to the organizational marketing strategy and to provide seamless customer service experience."@en,
        "制定各渠道须遵循的详细政策与操作规程，确保其符合组织营销战略并提供无缝客户服务体验。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.7.3" ;
    skos:prefLabel "Develop omni-channel policies and procedures"@en,
        "制定全渠道政策与流程"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.2.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.8" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Determining the actions that need to be taken for successful multichannel marketing, the ordering, timing and dependencies of the steps, and the governance mechanism for reviewing and changing the protocol, if needed."@en,
        "明确多渠道营销成功所需的关键行动、步骤顺序、时间安排与依赖关系，并建立评审与动态调整协议的治理机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.8" ;
    skos:prefLabel "Develop and manage execution roadmap"@en,
        "制定并管理执行路线图"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.9" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Establishing and overseeing the strategic role, structure, and positioning of marketing channels and customer engagement formats, including how they are used to reach target audiences, deliver brand experiences, and support overall marketing objectives."@en,
        "建立并统筹管理营销渠道与客户互动形式的战略定位、架构与角色，明确其在触达目标受众、传递品牌体验及支撑整体营销目标中的作用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.9" ;
    skos:prefLabel "Define and manage channel/store format strategy"@en,
        "定义并管理渠道/门店形态策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.5> ;
    skos:definition "Determining measurable parameters to be used for comparing the performance of different marketing channels. Decide on benchmarks and values for optimum or desired performance."@en,
        "设定可量化的渠道绩效对比参数；明确最优或期望绩效的基准值与衡量标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5.1" ;
    skos:prefLabel "Establish channel-specific measures and targets"@en,
        "建立渠道专属衡量指标与目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.5> ;
    skos:definition "Tracking trends and changes in performance inside individual marketing channels and in channels collectively. Summarize and document results. Alert relevant parties about significant or unexpected deviations from expected behaviors."@en,
        "跟踪各营销渠道内部及整体渠道组合的绩效趋势与变化；汇总并记录分析结果；就显著或异常偏离预期表现的情况向相关方发出预警。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5.2" ;
    skos:prefLabel "Monitor and report performance"@en,
        "监控并报告绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.5> ;
    skos:definition "Analyzing the factors and circumstances that influence desired outcomes. Communicate core findings to relevant parties."@en,
        "分析影响预期成果达成的关键因素与情境；向相关方传达核心发现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5.3" ;
    skos:prefLabel "Monitor and report events influencing factors"@en,
        "监控并报告影响事件的因素"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.5> ;
    skos:definition "Conducting an analysis to review channel performance with respect to chosen metrics, benchmarks and performance targets [16573]. Compare to past performance and forecasts for the channel."@en,
        "基于选定指标、基准及绩效目标[16573]，开展渠道绩效评估；并与历史表现及渠道预测数据进行比对。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5.4" ;
    skos:prefLabel "Analyze channel performance"@en,
        "分析渠道绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/3.2.5> ;
    skos:definition "Devising a course of action to be taken to improve under-performing channels and to promote or expand channels that surpass expectations."@en,
        "制定改进低效渠道的行动方案，并推动或拓展表现超预期的渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.5.5" ;
    skos:prefLabel "Develop plan for channel improvements"@en,
        "制定渠道改进计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Timing and scheduling the delivery of marketing messages to maximize their impact on customer purchasing behavior. Integrate individual messages to larger marketing campaigns and to seasonal purchasing patterns."@en,
        "统筹营销信息的投放时机与节奏，以最大化其对客户购买行为的影响；将单条信息有机整合至整体营销活动及季节性消费周期中。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.1" ;
    skos:prefLabel "Develop customer communication calendar"@en,
        "制定客户沟通日历"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Deciding how to promote and maintain a favorable public image of the company in the eyes of its employees, customers, investors, suppliers, politicians or the general public. This may involve various means but is frequently conducted through publicity, education, corporate social responsibility, charitable causes or civic engagements."@en,
        "策划并维护公司在员工、客户、投资者、供应商、政界人士及公众心目中的正面形象；手段包括公关宣传、公众教育、企业社会责任（CSR）、慈善公益及社区参与等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.2" ;
    skos:prefLabel "Define public relations (PR) strategy"@en,
        "制定公共关系（PR）策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Devising a master plan how to select potential customers or qualified clients for customized offers, and contact them on one-to-one basis through chat, phone, email or regular mail. The strategy would need to take into account that personalizing offers and contacting customers individually is an effective but resource-intensive marketing technique, and that ill-targeted offers risk at angering and alienating the contactees."@en,
        "制定精准客户触达策略：筛选潜在客户或合格客户，通过在线聊天、电话、电子邮件或传统邮件开展一对一沟通；需兼顾个性化营销的高有效性与资源密集性，并规避因定位不准引发客户反感与疏离的风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.3" ;
    skos:prefLabel "Define direct marketing strategy"@en,
        "制定直复营销策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Developing a program to promote the objectives, values, products and services of the company to its employees by treating them as potential customers, in order to extend company client base, increase employee engagement or to foster brand advocacy."@en,
        "面向员工开展内部品牌传播计划，将其视为潜在客户，宣贯公司使命、价值观、产品和服务，以拓展客户基础、提升员工敬业度或培育品牌拥护者。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.4" ;
    skos:prefLabel "Define internal marketing communication strategy"@en,
        "制定内部营销传播策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.5" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Finding emerging media based on digital or other technologies that would enable the company to increase the speed and volume of marketing communications, to make communications more interactive and to customize promotional messages more easily to the target audience, thus rendering them more effective."@en,
        "发掘基于数字技术或其他新兴技术的媒体形态，以提升营销传播的速度与规模，增强互动性，并更便捷地实现面向目标受众的定制化信息推送，从而提升传播效能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.5" ;
    skos:prefLabel "Identify new media for marketing communication"@en,
        "识别新型营销传播媒介"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.6" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Developing a marketing strategy that is maximally effective in a new or emerging media channel by capitalizing on its novel attributes and capabilities."@en,
        "依托新兴媒体渠道的独特属性与能力，制定最具实效性的营销策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.6" ;
    skos:prefLabel "Define new media communication strategy"@en,
        "制定新型媒介传播策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.7" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Establishing a framework for coordinated marketing to increase the profitability and increase brand awareness at the point of sale. This may include promotional posters on product shelves or island displays, advertisements in shopping carts, stickers on the floor that lead consumers to the promoted product, multi-buy promotions, coupons on sales receipts, etc."@en,
        "构建终端协同营销框架，以提升销售点盈利水平与品牌曝光度；具体形式包括货架端促销海报、岛式陈列、购物车广告、地面导流贴纸、多件优惠、收据优惠券等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.7" ;
    skos:prefLabel "Define point of sale (POS) communication strategy"@en,
        "制定销售点（POS）传播策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.6.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.6.8" ;
    skos:broader <https://oprocess.net/opf/node/3.2.6> ;
    skos:definition "Establishing standardized procedures for effective communication that maximizes ROI, promotes brand awareness and respects customers. In its simplest form, it includes a message (what is to be said), a target (to whom the message is reaching) and a medium or a channel (where the message is to be said)."@en,
        "建立标准化高效传播流程，以实现投资回报率（ROI）最大化、品牌认知度提升及客户尊重；其基本要素包括信息内容（说什么）、目标受众（对谁说）及传播媒介/渠道（在哪说）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.6.8" ;
    skos:prefLabel "Define communication guidelines and mechanisms"@en,
        "制定传播规范与机制"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2.7> ;
    skos:definition "Devising procedures and mechanisms to retain existing customers, promote repeat business and increase the likelihood that previous customers to continue to buy products or services from the company. This may be achieved by rewarding customers for repeat business by means of gifts, discounts, redeemable \"points\", or prioritized access to new products, events or services."@en,
        "设计客户留存机制，促进重复购买，提高既有客户持续采购公司产品或服务的可能性；可通过赠品、折扣、“积分”兑换、新品/活动/服务优先体验权等方式激励复购。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7.1" ;
    skos:prefLabel "Define customer loyalty program"@en,
        "定义客户忠诚度计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2.7> ;
    skos:definition "Convincing customers to register their personal information with the company and be assigned a unique identifier that they use when making purchases. The identifier makes it easier for the company to track customer purchases. Customers are rewarded by various incentives that encourage repeat business [20007]."@en,
        "引导客户注册个人信息并分配唯一识别码，用于购物流程；该识别码便于企业追踪客户行为；客户通过各类激励措施获得回馈，以增强复购意愿[20007]。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7.2" ;
    skos:prefLabel "Acquire members to customer loyalty program"@en,
        "招募会员加入客户忠诚度计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2.7> ;
    skos:definition "Building deeper relationships between a customer and a brand in order to promote customer loyalty and derive repeat business. Besides making frequent purchases, highly engaged customers refer family, friends and colleagues to make purchases as well, consume and re-broadcast promotional materials, provide feedback to the purchases they make and do not support competing brands."@en,
        "深化客户与品牌的情感联结，以驱动忠诚度与重复购买；高参与度客户不仅高频复购，还主动向亲友同事推荐、传播推广内容、反馈使用意见，并抵制竞品。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7.3" ;
    skos:prefLabel "Build engagement and relationship with members"@en,
        "提升会员参与度并维系客户关系"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7.4" ;
    skos:broader <https://oprocess.net/opf/node/3.2.7> ;
    skos:definition "Surveying and tracking the benefits of customer loyalty programs both for the company and for customers. Compare with comparable loyalty programs instituted in competitor companies. Propose changes as needed to keep up with market trends."@en,
        "评估客户忠诚度计划对公司及客户的实际效益；对标竞争对手同类计划；结合市场趋势提出优化建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7.4" ;
    skos:prefLabel "Monitor customer loyalty program benefits to the enterprise and the customer"@en,
        "监控客户忠诚度计划对企业及客户的效益"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.2.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.7.5" ;
    skos:broader <https://oprocess.net/opf/node/3.2.7> ;
    skos:definition "Enhancing the customer loyalty program so that it will yield maximum value both for the company and for the patrons enrolled in the program, increasing customer retention and continued engagement."@en,
        "持续优化客户忠诚度计划，使其在提升客户留存率与活跃度的同时，为公司与会员创造最大价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.7.5" ;
    skos:prefLabel "Optimize loyalty program value to both the enterprise and the customer"@en,
        "优化忠诚度计划对企业与客户的双重价值"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Determining what to achieve by marketing. Create qualitative and quantitative targets. Establish metrics to track performance (for individual Market segments [10109] and Channels for target segments [10129]). Enlist the head of marketing to determine marketing priorities and the related measures. (The decision in establishing these goals, objectives, and metrics is founded in Develop marketing strategy [10102] and takes cues from current priorities and organizational strategy.)"@en,
        "明确营销目标，设定定性与定量指标；建立绩效追踪指标（覆盖各细分市场[10109]及目标细分市场的渠道[10129]）；由市场负责人确定营销优先级及相关衡量标准。（目标、指标的设定依据源自“制定营销战略”[10102]，并承接当前组织战略重点。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.1" ;
    skos:prefLabel "Establish goals, objectives, and measures for products/services by channel/segment"@en,
        "按渠道/细分市场设定产品和服务的目标、目的及衡量指标"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "AI-era activity: AI-Powered Pricing Optimization."@en,
        "AI时代专项活动：人工智能（AI）驱动的定价优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.10" ;
    skos:prefLabel "AI-Powered Pricing Optimization"@en,
        "人工智能驱动的定价优化（AI-Powered Pricing Optimization）"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.2> ;
    skos:definition "Ensuring corroboration of the marketing strategy and the organizational strategy. Ensure the organization's marketing strategy/plan aligns with the overall business strategy. Fine-tune the marketing plan according to the organizational strategy."@en,
        "确保营销战略与组织战略相互印证；校准营销战略/计划与企业整体战略的一致性；依据组织战略动态优化营销计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.2.1" ;
    skos:prefLabel "Confirm marketing alignment to business strategy"@en,
        "确认营销活动与业务战略的一致性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.2> ;
    skos:definition "Calculating the total cost of marketing the organization's portfolio of products/services. Calculate the total outlay needed for promoting, selling, and delivering the organization's products/services to customers. Account for all costs to acquire customers and sustain a relationship with them. Include the expenses needed for promotional actives, warehousing, transactional costs, and distribution of the organization's offering."@en,
        "核算企业全产品/服务组合的营销总成本；涵盖推广、销售及交付全过程支出；纳入客户获取与关系维系的全部成本；包括促销活动、仓储、交易及产品/服务分销等各项开支。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.2.2" ;
    skos:prefLabel "Determine costs of marketing"@en,
        "核定营销成本"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.2> ;
    skos:definition "Estimating the outlay required for promoting, selling, and distributing the products/services of the organization. Add up the expenses of all activities necessitated in marketing, such as promotional campaigns, advertising, marketing communications, PR campaigns, employing skilled personnel, and office space."@en,
        "估算企业产品/服务的推广、销售与分销所需总投入；汇总所有营销活动支出，包括促销活动、广告、营销传播、公关活动、专业人员薪酬及办公场地费用等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.2.3" ;
    skos:prefLabel "Create marketing budget"@en,
        "编制营销预算"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.2> ;
    skos:definition "Estimating how much profit the company would generate for its expenses on marketing . Forecasted return on investment, used as a metric to gauge the efficiency of marketing, is beneficial in revising marketing budgets and adjusting costs to improve the overall yield."@en,
        "测算营销投入所能产生的利润；预测投资回报率（ROI）作为衡量营销效率的关键指标，有助于优化预算分配与成本控制，提升整体产出效益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.2.4" ;
    skos:prefLabel "Determine projected ROI for marketing investment"@en,
        "测算营销投入的预期投资回报率（ROI）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Determining the production and distribution costs for each product or service, and each channel or method as factors in determining overall pricing."@en,
        "将各产品/服务及各渠道/方式的生产与分销成本，作为整体定价决策的关键输入因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.1" ;
    skos:prefLabel "Understand resource requirements for each product/service and delivery channel/method"@en,
        "明确各产品/服务及交付渠道/方式所需的资源"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.10" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Obtaining internal price approvals and governmental approvals that are required for licensed products and for products that can be reimbursed by the government."@en,
        "获取内部价格审批，以及针对许可类产品和政府报销类产品所需的政府审批。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.10" ;
    skos:prefLabel "Achieve regulatory approval for pricing"@en,
        "获取定价监管审批"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.11" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Analyzing competitor pricing across relevant channels and markets to understand relative price positioning, identify pricing gaps or risks, and inform pricing strategy and adjustments."@en,
        "分析竞品在相关渠道与市场的定价策略，明确自身价格定位，识别价格缺口或风险，支撑定价策略制定与调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.11" ;
    skos:prefLabel "Conduct competitive pricing review (online, offline etc.)"@en,
        "开展竞争性定价审查（线上、线下等）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.12" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Defining pricing approaches and price levels for specific customer segments based on value propositions, market conditions, and strategic pricing objectives."@en,
        "依据价值主张、市场环境及战略性定价目标，为特定客户群体制定差异化定价策略与价格水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.12" ;
    skos:prefLabel "Determine customer segment specific pricing"@en,
        "制定面向特定客户细分市场的差异化定价"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Introducing financial inducements, such as discounts, to distributors, resellers or vendors as a motivation to prioritize selling company's products or services over those of its competitors."@en,
        "向分销商、经销商或供应商提供财务激励（如折扣），促使其优先推广本公司产品/服务而非竞品。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.2" ;
    skos:prefLabel "Determine corporate incentives"@en,
        "确定企业激励政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Establishing a dynamic pricing mechanism for the organization's offerings that is supported by the number of units in production. Outline a system for determining the optimum price point for each product/service. Based this model on an estimation of the volume of anticipated sales for each offering and variable costs."@en,
        "建立基于产量规模的动态定价机制；设计系统化模型，为每项产品/服务确定最优价格点；模型依据各产品的预期销量与可变成本估算构建。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.3" ;
    skos:prefLabel "Determine pricing based on volume/unit forecast"@en,
        "基于销量/单位预测确定定价"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Implementing the pricing mechanism to determine prices for all individual offerings in the organizational portfolio. Calculate the prices of all offerings based on the established methodology and/or formulaic structure."@en,
        "将定价机制应用于组织全部产品/服务组合，依据既定方法论或公式结构统一计算各单项报价。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.4" ;
    skos:prefLabel "Execute pricing plan"@en,
        "执行定价方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Examining the efficiency of pricing with the objective of identifying any divergence from the equilibrium prices and avoiding any deadweight loss. Gauge the performance of the pricing plan by tracking growth in the revenue and/or customer uptake, secured as a result of new prices. Measure the performance of pricing by periodically checking the profits generated from the sale of each of the organization's offerings against the backdrop of any events that may have influenced the uptake of a certain good/service by the customer base."@en,
        "评估定价机制运行效率，识别偏离均衡价格的情形并规避无谓损失；通过追踪收入增长及/或客户采纳率变化，检验新定价策略成效；定期比对各产品/服务销售利润与可能影响客户采纳的相关事件，评估定价绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.5" ;
    skos:prefLabel "Evaluate pricing performance"@en,
        "评估定价效果"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.6" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Refining the pricing mechanism to create equitable prices for all products/services with the objective of maximizing the profits and/or customer uptake of these offerings. Reconcile the pricing mechanism in order to achieve equilibrium pricing. Adjust the prices for all of the organization's offerings, using the insights gleaned from examining how much profit or customer uptake is generated by the present pricing strategy."@en,
        "优化定价机制，实现所有产品/服务的公平定价，以最大化利润与/或客户采纳率；通过机制调优达成均衡定价；依据现行定价策略所产生的利润或客户采纳数据，统一调整全部产品/服务价格。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.6" ;
    skos:prefLabel "Refine pricing as needed"@en,
        "根据需要优化定价"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.7" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Managing schemes that offer lower pricing for a limited time as a promotional and sales incentive when launching a new product or a service."@en,
        "设计限时低价促销方案，在新产品或新服务上市阶段作为推广与销售激励手段。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.7" ;
    skos:prefLabel "Implement promotional pricing programs"@en,
        "实施促销定价方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.8" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Determining the optimum consumer pricing for each product or service at the point of sale, based on production and distribution costs and estimated sales volume."@en,
        "基于生产与分销成本及预估销量，在销售终端确定各产品/服务的最优消费者价格。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.8" ;
    skos:prefLabel "Implement other retail pricing programs"@en,
        "实施其他零售定价方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.3.9" ;
    skos:broader <https://oprocess.net/opf/node/3.3.3> ;
    skos:definition "Assigning new prices or pricing adjustments to products or services to replace the original base prices. Update the prices in product catalogs and databases, and disseminate the information through all involved distribution and marketing channels."@en,
        "对产品/服务实施新定价或价格调整，替代原始基准价；同步更新产品目录与数据库价格信息，并通过所有相关分销与营销渠道发布。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.3.9" ;
    skos:prefLabel "Communicate and implement price changes"@en,
        "传达并落实价格调整"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Outlining a conceptual framework for all promotional activity in order to create an overarching aspiration and ensure consistency. Create a plan for running promotional programs and designing the associated activities in order to increase visibility or sales. Determine how the organization quantifies what it wishes to achieve from these activities, what sort of messages the organization comfortable publicizing, what channels the organization wishes to employ, etc."@en,
        "构建覆盖全部促销活动的概念框架，以确立统一的愿景并确保一致性；制定促销计划及配套活动设计方案，提升品牌曝光度或促进销售；明确组织如何量化促销目标、界定可对外传播的信息内容、选定拟采用的传播渠道等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.1" ;
    skos:prefLabel "Define promotional concepts and objectives"@en,
        "定义促销概念与目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Developing the central messages for a segment of its customers. Craft concise statements that position the value proposition of individual products/services around the pressing concerns in the market, thereby showing how the organization's offerings are the right fit for the customers."@en,
        "针对特定客户群体制定核心传播信息。围绕市场紧迫关切，提炼简洁有力的价值主张陈述，清晰展现组织的产品/服务项目如何精准契合客户需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.2" ;
    skos:prefLabel "Develop marketing messages"@en,
        "制定营销信息"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Determining the appropriate audience to direct marketing efforts at. Identify the particular group of customers to target. Discover the appropriate customer groups at a micro-level. Use techniques such as segmentation analysis, whereby the entire population is sliced according to certain demographic or behavioral attributes."@en,
        "精准识别营销活动的目标受众；在微观层面细分客户群体；运用人口统计学或行为特征等维度开展客户细分分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.3" ;
    skos:prefLabel "Define target audience"@en,
        "界定目标受众"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Developing a scheme for executing the promotional programs and campaigns, and testing these on sample audiences. Create a program plan, and carry out trials for promotional activities. Develop a scheme for how, when, where, and by whom the promotional schemes and campaigns will be deployed. Design incentives that convince or tempt the consumer to take up the organization's offerings. Conduct focus groups and pilot programs that reach out to a smaller number of people from among the target audiences to validate effectiveness."@en,
        "制定促销活动与营销战役的执行方案，并面向样本受众开展测试；编制促销项目计划，实施试点活动；明确促销方案与战役的执行方式、时间、地点及责任主体；设计激励机制以增强消费者采纳意愿；通过焦点小组与小规模试点项目验证方案有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.4" ;
    skos:prefLabel "Plan and test promotional activities"@en,
        "规划并测试促销活动"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Executing promotional programs in the market for reaching out to the desired customer segments. Implement the promotional schemes and campaigns. Create collaterals for the dissemination of information about the product, product line, brand, or company to the target audiences in an effective manner. Leverage relationships with distributors, vendors, and retailers. Consider enlisting professional services such as design, PR, and advertising firms."@en,
        "面向目标客户群落地执行促销项目；实施促销方案与营销战役；高效制作并分发面向目标受众的产品、产品线、品牌或企业宣传物料；协同分销商、供应商与零售商资源；酌情引入专业服务机构（如设计、公关、广告公司）支持执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.5" ;
    skos:prefLabel "Execute promotional activities"@en,
        "执行促销活动"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.6" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Evaluating the success of promotional programs through metrics that track the impact of these activities. Examine the performance of promotional activities. Measure the success of these programs through metrics representative of customer uptake, market penetration, sustenance of impact created, revenue growth through offerings marketed, etc. Measure through primary data collection. Analyze through various statistical techniques to generate insights."@en,
        "依托可衡量指标评估促销成效，追踪活动实际影响；检视促销活动绩效；通过客户采纳率、市场渗透率、影响持续性、营销带动的营收增长等代表性指标衡量效果；开展一手数据采集；运用多元统计方法深度分析，生成业务洞见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.6" ;
    skos:prefLabel "Evaluate promotional performance metrics"@en,
        "评估促销绩效指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.7" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Fine-tuning promotional activities by employing the insights gleaned from the quantitative, as well as any qualitative, performance evaluations. Change certain attributes of the schemes, campaigns, and programs deployed in order to increase the impact generated, in terms of measures already agreed upon such as customer uptake, market penetration, sustenance of impact created, and revenue growth through offerings marketed."@en,
        "基于定量及定性绩效评估结果优化促销活动；调整已部署方案、战役与项目的具体属性，以提升客户采纳率、市场渗透率、影响持续性及营销带动的营收增长等既定指标表现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.7" ;
    skos:prefLabel "Refine promotional performance metrics"@en,
        "优化促销绩效指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.4.8" ;
    skos:broader <https://oprocess.net/opf/node/3.3.4> ;
    skos:definition "Incorporating the understanding developed by studying promotional activities as well as refining them. Include the best practices and value-enhancing attributes identified in Refine promotional activities [10171] into similarly planned schemes, programs, and campaigns. Adjust promotional activities to further increase the effectiveness of the overall promotional efforts."@en,
        "将促销活动研究与优化过程中形成的知识沉淀制度化；将‘优化促销活动’[10171]中识别出的最佳实践与价值提升要素，嵌入同类策划的方案、项目与战役中；持续调优促销活动，全面提升整体促销效能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.4.8" ;
    skos:prefLabel "Incorporate learning into future/planned consumer promotions"@en,
        "将经验融入未来/计划中的消费者促销"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.5> ;
    skos:definition "Estimating customer loyalty and the average contribution made by them to revenues, over their lifespan. Use metrics to quantify the commitment of customers to the offerings of the organization, such as measures of tendency to switch brands/providers, number/proportion of return customers, and the number of customers using multiple substitutable offerings."@en,
        "测算客户忠诚度及其全生命周期平均收入贡献；采用客户品牌/供应商转换倾向、复购客户数量/占比、多产品交叉使用客户数等指标，量化客户对组织产品/服务的承诺程度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5.1" ;
    skos:prefLabel "Determine customer lifetime value"@en,
        "测算客户终身价值"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.5> ;
    skos:definition "Analyzing the revenue stream generated by the sale of the organization's products/services in order to identify trends therein. Examine data relating to the inflow of revenue from individual/groups of customers in order to identify patterns in the generation and sustenance of receivables. Conduct statistical analysis over the stream of revenue collected and the point of origin associated with each unit of sale through metrics such as the accounting rate of return, the GAAP revenue over a given period, and customer lifetime revenue."@en,
        "分析组织产品/服务销售所形成的收入流，识别其中趋势；考察单个/群体客户的收入流入数据，识别应收款项的生成与维系规律；结合会计收益率、通用会计准则（GAAP）期间收入、客户终身收入等指标，对收入流及每笔销售来源开展统计分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5.2" ;
    skos:prefLabel "Analyze customer revenue trend"@en,
        "分析客户收入趋势"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.5> ;
    skos:definition "Calculating measures that capture the proportion of customers the organization is able to retain to those it is losing. Compute metrics such as the tendency to switch brands/providers and the proportion of return customers to comprehend the trends within the customer attrition and retention rates."@en,
        "计算客户留存率与流失率之比；通过品牌/供应商转换倾向、复购客户占比等指标，深入理解客户流失与留存趋势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5.3" ;
    skos:prefLabel "Analyze customer attrition and retention rates"@en,
        "分析客户流失率与留存率"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.5> ;
    skos:definition "Studying all measures of the customer's behavior and conduct toward the organization's offerings in order to glean insight and identify patterns into their decision making. Closely examine all categories of data sets over a customer base. Analyze data points related to customer loyalty, retention, value, conversion, level of satisfaction, attrition, etc. Flesh out measures for an all-encompassing analysis that provides a macro-level picture of the customer's behavior and mindset related to the organization's products/services."@en,
        "全面分析客户对组织产品/服务的行为与态度数据，挖掘决策规律与行为模式；系统审视客户数据库全部类别；分析客户忠诚度、留存率、价值、转化率、满意度、流失率等关键数据点；构建涵盖全面的度量体系，呈现客户行为与心智的宏观图景。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5.4" ;
    skos:prefLabel "Analyze customer metrics"@en,
        "分析客户相关指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.5.5" ;
    skos:broader <https://oprocess.net/opf/node/3.3.5> ;
    skos:definition "Reviewing and reappraising the strategies, objectives, and plans for all customer-centered processes. Revisit all customer-focused processes and activities--which relate to their acquisition, conversion, and retention--with the objective of revising them in light of customer analysis. Revise accordingly."@en,
        "审视并重新评估所有以客户为中心的流程策略、目标与计划；结合客户分析结果，全面复盘客户获取、转化与留存等客户导向型流程及活动，并据此修订优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.5.5" ;
    skos:prefLabel "Revise customer strategies, objectives, and plans based on metrics"@en,
        "基于指标修订客户策略、目标与计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.6> ;
    skos:definition "Following postings on social media to promote offerings, raise brand awareness, interact with customers, increase customer engagement and brand loyalty, respond to queries, gauge sentiment regarding company's products or services, and to derive customer insight."@en,
        "监测社交媒体动态，用于推广产品/服务、提升品牌认知度、开展客户互动、增强客户参与度与品牌忠诚度、及时应答咨询、评估客户对产品/服务的情感倾向，并获取客户洞察。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6.1" ;
    skos:prefLabel "Monitor and respond to social media activity"@en,
        "监测并响应社交媒体动态"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.6> ;
    skos:definition "Examining user activity on company, vendor or reseller websites to improve traffic on and to the website, improve user experience on the website to simplify purchasing process and encourage repeat purchases, and to increase the site's visibility in search engine results. Various metrics can be used to measure user activity, such as number of users who are new, returning or unique, time spent on page, session duration, bounce rate, click through rate, conversion rate, and others."@en,
        "分析客户在企业、供应商或经销商网站上的行为数据，以提升网站流量、优化用户体验（简化购买流程、促进重复购买）、提高搜索引擎可见度；常用度量指标包括新访客/回访客/独立访客数量、页面停留时长、会话时长、跳出率、点击率、转化率等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6.2" ;
    skos:prefLabel "Analyze customer website activity"@en,
        "分析客户网站行为"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.6> ;
    skos:definition "Conducting analyses to uncover customer purchasing habits. Detect patterns and categorize users based on similar characteristics and behaviors, demographic information, geographic location, search history, etc."@en,
        "开展客户购买行为分析，识别消费习惯；依据相似特征与行为、人口统计信息、地理位置、搜索历史等维度对用户进行聚类与分类。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6.3" ;
    skos:prefLabel "Analyze customer purchase patterns"@en,
        "分析客户购买模式"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.6> ;
    skos:definition "Creating formulas for personalized offers, purchasing recommendations and targeted advertisements for customers on the basis of previously detected purchase patterns [16615]."@en,
        "基于已识别的购买模式[16615]，构建个性化优惠、购买推荐与定向广告的算法模型。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6.4" ;
    skos:prefLabel "Develop business rules to provide personalized offers"@en,
        "制定个性化优惠业务规则"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.6.5" ;
    skos:broader <https://oprocess.net/opf/node/3.3.6> ;
    skos:definition "Analyzing how well the targeted offers perform to see whether they result in an increased conversion rate. Reanalyze the purchase patterns or modify those business rules that are produce effective recommendations."@en,
        "评估定向营销效果，检验其是否有效提升转化率；重新分析购买模式，或优化生成高质推荐的业务规则。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.6.5" ;
    skos:prefLabel "Monitor effectiveness of personalized offers and adjust offers accordingly"@en,
        "监测个性化优惠效果并动态调整"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.7.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.7> ;
    skos:definition "Creating a strategic road map for how to package products/services into desirable solutions while increasing profitability. Create a scheme for how the organization will bundle and wrap its products/services into a presentable and sellable offering. Consider what aspects or components of an offering the organization can extract the maximum revenue from, and reduce the less profitable constituents while maintaining a high perceptible value for the customers. Balance maximizing profit with benefits to the customer."@en,
        "制定提升盈利性的产品/服务包装战略路线图；设计产品/服务打包与封装方案，形成具备市场吸引力与销售力的整合方案；识别可最大化收益的方案构成要素，精简低利润成分，同时维持客户感知价值；平衡利润最大化与客户利益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.7.1" ;
    skos:prefLabel "Plan packaging strategy"@en,
        "规划包装策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.7.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.7> ;
    skos:definition "Piloting the packaged products/services in the market with a test audience. Create trial runs using techniques such as focus groups of the final product, wrapped and bundled."@en,
        "面向测试受众开展包装后产品/服务的市场试运行；采用焦点小组等方式对最终包装形态开展实测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.7.2" ;
    skos:prefLabel "Test packaging options"@en,
        "测试包装方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.7.3" ;
    skos:broader <https://oprocess.net/opf/node/3.3.7> ;
    skos:definition "Implementing the final packaging. Put into action the packaging strategy in light of the insights accumulated from testing various options."@en,
        "正式实施最终包装方案；依据多轮测试积累的洞察，落地执行包装策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.7.3" ;
    skos:prefLabel "Execute packaging strategy"@en,
        "实施包装策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.7.4" ;
    skos:broader <https://oprocess.net/opf/node/3.3.7> ;
    skos:definition "Fine-tuning the packaging that has been developed and tested using insights gleaned from feedback."@en,
        "基于客户反馈洞察，持续微调已开发并验证的包装方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.7.4" ;
    skos:prefLabel "Refine packaging"@en,
        "优化包装设计"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.8" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Creation of a plan detailing how a company plans to execute a successful product release and promotion, and ultimately its sale to customers."@en,
        "制定产品发布与推广的完整执行计划，最终实现向客户的成功销售。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.8" ;
    skos:prefLabel "Develop go-to-market strategy"@en,
        "制定上市策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.9.1" ;
    skos:broader <https://oprocess.net/opf/node/3.3.9> ;
    skos:definition "Producing or overseeing the creation or acquisition of photos, images and graphics for a product description, advertisement or a website. Like the copy [18131], product images are chosen and edited to enhance the product description and to convince consumers to purchase the product."@en,
        "负责或统筹产品描述、广告或网站所需的图片、图像与图形素材的制作、采购与编辑；如同文案[18131]，产品图片经精选与修图，旨在强化产品描述说服力，驱动消费者购买决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.9.1" ;
    skos:prefLabel "Manage product images"@en,
        "管理产品图片"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.9.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3.9> ;
    skos:definition "Authoring or overseeing the creation of the textual portion of a product description, advertisement, or web page, including the headline, body, product attributes, and brand or advertiser information. A copy is designed to provide information about the product and to catch and hold the interest of prospective buyers long enough to persuade them to make a purchase. The copy of a website is called its content."@en,
        "负责或统筹产品描述、广告或网页的文字内容创作，包括标题、正文、产品属性、品牌或广告主信息；文案旨在传递产品信息，并在有限时间内吸引潜在买家注意力，促使其完成购买；网站文案即为其内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.9.2" ;
    skos:prefLabel "Manage product copy"@en,
        "管理产品文案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.4.1> ;
    skos:definition "Gathering all information about sales orders into an index. Create a directory of all sales orders, whether open or those which have been fulfilled. Track what product/service was ordered, the quantity ordered, who ordered it, the delivery date, the shipping method, the unit price and line total, payment terms, and any discount applied."@en,
        "汇总全部销售订单信息并建立索引；构建涵盖未结与已履约订单的销售订单目录；追踪所订产品/服务、订购数量、订购方、交付日期、运输方式、单价与行项目总额、付款条款及适用折扣等字段。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.1.1" ;
    skos:prefLabel "Gather current and historic order information"@en,
        "收集当前及历史订单信息"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.4.1> ;
    skos:definition "Analyzing sales order data to identify patterns in order to capitalize on emerging trends in the industry or the economy. Closely examine the directory of sales orders. Discern any patterns from this index, which is representative of the demand for the organization's offerings. Identify trends among the various segments of the organization's customer base to create forecasts. Glean patterns from this analysis, including the triangulation of segments that are showing the most growth in demand or those that represent the highest decline revenue, industry-wide trends such as decline/boost in overall demand, and any unusual trends that lie outside of the organization's expectations."@en,
        "分析销售订单数据以识别规律，把握行业或经济新趋势；深度审阅销售订单目录；从该需求表征索引中识别模式；按客户细分维度识别趋势，支撑销售预测；提炼分析结论，包括需求增长最快/营收下滑最显著的客户三角细分、行业整体需求升降趋势，以及超出组织预期的异常趋势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.1.2" ;
    skos:prefLabel "Analyze sales trends and patterns"@en,
        "分析销售趋势与模式"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/3.4.1> ;
    skos:definition "Calculating the future demand for the organization's products/services. Use the trends and patterns identified in the sales data to estimate future demand. Use forecast to prepare for future customer demand and to recalibrate the strategic course of functions and business units."@en,
        "测算组织产品/服务的未来需求；基于销售数据识别的趋势与模式，估算未来需求；利用预测结果提前应对客户需求，并重新校准各职能与业务单元的战略方向。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.1.3" ;
    skos:prefLabel "Generate sales forecast"@en,
        "生成销售预测"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/3.4.1> ;
    skos:definition "Reviewing promotional activities' effect on the sales orders. Analyze all promotional events and campaigns that the organization has already employed or is planning to deploy."@en,
        "评估促销活动对销售订单的实际影响；全面分析组织已实施或计划开展的各类促销事件与战役。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.1.4" ;
    skos:prefLabel "Analyze historical and planned promotions and events"@en,
        "分析历史及计划中的促销与活动"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Identifying collaboration opportunities for selling, marketing, and distributing the organization's products/services. Determine any scope for partnering with other economic agents, with synergies for the marketing, sales, and/or distribution of the organization's products/services. Identify alliance opportunities that target customer segments who would be interested."@en,
        "识别在销售、营销与分销环节开展协作的机会；评估与其他经济主体在营销、销售和/或分销组织产品/服务方面的协同潜力；锁定对组织产品/服务感兴趣的客户细分作为联盟目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.1" ;
    skos:prefLabel "Identify alliance opportunities"@en,
        "识别联盟机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.10" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Combining scheduled promotional, category management and trade marketing events into unified timetables. Update the calendars. Register new events."@en,
        "整合促销活动、品类管理活动与贸易营销活动日程，形成统一时间表；动态更新日历，登记新增活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.10" ;
    skos:prefLabel "Develop promotional and category management calendars (trade marketing calendars)"@en,
        "编制促销与品类管理日历（贸易营销日历）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.11" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Establishing long term customer sales plans to assess current sales and to determine future sales objectives, strategies for achieving the goals, and available resources."@en,
        "制定长期客户销售计划，评估当前销售状况，明确未来销售目标、达成路径及可用资源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.11" ;
    skos:prefLabel "Create strategic and tactical sales plans by customer"@en,
        "按客户制定战略性与战术性销售计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.12" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Sending invitations and distributing information about upcoming events to customer teams and other involved entities."@en,
        "向客户团队及相关方发送活动邀请函并分发活动信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.12" ;
    skos:prefLabel "Communicate planning information to customer teams"@en,
        "向客户团队传达规划信息"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Creating the frameworks needed to select alliance partners, and maintaining relationships with them. Create a framework for structured programs that can receive and support multiple alliances. Clearly outline the responsibilities and benefits of the alliance partners. Create frameworks for selecting the right alliance partners, and maintain a relationship with them. Create or repurpose teams of relationship managers and outline a methodology for selecting alliance partners."@en,
        "构建联盟伙伴遴选与关系维护框架；设计可承载并支持多类型联盟的结构化项目体系；清晰界定联盟伙伴权责与收益；组建或复用关系管理团队，制定联盟伙伴遴选方法论。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.2" ;
    skos:prefLabel "Design alliance programs and methods for selecting and managing relationships"@en,
        "设计联盟项目及合作伙伴遴选与管理机制"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Choosing alliance partners using the selected programs and methodology. Select the most feasible and profitable alliance partners, based on Design alliance programs and methods for selecting and managing relationships [10139] and through a careful scrutiny of the potential alliance."@en,
        "依据既定项目与方法论遴选联盟伙伴；基于‘设计联盟项目及伙伴遴选与关系管理方法’[10139]，结合对潜在联盟的审慎评估，择优选择可行性与盈利性俱佳的合作伙伴。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.3" ;
    skos:prefLabel "Select alliances"@en,
        "遴选联盟伙伴"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Implementing category management strategies for customers through the use of consumer insights and understanding of customer specifics. Develop consumer and channel insights. Establish long term strategies, objectives and targets across the brand."@en,
        "通过消费者洞察及对客户特性的深入理解，实施面向客户的品类管理策略；开展消费者与渠道洞察分析；制定覆盖全品牌的长期战略、目标与绩效指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.4" ;
    skos:prefLabel "Develop customer trade strategy and customer objectives/targets"@en,
        "制定客户贸易策略及客户目标/指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Establishing business-to-business marketing campaigns and financial incentives for wholesalers, dealers, distributors and other intermediaries that the company uses to distribute its products or services."@en,
        "面向批发商、经销商、分销商及其他中间渠道合作伙伴，策划并实施B2B营销活动与财务激励方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.5" ;
    skos:prefLabel "Define trade programs and funding options"@en,
        "定义贸易计划及资金支持方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.6" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Arranging meetings with trade partners to coordinate logistics, manage critical resources, resolve bottlenecks, and schedule urgent or time-sensitive matters."@en,
        "组织与贸易伙伴的协调会议，统筹物流安排、关键资源管理、瓶颈问题解决，以及紧急或时效性强事项的排期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.6" ;
    skos:prefLabel "Conduct planning activities for major trade customers"@en,
        "开展重点贸易客户规划活动"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.7" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Designing strategies for effectively managing, identifying, and countering any possible issues from the alliance partnerships formed. Create a strategic road map for managing the partnerships forged through Design alliance programs and methods for selecting and managing relationships [10139]. Determine where the alliance partnerships are headed, possible problems or pushback from the partners, how these issues might be countered, how these alliance partnerships would evolve in the future, any other business cases where these partnerships might be deployed, etc."@en,
        "设计联盟伙伴关系的风险识别、应对与管控策略；制定设计联盟计划所构建合作关系的战略路线图，明确合作伙伴遴选与关系管理方法；研判联盟发展方向、潜在阻力或合作方异议、应对举措、未来演进路径，以及该类联盟可拓展的其他业务场景。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.7" ;
    skos:prefLabel "Develop partner and alliance management strategies"@en,
        "制定合作伙伴与联盟管理策略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.8" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Setting targets for organizational achievement. This includes what the organization aims to achieve from and how it wishes to manage both the individual partners and the alliance as a whole. Set immediate through long-term goals including revenue targets, market penetration, footfall numbers, and geographical coverage."@en,
        "设定组织级业绩目标，涵盖对单个合作伙伴及整体联盟的管理预期；设定涵盖短期至长期的多维目标，包括营收目标、市场渗透率、客流量及地理覆盖范围。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.8" ;
    skos:prefLabel "Establish partner and alliance management goals"@en,
        "设定合作伙伴与联盟管理目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.2.9" ;
    skos:broader <https://oprocess.net/opf/node/3.4.2> ;
    skos:definition "Setting up strategic alliances with key trade partners and ratifying partnership agreements."@en,
        "与关键贸易伙伴建立战略合作关系，并签署正式合作协议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.2.9" ;
    skos:prefLabel "Establish partner and alliance agreements"@en,
        "建立合作伙伴与联盟协议"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Determining the percentage of total sales volume in the market for a particular product."@en,
        "测算特定产品在目标市场中的销售份额占比。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.1" ;
    skos:prefLabel "Calculate product market share"@en,
        "计算产品市场份额"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Estimating revenue from the sale of products/services. Approximate the anticipated sale of products/services and multiply it by the selling price of the respective offering. (This represents the total amount of money that the organization receives from the sale of its portfolio of offerings.)"@en,
        "估算产品/服务销售收入：基于预估销量乘以对应售价得出（即组织从其全部产品/服务组合销售中获得的总收入）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.2" ;
    skos:prefLabel "Calculate product revenue"@en,
        "计算产品收入"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Calculating the variable costs of production. Approximate those costs that depend on the volume of products/services produced by the organization."@en,
        "核算生产可变成本：估算随产品/服务产量变动而变化的成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.3" ;
    skos:prefLabel "Determine variable costs"@en,
        "确定可变成本"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Calculating the overhead costs associated with selling the organization's products/services. Determine fixed costs that are not directly related to the volume of products/services processed or the sale of these offerings (e.g., expense over machinery and equipment)."@en,
        "核算销售相关间接费用：确定与产品/服务处理量或销售量无直接关联的固定成本（如设备与机械折旧等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.4" ;
    skos:prefLabel "Determine overhead and fixed costs"@en,
        "确定间接费用与固定成本"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.5" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Calculating the net income. Calculate the organization's profitability by accounting for Determine overhead and fixed costs [10145] and Determine variable costs [10144]."@en,
        "计算净利润：综合考虑间接费用与固定成本（[10145]）、可变成本（[10144]），核算组织盈利能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.5" ;
    skos:prefLabel "Calculate net profit"@en,
        "计算净利润"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.3.6" ;
    skos:broader <https://oprocess.net/opf/node/3.4.3> ;
    skos:definition "Creating a plan in measurable terms for the financial outlay that best captures resource allocation for the sales forecast. Consider the outlay of capital, HR, raw materials, and provisions needed to reach sales targets."@en,
        "以可量化方式制定销售预算计划，精准反映资本、人力资本（HR）、原材料及必要保障资源的配置，以支撑销售目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.3.6" ;
    skos:prefLabel "Create budget"@en,
        "编制预算"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/3.4> ;
    skos:definition "Establishing specific quantitative and qualitative measures of realizing sales targets. Create sales targets by analyzing historical sales data and comparing the forecasts to results, in light of customer and market intelligence. Examine the performance of sales personnel in light of market opportunities. Based on this review, establish sales targets along with metrics to quantify these goals, corresponding with the overall business strategy."@en,
        "建立实现销售目标的定量与定性衡量体系：基于历史销售数据、客户与市场情报，结合预测与实际结果对比，设定销售目标；结合市场机会评估销售团队绩效，并据此制定与整体业务战略一致的销售目标及配套量化指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.4" ;
    skos:prefLabel "Establish sales goals and measures"@en,
        "设定销售目标与衡量指标"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/3.4> ;
    skos:definition "Identifying the appropriate measures that can represent key attributes of the customer management function. Select measures to track customer activity, feedback, satisfaction, organizational responsiveness to customer needs, and general data on how the organization is managing customer accounts, leads, and contacts. Build on customer and market intelligence to identify metrics gauging aspects related to customer management. Select measures based on the nature of the business, the type and size of customer base, strategic goals, and the model used to structure sales and customer relationships."@en,
        "甄选能有效表征客户管理职能核心特征的关键指标：选取用于追踪客户行为、反馈、满意度、组织响应速度，以及客户账户、线索与联系人管理状况的指标；依托客户与市场情报，构建客户管理相关维度的度量体系；指标选择需兼顾业务性质、客户规模与结构、战略目标，以及销售与客户关系管理模式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.5" ;
    skos:prefLabel "Establish customer management measures"@en,
        "设定客户管理衡量指标"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Identifying people who can be converted into customers. Leverage personal and professional networks, business research over databases and directories, and secondary research."@en,
        "识别具备转化潜力的目标人群：借助个人与职业网络、数据库及名录商业调研、二手资料研究等途径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.1" ;
    skos:prefLabel "Identify potential customers"@en,
        "识别潜在客户"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Qualifying the prospective customers into credible leads by gauging their behavior against the organization's offering. Triangulate leads to increase the efficiency of sales and marketing efforts. Build a detailed profile of the prospects. Determine what products/services they already use, if they have decision-making authority, their views on the products/services they already use, how prone they are to switch, if the organization's solution better in some attributes than those prospects currently use, etc."@en,
        "依据组织产品/服务匹配度对潜在客户开展线索资质评估；采用三角验证法提升销售与营销效率；构建详尽的客户画像，分析其现有使用的产品/服务、决策权限、对现有方案的评价、转换意愿、我方解决方案相较其当前选择的优势维度等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.2" ;
    skos:prefLabel "Identify/receive leads/opportunities"@en,
        "识别/获取销售线索/商机"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Reviewing the set of potential customers and sales opportunities. Approve the leads that meet company requirements on new businesses."@en,
        "评审潜在客户清单与销售机会池，批准符合公司新业务准入标准的线索。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.3" ;
    skos:prefLabel "Validate and qualify leads/opportunities"@en,
        "验证并甄别销售线索/商机"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Aligning sales leads with business objectives."@en,
        "将销售线索与企业战略目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.4" ;
    skos:prefLabel "Match opportunities to business strategy"@en,
        "将商机与业务战略匹配"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Creating plans about how to close leads and win sales opportunities."@en,
        "制定线索转化与销售机会赢取的具体行动计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.5" ;
    skos:prefLabel "Develop opportunity win plans"@en,
        "制定商机赢标计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.6" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Overseeing and planning the acquisition of new customers."@en,
        "统筹规划新客户获取全过程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.6" ;
    skos:prefLabel "Manage opportunity pipeline"@en,
        "管理商机管道"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.7" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1> ;
    skos:definition "Planning the distribution of personnel across various sales functions. Match the capabilities of individual employees with the skill sets needed for specific roles. Seek assistance from HR."@en,
        "统筹销售职能人员配置：按岗位能力需求匹配员工专长，必要时协同人力资本（HR）部门支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.7" ;
    skos:prefLabel "Determine sales resource allocation"@en,
        "确定销售资源配置"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.1.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1.8> ;
    skos:definition "Communicating with customers and prospects with the intent of creating sales opportunities. Reach out to existing and prospective customers through alternate media and networking channels, apart from cold calling/emailing."@en,
        "主动触达客户与潜在客户，创造销售机会：除电话/邮件外，通过多元媒体与社交网络渠道开展沟通。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8.1" ;
    skos:prefLabel "Perform sales calls"@en,
        "执行销售拜访"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.1.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1.8> ;
    skos:definition "Capitalizing on sales calls by pitching on bids and closing deals. Outline the nature and scope of the work, draft agreement terms, prepare proposals and agreements, and propose timelines and prices."@en,
        "高效转化销售拜访成果：精准推介方案、推动签约落地；明确工作范围与内容、拟定协议条款、编制提案与合同文本、提出交付周期与报价方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8.2" ;
    skos:prefLabel "Perform pre-sales activities"@en,
        "开展售前活动"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.1.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1.8> ;
    skos:definition "Arranging and leading meetings, seminars, workshops and training events with customers to educate them about current offerings, best practices and technological advances to provide more value to customers and to increase their attrition and loyalty."@en,
        "面向客户组织并主持会议、研讨会、工作坊及培训活动，宣贯现有产品/服务、最佳实践与技术进展，提升客户价值感知、降低流失率、增强忠诚度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8.3" ;
    skos:prefLabel "Manage customer meetings/workshops"@en,
        "管理客户会议/研讨会"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.1.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1.8> ;
    skos:definition "Formalizing a sale by reaching an agreement on terms of the deal. Negotiate on the price, and reach a consensus on the terms and conditions."@en,
        "通过协商达成交易条款，正式确认销售意向：就价格及合同条款与条件开展谈判并形成共识。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8.4" ;
    skos:prefLabel "Close the sale"@en,
        "完成销售签约"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.1.8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.1.8.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.1.8> ;
    skos:definition "Completing all the paper-work associated with the sale of its products/services. Exchange any pertinent legal/financial information required for completing the sale, signing of a contract/work-order, and issuing copies of bills/invoices."@en,
        "完成销售全流程文书工作：交换完成交易所需的法律/财务文件，签署合同或工单，并开具发票/账单副本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.1.8.5" ;
    skos:prefLabel "Record outcome of sales process"@en,
        "记录销售流程结果"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2> ;
    skos:definition "Choosing principal clients that are vital for the company."@en,
        "甄选对公司具有战略价值的核心客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.1" ;
    skos:prefLabel "Select key customers/accounts"@en,
        "遴选关键客户/账户"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2> ;
    skos:definition "Creating a plan for managing the accounts of key customers in order to better maintain relationships with them. Chart a scheme for managing sales. Create a plan for administering accounts of the significant and most important customers of the organization. Coordinate the accounts of principal clients."@en,
        "制定核心客户账户管理计划，强化客户关系维系；绘制销售管理路线图；针对组织最重要客户制定专属账户管理方案；统筹核心客户账户协同管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.2" ;
    skos:prefLabel "Develop sales/key account plan"@en,
        "制定销售/关键客户账户计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2> ;
    skos:definition "Handling the accounts of important clients."@en,
        "开展重点客户账户日常运营管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.3" ;
    skos:prefLabel "Manage sales/key account plan"@en,
        "管理销售/关键客户账户计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2> ;
    skos:definition "Managing the organization's relationship with its customers, by systematically coordinating interactions over multiple touch points, on a regular basis. Coordinate the organization's efforts to reach out to its customers. Create and manage effective touch points for interactions from the customers, which could include emails, social-media interactions, newsletters, and direct conversations."@en,
        "系统化管理客户关系：定期、跨触点统筹客户交互；整合组织面向客户的各项触达行动；构建并维护高效客户互动触点，包括电子邮件、社交媒体互动、电子简报及面对面沟通等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.4" ;
    skos:prefLabel "Manage customer relationships"@en,
        "管理客户关系"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2.5> ;
    skos:definition "Gathering the data about customers. Combine the information available locally with the data obtained from external sources."@en,
        "整合客户数据采集：融合本地已有信息与外部来源获取的数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.5.1" ;
    skos:prefLabel "Collect and merge internal and third-party customer information"@en,
        "收集并整合内外部客户信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2.5> ;
    skos:definition "Eliminating redundant information in customer data."@en,
        "消除客户数据中的冗余信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.5.2" ;
    skos:prefLabel "De-duplicate customer data"@en,
        "客户数据去重"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Accepting procurement proposals."@en,
        "接收采购提案"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.1" ;
    skos:prefLabel "Receive Request For Proposal (RFP)/Request For Quote (RFQ)"@en,
        "接收招标书（RFP）/询价单（RFQ）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.10" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Reviewing profitability data. Analyze systematically all relevant metrics and parameters. Report findings and make recommendations for changes to operational strategies."@en,
        "审核盈利能力数据；系统分析所有相关指标与参数；形成报告并就运营策略调整提出建议"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.10" ;
    skos:prefLabel "Conduct profitability analysis"@en,
        "开展盈利性分析"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.11" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Overseeing the internal review process."@en,
        "监督内部评审流程"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.11" ;
    skos:prefLabel "Manage internal reviews"@en,
        "组织内部评审"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.12> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.12" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Obtaining required company-internal authorizations."@en,
        "获取公司内部所需的审批授权"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.12" ;
    skos:prefLabel "Manage internal approvals"@en,
        "管理内部审批"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.13> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.13" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Delivering the proposal to the potential client."@en,
        "向潜在客户递交提案"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.13" ;
    skos:prefLabel "Submit/present bid/proposal/quote to customer"@en,
        "向客户提交或演示投标/方案/报价"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.14> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.14" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Amending bids, proposals or quotes with more accurate time, cost or delivery estimates."@en,
        "根据更准确的时间、成本或交付估算，修订投标、提案或报价"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.14" ;
    skos:prefLabel "Revise bid/proposal/quote"@en,
        "修订投标/方案/报价"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.15> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.15" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Handling proposals depending on whether they were accepted or rejected."@en,
        "依据提案是否被接受或拒绝，开展相应后续处理"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.15" ;
    skos:prefLabel "Manage notification outcome"@en,
        "管理结果通知"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Clarifying the details about procurement requests, such as the scope, timeline, data sources, type and characteristics and evaluation criteria for the goods or services to be delivered, and any additional terms, conditions or special requirements."@en,
        "澄清采购需求的细节，包括范围、时间表、数据来源、拟交付商品或服务的类型与特征、评估标准，以及任何附加条款、条件或特殊要求"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.2" ;
    skos:prefLabel "Refine customer requirements"@en,
        "细化客户需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Evaluating individual price and delivery solicitations for their strengths and weaknesses. Analyze how closely the submitted bids respond to the requirements outlined in the RFPs."@en,
        "评估各价格与交付邀标方案的优劣势；分析所提交投标对RFP中各项要求的响应程度"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.3" ;
    skos:prefLabel "Review RFP/RFQ request"@en,
        "评审招标书（RFP）/询价单（RFQ）请求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Comparing the proposals submitted by different bidders in terms of cost, efficiency and value."@en,
        "从成本、效率与价值维度对比不同投标方提交的提案"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.4" ;
    skos:prefLabel "Perform competitive analysis"@en,
        "开展竞争分析"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Assessing the business strategy, forecasted performance, financing and cash flow of the proposals."@en,
        "评估提案所涉业务战略、预测绩效、融资能力及现金流状况"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.5" ;
    skos:prefLabel "Validate with strategy/business plans"@en,
        "与战略及业务计划对齐验证"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.6" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Deepening knowledge about the customer's field of operation and business needs."@en,
        "深化对客户所在行业及业务需求的理解"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.6" ;
    skos:prefLabel "Understand customer business and requirements"@en,
        "理解客户业务与需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.7" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Creating a plan with detailed steps about how produce and deliver the goods or services."@en,
        "制定详细的产品或服务生产与交付执行计划"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.7" ;
    skos:prefLabel "Develop solution and delivery approach"@en,
        "制定解决方案与交付方法"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.8" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Determining the needs for internal resources and vacancies."@en,
        "确定内部资源需求及岗位空缺情况"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.8" ;
    skos:prefLabel "Identify staffing requirements"@en,
        "识别人员配置需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.3.9" ;
    skos:broader <https://oprocess.net/opf/node/3.5.3> ;
    skos:definition "Establishing predicted delivery costs, fees and timelines."@en,
        "预估交付成本、费用及时间周期"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.3.9" ;
    skos:prefLabel "Develop pricing and scheduling estimates"@en,
        "编制定价与进度估算"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Receiving and confirming orders from customers. Verify that no extra expenses have to be disbursed on part of the organization for labor or inventory when processing the order."@en,
        "接收并确认客户订单；核实订单处理过程中组织是否需额外承担人工或库存成本"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.1" ;
    skos:prefLabel "Accept and validate sales orders"@en,
        "接收并校验销售订单"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Managing essential information of customer accounts."@en,
        "管理客户账户核心信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.1" ;
    skos:prefLabel "Administer key account details"@en,
        "管理关键客户信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Obtaining detailed information about customers."@en,
        "获取客户详细信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.2" ;
    skos:prefLabel "Retrieve full customer details"@en,
        "调取完整客户信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Altering information about involved parties."@en,
        "修改相关方信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.3" ;
    skos:prefLabel "Modify involved party details"@en,
        "修改相关方信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Documenting address information."@en,
        "记录地址信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.4" ;
    skos:prefLabel "Record address details"@en,
        "记录地址信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Documenting contact information."@en,
        "记录联系人信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.5" ;
    skos:prefLabel "Record contact details"@en,
        "记录联系人信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.6" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Providing information about important business rules regarding communicating with customers."@en,
        "提供关于客户沟通重要业务规则的信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.6" ;
    skos:prefLabel "Record key customer communication profile details"@en,
        "记录关键客户沟通画像信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.7" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Revising information about involved parties."@en,
        "更新相关方信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.7" ;
    skos:prefLabel "Review involved party information"@en,
        "审核相关方信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.2.8" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4.2> ;
    skos:definition "Dismissing information about involved parties."@en,
        "注销相关方信息"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.2.8" ;
    skos:prefLabel "Terminate involved party information"@en,
        "终止相关方信息"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Ascertaining the volume or scale of products/services to provide to customers to fulfill sales orders. Check the finished products stored in warehouses, the production capacity, and (in the case of services) the processing speed, as well as work force availability."@en,
        "核定满足销售订单所需的产品/服务数量或规模；核查仓库成品库存、生产能力，以及（针对服务）处理速度与人力资源可用性"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.3" ;
    skos:prefLabel "Determine availability"@en,
        "确认资源可用性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Devising a blueprint for order fulfillment. Create a schematic flow encompassing all activities to deliver orders to the customers. Outline a procedure for satisfying these orders by answering questions about what needs to happen in sequence to realize an order."@en,
        "设计订单履约蓝图；构建涵盖全部交付活动的流程图；明确实现订单所需的顺序化操作步骤"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.4" ;
    skos:prefLabel "Determine fulfillment process"@en,
        "确定履约流程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Processing any unfulfilled orders, and updating the status of any orders that have been accepted and are being attended to. Deliver on any purchase orders that remain unserviced due to temporary unavailability of the product/service. Manage any updates to the sales orders. Revise their status in the order system."@en,
        "处理未履约订单，并更新已受理且正在执行的订单状态；对因产品/服务暂时缺货而未能及时履行的采购订单予以补发；管理销售订单变更，并在订单系统中同步更新其状态"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.5" ;
    skos:prefLabel "Process back orders and updates"@en,
        "处理缺货订单及更新"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.6" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Attending to any queries received from the customers, even after a sales order has been serviced. Deploy ad hoc personnel for managing these enquiries."@en,
        "在销售订单履约完成后，继续响应客户咨询；视需调配临时人员处理此类问询"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.6" ;
    skos:prefLabel "Handle sales order inquiries including post-order fulfillment transactions"@en,
        "处理销售订单查询（含履约后交易）"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.4.7" ;
    skos:broader <https://oprocess.net/opf/node/3.5.4> ;
    skos:definition "Providing visibility into the status and progress of products associated with customer orders to support order fulfillment, customer communication, and issue resolution."@en,
        "提供客户订单关联产品的实时状态与进度可视性，以支持订单履约、客户服务及问题解决"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.4.7" ;
    skos:prefLabel "Provide product tracking"@en,
        "提供产品追踪服务"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5.1> ;
    skos:definition "Provide training and certification to develop strategies for marketing-driven sales."@en,
        "提供培训与认证，助力构建以营销驱动的销售策略"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.1.1" ;
    skos:prefLabel "Provide certification enablement training"@en,
        "提供认证赋能培训"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5.1> ;
    skos:definition "Reviewing, processing and issuing certifications and accrediting skills and competencies."@en,
        "审核、处理并颁发认证，认可合作伙伴的技能与能力"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.1.2" ;
    skos:prefLabel "Manage certifications and skills"@en,
        "管理认证与技能资质"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5.1> ;
    skos:definition "Backing sales partners and strategic alliances."@en,
        "支持销售合作伙伴与战略联盟"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.1.3" ;
    skos:prefLabel "Provide support to partners/alliances"@en,
        "为合作伙伴/联盟提供支持"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/3.5.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.2" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5> ;
    skos:definition "Distributing marketing materials and sales brochures to entities that the company partners with."@en,
        "向公司合作方分发营销材料与销售手册"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.2" ;
    skos:prefLabel "Provide marketing materials to sales partners/alliances"@en,
        "向销售合作伙伴/联盟提供营销资料"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.3" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5> ;
    skos:definition "Examining the performance of its partners/alliances in selling its products/services. Use metrics such as growth in revenue generated, conversion rate, and total outreach to customers for assessing the performance results."@en,
        "评估合作伙伴/联盟在销售本组织产品/服务方面的绩效；采用营收增长率、转化率、客户触达总量等指标衡量绩效结果"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.3" ;
    skos:prefLabel "Evaluate partner/alliance results"@en,
        "评估合作伙伴/联盟绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.4" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5> ;
    skos:definition "Managing the repository of data relating to the organization's partners/alliances over time. Store, maintain, access, revise, and use all data on partners/alliances. Manage data. Ensure its security. Determine legitimate use cases that are beneficial to the organization."@en,
        "管理组织合作伙伴/联盟关系的长期数据仓库：存储、维护、访问、修订和使用所有合作伙伴/联盟相关数据；确保数据安全；识别并界定有利于组织的合法使用场景。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.4" ;
    skos:prefLabel "Manage sales partner/alliance master data"@en,
        "管理销售合作伙伴/联盟主数据"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.6" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Execution of sales at physical / brick and mortar locations."@en,
        "在实体门店（线下门店）执行销售。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.6" ;
    skos:prefLabel "Perform sales at physical outlets"@en,
        "开展实体渠道销售"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.7" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Execution of sales within field/remote locations.  This could be any location that is not part of a headquarters location."@en,
        "在实地/远程场所执行销售（不含总部所在地的任何场所）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.7" ;
    skos:prefLabel "Perform field sales"@en,
        "开展外勤销售"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.8" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Execution of sales in an online environment."@en,
        "在在线环境中执行销售。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.8" ;
    skos:prefLabel "Perform digital sales"@en,
        "开展数字化销售"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Creating quantifiable strategic objectives for each manufacturing segment in conjunction with sales projections."@en,
        "结合销售预测，为各制造业务单元设定可量化的战略目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.1" ;
    skos:prefLabel "Define manufacturing goals"@en,
        "设定制造目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Setting up internal rules and regulations regarding the employees and the materials."@en,
        "制定关于员工与物料的内部规章制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.2" ;
    skos:prefLabel "Define labor and materials policies"@en,
        "制定人力与物料政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Creating rules and regulations regarding contracting out of a business process to another party in order to reduce costs."@en,
        "制定业务流程外包规则，以降低成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.3" ;
    skos:prefLabel "Define outsourcing policies"@en,
        "制定外包政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Designing rules and regulations pertaining to the expenditure incurred in acquiring or upgrading the existing stock of manufacturing capital."@en,
        "制定关于购置或升级现有制造资本所涉支出的规章制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.4" ;
    skos:prefLabel "Define capital expense policies"@en,
        "制定资本性支出政策"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Outlining the manufacturing and processing capacities of the organization. Delineate the capabilities required for optimizing output with available resources. Analyze capabilities possessed by the organization concerning the raw materials required and the process necessitated for producing finished products."@en,
        "明确组织的制造与加工能力；界定优化现有资源产出所需的能力；分析组织在原材料获取及成品制造工艺方面所具备的能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.5" ;
    skos:prefLabel "Define capacities"@en,
        "设定产能"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.6" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Defining limitations in the ability of the organization's supply chain to deliver a new stock, and creating a network of production stakeholders. Frame and manage relationships within the flow of manufacturing and processing operations. Identify probable supply issues."@en,
        "界定组织供应链交付新库存的能力限制，构建生产利益相关方网络；统筹管理制造与加工流程中的各方关系；识别潜在供应风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.6" ;
    skos:prefLabel "Define production network and supply constraints"@en,
        "设定生产网络与供应约束条件"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.7" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Outlining the scheme of processing inventory into finished products/services. This includes the use of raw materials, machinery, skill sets, and knowledge to create new offerings."@en,
        "规划将库存转化为成品/服务的加工流程，涵盖原材料、设备、技能与知识等要素，以开发新产品或服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.7" ;
    skos:prefLabel "Define production process"@en,
        "定义生产工艺"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.8" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Establishing or prescribing methods to be followed routinely for the performance of designated operations or in designated situations. This may include step-by-step instructions to help workers carry out complex routine operations. The goal is to improve efficiency, quality, and uniformity of performance, while reducing miscommunication, failure, or rework."@en,
        "建立或规定特定作业或特定情境下须常规遵循的操作方法，包括分步操作指南，以提升效率、质量与执行一致性，并减少沟通失误、失败或返工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.8" ;
    skos:prefLabel "Define standard operating procedures"@en,
        "制定标准作业规程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.1.9" ;
    skos:broader <https://oprocess.net/opf/node/4.1.1> ;
    skos:definition "Determining the floor plans for the processing facility that is meant for delivering finished products/services. Identify the totality of infrastructure needed for using this space in the manufacturing process, including machinery, factory floors, offices, and furniture."@en,
        "确定用于交付成品/服务的加工设施布局方案；识别制造过程中该空间所需的全部基础设施，包括设备、厂房、办公区及家具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.1.9" ;
    skos:prefLabel "Define production workplace layout and infrastructure"@en,
        "规划生产场所布局与基础设施"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP2" ;
    skos:broader <https://oprocess.net/opf/node/4.1.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Plan Source'."@en,
        "SCOR DS 14.0‘规划采购’流程中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.10.1" ;
    skos:prefLabel "Identify and assess source requirements"@en,
        "识别并评估采购需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP2" ;
    skos:broader <https://oprocess.net/opf/node/4.1.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Plan Source'."@en,
        "SCOR DS 14.0‘规划采购’流程中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.10.2" ;
    skos:prefLabel "Balance source resources"@en,
        "平衡采购资源"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP2" ;
    skos:broader <https://oprocess.net/opf/node/4.1.10> ;
    skos:definition "SCOR DS 14.0 activity in 'Plan Source'."@en,
        "SCOR DS 14.0‘规划采购’流程中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.10.3" ;
    skos:prefLabel "Establish sourcing plans"@en,
        "制定采购计划"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.1.11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP3" ;
