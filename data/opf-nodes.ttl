    skos:definition "Defining and managing measurement and benchmarking. Measure and benchmark the performance of internal processes, as well as the organization as a whole."@en,
        "Defining and managing measurement and benchmarking. Measure and benchmark the 绩效 of internal processes, as well as the organization as a whole."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7" ;
    skos:prefLabel "Measure and benchmark"@en ;
    opf:domain "management_support" ;
