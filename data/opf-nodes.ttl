    skos:notation "8.7.2.2" ;
    skos:prefLabel "Define IT service support portfolio"@en,
        "定义IT服务支持组合"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.2> ;
    skos:definition "Design and maintaining an IT support model that defines the processes and procedures needed to support users of IT services and solutions."@en,
        "设计并持续优化 IT 支撑服务模型，明确支撑 IT 服务与解决方案用户所需的流程与规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.2.3" ;
    skos:prefLabel "Create and maintain IT support model"@en,
        "创建并维护IT支持模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.2> ;
    skos:definition "Developing a strategy for sourcing resources to support users of IT services and solutions. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support."@en,
        "制定支撑 IT 服务与解决方案用户的资源获取策略；建立基于电子邮件、在线实时支持软件或用户自助报修（事件登记）工具的支撑渠道。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.2.4" ;
    skos:prefLabel "Develop IT support service sourcing strategy"@en,
        "制定IT支持服务外包策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.2> ;
    skos:definition "Creating an agenda for the rules and regulations of support service that deal with providing support to users of IT services and solutions."@en,
        "制定支撑服务的规则与规范，明确面向 IT 服务与解决方案用户的支撑服务要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.2.5" ;
    skos:prefLabel "Establish support service framework"@en,
        "建立支持服务框架"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.2.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.2> ;
    skos:definition "Providing the tools and techniques to support users of IT services and solutions, and choosing the most appropriate tools and techniques. Evaluate the pros and cons of all the methodologies and tools available. Choose the most efficient and effective methodology."@en,
        "提供支撑 IT 服务与解决方案用户的工具与方法，并择优选用；全面评估各类方法与工具的优劣，选择效率与效果俱佳的方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.2.6" ;
    skos:prefLabel "Provide service support tools and technology"@en,
        "提供服务支持工具与技术"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Scheduling resources to provide service delivery to IT users. Ensure design, development, deployment, and operations are aligned with the business objectives."@en,
        "统筹调度资源以保障 IT 用户服务交付；确保设计、开发、部署与运维各环节与业务目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.1" ;
    skos:prefLabel "Schedule service delivery resources"@en,
        "调度服务交付资源"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Maintaining and scheduling batch jobs to run in the background at a certain date and time."@en,
        "维护并调度后台批处理作业，在指定日期与时间自动执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.2" ;
    skos:prefLabel "Maintain/optimize batch job schedule"@en,
        "维护/优化批处理作业计划"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Determine the timely change or release of IT services or support. Assign periodic release/change to IT systems or services."@en,
        "确定 IT 服务或支撑的变更与发布时效性；对 IT 系统或服务实施周期性变更或发布。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.3" ;
    skos:prefLabel "Schedule change/release windows"@en,
        "调度变更/发布窗口"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Schedule or optimize backup and archive activities for IT services and solutions. Use a backup system or application and archive operations data for future retrieval."@en,
        "规划或优化 IT 服务与解决方案的备份与归档活动；使用备份系统或应用，归档运维数据以备后续调阅。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.4" ;
    skos:prefLabel "Schedule/optimize backup and archive activities"@en,
        "调度/优化备份与归档活动"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Balancing workloads of all the processes and services that are provisioned to their internal or external clients, across available components of IT infrastructure. No component should be over or under utilized with the workflow of the IT operations."@en,
        "均衡分配面向内部或外部客户的所有流程与服务工作负载，确保 IT 基础设施各组件利用率合理；避免任一组件在 IT 运维工作流中过载或闲置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.5" ;
    skos:prefLabel "Balance operational workloads across available infrastructure components"@en,
        "在可用基础设施组件间均衡运营工作负载"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.3.1> ;
    skos:definition "Determining process and procedure to provide support for specific IT service problems."@en,
        "制定针对特定 IT 服务问题的支撑流程与规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3.1.6" ;
    skos:prefLabel "Determine specific problem support procedures"@en,
        "确定具体问题支持流程"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/8.7.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.4> ;
    skos:definition "Creating a strategy for delivering IT services and solutions. Establish the sourcing strategy. Establish the delivery process procedures and tools. Examine and choose the most effective methodologies and tools."@en,
        "制定 IT 服务与解决方案交付策略；确立资源获取策略；明确交付流程、规程及工具；评估并优选高效能的方法与工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4.1" ;
    skos:prefLabel "Develop IT service delivery strategy"@en,
        "制定IT服务交付策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.4> ;
    skos:definition "Assessing the goals and objectives of IT infrastructure and how it contributes to the overall business objectives."@en,
        "评估IT基础设施的目标与目的，及其对整体业务目标的贡献。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4.2" ;
    skos:prefLabel "Assess IT infrastructure business objectives"@en,
        "评估IT基础设施业务目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.4> ;
    skos:definition "Determining existing IT infrastructure capabilities. Identify the gaps and needs in order to enhance the existing IT infrastructure to meet growth objectives."@en,
        "评估现有IT基础设施能力，识别差距与需求，以增强基础设施支撑业务增长目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4.3" ;
    skos:prefLabel "Determine ongoing IT infrastructure capabilities"@en,
        "确定IT基础设施持续能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.4> ;
    skos:definition "Identify the gaps and needs of existing IT infrastructure. Plan and develop strategies to upgrade/replace existing IT infrastructure."@en,
        "识别现有IT基础设施的差距与需求，规划并制定升级或替换策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4.4" ;
    skos:prefLabel "Plan IT infrastructure change"@en,
        "规划IT基础设施变更"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.4.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.4> ;
    skos:definition "Creating a plan associated with usage volumes of IT licenses. Develop a framework to govern the licensing of an IT services along with identified usage volumes. Determine the amount of investment in IT license usage volumes and how would the license volumes be financed."@en,
        "制定IT许可证用量计划；构建IT服务许可证治理框架，并明确用量基准；确定许可证用量所需投资及融资方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.4.5" ;
    skos:prefLabel "Plan and budget IT license usage volumes"@en,
        "规划与预算IT许可证使用量"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Evaluate criticality catered by the IT support and expectations to resolve raised or identified issues. Determine the usual requests received for IT support for each area of IT operations. Ensure resolution to every identified or reported issue within specified SLAs."@en,
        "评估IT支持所覆盖问题的关键性及问题解决预期；统计各IT运维领域常见支持请求；确保所有已识别或上报问题均在约定SLA内完成解决。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.1" ;
    skos:prefLabel "Understand IT support demand patterns"@en,
        "识别IT支持需求模式"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.10" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Defining methodology and frequency of assessment for measuring and monitoring performance of various processes and activities of IT service support against standard set goals."@en,
        "定义IT服务支持各项流程与活动的绩效评估方法与频次，对照既定目标开展测量与监控。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.10" ;
    skos:prefLabel "Monitor IT service support performance"@en,
        "监控IT服务支持绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Determining levels of required support resources along with their responsibilities, and capabilities to resolve IT issues. Evaluate and ensure that support resources are fulfilling their responsibilities n a timely manner."@en,
        "确定所需支持资源的层级、职责与问题解决能力；评估并确保支持资源及时履行其职责。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.2" ;
    skos:prefLabel "Determine required support resource levels, responsibilities, and capabilities"@en,
        "确定所需支持资源水平、职责与能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Create and maintain service support knowledge repository. Store, maintain, access, revise, and use knowledge for IT services. Review knowledge trends and implement knowledge transfer methodologies for competitive advantage."@en,
        "建立并维护服务支持知识库；实现知识的存储、维护、访问、修订与复用；分析知识趋势，实施知识转移方法以提升竞争优势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.3" ;
    skos:prefLabel "Maintain service support knowledge repository"@en,
        "维护服务支持知识库"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Maintaining and transfer of knowledge towards service support with the change/upgrade in technology over a stipulated period. Ensure IT staff is well trained and tested on the new learning of service support."@en,
        "在技术变更或升级周期内持续开展服务支持知识的维护与转移；确保IT人员接受新知识培训并通过考核。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.4" ;
    skos:prefLabel "Maintain service support learning"@en,
        "持续优化服务支持学习机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Conveying service support needs within the organization, with the objective of providing required support services. Define processes and procedures needed to support users of IT services and solutions. Convey these procedures to appropriate governing authority."@en,
        "在组织内部传达服务支持需求，以保障所需支持服务交付；定义面向IT服务与解决方案用户的支撑流程及规程，并向相应治理机构报备。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.5" ;
    skos:prefLabel "Communicate service support needs"@en,
        "沟通服务支持需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Determining mechanisms to report for a higher degree of decision making depending on the criticality of IT escalations. Define the processes and procedures needed to follow for IT escalation at different levels. Convey the mechanisms within the organization."@en,
        "依据IT升级事件的关键程度，确定高阶决策报告机制；明确定义各级IT升级事件的处理流程与规程，并在组织内宣贯执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.6" ;
    skos:prefLabel "Define IT escalation mechanisms"@en,
        "定义IT升级响应机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.7" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Managing resources required for administration of IT service support. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support."@en,
        "统筹管理IT服务支持所需的行政资源；建立支持渠道（如电子邮件、在线实时支持软件或用户自助提交工单/事件的工具）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.7" ;
    skos:prefLabel "Manage IT service support resources"@en,
        "管理IT服务支持资源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.8" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Developing a strategy that will make use of multiple resources to coordinate with external support providers in order to make the support services work more smoother."@en,
        "制定多资源整合策略，协同外部支持提供商，提升服务支持运行效率与协同性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.8" ;
    skos:prefLabel "Coordinate with external support providers"@en,
        "协调外部支持提供商"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.5.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.5.9" ;
    skos:broader <https://oprocess.net/opf/node/8.7.5> ;
    skos:definition "Sorting the incidents of IT service delivery in certain order so that the services could be delivered based on the criticality."@en,
        "按关键程度对IT服务交付事件进行分级排序，实现差异化响应与服务交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.5.9" ;
    skos:prefLabel "Triage IT service delivery incidents"@en,
        "分类处置IT服务交付事件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Operating and defining methodology of assessment for measuring and monitoring performance of online systems against its expected result."@en,
        "运行在线系统，并制定评估方法，对其实际运行结果与预期目标的一致性开展测量与监控。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.1" ;
    skos:prefLabel "Operate and monitor online systems"@en,
        "运行与监控在线系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Operate and monitor the application of scheduling batch jobs to be run in the background at a certain date and time."@en,
        "运行并监控批处理作业调度功能，确保其按预定日期与时间后台执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.2" ;
    skos:prefLabel "Run and monitor batch job schedule"@en,
        "执行与监控批处理作业调度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Analyze and manage workload needs in relation to service delivery. Plan resources and mechanism around those workload needs so that services could be delivered smoothly."@en,
        "分析并管理服务交付相关的负载需求；围绕负载需求统筹规划资源与响应机制，保障服务平稳交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.3" ;
    skos:prefLabel "Manage service delivery workloads"@en,
        "管理服务交付工作负载"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Managing the performance and capacity of infrastructure by using key performance indicators to routinely track the performance and capacity levels. Review performance. Evaluate the efficiency and effectiveness of the infrastructure."@en,
        "运用关键绩效指标（KPI）常态化跟踪基础设施性能与容量水平；开展绩效复盘；评估基础设施运行效率与有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.4" ;
    skos:prefLabel "Manage infrastructure performance and capacity"@en,
        "管理基础设施性能与容量"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Addressing to an issue in operational activities within the IT function, that occur outside of normal routine or preventative maintenance."@en,
        "处置IT职能日常运营及预防性维护之外发生的异常运营问题。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.5" ;
    skos:prefLabel "Respond to unplanned operational issues"@en,
        "响应非计划性运营问题"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Identify and introduce resources to display output in a viewable form to key decision makers and evaluators."@en,
        "识别并引入可视化资源，向关键决策者与评估者呈现可读性输出。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.6" ;
    skos:prefLabel "Produce and distribute output media"@en,
        "生成与分发输出介质"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.7" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Identifying, examining, and recognizing any flaw or breach in security of IT infrastructure. Ensure that protocols and guidelines for individual IT components are being followed and there is no misuse of information and breach of individual or organizational privacy."@en,
        "识别、检查并确认IT基础设施存在的安全缺陷或违规行为；确保各IT组件严格遵循既定协议与规范，杜绝信息滥用及个人或组织隐私泄露。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.7" ;
    skos:prefLabel "Monitor IT infrastructure security"@en,
        "监控IT基础设施安全"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.6.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.6.8" ;
    skos:broader <https://oprocess.net/opf/node/8.7.6> ;
    skos:definition "Managing resources of IT infrastructure and their recovery capacity. Manage storage, computer hardware, software, and infrastructure resources that can be stored as inventory or provided by the organization as needed. Managing backup/recovery for IT services and solutions. Use a backup system or application."@en,
        "管理IT基础设施资源及其灾备恢复能力；统筹管理存储、硬件、软件及基础设施类资产（含库存储备与按需调用）；实施IT服务与解决方案的备份/恢复管理，部署备份系统或应用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.6.8" ;
    skos:prefLabel "Manage IT infrastructure/data recovery"@en,
        "管理IT基础设施/数据恢复"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Identifying and tracking individual configuration items, documenting functional capabilities and interdependencies of IT infrastructure. Determining the gaps and needs in order to enhance existing infrastructure configuration."@en,
        "识别并追踪各项配置项，记录其功能特性与相互依赖关系；识别现有基础设施配置的差距与需求，推动配置优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.1" ;
    skos:prefLabel "Manage infrastructure configuration"@en,
        "管理基础设施配置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Evaluating and maintaining all aspects of infrastructure component maintenance. Ensure that all components of an IT infrastructure are functioning properly as per the expectation. Maintenance includes all preventative, routine, and corrective measures."@en,
        "评估并维护基础设施各组件的全生命周期运维工作；确保所有IT基础设施组件按预期稳定运行；运维涵盖预防性、例行性及纠正性措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.2" ;
    skos:prefLabel "Perform infrastructure component maintenance"@en,
        "执行基础设施组件维护"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Installing/configuring/upgrading all the components required for operational activities within IT infrastructure. Ensure that all components of an IT infrastructure are functioning properly and updated to latest version/technology."@en,
        "完成IT基础设施中各组件的安装、配置与升级；确保所有组件正常运行且更新至最新版本/技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.3" ;
    skos:prefLabel "Install/configure/upgrade infrastructure components"@en,
        "安装/配置/升级基础设施组件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Maintaining the complete list of IT items or resources available with the organization with the details on date of purchase, licenses, deployment and SLAs."@en,
        "维护组织全部IT资产清单，详细记录采购日期、许可证信息、部署状态及SLA条款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.4" ;
    skos:prefLabel "Maintain IT asset records"@en,
        "维护IT资产记录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Administering and overseeing the terms and policies associated with licensing the IT intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization."@en,
        "管理IT知识产权许可相关条款与政策；制定并管理向外部主体授予许可的政策与条款；明确界定组织持有的专利权、著作权等知识产权许可治理框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.5" ;
    skos:prefLabel "Administer IT licenses/user agreements"@en,
        "管理IT许可证与用户协议"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.7.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.7.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.7> ;
    skos:definition "Providing all the infrastructure services and capabilities required for operational activities within the IT function supporting overall business objectives."@en,
        "提供支撑IT职能日常运营所需的全部基础设施服务与能力，服务整体业务目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.7.6" ;
    skos:prefLabel "Provide IT infrastructure service and capabilities"@en,
        "提供IT基础设施服务与能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.1" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Evaluate and assign IT issues/requests accordingly to allow for the correct routing of IT issues to the relevant support teams."@en,
        "评估并合理分派IT问题/请求，确保准确路由至对应支持团队。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.1" ;
    skos:prefLabel "Triage IT issues/requests"@en,
        "分类处置IT问题/请求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.2" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Providing the necessary skills and competencies required to efficiently provide IT resolution through the support structure."@en,
        "为支持体系高效提供IT问题解决方案，配备必要的技能与胜任力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.2" ;
    skos:prefLabel "Provide IT resolution capabilities"@en,
        "提供IT问题解决能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Creating an effective plan and structure to address and resolve requests of IT users. Determine, record, and monitor user requests. Obtain information about the effectiveness and performance of the user request handling process from the IT users through various means."@en,
        "构建高效的问题/请求响应与解决机制；受理、记录并监控用户请求；通过多种方式收集IT用户反馈，评估用户请求处理流程的有效性与绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.3" ;
    skos:prefLabel "Manage IT user requests"@en,
        "管理IT用户请求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.4" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Follow processes and procedures to escalate IT requests to required levels for resolution or effective decision making when necessary."@en,
        "按既定流程与规程，在必要时将IT请求逐级升级至相应层级，以推动问题解决或支撑有效决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.4" ;
    skos:prefLabel "Escalate IT requests"@en,
        "升级IT请求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.5" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Creating a structure to resolve issues/requests of IT services using different mechanisms."@en,
        "构建多元化机制，支撑IT服务问题/请求的分类响应与闭环解决。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.5" ;
    skos:prefLabel "Resolve IT issues/requests"@en,
        "解决IT问题/请求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.8.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.8.6" ;
    skos:broader <https://oprocess.net/opf/node/8.7.8> ;
    skos:definition "Successfully implement preventive measures to manage IT risk of exposure to internal and external threats. Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT."@en,
        "有效落实预防性措施，管控IT面临内外部威胁的风险暴露；整合应急响应、危机管理、灾难恢复（技术连续性）与IT业务连续性管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.8.6" ;
    skos:prefLabel "Execute IT continuity and recovery action"@en,
        "执行IT连续性与恢复行动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Level Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7.9> ;
    skos:definition "Activity within ITIL practice 'Service Level Management'."@en,
        "ITIL实践‘服务级别管理’中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.9.1" ;
    skos:prefLabel "Define service level agreements"@en,
        "定义服务级别协议（SLA）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Level Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7.9> ;
    skos:definition "Activity within ITIL practice 'Service Level Management'."@en,
        "ITIL 实践「服务级别管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.9.2" ;
    skos:prefLabel "Monitor service levels"@en,
        "监控服务水平"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.9.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Level Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7.9> ;
    skos:definition "Activity within ITIL practice 'Service Level Management'."@en,
        "ITIL 实践「服务级别管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.9.3" ;
    skos:prefLabel "Report on service performance"@en,
        "报告服务绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.7.9.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Level Management" ;
    skos:broader <https://oprocess.net/opf/node/8.7.9> ;
    skos:definition "Activity within ITIL practice 'Service Level Management'."@en,
        "ITIL 实践「服务级别管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.9.4" ;
    skos:prefLabel "Review and improve SLAs"@en,
        "评审与改进服务等级协议（SLA）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:IT Asset Management" ;
    skos:broader <https://oprocess.net/opf/node/8.8> ;
    skos:definition "Activity within ITIL practice 'IT Asset Management'."@en,
        "ITIL 实践「IT 资产管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.8.1" ;
    skos:prefLabel "Track IT asset lifecycle"@en,
        "跟踪 IT 资产生命周期"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:IT Asset Management" ;
    skos:broader <https://oprocess.net/opf/node/8.8> ;
    skos:definition "Activity within ITIL practice 'IT Asset Management'."@en,
        "ITIL 实践「IT 资产管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.8.2" ;
    skos:prefLabel "Manage software licenses"@en,
        "管理软件许可证"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:IT Asset Management" ;
    skos:broader <https://oprocess.net/opf/node/8.8> ;
    skos:definition "Activity within ITIL practice 'IT Asset Management'."@en,
        "ITIL 实践「IT 资产管理」中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.8.3" ;
    skos:prefLabel "Optimize asset utilization"@en,
        "优化资产利用率"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Infrastructure and Platform Management" ;
    skos:broader <https://oprocess.net/opf/node/8.9> ;
    skos:definition "Activity within ITIL practice 'Infrastructure and Platform Management'."@en,
        "ITIL 实践「基础设施与平台管理」中的活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.9.1" ;
    skos:prefLabel "Manage cloud infrastructure"@en,
        "管理云基础设施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Infrastructure and Platform Management" ;
    skos:broader <https://oprocess.net/opf/node/8.9> ;
    skos:definition "Activity within ITIL practice 'Infrastructure and Platform Management'."@en,
        "ITIL 实践「基础设施与平台管理」中的活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.9.2" ;
    skos:prefLabel "Manage on-premises platforms"@en,
        "管理本地平台"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.9.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Infrastructure and Platform Management" ;
    skos:broader <https://oprocess.net/opf/node/8.9> ;
    skos:definition "Activity within ITIL practice 'Infrastructure and Platform Management'."@en,
        "ITIL 实践「基础设施与平台管理」中的活动"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.9.3" ;
    skos:prefLabel "Optimize infrastructure costs"@en,
        "优化基础设施成本"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.1> ;
    skos:definition "Ensuring the effective allocation, utilization, and sustainability of financial assets. Activities include analyzing internal and external financial drivers; identifying long-term funding needs; evaluating investment, capital, and liquidity requirements; and defining guiding financial principles that support enterprise objectives."@en,
        "确保财务资源的有效配置、高效利用与可持续性。活动包括分析内外部财务驱动因素；识别长期资金需求；评估投资、资本与流动性要求；制定支撑企业目标的财务指导原则"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.1" ;
    skos:prefLabel "Develop and manage financial resources strategy"@en,
        "制定并管理财务资源战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.1.2> ;
    skos:definition "Formulating financial budgetary guidelines and strategies. Develop a framework for rules and regulations regarding budgets. Create a step-by-step process to achieve financial goals."@en,
        "制定财务预算指导方针与战略。建立预算相关规章制度框架，并设计分步实施流程以达成财务目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2.1" ;
    skos:prefLabel "Develop and maintain budget policies and procedures"@en,
        "制定并维护预算政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.1.2> ;
    skos:definition "Creating reports on a quarterly or annual basis for fund allocation. Create a financial statement that estimates revenues and expenses over a specific period of time. (Leverage budget methods such as cost-based and zero-based budgeting techniques, in light of the periodic targets outlined during Develop and maintain budget policies and procedures [10771].)"@en,
        "按季度或年度编制资金分配报告。编制预计特定期间内收入与支出的财务报表。（可采用基于成本的预算法、零基预算法等方法，结合‘制定并维护预算政策与程序’[10771]中设定的周期性目标。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2.2" ;
    skos:prefLabel "Prepare periodic budgets and plans"@en,
        "编制周期性预算与计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.1.2> ;
    skos:definition "Putting budgeting plans into practical use keeping within designated forecasting parameters."@en,
        "在既定预测参数范围内，将预算计划付诸实践。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2.3" ;
    skos:prefLabel "Operationalize and implement plans to achieve budget"@en,
        "推动计划落地实施以达成预算目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.1.2> ;
    skos:definition "Creating estimates of the projected income and expenses required over a predetermined time frame. Develop the projections of profit and loss statements, balance sheets, and the cash flow forecast."@en,
        "在预设时间范围内，预测所需收入与支出金额。编制利润表、资产负债表及现金流量预测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2.4" ;
    skos:prefLabel "Prepare periodic financial forecasts"@en,
        "编制周期性财务预测"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.1.2> ;
    skos:definition "Conducting a quantitative analysis between what was forecasted and budgeted and actual financial behavior."@en,
        "开展定量分析，比对实际财务表现与预算及预测结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.2.5" ;
    skos:prefLabel "Perform variance analysis against forecasts and budgets"@en,
        "开展预算与预测差异分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Conducting accounting for assets, and finding reasons for changes (depreciation, obsolescence, deterioration, change in customer taste, increased demand, decreased market supply, etc.)."@en,
        "开展资产会计核算，并分析资产价值变动原因（如折旧、技术淘汰、性能劣化、客户偏好变化、需求上升、市场供给下降等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.1" ;
    skos:prefLabel "Perform inventory accounting"@en,
        "开展存货核算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Determining the revenue, profits, and losses incurred by each unit within the organization that produces profit."@en,
        "核算组织内各盈利单元所实现的收入、利润与亏损。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.2" ;
    skos:prefLabel "Perform profit center accounting"@en,
        "开展利润中心核算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Studying expenses directly associated with product. Analyze the cost of sales, which is the cost of manufacturing products."@en,
        "分析与产品直接相关的费用，重点研究销售成本（即产品制造成本）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.3" ;
    skos:prefLabel "Perform cost of sales analysis"@en,
        "开展销售成本分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Studying and finding out the relevant cost center for a product by studying every resource used in its making."@en,
        "通过分析产品生产全过程所消耗的各项资源，识别其对应的成本中心。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.4" ;
    skos:prefLabel "Perform product costing"@en,
        "开展产品成本核算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Discovering the changes between forecasted and actual costing. Analyze actual and planned behavior by reviewing the amount of a variance on a trend line in order to maintain control over a business."@en,
        "识别实际成本与预测成本之间的差异。通过趋势线上的偏差量分析，对比实际与计划行为，以维持业务可控性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.5" ;
    skos:prefLabel "Perform variance analysis"@en,
        "开展差异分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.3.6" ;
    skos:broader <https://oprocess.net/opf/node/9.1.3> ;
    skos:definition "Making a report about revenues generated by the organization or business unit concerned. This process requires the organization to create a report which shows how business is generating profits. Profits are the part which is left after paying all expenses directly related to the generation of the revenue, such as producing a product, and other expenses related to conducting business activities."@en,
        "编制组织或相关业务单元的收入报告。该过程要求组织出具反映盈利来源的报告；利润指扣除所有与收入获取直接相关费用（如产品生产）及其他经营活动相关费用后的剩余部分。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.3.6" ;
    skos:prefLabel "Report on profitability"@en,
        "编制盈利能力报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.1.4> ;
    skos:definition "Defining cost drivers for a particular activity."@en,
        "界定特定活动的成本动因。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.4.1" ;
    skos:prefLabel "Determine key cost drivers"@en,
        "识别关键成本动因"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.1.4> ;
    skos:definition "Calculating cost drivers."@en,
        "测算成本动因。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.4.2" ;
    skos:prefLabel "Measure cost drivers"@en,
        "计量成本动因"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/9.1.4> ;
    skos:definition "Determine the activities that hinder the progress of finance activities. This requires the organization to determine those business activities carried out by the financial function of the organization and which are indispensable. This undertaking helps the organization triangulate those activities which are essential and where costs cannot be slashed."@en,
        "识别阻碍财务职能有效运行的业务活动。组织需厘清财务部门承担的各项业务活动及其必要性，从而甄别出不可削减成本的关键活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.4.3" ;
    skos:prefLabel "Determine critical activities"@en,
        "识别关键业务活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.4.4" ;
    skos:broader <https://oprocess.net/opf/node/9.1.4> ;
    skos:definition "Distributing or allocating asset resources in different processes for optimal utilization."@en,
        "在不同业务流程间合理配置或分配资产资源，实现最优利用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.4.4" ;
    skos:prefLabel "Manage asset resource deployment and utilization"@en,
        "管理资产资源配置与使用效率"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Studying product demand and targeted customer preferences. Study customers' demands or preferences after deducting the cost of delivering the final product."@en,
        "研究产品市场需求及目标客户偏好。在扣除最终产品交付成本后，分析客户实际需求或偏好。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.1" ;
    skos:prefLabel "Assess customer and product profitability"@en,
        "评估客户与产品盈利能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Checking demand about a specific product by a customer segment. Conduct a detailed study--or research a customer behavior or preference for a product--in order to determine its production and profitability in a specific market."@en,
        "针对特定客户群体开展某产品的市场需求调研。深入研究客户行为或产品偏好，以判断其在特定市场的生产可行性与盈利潜力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.2" ;
    skos:prefLabel "Evaluate new products"@en,
        "评估新产品"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Determining the cost of delivering an end product at different stages of production. Study the total life cycle of a product/process to determine how much revenue and production cost will be incurred at every stage in order to make strategic decisions."@en,
        "测算终端产品在不同生产阶段的交付成本。通过全生命周期分析，量化各阶段预期收入与生产成本，支撑战略决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.3" ;
    skos:prefLabel "Perform life cycle costing"@en,
        "开展全生命周期成本核算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.4" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Creating the best fit between a product and the end user. Maximize the customer base by providing different products in the market."@en,
        "实现产品与终端用户的最佳匹配。通过提供多样化产品扩大客户基础。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.4" ;
    skos:prefLabel "Optimize customer and product mix"@en,
        "优化客户与产品组合"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.5" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Observing the behavior of a new set of customers for different products. Prepare strategies to improve sales and profits."@en,
        "观察新客户群对不同产品的行为特征，制定提升销售与利润的策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.5" ;
    skos:prefLabel "Track performance of new-customer and product strategies"@en,
        "跟踪新客户与新产品策略执行成效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.6" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Evaluating performance based on different sets of activities created by management to measure performance."@en,
        "依据管理层设定的多维度绩效活动开展绩效评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.6" ;
    skos:prefLabel "Prepare activity-based performance measures"@en,
        "制定基于作业的绩效度量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.1.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.1.5.7" ;
    skos:broader <https://oprocess.net/opf/node/9.1.5> ;
    skos:definition "Conducting activities to improve cost distribution regularly. Follow or adopt different ways of reducing costs."@en,
        "定期优化成本分摊机制，持续落实各类降本举措。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.1.5.7" ;
    skos:prefLabel "Manage continuous cost improvement"@en,
        "推进持续成本改进"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.10.1" ;
    skos:broader <https://oprocess.net/opf/node/9.10> ;
    skos:definition "Forecasting and monitoring changes in foreign currency value or interest rates around the world that play an important role in the organization."@en,
        "预测并监控全球范围内影响组织的重要汇率及利率变动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.10.1" ;
    skos:prefLabel "Monitor international rates"@en,
        "监控国际汇率"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.10.2" ;
    skos:broader <https://oprocess.net/opf/node/9.10> ;
    skos:definition "Managing any transfer of funds in the course of conducting cross-border trades or investments, including conversion across currencies. Find the most suitable alternative for making payments, while saving taxes and avoiding any unwarranted regulation, with the objective of protecting capital."@en,
        "管理跨境贸易或投资过程中的资金划转，含币种兑换；在保障资本安全前提下，选择最优支付方案，兼顾节税与规避不必要监管。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.10.2" ;
    skos:prefLabel "Manage transactions"@en,
        "管理跨境交易"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.10.3" ;
    skos:broader <https://oprocess.net/opf/node/9.10> ;
    skos:definition "Assessing exposure to potential financial losses as a result of changes in the value of currencies. Forecast the impact of movements in foreign currency values. Enter into financial transactions designed to offset or limit potential exposure to loss."@en,
        "评估汇率波动可能导致的潜在财务损失敞口；预测外汇价值变动影响；开展金融交易以对冲或限制损失风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.10.3" ;
    skos:prefLabel "Monitor currency exposure/hedge currency"@en,
        "监控汇率风险／实施外汇对冲"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.10.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.10.4" ;
    skos:broader <https://oprocess.net/opf/node/9.10> ;
    skos:definition "Documenting and reporting accounting entries to formally report financial gains or losses experienced as a result of foreign exchange activity."@en,
        "就外汇交易产生的财务损益，规范记账并正式报告会计分录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.10.4" ;
    skos:prefLabel "Report results"@en,
        "报告相关结果"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.1" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Evaluating the approved list of parties for engaging in international trade in order to ensure the safety of the organization's business transactions. Examine agents that have been granted legal rights to engage in global trade and their credentials."@en,
        "审核经批准的国际贸易合作方清单，确保组织商业交易安全；核查获授权开展全球贸易的代理机构资质及法律授权文件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.1" ;
    skos:prefLabel "Screen sanctioned party list"@en,
        "筛查受制裁方名单"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.10" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Creating a document assuring that a seller will receive payment when certain delivery conditions are met. (If the buyer is unable to make payment on the purchase, a bank covers the outstanding amount.)"@en,
        "开立信用证，确保卖方在满足约定交货条件后获得付款（若买方无法付款，由银行承担未付金额）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.10" ;
    skos:prefLabel "Prepare letter of credit"@en,
        "开立信用证"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.2" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Overseeing and directing the flow of trade to/from the organization in order to ensure financial gains."@en,
        "统筹监管组织进出口贸易流向，确保实现财务收益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.2" ;
    skos:prefLabel "Control exports and imports"@en,
        "管控进出口业务"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.3" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Systematically categorizing products/services for their suitability to international trade. Create classes and categories for demarcating the types of products suitable for international trade. Study requisite national and international standards and the adherence of the organization's portfolio of offerings to these."@en,
        "系统化分类产品和服务，评估其国际适贸性；建立类别体系界定适贸产品类型；研究相关国家及国际标准，评估组织产品组合的合规性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.3" ;
    skos:prefLabel "Classify products"@en,
        "开展产品归类"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.4" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Identifying current exchange rates between two currencies and converting the foreign currency to that of the local monetary unit. I.E., yen to US dollar."@en,
        "识别两种货币间的现行汇率，并将外币折算为本币（如日元兑美元）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.4" ;
    skos:prefLabel "Perform currency conversion"@en,
        "执行货币兑换"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.5" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Computing the excise duty to be paid during international trade."@en,
        "核算国际贸易中应缴纳的消费税。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.5" ;
    skos:prefLabel "Calculate duty"@en,
        "计算关税"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.6" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Communicating with the customs department to ensure fluid compliance. Share pertinent information mandated by law with the government agency that controls and collects the duties levied for the international exchange of products/services."@en,
        "对接海关部门，确保顺畅合规；依法向主管政府机构共享关税征管所必需的信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.6" ;
    skos:prefLabel "Communicate with customs"@en,
        "对接海关部门"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.7" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Documenting and recording the trade processes while making transactions, noting the description, quality, number, transportation medium, indemnity, and inspection."@en,
        "在交易过程中完整记录贸易流程，注明货物描述、质量、数量、运输方式、保险及检验情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.7" ;
    skos:prefLabel "Document trade"@en,
        "归档贸易单证"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.8" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Preparing global trade under preference, which allows the organization to import/export products at a lower or nil rate of customs duty and/or levy charge."@en,
        "办理优惠贸易安排下的全球贸易，使组织可享受较低或零税率的进口/出口关税及附加费。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.8" ;
    skos:prefLabel "Process trade preferences"@en,
        "办理贸易优惠手续"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.11.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.11.9" ;
    skos:broader <https://oprocess.net/opf/node/9.11> ;
    skos:definition "Administering and overseeing all restitution activities the organization may be subjected to. Manage compliance with apposite legal frameworks. Make any restitution that may be required by law; comply with authorities over any fines or non-financial measures imposed."@en,
        "统筹管理组织可能面临的各类追偿活动；确保符合适用法律框架；依法履行赔偿义务，配合主管部门落实罚款或其他非金钱处罚措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.11.9" ;
    skos:prefLabel "Handle restitution"@en,
        "处理退税事宜"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Creating guidelines for providing advances. Set up credit standards, credit terms, and collection policies."@en,
        "制定预付款发放指南，明确信用标准、信用条款及催收政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.1" ;
    skos:prefLabel "Establish credit policies"@en,
        "制定信用政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Checking and accepting new requests based on eligibility criteria. Analyze the status of applicants and requirements to be met for a new account."@en,
        "依据准入条件审核并受理新申请。分析申请人资质及新开户所需满足的各项要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.2" ;
    skos:prefLabel "Analyze/Approve new account applications"@en,
        "审核／批准新账户申请"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Reviewing past credit scores to determine the if a line of credit will be extended to potential customers. This could also include extending additional credit to existing accounts."@en,
        "查阅历史信用评分，决定是否向潜在客户授予授信额度；亦包括向现有账户追加授信。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.3" ;
    skos:prefLabel "Analyze credit scoring history"@en,
        "分析信用评分历史"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Planning credit score requirements based on established credit policies."@en,
        "依据既定信用政策，规划信用评分准入要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.4" ;
    skos:prefLabel "Forecast credit scoring requirement"@en,
        "预测信用评分需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Evaluating existing account holders and their past performance. Regularly review existing accounts to get the required information about the status at present."@en,
        "评估现有账户持有人的历史履约表现。定期复审存量账户，及时掌握当前状态信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.5" ;
    skos:prefLabel "Review existing accounts"@en,
        "复核现有账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.6" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Preparing account payable reports about payments to be made according to accounting rules and principles, and providing the reports to management."@en,
        "按会计准则与原则编制应付账款报告，并提交管理层。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.6" ;
    skos:prefLabel "Produce credit/collection reports"@en,
        "生成信用／催收报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.7" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Closing or restarting accounts according to changes made in credit policies."@en,
        "根据信用政策调整情况，执行账户关闭或重启操作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.7" ;
    skos:prefLabel "Reinstate or suspend accounts based on credit policies"@en,
        "依据信用政策恢复或暂停账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Creating and updating a record of customers and the products being purchased by them in a database. This process element requires the organization to maintain a database of customers and their purchases. Such a master-file can be used to ensure customer touch point, enhance customer satisfaction, explore cross selling opportunities, and identify future trends. This database will include several particulars about the personal details of the organization's customers and a tracking of the products being sold."@en,
        "在数据库中创建并更新客户及其采购产品的记录。组织需维护客户及采购信息主数据，用于保障客户触点、提升满意度、挖掘交叉销售机会及识别未来趋势；该数据库应包含客户个人信息及所购产品追踪信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.1" ;
    skos:prefLabel "Maintain customer/product master files"@en,
        "维护客户／产品主数据文件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Preparing detailed reports about products purchased by customers. Record and generate a detail account of transactions made by customers fat a particular time and location. Include all details about products such as price, quantity, and name."@en,
        "编制客户采购产品明细报告。按特定时间与地点，记录并生成客户交易明细账，涵盖产品名称、价格、数量等全部要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.2" ;
    skos:prefLabel "Generate customer billing data"@en,
        "生成客户计费数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Providing information to customers about purchases made by them. Communicate the details of purchases. Provide customers with a copy of details for their reference."@en,
        "向客户提供其采购信息。主动告知采购详情，并向客户交付含完整信息的副本供其留存参考。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.3" ;
    skos:prefLabel "Transmit billing data to customers"@en,
        "向客户传输计费数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Registering transactions and their scheduled payments."@en,
        "登记交易及其约定付款安排。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.4" ;
    skos:prefLabel "Post receivable entries"@en,
        "登记应收账款分录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.2> ;
    skos:definition "Checking and solving billing queries raised by customers."@en,
        "处理客户提出的账单查询并予以解决。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.2.5" ;
    skos:prefLabel "Resolve customer billing inquiries"@en,
        "处理客户账单查询"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Creating rules and regulations to be followed in case of credit sales to customers. Create rules and procedures to follow at the time of sale (e.g., the allowable number of installments)."@en,
        "制定信用销售给客户的规则与制度，明确销售时应遵循的规程（如允许的分期付款期数）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.1" ;
    skos:prefLabel "Establish AR policies"@en,
        "制定应收账款政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Collecting cash from customers. Deposit it into bank account. Make entries into the books of accounts."@en,
        "向客户收取现金，并存入银行账户；在会计账簿中进行相应记账。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.2" ;
    skos:prefLabel "Receive/Deposit customer payments"@en,
        "接收并存入客户付款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Checking and moving funds between countries for business activities, typically through authorized remittance agents."@en,
        "核查并划转用于商业活动的跨境资金，通常通过授权汇款代理机构执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.3" ;
    skos:prefLabel "Apply cash remittances"@en,
        "核销现金回款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Preparing reports that detail balances due or what to collect from customers at a certain point in time."@en,
        "编制应收账款余额报告，列明某一时点应向客户收取的款项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.4" ;
    skos:prefLabel "Prepare AR reports"@en,
        "编制应收账款报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.3> ;
    skos:definition "Preparing the general ledger for account receivables from journals. Place all journal entries related to accounts receivables in the general ledger accounts of a business."@en,
        "根据日记账编制应收账款总分类账，将所有与应收账款相关的日记账分录归集至企业总账账户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.3.5" ;
    skos:prefLabel "Post AR activity to the general ledger"@en,
        "将应收账款业务记入总账"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Creating a process to follow in case of a failed payment by account holders. Create rules and regulations for the account holder who has failed to make at least the minimum monthly payment by the due date."@en,
        "建立账户持有人付款失败时的应对流程，制定针对未按期足额支付最低月还款额的账户持有人的规则与制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.1" ;
    skos:prefLabel "Establish policies for delinquent accounts"@en,
        "制定逾期账户管理政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Examining balance statements of accountholders who failed to make required payments. Study or review the account details of customers' past payments when preparing negotiations policies."@en,
        "审核未履行付款义务的账户持有人对账单；在制定催收谈判策略时，分析或复核客户历史付款记录及账户详情。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.2" ;
    skos:prefLabel "Analyze delinquent account balances"@en,
        "分析逾期账户余额"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Determine ways for customers in default to repay debts (e.g., allowing more time or discounts)."@en,
        "制定违约客户的债务清偿方案（如延长还款期限、提供折扣等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.3" ;
    skos:prefLabel "Correspond/Negotiate with delinquent accounts"@en,
        "与逾期账户客户沟通或协商"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Determining rules for handling accounts. Discuss and plan with internal parties (department heads, managers, and senior management) about rules to follow in coming months."@en,
        "制定账户管理规则，并与内部相关方（部门负责人、经理及高级管理层）就未来数月拟执行的规则开展讨论与规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.4" ;
    skos:prefLabel "Discuss account resolution with internal parties"@en,
        "与内部相关部门讨论账户解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Maintaining reserves for write-offs and adjustments. Adjust or write off certain expenses and losses."@en,
        "计提坏账准备及调整准备金，对特定费用和损失进行调整或核销。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.5" ;
    skos:prefLabel "Process adjustments/write off balances"@en,
        "处理账务调整或坏账核销"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.6" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Renegotiating the terms of a loan agreement in order to recoup money from a default account."@en,
        "重新协商贷款协议条款，以从违约账户中回收资金。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.6" ;
    skos:prefLabel "Perform recovery workout"@en,
        "开展债务重组与回收工作"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.7" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Managing accounts that have not met the requirements agreed upon to pay off outstanding debts."@en,
        "管理未按约定条件清偿逾期债务的账户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.7" ;
    skos:prefLabel "Manage default accounts"@en,
        "管理违约账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Creating guidelines to follow in case of adjustments to business processes."@en,
        "制定业务流程调整所应遵循的指导方针。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.1" ;
    skos:prefLabel "Establish policies/procedures for adjustments"@en,
        "制定账务调整政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Checking changes made in accounts during the year. Examine the alterations made in final accounts to rectify errors/omissions."@en,
        "核查年度内各账户变动情况；审查决算报表中的修改内容，以更正差错或遗漏。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.2" ;
    skos:prefLabel "Analyze adjustments"@en,
        "分析账务调整事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Providing suitable offers to customers. Present different offers (e.g., discounts) available for customers or buyers."@en,
        "向客户提供适配的优惠方案，例如面向客户或买方的不同折扣政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.3" ;
    skos:prefLabel "Correspond/Negotiate with customer"@en,
        "与客户沟通或协商调整事宜"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Discussing and planning with internal parties (department heads, managers, and senior management) about rules to follow in coming months."@en,
        "与内部相关方（部门负责人、经理及高级管理层）就未来数月拟执行的规则开展讨论与规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.4" ;
    skos:prefLabel "Discuss resolution with internal parties"@en,
        "与内部相关部门讨论调整解决方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Creating a mechanism for consumer protection in case of a higher price charged. When a supplier sells a product at a higher price to the distributor than the price they have set with the end user, submit a chargeback to the supplier to recover the money lost in the transaction."@en,
        "建立消费者价格保护机制：当供应商向分销商销售产品价格高于其与终端用户约定价格时，向供应商发起退单（chargeback）以追回交易损失。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.5" ;
    skos:prefLabel "Prepare chargeback invoices"@en,
        "开具拒付（chargeback）发票"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.6" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
    skos:definition "Recording business transactions as they occur in order to provide a balanced accounts for financial reporting."@en,
        "实时记录各项经营交易，确保财务报告所依据的账务平衡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.5.6" ;
    skos:prefLabel "Process related entries"@en,
        "处理相关会计分录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/9.2> ;
    skos:definition "AI-era activity: AI-Powered Fraud Detection."@en,
        "AI时代活动：人工智能（AI）驱动的欺诈检测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.6" ;
    skos:prefLabel "AI-Powered Fraud Detection"@en,
        "人工智能（AI）驱动的欺诈检测"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.3.1> ;
    skos:definition "Agreeing upon terms and conditions. Negotiate an agreement between two or more parties, the customer and service providers. Specify scope, quality, and responsibilities."@en,
        "协商并确定合同条款与条件，即客户与服务提供商之间就服务范围、质量标准及各方责任达成一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1.1" ;
    skos:prefLabel "Negotiate service-level agreements"@en,
        "协商服务级别协议（SLA）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.3.1> ;
    skos:definition "Establishing policies and procedures to prepare financial statements, including methods, measurement systems, and procedures for providing disclosures."@en,
        "制定财务报表编制政策与程序，涵盖计量方法、核算体系及信息披露规范。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1.2" ;
    skos:prefLabel "Establish accounting policies"@en,
        "制定会计政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.3.1> ;
    skos:definition "Creating a written copy of agreed-upon procedures for preparing financial statements, and making them available to the public."@en,
        "形成书面化的财务报表编制约定程序，并向公众公开。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1.3" ;
    skos:prefLabel "Publish accounting policies"@en,
        "发布会计政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.3.1> ;
    skos:definition "Implementing parameters for accounting. Apply set conditions for any approval process."@en,
        "设定会计参数，对各类审批流程应用既定条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1.4" ;
    skos:prefLabel "Set and enforce approval limits"@en,
        "设定并执行审批权限限额"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.3.1> ;
    skos:definition "Establishing processes and procedures to exercise financial control and accountability. Record, verify, and report transactions that affect revenues, expenditures, assets, and liabilities."@en,
        "建立财务管控与问责机制，对影响收入、支出、资产及负债的交易进行记录、验证与报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.1.5" ;
    skos:prefLabel "Establish common financial systems"@en,
        "建立统一财务系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Preparing trial balance account from general ledgers. List all accounts used in the general ledger. Alter accounts according to business requirements."@en,
        "根据总分类账编制试算平衡表，列示总账中使用的所有账户，并依业务需求调整账户设置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.1" ;
    skos:prefLabel "Maintain chart of accounts"@en,
        "维护会计科目表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Making ledger and trial balance accounts from journal entries. This process requires the organization to record every transaction into accounts done by business. It is a base documents for preparing final accounts of company."@en,
        "依据日记账分录登记明细账与试算平衡表；该过程要求企业将每一笔交易完整记入对应账户，是编制公司决算报表的基础性文档。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.2" ;
    skos:prefLabel "Process journal entries"@en,
        "处理记账凭证"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Allocating funds across functions. Apportion funds in line with the budgets created. Formalize allocations in centralized internal records."@en,
        "按职能分配资金，严格依照预算方案执行资金划拨，并在集中式内部记录中正式固化分配结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.3" ;
    skos:prefLabel "Process allocations"@en,
        "处理费用分摊"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Updating journal entries to adjust the balance of income and expenses at the end of an accounting period."@en,
        "于会计期末更新日记账分录，调整收入与费用账户余额。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.4" ;
    skos:prefLabel "Process period end adjustments"@en,
        "处理期末调整事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Checking accounts separately for a parent and subsidiary company. Manage relationship between a parent company and subsidiaries. Document intercompany transactions in separate financial statements."@en,
        "分别核算母公司与子公司账务，统筹管理母子公司关系，并在独立财务报表中单独列示内部往来交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.5" ;
    skos:prefLabel "Post and reconcile intercompany transactions"@en,
        "记录并核对关联交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.6" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Reviewing general ledger accounts for a parent and subsidiaries companies. Validate the integrity of account balances on the company's general ledger of accounts. Review and compare general ledger accounts balances with source documents to ensure that balances match."@en,
        "复核母公司及子公司总分类账账户，验证公司总账账户余额的完整性；比对总账余额与原始凭证，确保账实相符。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.6" ;
    skos:prefLabel "Reconcile general ledger accounts"@en,
        "核对总账科目余额"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.7" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Aggregating different processes in the business. Eliminate discontinued processes."@en,
        "整合企业内各项业务流程，淘汰已终止运行的流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.7" ;
    skos:prefLabel "Perform consolidations and process eliminations"@en,
        "执行合并报表及抵销处理"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.8" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Balancing debit and credit balances of trial balance to preparing final accounts. Calculate the total debits and credits in company's accounts. Correspond the sum of all debits with the sum of all credits. Adjust entries as appropriate."@en,
        "平衡试算平衡表中的借方与贷方总额，以编制最终财务报表；汇总公司全部账户的借方与贷方发生额，确保借贷合计相等，并视情调整分录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.8" ;
    skos:prefLabel "Prepare trial balance"@en,
        "编制试算平衡表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.2.9" ;
    skos:broader <https://oprocess.net/opf/node/9.3.2> ;
    skos:definition "Accounting for changes due to country-level policy changes. Record adjustments made by management in the accounts."@en,
        "核算因国家层面政策调整引发的会计变动，如实记录管理层在账务中作出的相关调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.2.9" ;
    skos:prefLabel "Prepare and post management adjustments"@en,
        "编制并过账管理调整分录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Creating rules for fixed assets market valuation. Make rules and regulations for fixed assets regarding depreciation, provisions, resale, usage, etc."@en,
        "制定固定资产市场估值规则。明确固定资产在折旧、准备金、再出售、使用等方面的规章制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.1" ;
    skos:prefLabel "Establish fixed-asset policies and procedures"@en,
        "制定固定资产政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Keeping reports up-to-date regarding fixed assets. Create a fixed assets database detailing price, life cycle, depreciation rate, resale value, installation information, usage information, etc."@en,
        "持续更新固定资产台账。建立固定资产数据库，详列采购价格、生命周期、折旧率、残值、安装信息、使用信息等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.2" ;
    skos:prefLabel "Maintain fixed-asset master data files"@en,
        "维护固定资产主数据文件"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Keeping a summary of sales and purchases of assets. Record any expenses made for new assets purchased and sales of any old assets during the fiscal year."@en,
        "汇总资产购销情况。记录财年内新增资产采购支出及旧资产处置收入。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.3" ;
    skos:prefLabel "Process and record fixed-asset additions and retires"@en,
        "处理并记录固定资产新增与报废"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Keeping a summary of expenses for installing and modifying assets. Record any expenses made for new assets purchased, any expenses incurred on improvements, the valuation of assets to reach current market price, and any transfer assets from one location to another during the fiscal year."@en,
        "汇总资产安装与改造费用。记录财年内新增资产采购支出、改良支出、为达到当前市价而进行的资产重估支出，以及资产跨地点调拨相关支出。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.4" ;
    skos:prefLabel "Process and record fixed-asset adjustments, enhancements, revaluations, and transfers"@en,
        "处理并记录固定资产调整、改良、重估及调拨"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Maintaining a record of expenses necessitated for repairs and the preservation of assets. Administer and oversee the maintenance and repair of any fixed assets. Record all related transactions."@en,
        "记录资产维修与保全必要支出。统筹管理并监督固定资产的维护与修理工作，完整登记相关交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.5" ;
    skos:prefLabel "Process and record fixed-asset maintenance and repair expenses"@en,
        "处理并记录固定资产维修与保养费用"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.6" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Carrying out accounting for depreciation over fixed assets. Compute the sums necessitated. Maintain a record of the cost value of fixed assets over their useful life in the book of accounts."@en,
        "开展固定资产折旧会计处理。计算应计提折旧金额，并在账簿中持续记录固定资产在其使用寿命内的账面价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.6" ;
    skos:prefLabel "Calculate and record depreciation expense"@en,
        "计算并记录折旧费用"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.7" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Balancing the ledger account balance for fixed assets. Correct errors in the books of fixed assets. Provide correct information in relevant accounts."@en,
        "核对并平衡固定资产总账余额。更正固定资产账簿中的差错，确保相关科目信息准确无误。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.7" ;
    skos:prefLabel "Reconcile fixed-asset ledger"@en,
        "核对固定资产明细账"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.8" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Checking and updating the record of all raw materials and fixed assets. Track all fixes asset. Maintain a record of all inventory items."@en,
        "定期核查并更新原材料与固定资产台账。全面追踪所有固定资产，维护完整的存货明细记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.8" ;
    skos:prefLabel "Track fixed-assets including physical inventory"@en,
        "跟踪固定资产（含实物盘点）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.3.9" ;
    skos:broader <https://oprocess.net/opf/node/9.3.3> ;
    skos:definition "Showing market value and related expenses on fixed assets data for taxation. Provide complete information recorded in the books of fixed assets about purchase price, depreciation, installation charges, resale market value etc. for tax and regulatory purposes."@en,
        "按税务要求列示固定资产市场价值及相关费用。向税务及监管机构提供固定资产账簿中记载的完整信息，包括采购价格、折旧额、安装费用、市场再出售价值等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.3.9" ;
    skos:prefLabel "Provide fixed-asset data to support tax, statutory, and regulatory reporting"@en,
        "提供固定资产数据以支持税务、法定及监管报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Making reports of subsidiaries units to show profits generated from them. Prepare financial statements (balance sheets, income statements, cash flow statements and statements of shareholders' equity) for a single unit of a business."@en,
        "编制下属单位财务报告以反映其盈利贡献。为单个业务单元编制财务报表（含资产负债表、利润表、现金流量表及股东权益变动表）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.1" ;
    skos:prefLabel "Prepare business unit financial statements"@en,
        "编制业务单元财务报表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Making final accounts for all units of company together. Prepare combined financial statements of a parent company and its subsidiaries (i.e., separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses, and cash flows."@en,
        "合并编制公司全部单位的最终财务报表。编制母公司及其子公司（受母公司控制的独立法人实体）的合并财务报表，全面反映资产、负债、权益、收入、费用及现金流量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.2" ;
    skos:prefLabel "Prepare consolidated financial statements"@en,
        "编制合并财务报表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Making reports for units/subsidiaries to help management in decision making. Prepare financial statements (balance sheets, income statements, cash flow statements, and statements of shareholders' equity) for a single unit of a business. Break down profits and losses by function/unit, clients, products, and region."@en,
        "编制分单位/子公司财务报告以支持管理层决策。为单个业务单元编制财务报表（含资产负债表、利润表、现金流量表及股东权益变动表），并按职能/单位、客户、产品及区域维度分解盈亏情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.3" ;
    skos:prefLabel "Perform business unit reporting/review management reports"@en,
        "开展业务单元报告／审阅管理报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.4" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Making reports for all units to help higher management in decision making. Prepare combined financial statements of a parent company and its all subsidiaries (separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses and cash flows, and also going through periodic reports which shows the actual and estimated costs and their variances."@en,
        "编制全部单位财务报告以支持高层管理决策。编制母公司及其全部子公司的合并财务报表（含资产、负债、权益、收入、费用及现金流量），并结合周期性报告分析实际成本与预算成本及其差异。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.4" ;
    skos:prefLabel "Perform consolidated reporting/review of cost management reports"@en,
        "开展合并报告／审阅成本管理报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.5" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Preparing a draft of financial statements for the board to review before they are sent to the auditor."@en,
        "编制财务报表草案供董事会审阅，待其批准后提交审计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.5" ;
    skos:prefLabel "Prepare statements for board review"@en,
        "编制供董事会审阅的报表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.6" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Making and presenting financial reports to stakeholders. Create annual and quarterly financial statements for reporting purposes. Prepare shareholder reports with details of the profit-and-loss account, balance sheet, and past year's business activities."@en,
        "编制并向利益相关方呈报财务报告。编制年度及季度财务报表用于对外披露；编制股东报告，详述损益情况、资产负债状况及上年度经营成果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.6" ;
    skos:prefLabel "Produce quarterly/annual filings and shareholder reports"@en,
        "编制季度／年度申报文件及股东报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.7" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Reporting raw or summary data for final accounts following rules and regulations."@en,
        "依据法规要求报送原始或汇总数据用于最终财务决算。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.7" ;
    skos:prefLabel "Produce regulatory reports"@en,
        "编制监管报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.3.4.8" ;
    skos:broader <https://oprocess.net/opf/node/9.3.4> ;
    skos:definition "Carrying out activities associated with legal and management consolidation. Legal consolidation can include currency conversion, balance carry forward, and consolidation of journal entries. Management consolidation can include reporting on financials on a reporting cycle basis to gauge the performance of the organization."@en,
        "开展法律与管理层面的合并工作。法律合并包括币种转换、余额结转及记账凭证合并；管理合并包括按报告周期编制财务报告，以评估组织整体绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.4.8" ;
    skos:prefLabel "Perform legal and management consolidation"@en,
        "开展法律与管理层面的合并"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/9.3> ;
    skos:definition "AI-era activity: AI-Driven Financial Forecasting."@en,
        "AI时代活动：人工智能驱动的财务预测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.3.5" ;
    skos:prefLabel "AI-Driven Financial Forecasting"@en,
        "AI驱动的财务预测"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.4.1> ;
    skos:definition "Creating procedures and policies to follow for investing in capital projects. Create rules and regulations regarding large investment plans, which require in-depth forecasting for expenditure and revenue."@en,
        "制定资本性项目投资的流程与政策。针对需深度收支预测的重大投资计划，制定相应规章制度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.1.1" ;
    skos:prefLabel "Develop capital investment policies and procedures"@en,
        "制定资本投资政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.4.1> ;
    skos:definition "Creating budgets, and soliciting approvals for capital projects. Prepare budgets for projects that require heavy investments. Secure approvals from management."@en,
        "编制资本性项目预算并获取审批。为重大投资项目编制预算，并取得管理层批准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.1.2" ;
    skos:prefLabel "Develop and approve capital expenditure plans and budgets"@en,
        "制定并审批资本支出计划与预算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.4.1> ;
    skos:definition "Evaluating and supporting capital investments in projects and fixed assets. Confirm details of capital projects. Secure approvals from managements for large investments."@en,
        "评估并支持资本性项目及固定资产投资。核实资本性项目细节，就重大投资事项取得管理层批准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.1.3" ;
    skos:prefLabel "Review and approve capital projects and fixed-asset acquisitions"@en,
        "审阅并批准资本项目及固定资产购置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.4.1> ;
    skos:definition "Reviewing all project business cases in order to substantiate projected financial gains. Validate any project's business case. Juxtapose the benefits derived from moving a project forward against the associated costs."@en,
        "全面复核各项目商业论证以支撑预期财务收益。验证任一项目的商业论证，权衡项目推进所获收益与对应成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.1.4" ;
    skos:prefLabel "Conduct financial justification for project approval"@en,
        "开展项目审批所需的财务可行性分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.4.2> ;
    skos:definition "Giving reference codes for every project."@en,
        "为每个项目分配唯一参考编码。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2.1" ;
    skos:prefLabel "Create project account codes"@en,
        "创建项目会计科目编码"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.4.2> ;
    skos:definition "Noting every transaction during a project in a common financial database. Document all transactions associated with any project. Maintain a centralized repository of all such financial data."@en,
        "在统一财务数据库中记录项目全过程每一笔交易。归档所有项目相关交易，建立集中化的财务数据存储库。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2.2" ;
    skos:prefLabel "Record project-related transactions"@en,
        "记录项目相关交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.4.2> ;
    skos:definition "Evaluating project progress and funds invested. Observe and track significant funds invested on any long-term project. Compare to budget."@en,
        "评估项目进展及已投入资金。跟踪重大长期项目的资金投入情况，并与预算进行比对。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2.3" ;
    skos:prefLabel "Monitor and track capital projects and budget spending"@en,
        "监控并跟踪资本项目进展及预算执行情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.4.2> ;
    skos:definition "Checking for returns generated from projects for decision making. Evaluate capital projects that require heavy investments. Decide whether to proceed based on the revenues generated."@en,
        "基于项目收益开展决策分析。评估需重大投资的资本性项目，依据预期收入决定是否继续推进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2.4" ;
    skos:prefLabel "Close/Capitalize projects"@en,
        "结项／资本化项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.4.2> ;
    skos:definition "Comparing a finished project's profitability with forecasted returns. Scrutinize revenues generated by completed projects that required heavy investments. Determine profitability."@en,
        "对比完工项目实际盈利与预测收益。审阅需重大投资的完工项目所产生收入，判定其盈利能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4.2.5" ;
    skos:prefLabel "Measure financial returns on completed capital projects"@en,
        "评估已完成资本项目的财务回报"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.5.1> ;
    skos:definition "Developing policies and procedures for the HR function to calculate compensation."@en,
        "制定人力资源部门薪酬核算的政策与流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1.1" ;
    skos:prefLabel "Establish policies and procedures"@en,
        "制定相关政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.5.1> ;
    skos:definition "Tracking billing hours of each employee on daily basis."@en,
        "按日跟踪每位员工的计费工时。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1.2" ;
    skos:prefLabel "Collect and record employee time worked"@en,
        "收集并记录员工实际工作工时"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.5.1> ;
    skos:definition "Tracking leaves allowed and taken by employees."@en,
        "跟踪员工享有的及已使用的各类假期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1.3" ;
    skos:prefLabel "Analyze and report paid and unpaid leave"@en,
        "分析并报告带薪与无薪休假情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.5.1> ;
    skos:definition "Observing the number of hours worked by an employees on daily basis. Track the number of hours worked by an employee, as well as the number of hours worked beyond normal working hour's according to company standards."@en,
        "按日统计员工实际工作时长。记录员工每日工作小时数，以及依据公司标准超出正常工作时间的加班时长。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1.4" ;
    skos:prefLabel "Monitor regular, overtime, and other hours"@en,
        "监控正常工时、加班工时及其他工时"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.5.1> ;
    skos:definition "Monitoring the number of productive hours for employees."@en,
        "监控员工的有效工作时长。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.1.5" ;
    skos:prefLabel "Analyze and report employee utilization"@en,
        "分析并报告员工利用率"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Tracking the number of hours worked for the payroll system. Register the number of hours worked by an employee into the payroll system for the purpose of calculating salaries or wages."@en,
        "记录员工工时并录入薪酬系统，用于薪资或工资计算。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.1" ;
    skos:prefLabel "Enter employee time worked into payroll system"@en,
        "录入员工工时至薪酬系统"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Tracking and oversee salary breakups of employees. This process requires the organization to manage and update information pertaining to the structure of every employee's salary. This would involve the updating any changes to the salary structures of the employees, in a central repository which can be accessed by pertinent departments."@en,
        "跟踪与监督员工薪资构成。该流程要求组织在中央存储库中统一管理并更新每位员工的薪资结构信息，并支持相关部门访问和及时更新变动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.2" ;
    skos:prefLabel "Maintain and administer employee earnings information"@en,
        "维护与管理员工薪酬信息"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Processing salary deductions for tax purposes. Keep and manage the details of every employee's salary deductions based on their expenses and investments during the year."@en,
        "处理基于员工年度支出与投资情况的个税扣缴。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.3" ;
    skos:prefLabel "Maintain and administer applicable deductions"@en,
        "维护与管理适用的扣款项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Tracking changes in the salary structure of employees for tax deductions."@en,
        "跟踪员工薪资结构变动，以支持个税扣缴调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.4" ;
    skos:prefLabel "Monitor changes in tax status of employees"@en,
        "监控员工税务状态变更"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Processing and distributing salaries to all employees. Execute the payroll management function through the dispensation of employee salaries. Leverage a centralized database of all payroll expenses."@en,
        "执行全员薪资发放。通过集中式薪酬数据库开展薪酬管理职能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.5" ;
    skos:prefLabel "Process and distribute payments"@en,
        "处理并发放薪酬款项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.6" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Handling incorrect/omitted salary payments."@en,
        "处理错发或漏发薪资事项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.6" ;
    skos:prefLabel "Process and distribute manual checks"@en,
        "处理并发放手工支票"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.7" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Adjusting salary deductions for tax purposes at the end of the year."@en,
        "于财年末调整个税扣缴金额。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.7" ;
    skos:prefLabel "Process period-end adjustments"@en,
        "处理期末调整事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.2.8" ;
    skos:broader <https://oprocess.net/opf/node/9.5.2> ;
    skos:definition "Addressing salary-related queries raised by employees."@en,
        "响应员工提出的薪资相关咨询。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.2.8" ;
    skos:prefLabel "Respond to employee payroll inquiries"@en,
        "响应员工薪酬相关咨询"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.5.3> ;
    skos:definition "Devising a method to minimize payroll tax liability by means of allowances, deductions, exclusions or exemptions."@en,
        "制定津贴、扣除项、排除项或免税项等策略，以优化薪酬税务负担。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3.1" ;
    skos:prefLabel "Develop tax plan"@en,
        "制定税务筹划方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.5.3> ;
    skos:definition "Overseeing maintaining the reduction of payroll taxes [14075]."@en,
        "监督并落实薪酬税负降低措施［14075］。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3.2" ;
    skos:prefLabel "Manage tax plan"@en,
        "管理税务筹划方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.5.3> ;
    skos:definition "Paying tax according to appropriate deductions made from salaries. Calculate and pay the tax liabilities according to the salaries and tax regulations of employees with the help of certified chartered accountants."@en,
        "依据薪资及税收法规，核算并缴纳员工个税负债，由注册会计师提供专业支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3.3" ;
    skos:prefLabel "Calculate and pay applicable payroll taxes"@en,
        "核算并缴纳适用的薪酬税"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.5.3> ;
    skos:definition "Providing tax deductions statements created by certified chartered accountants to every employee for their reference or refunds."@en,
        "向每位员工提供由注册会计师出具的个税扣缴明细单，供其查阅或办理退税。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3.4" ;
    skos:prefLabel "Produce and distribute employee annual tax statements"@en,
        "编制并发放员工年度税务报表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.5.3> ;
    skos:definition "Filling taxes, and highlighting different sources of income and expenditures made."@en,
        "完成纳税申报，列明各项收入来源及支出明细。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.5.3.5" ;
    skos:prefLabel "File regulatory payroll tax forms"@en,
        "申报监管要求的薪酬税表单"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Matching records of bills to be paid with accounts. Check accounts payable entries with vendor's account for every payment made."@en,
        "核对拟付款账单与应付账款明细。逐笔验证付款记录与供应商账户的一致性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.1" ;
    skos:prefLabel "Verify AP pay file with purchase order vendor master file"@en,
        "核对应付账款付款文件与采购订单及供应商主数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.10" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Keeping bills of every transaction for future reference."@en,
        "归档每笔交易的原始账单，以备后续查证。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.10" ;
    skos:prefLabel "Retain records"@en,
        "归档保存相关记录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.11" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Rectifying for alterations occurred in accounts while recording."@en,
        "修正账务记录过程中发生的账目变更。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.11" ;
    skos:prefLabel "Adjust accounting records"@en,
        "调整会计账目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Tracking all online transactions."@en,
        "跟踪全部线上交易记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.2" ;
    skos:prefLabel "Maintain/Manage electronic commerce"@en,
        "维护与管理电子商贸"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Monitoring and evaluating bills registered in accounts books. Check all invoices. Maintain records."@en,
        "监控与审核账簿中登记的各类账单。全面核查发票并留存完整记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.3" ;
    skos:prefLabel "Audit invoices and key data in AP system"@en,
        "审核发票及应付账款系统中的关键数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Processing payments for products/services."@en,
        "处理商品或服务采购付款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.4" ;
    skos:prefLabel "Approve payments"@en,
        "审批付款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Handling transactions for accruals and reversals. Record transactions in the books of accounts on an accrual basis (irrespective of the actual cash flow) and reversals basis (cancel out the adjusting entries) for balancing accounts."@en,
        "处理权责发生制下的应计与冲销事项。按权责发生制（不以实际现金流为依据）及冲销制（抵消调整分录）记账，确保账务平衡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.5" ;
    skos:prefLabel "Process financial accruals and reversals"@en,
        "处理财务应计与冲销事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.6" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Filing the amount of taxes that a company owes as of the balance sheet date. Prepare tax returns, including the income tax filing for an individual or business entity from earnings."@en,
        "按资产负债表日确认企业应缴税额并完成纳税申报，包括个人或企业实体的所得税申报。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.6" ;
    skos:prefLabel "Process payables taxes"@en,
        "处理应付账款相关税费"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.7" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Resolving any atypical or inconsistent situation concerning payments to be made by the organization. Address any exceptional case of accounts payable on an ad hoc basis, by seeking counsel or carrying out any necessary research."@en,
        "处置异常或不一致的应付账款事项。针对应付账款中的特殊情形，采取临时性应对措施，包括征询专业意见或开展必要调研。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.7" ;
    skos:prefLabel "Research/Resolve payable exceptions"@en,
        "调查与解决应付账款异常事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.8" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Making payments for products/services on due dates (payment cycle) decided by parties involved."@en,
        "按合同约定或双方协商确定的付款周期（到期日）支付商品或服务款项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.8" ;
    skos:prefLabel "Process payments"@en,
        "执行付款操作"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.1.9" ;
    skos:broader <https://oprocess.net/opf/node/9.6.1> ;
    skos:definition "Clarifying or address queries relating to the particulars of AP such as date, discounts, amount, and installments. Coordinate with concerned parties about the fulfillment of bills payable."@en,
        "解答或处理关于应付账款明细（如日期、折扣、金额、分期安排等）的咨询，协同相关方推进应付账款履约。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.1.9" ;
    skos:prefLabel "Respond to AP inquiries"@en,
        "响应应付账款相关咨询"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.6.2> ;
    skos:definition "Explaining policies and procedures related to reimbursements requests by employees. Set policies regarding reimbursement process and amount limits etc. Inform employees."@en,
        "宣贯员工费用报销相关政策与流程，明确报销标准、限额等规定并及时传达。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2.1" ;
    skos:prefLabel "Establish and communicate expense reimbursement policies and approval limits"@en,
        "制定并宣贯费用报销政策及审批限额"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.6.2> ;
    skos:definition "Collecting and reporting all pertinent information regarding the taxes paid by the organization's employees."@en,
        "汇总并报送组织员工所缴纳的各项税费信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2.2" ;
    skos:prefLabel "Capture and report relevant tax data"@en,
        "采集并报送相关税务数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.6.2> ;
    skos:definition "Permitting expense reimbursement requests from employees."@en,
        "受理员工提交的费用报销申请。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2.3" ;
    skos:prefLabel "Approve reimbursements and advances"@en,
        "审批费用报销及预支款项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.6.2> ;
    skos:definition "Paying for expense reimbursement requests from employees. (Follow Approve reimbursements and advances [10882] according to policies and conditions.)"@en,
        "向员工支付经批准的费用报销款项（须遵循［10882］《报销及预支审批》政策与条件）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2.4" ;
    skos:prefLabel "Process reimbursements and advances"@en,
        "处理费用报销及预支款项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.6.2> ;
    skos:definition "Maintaining accounts of individuals who are connected with business."@en,
        "维护与企业经营活动相关的个人账户信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.2.5" ;
    skos:prefLabel "Manage personnel accounts"@en,
        "管理员工个人往来账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Developing procedures for using company credit cards. Set or approve credit limits."@en,
        "制定公司信用卡使用规范，设定或审批信用额度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.1" ;
    skos:prefLabel "Establish corporate credit card policies and approval limits"@en,
        "制定企业信用卡政策及审批限额"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Handling applications credit card applications for business expenses."@en,
        "受理企业用途信用卡申请。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.2" ;
    skos:prefLabel "Process corporate credit card requests"@en,
        "受理企业信用卡申请"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Obtaining credit cards for business-related expenses."@en,
        "申领用于公务支出的信用卡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.3" ;
    skos:prefLabel "Order corporate credit cards"@en,
        "订购企业信用卡"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Handling credit card accounts of business customers."@en,
        "管理企业客户的信用卡账户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.4" ;
    skos:prefLabel "Manage corporate credit card accounts"@en,
        "管理企业信用卡账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Authorizing changes to the available credit advances."@en,
        "审批可用信用额度的调整申请。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.5" ;
    skos:prefLabel "Approve/Change credit limits"@en,
        "审批或调整信用额度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.6.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.6.3.6" ;
    skos:broader <https://oprocess.net/opf/node/9.6.3> ;
    skos:definition "Blocking an existing credit card to disable all future transactions."@en,
        "冻结现有信用卡，终止所有后续交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.6.3.6" ;
    skos:prefLabel "Cancel/Deactivate credit card"@en,
        "注销或停用信用卡"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Selecting opportunities and the authoritative body for investments in trading in bonds, currencies, financial derivatives, etc."@en,
        "遴选债券、外汇、金融衍生品等交易投资机会，并明确投资决策授权主体。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.1" ;
    skos:prefLabel "Establish scope and governance of treasury operations"@en,
        "界定资金运营范围与治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Creating and providing investment regulations for the organization. Establish policies and procedures for investments to optimize liquidity in treasury operations. Create a written copy of it."@en,
        "为组织制定并发布投资管理规定；建立优化司库流动性所需的投资政策与流程，并形成书面文件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.2" ;
    skos:prefLabel "Establish and publish treasury policies"@en,
        "制定并发布资金政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Making processes for investing. Create steps for investments in bonds, currencies, and financial derivatives in order to optimize company's liquidity, invest excess cash, and reduce its financial risks."@en,
        "设计并实施投资流程；明确债券、外汇及金融衍生品投资的操作步骤，以优化公司流动性、投资闲置资金并降低财务风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.3" ;
    skos:prefLabel "Develop treasury procedures"@en,
        "制定资金操作流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Checking treasury processes in order to optimize company's liquidity, invest excess cash, and reduce its financial risks."@en,
        "审查司库流程，以优化公司流动性、投资闲置资金并降低财务风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.4" ;
    skos:prefLabel "Monitor treasury procedures"@en,
        "监控资金操作流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Auditing the treasury function."@en,
        "对司库职能开展审计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.5" ;
    skos:prefLabel "Audit treasury procedures"@en,
        "审计资金操作流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Reassessing all treasury procedures based on audit findings."@en,
        "依据审计结果，全面复审并更新所有司库流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.6" ;
    skos:prefLabel "Revise treasury procedures"@en,
        "修订资金操作流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.7" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Creating and managing the internal control systems for investments in bonds, currencies, and financial derivatives to verify procedures."@en,
        "建立并管理针对债券、外汇及金融衍生品投资的内部控制体系，以验证相关流程执行的有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.7" ;
    skos:prefLabel "Develop and confirm internal controls for treasury"@en,
        "设计并确认资金内控机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.1.8" ;
    skos:broader <https://oprocess.net/opf/node/9.7.1> ;
    skos:definition "Describing the need of treasury security requirements for controlling access, reliability of information, accountability, and availability of information in the organization."@en,
        "明确司库安全要求，涵盖访问控制、信息可靠性、责任可追溯性及信息可用性等方面。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.1.8" ;
    skos:prefLabel "Define treasury security requirements"@en,
        "明确资金安全要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Correcting cash differences in the books of accounts. Make optimum utilization of funds available in the business. Check for differences to rectify."@en,
        "核对账簿中现金差异并及时调整；最大化利用企业可用资金；定期核查差异并予以纠正。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.1" ;
    skos:prefLabel "Manage and reconcile cash positions"@en,
        "管理与核对现金头寸"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Taking care of all cash-related activities in the business. Utilize short-term assets that can be easily convertible into cash, such as marketable securities, commercial paper and short-term government bonds, and treasury bills."@en,
        "统筹管理企业全部现金相关活动；运用可快速变现的短期资产，如上市证券、商业票据、短期国债及国库券。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.2" ;
    skos:prefLabel "Manage cash equivalents"@en,
        "管理现金等价物"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Supervising all online transactions."@en,
        "监督全部线上资金交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.3" ;
    skos:prefLabel "Process and oversee electronic fund transfers (EFTs)"@en,
        "处理与监督电子资金转账（EFT）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Preparing forecasts for the cash generated or used by the organization."@en,
        "编制组织经营活动产生的或使用的现金流预测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.4" ;
    skos:prefLabel "Develop cash flow forecasts"@en,
        "编制现金流量预测"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Delaying the outflow of funds as long as possible, but encourage the inflow of as fast as possible."@en,
        "在合规前提下尽可能延缓资金流出，同时加速资金流入。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.5" ;
    skos:prefLabel "Manage cash flows"@en,
        "管理现金流"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Presenting reports on all cash-related activities. Collect and manage short-term investing activities. Prepare reports of all transactions done."@en,
        "汇总并呈报全部现金相关活动报告；归集与管理短期投资活动；编制全部交易明细报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.6" ;
    skos:prefLabel "Produce cash management accounting transactions and reports"@en,
        "生成资金管理会计分录及报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.7" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Maintaining and directing the course of relationships with banking partners."@en,
        "维护并主导与银行合作伙伴的关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.7" ;
    skos:prefLabel "Manage and oversee banking relationships"@en,
        "管理与监督银行合作关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.2.8" ;
    skos:broader <https://oprocess.net/opf/node/9.7.2> ;
    skos:definition "Studying and finalizing bank fees for services provided by banks. Negotiate and finalize nominal fees that bank charges for various services, such as requesting a deposit slip or counter check or certifying papers."@en,
        "研究、协商并最终确定银行所提供服务的各项收费；就存款单、柜台支票、文件认证等具体服务，谈判并锁定合理费率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.2.8" ;
    skos:prefLabel "Analyze, negotiate, resolve, and confirm bank fees"@en,
        "分析、协商、解决并确认银行费用"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Maintaining subsidiaries' company accounts opened with bank inside the corporation. Manage different financial services provided by in-house bank structure for parent companies' subsidiaries or branches."@en,
        "维护子公司在集团内部银行开立的账户；向母公司下属子公司或分支机构提供内部银行架构所支持的各类金融服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.1" ;
    skos:prefLabel "Manage in-house bank accounts for subsidiaries"@en,
        "为子公司管理内部银行账户"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Arranging loans for subsidiaries from in-house banks."@en,
        "安排内部银行向子公司提供贷款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.2" ;
    skos:prefLabel "Manage and facilitate inter-company borrowing transactions"@en,
        "管理并促进关联公司间借贷交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Handling payments made for subsidiaries by parent company."@en,
        "处理母公司代子公司对外支付的款项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.3" ;
    skos:prefLabel "Manage centralized outgoing payments on behalf of subsidiaries"@en,
        "代表子公司集中处理对外付款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Handling payments received by parent company for subsidiaries."@en,
        "处理母公司代子公司收取的款项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.4" ;
    skos:prefLabel "Manage central incoming payments on behalf of subsidiaries"@en,
        "代表子公司集中处理收款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Taking care of all business outflows and recording as whole. Manage making all payments for the organization and its units or subsidiaries. Track in books of accounts of parent company."@en,
        "统筹管理企业全部资金支出并统一记账；负责组织及其下属单位或子公司的全部付款事务，并在母公司账簿中完整记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.5" ;
    skos:prefLabel "Manage internal payments and netting transactions"@en,
        "管理内部付款及净额结算交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Computing all expenses paid to and receivables collected over the organization's banking activity. Calculate all charges and receivables, towards interest, fees, and any other payments over its own bank accounts. Record transactions in the books of accounts."@en,
        "核算集团银行业务产生的全部费用支出与应收款项，包括利息、手续费及其他账户相关收支，并在账簿中准确记账。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.6" ;
    skos:prefLabel "Calculate interest and fees for in-house bank accounts"@en,
        "核算内部银行账户的利息与费用"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.3.7" ;
    skos:broader <https://oprocess.net/opf/node/9.7.3> ;
    skos:definition "Facilitating account statements for all in-house banking activity."@en,
        "为全部内部银行业务生成并提供账户对账单。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.3.7" ;
    skos:prefLabel "Provide account statements for in-house bank accounts"@en,
        "出具内部银行账户对账单"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Developing and instituting principles that the organization ill use in making investments."@en,
        "制定并推行组织投资决策所遵循的基本原则。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.1" ;
    skos:prefLabel "Establish investment policy"@en,
        "制定投资政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Maintaining smooth relations with financial investment banks that help availing loans and services."@en,
        "持续维护与投资银行等金融机构的良好合作关系，以高效获取贷款及相关服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.2" ;
    skos:prefLabel "Manage financial intermediary relationships"@en,
        "管理金融中介机构关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Managing and maintaining enough liquidity in form of cash and cash equivalents in the business to meet urgent and timely requirements"@en,
        "确保企业持有充足现金及现金等价物，以满足紧急及日常资金需求，维持必要流动性水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.3" ;
    skos:prefLabel "Manage liquidity"@en,
        "管理流动性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Managing the exposure incurred by the issuer for providing credit to the borrower."@en,
        "管理发行人因向借款人提供信贷而产生的信用风险敞口。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.4" ;
    skos:prefLabel "Manage issuer exposure"@en,
        "管理发行人风险敞口"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Tracking loans taken and money invested in different options. Arrange and supervise loans from banks and individuals and investments in different available and profitable options."@en,
        "跟踪已获取贷款及各类投资情况；统筹安排并监督来自银行及个人的贷款，以及面向各类高收益可行渠道的投资。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.5" ;
    skos:prefLabel "Process and oversee debt and investment transactions"@en,
        "处理与监督债务及投资交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Arranging and supervising foreign exchange rate changes to avoid loss on foreign-currency transactions."@en,
        "统筹安排并监控汇率变动，规避外币交易可能产生的汇兑损失。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.6" ;
    skos:prefLabel "Process and oversee foreign currency transactions"@en,
        "处理与监督外汇交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.7" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Creating transactions report of loans and investments. Prepare and maintain records of loans and investment transactions."@en,
        "编制贷款与投资交易报告；建立并持续维护贷款及投资交易台账。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.7" ;
    skos:prefLabel "Produce debt and investment accounting transaction reports"@en,
        "生成债务与投资会计交易报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.4.8" ;
    skos:broader <https://oprocess.net/opf/node/9.7.4> ;
    skos:definition "Supervising the interest paid or received by the organization. Arrange and supervise interest rate swap transactions to manage exposure to fluctuations in interest rates. Or attain a marginally lower rate of interest than could be gained through a swap."@en,
        "监督组织应付及应收利息；统筹安排并执行利率互换交易，以对冲利率波动风险；或通过互换获取略优于直接融资的利率水平。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.4.8" ;
    skos:prefLabel "Process and oversee interest rate transactions"@en,
        "处理与监督利率相关交易"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Taking an investment position to offset exposure to certain risks. This may include purchasing opposite of the organization's position in the marketplace, using derivatives transactions, or futures contracts."@en,
        "采取反向投资头寸以对冲特定风险敞口，包括在市场中建立与组织现有头寸相反的仓位，或运用衍生工具、期货合约等开展对冲操作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.1" ;
    skos:prefLabel "Develop risk management/hedging strategy"@en,
        "制定风险管理/套期保值策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.5.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.2> ;
    skos:definition "Collecting and storing data that pertains to interest rate markets."@en,
        "采集并存储与利率市场相关的数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.2.1" ;
    skos:prefLabel "Manage interest rate market data"@en,
        "管理利率市场数据"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.2> ;
    skos:definition "Identifying potential interest rate risks for all markets."@en,
        "识别所有市场的潜在利率风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.2.2" ;
    skos:prefLabel "Determine interest rate exposure for all markets"@en,
        "评估各市场的利率风险敞口"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.2> ;
    skos:definition "Deciding the requirements on interest rate investments that are made by trading in futures or options market, on the basis of the accepted risk policy."@en,
        "依据已批准的风险政策，确定通过期货或期权市场开展利率投资所需满足的要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.2.3" ;
    skos:prefLabel "Determine interest rate hedge requirements in accordance with risk policy"@en,
        "依据风险政策确定利率对冲需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.2> ;
    skos:definition "Performing trading on interest rates."@en,
        "执行利率交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.2.4" ;
    skos:prefLabel "Execute interest rate trades"@en,
        "执行利率交易"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.3> ;
    skos:definition "Handling and processing information about changes in foreign exchange rates."@en,
        "处理和分析汇率变动相关信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3.1" ;
    skos:prefLabel "Manage foreign exchange market data"@en,
        "管理外汇市场数据"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.3> ;
    skos:definition "Establishing potential foreign exchange risks for all currencies."@en,
        "识别所有币种的潜在外汇风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3.2" ;
    skos:prefLabel "Determine foreign exchange exposure for all currencies"@en,
        "评估各币种的外汇风险敞口"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.3> ;
    skos:definition "Deciding the requirements on investments in foreign exchange made by trading in futures or options market, on the basis of current risk policy."@en,
        "依据现行风险政策，确定通过期货或期权市场开展外汇投资所需满足的要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3.3" ;
    skos:prefLabel "Determine foreign exchange hedge requirements in accordance with risk policy"@en,
        "依据风险政策确定外汇对冲需求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.3> ;
    skos:definition "Executing all aspects for foreign exchange trade within foreign exchange market. This includes buying, selling, and exchanging currencies at the current or expressed price point."@en,
        "在外汇市场内执行全部外汇交易操作，包括按即期或约定汇率进行货币买卖与兑换。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3.4" ;
    skos:prefLabel "Execute foreign exchange trades"@en,
        "执行外汇交易"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.3.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.3> ;
    skos:definition "Overseeing the foreign exchange balance sheet with an eye towards potential risk. Risks include changes in conversion rates between the time the transaction occurred and when it is completed, or when transactions are made in a denomination other than that of the organization's base currency."@en,
        "监控外汇资产负债表，关注潜在风险；风险包括交易发生至完成期间的汇率变动，或以非组织本位币计价的交易。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.3.5" ;
    skos:prefLabel "Manage foreign exchange balance sheet risk"@en,
        "管理外汇资产负债表风险"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.4.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.4> ;
    skos:definition "Establishing ongoing risks that the customers face, and the exceptions to exceeded limits."@en,
        "持续识别客户面临的各类风险及超出限额的异常情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.4.1" ;
    skos:prefLabel "Determine current customer exposures and limit exceptions"@en,
        "识别当前客户风险敞口及限额例外情况"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.4.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.4> ;
    skos:definition "Settling cases that involve violations of customer exposure limit."@en,
        "处理客户敞口限额违规事件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.4.2" ;
    skos:prefLabel "Resolve customer exposure limit violations"@en,
        "处理客户风险敞口超限问题"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.4.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.4> ;
    skos:definition "Handling customer securities to recover loans that are not paid back."@en,
        "处置客户质押证券，用于清收未偿还贷款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.4.3" ;
    skos:prefLabel "Manage customer collateral"@en,
        "管理客户抵押品"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.4.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.4> ;
    skos:definition "Conducting reviews to assess customer credit on a yearly basis. Introduce changes or make recommendations, if needed."@en,
        "每年开展客户信用评估审查，必要时提出调整建议或改进措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.4.4" ;
    skos:prefLabel "Perform annual customer credit reviews"@en,
        "开展年度客户信用评审"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.5> ;
    skos:definition "Evaluating investments made in some market to offset the risks of investing in a contrary or opposing market."@en,
        "评估在某一市场所作投资能否有效对冲在相反或对立市场投资所产生的风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5.1" ;
    skos:prefLabel "Measure physical positions"@en,
        "计量实物头寸"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5.2" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.5> ;
    skos:definition "Determining which hedge options to execute."@en,
        "确定拟执行的对冲工具选项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5.2" ;
    skos:prefLabel "Establish hedges"@en,
        "建立套期保值头寸"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5.3" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.5> ;
    skos:definition "Closing out a position or cashing in derivatives early."@en,
        "提前平仓或提前行权衍生品合约。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5.3" ;
    skos:prefLabel "Unwind hedges"@en,
        "平仓套期保值头寸"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5.4" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.5> ;
    skos:definition "Examining options in the market for hedging investments. Select an option."@en,
        "评估市场可用的对冲投资工具并择优选用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5.4" ;
    skos:prefLabel "Evaluate and refine hedging positions"@en,
        "评估并优化套期保值头寸"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.5.5" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5.5> ;
    skos:definition "Revising credit reports periodically for accurateness and changes that could be suggestive of duplicitous activity."@en,
        "定期复核信用报告，确保其准确性，并识别可能暗示欺诈行为的异常变化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.5.5" ;
    skos:prefLabel "Monitor credit"@en,
        "监控信用风险"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/9.7.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.5.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7.5> ;
    skos:definition "Preparing and documenting accounts and records of all hedging investment transactions to reduce risks due to change in markets."@en,
        "编制并归档全部对冲投资交易的账目与记录，以降低市场变动引发的风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.5.6" ;
    skos:prefLabel "Produce hedge accounting transactions and reports"@en,
        "生成套期会计分录及报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.7.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.7.6" ;
    skos:broader <https://oprocess.net/opf/node/9.7> ;
    skos:definition "Handling cases that involve financial fraud. Resolve disputes."@en,
        "处理金融欺诈案件，解决相关争议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.7.6" ;
    skos:prefLabel "Manage financial fraud/dispute cases"@en,
        "管理财务欺诈/争议案件"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.8.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.8.1> ;
    skos:definition "Establishing board of directors and auditing committee in order to assign roles and responsibilities for internal controls."@en,
        "设立董事会及审计委员会，明确内部控制职责分工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1.1" ;
    skos:prefLabel "Establish board of directors and audit committee"@en,
        "设立董事会及审计委员会"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.8.1> ;
    skos:definition "Outlining and communicating a code of ethics act responsibly."@en,
        "制定并宣贯合规、尽责的职业道德规范。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1.2" ;
    skos:prefLabel "Define and communicate code of ethics"@en,
        "制定并宣贯职业道德规范"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.8.1> ;
    skos:definition "Defining roles, responsibilities, and accountabilities for effectiveness and proficiency of operations and reliability of financial reporting."@en,
        "明确运营效率、效果及财务报告可靠性相关的角色、职责与问责机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1.3" ;
    skos:prefLabel "Assign roles and responsibility for internal controls"@en,
        "明确内部控制职责分工"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.8.1> ;
    skos:definition "Outlining the objectives and risks associated with a process. Delineate process goals. Determine the risks attached to it. Determine what the process is meant to accomplish, potential issues, a timeline of potential risks, the scope and potential impact of risks, etc."@en,
        "梳理流程对应的目标与风险，界定流程目标，识别关联风险，明确流程预期成效、潜在问题、风险时间线、影响范围及潜在后果等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1.4" ;
    skos:prefLabel "Define business process objectives and risks"@en,
        "界定业务流程目标与风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.1.5" ;
    skos:broader <https://oprocess.net/opf/node/9.8.1> ;
    skos:definition "Outlining the risk tolerance levels of individual units, as well as the organization as a whole. Determine the specific maximum risk to take in quantitative terms for each relevant risk subcategory, including strategic, operational, financial, and compliance risks."@en,
        "设定各业务单元及组织整体的风险容忍度水平，以量化方式明确战略、运营、财务及合规等各子类风险的最大可接受风险值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.1.5" ;
    skos:prefLabel "Define entity/unit risk tolerances"@en,
        "设定组织/单元风险容忍度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.8.2> ;
    skos:definition "Overseeing the activities for internal controls. Observe the effectiveness of policies, procedures, techniques, and mechanisms actions taken to minimize risk."@en,
        "监督内部控制活动，评估相关政策、程序、技术及控制措施在风险最小化方面的有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.2.1" ;
    skos:prefLabel "Monitor control effectiveness"@en,
        "监控控制有效性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.8.2> ;
    skos:definition "Taking corrective measures for policies, procedures, techniques, and mechanisms actions taken to minimize risk. (Conduct in accordance with Monitor control effectiveness [10918] in order to determine and rectify the control deficiencies.)"@en,
        "针对政策、程序、技术及控制措施存在的缺陷采取整改行动（须依据‘监控控制有效性 [10918]’流程识别并纠正控制缺陷）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.2.2" ;
    skos:prefLabel "Remediate control deficiencies"@en,
        "整改控制缺陷"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.3.1" ;
    skos:broader <https://oprocess.net/opf/node/9.8.3> ;
    skos:definition "Reporting to external auditors. This process requires the organization to report to external auditors about the regulations for any critical data that the organization is holding."@en,
        "向外部审计机构报告，说明组织所持有关键数据适用的相关监管规定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.3.1" ;
    skos:prefLabel "Report to external auditors"@en,
        "向外部审计师报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.3.2" ;
    skos:broader <https://oprocess.net/opf/node/9.8.3> ;
    skos:definition "Reporting to regulators, shareholders, debt holders, securities exchanges, etc. about IT regulations and pertinent data."@en,
        "向监管机构、股东、债权人、证券交易所等报告信息技术（IT）监管要求及相关数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.3.2" ;
    skos:prefLabel "Report to regulators, share-/debt-holders, securities exchanges, etc."@en,
        "向监管机构、股东/债权人、证券交易所等报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.3.3" ;
    skos:broader <https://oprocess.net/opf/node/9.8.3> ;
    skos:definition "Reporting to suppliers, customers, and partners that are doing business with the company about IT regulations and pertinent data."@en,
        "向供应商、客户及合作伙伴等业务关联方报告信息技术（IT）监管要求及相关数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.3.3" ;
    skos:prefLabel "Report to third parties"@en,
        "向第三方报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.8.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.3.4" ;
    skos:broader <https://oprocess.net/opf/node/9.8.3> ;
    skos:definition "Reporting to internal management (all employees, directors, and management) about IT regulations and pertinent data."@en,
        "向内部管理层（含全体员工、董事及各级管理人员）报告信息技术（IT）监管要求及相关数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.3.4" ;
    skos:prefLabel "Report to internal management"@en,
        "向内部管理层报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.1.1" ;
    skos:broader <https://oprocess.net/opf/node/9.9.1> ;
    skos:definition "Developing a tax strategy for foreign, national, state, local administration. Set up tax strategies for foreign trade in imports and exports and at national, state, and local level."@en,
        "制定覆盖境外、国家、省（州）、地方层级的税收策略，统筹进出口外贸及国家、省（州）、地方三级税收安排。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.1.1" ;
    skos:prefLabel "Develop foreign, national, state, and local tax strategy"@en,
        "制定境外、国家、州（省）及地方税务战略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.1.2" ;
    skos:broader <https://oprocess.net/opf/node/9.9.1> ;
    skos:definition "Combining and enhancing a rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en,
        "从税务视角对财务状况或计划开展理性分析，并加以整合与优化，以通过高效税务规划实现财务目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.1.2" ;
    skos:prefLabel "Consolidate and optimize total tax plan"@en,
        "整合并优化整体税务规划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.1.3" ;
    skos:broader <https://oprocess.net/opf/node/9.9.1> ;
    skos:definition "Maintaining a master file about the rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en,
        "建立并维护一份主文件，系统记录从税务视角开展的财务状况或计划理性分析，支撑高效税务规划及财务目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.1.3" ;
    skos:prefLabel "Maintain tax master data"@en,
        "维护税务主数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.1" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Creating and implementing strategies for taxes to be paid or collected by the business."@en,
        "制定并实施企业应缴或代收税款的战略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.1" ;
    skos:prefLabel "Perform tax planning/strategy"@en,
        "开展税务筹划／制定税务策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.2" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Preparing and submitting tax reports for every employee to the tax department in order to show the tax paid and deducted from their salaries in the year."@en,
        "为全体员工编制并提交年度纳税申报表至税务主管部门，列明当年已缴及工资代扣税款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.2" ;
    skos:prefLabel "Prepare tax returns"@en,
        "编制纳税申报表"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.3" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Preparing reports about paid or accrued foreign taxes to an overseas country."@en,
        "编制已支付或已计提的境外国家税款报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.3" ;
    skos:prefLabel "Prepare foreign taxes"@en,
        "编制境外税款申报材料"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.4" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Calculating the income that has been realized when the tax on that income has not."@en,
        "核算已实现但尚未计税的收入。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.4" ;
    skos:prefLabel "Calculate deferred taxes"@en,
        "核算递延税款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.5" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Managing the organization's financial accounts for the purpose of taxation. Prepare and maintain the tax paid by the organization to the country they have business in."@en,
        "管理组织财务账目以满足税务要求；编制并持续维护组织在各经营所在国缴纳的税款记录。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.5" ;
    skos:prefLabel "Account for taxes"@en,
        "进行税务会计处理"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.6" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Checking and correcting the tax policies according to the rules and regulations set by the organization."@en,
        "依据组织内部规章制度，核查并修订税务政策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.6" ;
    skos:prefLabel "Monitor tax compliance"@en,
        "监控税务合规性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.9.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9.2.7" ;
    skos:broader <https://oprocess.net/opf/node/9.9.2> ;
    skos:definition "Addressing any tax queries by any regulatory or government authorities. Review historical records related to taxation within the organization in order to respond to queries."@en,
        "响应监管机构或政府部门提出的任何税务问询；调阅组织内部历史税务资料以支持答复。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9.2.7" ;
    skos:prefLabel "Address tax inquiries"@en,
        "响应税务咨询与问询"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Defining the various options available to achieve the goals highlighted in the mission statement. Delineate (in accordance with a predefined criteria) the various permutations of strategic decisions that would help the organization achieve the objectives outlined in Develop overall mission statement [10037]. Involve senior management and key strategy personnel, with timely help from professional services providers."@en,
        "界定实现使命陈述所列目标的多种可行路径。依据预设标准，系统梳理‘制定总体使命陈述’[10037]中提出目标的各类战略决策组合；由高管层与核心战略人员主导，适时引入专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.1" ;
    skos:prefLabel "Define strategic options"@en,
        "定义战略选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Developing possibilities and arrangements to improve opportunities and reduce deviations to project objectives."@en,
        "制定提升机遇、减少对项目目标偏离的备选方案与应对安排。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.3" ;
    skos:prefLabel "Develop mitigation plans for risks"@en,
        "制定风险缓解计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Assessing and examining the set of activities and tasks that, once completed, will accomplish an organizational goal. Create a business process model that captures how a business process works and how individuals from different groups work together to achieve a business goal."@en,
        "评估并分析为达成组织目标所需完成的一整套活动与任务。构建业务流程模型，展现流程运作逻辑及跨部门人员协同实现业务目标的方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.2" ;
    skos:prefLabel "Analyze processes"@en,
        "分析流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/13.1.4> ;
    skos:definition "Defining and using performance indicators to consider the financial perspective, customer perspective, internal process perspective, and learning perspective of the organization."@en,
        "定义并应用绩效指标，涵盖组织的财务视角、客户视角、内部流程视角及学习与成长视角。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.4.3" ;
    skos:prefLabel "Measure and report process performance"@en,
        "度量并报告流程绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/2.3.1> ;
    skos:definition "Allocating resources to the design, development, and evaluation of product/service concepts. Allocate funds, personnel, and time for developing the new and/or revised products/services. Begin to design the potential new product/service concepts that have been prioritized and selected for further development."@en,
        "为产品/服务概念的设计、开发与评估配置资源；统筹安排资金、人力与时间，用于新/修订产品/服务的开发；启动已优先筛选并确定进入下一阶段的产品/服务概念设计工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.1.1" ;
    skos:prefLabel "Assign resources to product/service project"@en,
        "为产品/服务项目配置资源"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/2.3.3> ;
    skos:definition "Finalizing production process or methodology. Install and initiate the production process to manufacture the new products, using the equipment and machinery already assembled. In the case of new services, implement delivery processes and methodologies. Validate processes for the accuracy of their operation and proper functioning."@en,
        "固化生产流程或方法论。依托已部署的设备与机械，正式启动新产品制造流程；若为新服务，则实施交付流程与方法论；验证流程运行准确性与功能完备性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.3.4" ;
    skos:prefLabel "Install and validate production/service delivery process"@en,
        "安装并验证生产/服务交付流程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Identifying a section of the customer population to target for marketing products/services. Create segments within the customer population for targeted marketing campaigns, which increase the efficacy of marketing outlay. Determine the right customer segments, craft effective marketing messages, and efficiently communicate them. Determine the optimal pricing mix. Consider assistance from professional services for market segmentation studies, with coordination and oversight from the marketing/sales functions."@en,
        "划定目标客户群体以开展精准营销。在客户群体中划分细分市场，支撑高成效的定向营销活动；精准定位目标客户群、设计有效营销信息并高效触达；确定最优定价组合；可借助专业服务机构开展市场细分研究，并由营销/销售职能统筹协调与监督。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.2" ;
    skos:prefLabel "Identify market segments"@en,
        "识别细分市场"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2> ;
    skos:definition "Identifying the targeted segment of customers. Deduce those particular customer segments that are to be targeted from among the market segments."@en,
        "明确目标客户群体。从整体市场细分中推导出需重点覆盖的具体客户细分。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.2" ;
    skos:prefLabel "Determine target segments"@en,
        "确定目标细分市场"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/7.2.5> ;
    skos:definition "Keeping track of all the information about the candidates who apply for jobs. Use applicant-tracking systems that can be accessed online as a central location and database for recruitment efforts."@en,
        "全程跟踪候选人应聘信息：依托可在线访问的申请人跟踪系统（ATS），打造招聘工作的统一中枢与数据库。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.2.5.3" ;
    skos:prefLabel "Manage/Track applicant data"@en,
        "管理与追踪应聘者数据"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.6.3" ;
    skos:broader <https://oprocess.net/opf/node/7.6> ;
    skos:definition "Managing the relocation of employees in order to carry out assignments. Manage internal business processes to transfer employees, their families, and/or entire departments of a business to a new location."@en,
        "为履行工作任务而管理员工异地调动，统筹内部业务流程，实现员工本人、家属及整建制部门的整体迁移。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.6.3" ;
    skos:prefLabel "Relocate employees and manage assignments"@en,
        "管理员工异地调动与岗位委派"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.4" ;
    skos:broader <https://oprocess.net/opf/node/8.5> ;
    skos:definition "Understanding customer requirements. Design the IT services and solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Test the IT services and solutions in advance. Confirm the customer experience post-sale."@en,
        "理解客户需求；基于需求设计IT服务与解决方案；开发满足需求的组件；培训支持人员；提前测试IT服务与解决方案；售后确认客户体验。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.4" ;
    skos:prefLabel "Execute IT service/solution creation and testing"@en,
        "执行IT服务/解决方案构建与测试"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.5.5" ;
    skos:broader <https://oprocess.net/opf/node/8.5> ;
    skos:definition "Engaging in all aspects of service/solution maintenance and testing includes all preventative, routine, and corrective activates. Ensure that IT service/solution are functioning properly and regulations where applicable."@en,
        "全面开展服务/解决方案的运维与测试工作，涵盖预防性、例行性及纠正性活动；确保IT服务/解决方案正常运行，并符合相关法规要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.5.5" ;
    skos:prefLabel "Perform service/solution maintenance and testing"@en,
        "开展服务/解决方案维护与测试"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.7.3" ;
    skos:broader <https://oprocess.net/opf/node/8.7> ;
    skos:definition "Determine and manage service delivery flow across different business functions. Understand the level of services needed by different stakeholders. Identify major service delivery touch points and criticality associated. Ensure timely communication with users."@en,
        "统筹跨业务职能的服务交付流程；识别不同干系人的服务需求层级；识别关键服务交付触点及其重要性；确保与用户及时沟通。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.7.3" ;
    skos:prefLabel "Plan and manage service delivery control"@en,
        "规划与管理服务交付管控"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Scoping and probing to study the impact of strategic options for fulfilling the organization's objectives. Estimate a measure of the impact effectuated by each set of strategic decisions, which comprise Define strategic options [10047]. Closely examine the consequences of each option."@en,
        "界定并探查各项战略选项对组织目标达成的影响范围与深度。量化评估‘界定战略选项’[10047]所涉每组战略决策的实际影响；深入剖析各选项可能引发的连锁后果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.2" ;
    skos:prefLabel "Assess and analyze impact of each option"@en,
        "评估各选项的影响"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.8.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8> ;
    skos:definition "Creating a roadmap for customer experience support with an overall approach, process flow, and impact timeframe."@en,
        "制定客户体验支持路线图，明确总体方法、流程路径与影响周期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.3" ;
    skos:prefLabel "Design customer experience support structure"@en,
        "设计客户体验支撑体系"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Examining projects of strategic significance that lie outside the purview of the organization's routine operations. Closely analyze strategic initiatives for their applicability and feasibility, given the organization's vision."@en,
        "审视超出组织日常运营范畴的战略级项目；结合组织愿景，深入分析战略举措的适用性与可行性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.2" ;
    skos:prefLabel "Evaluate strategic initiatives"@en,
        "评估战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Selecting relevant projects of strategic significance that create opportunities for the organization to realize its long-term objectives, on the basis of their suitability to the organization's constraints and reality. Select from the process Evaluate strategic initiatives [10058], based on their applicability and feasibility for the organization. Enlist senior management, especially strategy personnel."@en,
        "依据组织约束条件与现实基础，遴选能创造发展机遇、助力实现长期目标的战略级项目；从“评估战略举措”流程[10058]中，基于适用性与可行性择优选取，并纳入高层管理者（尤其是战略职能人员）参与决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.3" ;
    skos:prefLabel "Select strategic initiatives"@en,
        "遴选战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.3" ;
    skos:broader <https://oprocess.net/opf/node/10.1> ;
    skos:definition "Managing the provision of the workspace and its assets. Arrange an office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements."@en,
        "统筹提供办公空间及其配套资产；按需配置办公场所及全部资产（含桌椅、计算机、行政人员等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.3" ;
    skos:prefLabel "Provide workspace and facilities"@en,
        "提供办公场所与配套设施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.1" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Creating a strategy for managing asset exits."@en,
        "制定资产退出策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.1" ;
    skos:prefLabel "Develop exit strategy"@en,
        "制定退出策略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.3" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "Maintaining relations with representatives of the stockholders. Establish corporate management-related policies and to make decisions on major company issues. Implement practices designed to engender communication, trust, and cooperation."@en,
        "维系与股东代表的关系；制定公司治理相关政策，并就重大公司事项作出决策；推行旨在促进沟通、信任与协作的实践机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.3" ;
    skos:prefLabel "Manage relations with board of directors"@en,
        "管理与董事会的关系"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.4" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Ensuring the organization's compliance position. Validate compliance with different statutes, regulatory directions, and legal principles (using Establish compliance framework and policies [17468]). Coordinate with compliance and risk management personnel."@en,
        "确保组织整体合规状态；验证对各项成文法、监管指引及法律原则的遵从情况（参见「建立合规框架与政策 [17468]」）；协同合规与风险管理相关人员开展工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.4" ;
    skos:prefLabel "Ensure compliance"@en,
        "确保合规"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1> ;
    skos:definition "Determining and organizing the structural composition of business processes. Design, establish, and administer the framework. Identify any cross-functional processes that are mandatory for achieving business excellence."@en,
        "确定并构建业务流程的结构化体系。设计、建立并管理流程框架；识别支撑业务卓越所需的跨职能核心流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.2" ;
    skos:prefLabel "Define and manage process frameworks"@en,
        "定义并管理流程框架"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Developing and managing sustainability practices for the organization. Ensure proper understanding and communication of ESG standards, requirements, capabilities, and future trends. Promote awareness, alignment, and continuity."@en,
        "制定并管理组织可持续发展实践；确保准确理解与有效传达环境、社会与治理（ESG）标准、要求、能力及未来趋势；推动意识提升、目标对齐与持续落地。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10" ;
    skos:prefLabel "Manage sustainability"@en,
        "管理可持续发展"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.10.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2.3" ;
    skos:broader <https://oprocess.net/opf/node/13.10.2> ;
    skos:definition "Conducting and supporting sustainability reporting. Collect, analyze, and report sustainability performance to requirements. Align reporting across functional units and support teams."@en,
        "开展并支持可持续发展报告工作；按要求收集、分析与报告可持续发展绩效；确保各职能单元与支持团队报告口径一致、协同对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2.3" ;
    skos:prefLabel "Perform sustainability reporting"@en,
        "开展可持续发展报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3> ;
    skos:definition "Analyzing if the performance of the quality plan has achieved the estimated and desired requirements. Conduct tests against the quality plan. Assess the results of these tests."@en,
        "分析质量计划执行绩效是否达成预估与预期要求：依据质量计划开展测试，并评估测试结果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2" ;
    skos:prefLabel "Evaluate performance to requirements"@en,
        "评估绩效符合性"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.3" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Defining requirements for systems of record and storage locations to ensure content is securely stored, retrievable, retained appropriately, and aligned with governance and compliance needs."@en,
        "明确权威数据源与存储位置的要求，确保内容安全存储、可检索、合规留存，并契合治理与合规需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.3" ;
    skos:prefLabel "Define content systems of record and storage requirements"@en,
        "界定内容权威系统与存储要求"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7.1" ;
    skos:broader <https://oprocess.net/opf/node/13.7> ;
    skos:definition "Creating and implementing a strategy for managing organizational performance. The strategy should include approaches for measuring, tracking, streamlining, and improving internal performance. It encompasses a blueprint for the tactical measurement of internal processes and work force improvement, in alignment with Employee Metrics Developed and Managed [10526]."@en,
        "制定并管理组织绩效管理策略：涵盖绩效度量、跟踪、精简与改进方法；包括面向内部流程与人力资本提升的战术级度量蓝图，并与「员工指标开发与管理 [10526]」保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.1" ;
    skos:prefLabel "Define and manage organizational performance strategy"@en,
        "定义并管理组织绩效战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.9.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.1" ;
    skos:broader <https://oprocess.net/opf/node/13.9> ;
    skos:definition "Determining the impact of EHS offering--and the procedures it employs to process them--on the environment at large, as well as the health and safety of employees. Evaluate the environmental impact of the organization's products, services, and operations. Conduct health, safety, and environmental audits."@en,
        "评估EHS职能及其运作流程对整体环境、员工健康与安全的影响；评估组织产品、服务及运营活动的环境影响；开展健康、安全与环境审计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.1" ;
    skos:prefLabel "Determine environmental health and safety impacts"@en,
        "识别环境、健康与安全影响"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/3.1.1> ;
    skos:definition "Carrying out research studies to understand the behavior of customers and the realities of the market. Undertake research to understand the market conditions as well as the characteristics, drives, and desires of prospective customers. Gather highly contextualized intelligence through primary and secondary research methods, with the objective of gaining insights over how to best seize a market opportunity. Consider assistance from professional research services."@en,
        "开展研究以洞察客户行为与市场实况。通过一手与二手研究方法，全面了解市场环境及潜在客户的特征、动机与诉求；聚焦获取高度情境化的洞察，以指导市场机会的最佳把握路径；可引入专业研究服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.1.1" ;
    skos:prefLabel "Conduct customer and market research"@en,
        "开展客户与市场调研"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/3.1.2> ;
    skos:definition "Confirming the practicability and reasonableness of the market opportunities that have been identified. Give substance to the real-time feasibility of the market opportunities."@en,
        "确认已识别市场机会的可行性与合理性，夯实其在现实场景中的落地可行性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2.4" ;
    skos:prefLabel "Validate opportunities"@en,
        "验证市场机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.3.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.9" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Creating descriptions of products that are promotional and informative in content in order to initiate and increase sales. Marketing content consists of text, and optionally, images."@en,
        "创作兼具促销性与信息性的产品描述，以激发并促进销售；营销内容包含文字及可选配图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.9" ;
    skos:prefLabel "Manage product marketing material"@en,
        "管理产品营销物料"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.2.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5.2> ;
    skos:definition "Managing the corpus of data relating all customers acquired over time. Manage the storage, maintenance, access, revision, and usage of all data on customers. Ensure its security, and determine legitimate use cases that are beneficial to the organization."@en,
        "统筹管理全量客户数据资产：规范客户数据的存储、维护、访问、更新与使用；保障数据安全，界定合法、有益于组织发展的数据应用场景。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.2.5" ;
    skos:prefLabel "Manage customer master data"@en,
        "管理客户主数据"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.13> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sOr3" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Manage SC Data and Information (sOr3)."@en,
        "SCOR DS 14.0：管理供应链数据与信息（sOr3）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.13" ;
    skos:prefLabel "Manage SC Data and Information"@en,
        "管理供应链数据与信息"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3.4" ;
    skos:broader <https://oprocess.net/opf/node/4.3> ;
    skos:definition "Perpetuating the production records by systematically documenting and using it to ensure the effective management of lots. Determine the lot numbering system and its use. (The lot number enables tracking of the constituent parts, as well as labor and equipment records involved in the manufacturing of a product. It enables manufacturers and to perform quality control checks, calculate expiration dates, and issue corrections of their production output.)"@en,
        "通过系统化记录并应用生产记录，确保批号管理的有效性。确定批号编码规则及其使用方式。（批号用于追溯产品所用的组成部件、人工及设备记录；支持制造商开展质量控制检查、计算有效期，并对生产输出实施整改。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.4" ;
    skos:prefLabel "Maintain production records and manage lot traceability"@en,
        "维护生产记录并管理批次可追溯性"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.2" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5> ;
    skos:definition "Determining and scheduling the resources required to fulfill customer service requirements. Create a detailed schedule about the service orders and development of these service orders."@en,
        "确定并调度满足客户服务需求所需的资源；制定服务工单的详细排程及工单开发计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.2" ;
    skos:prefLabel "Identify and schedule resources to meet last mile delivery requirements"@en,
        "识别并调度资源以满足末端配送需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.4.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.4.1.6" ;
    skos:broader <https://oprocess.net/opf/node/5.4.1> ;
    skos:definition "Identifying, selecting, and assigning resources required to deliver service to the customer. Ensure that all objectives are established and met, and the all rules of engagement have been identified and communicated."@en,
        "识别、遴选并指派服务交付所需资源；确保所有目标已明确并达成，且所有协作规则均已识别并传达。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.4.1.6" ;
    skos:prefLabel "Identify, select, and assign resources"@en,
        "识别、遴选与分配资源"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/6.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.2.4" ;
    skos:broader <https://oprocess.net/opf/node/6.2> ;
    skos:definition "Acquiring returns and identify if the returns are scraped or salvaged."@en,
        "接收退货并判定其属于报废或可修复状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.2.4" ;
    skos:prefLabel "Process returns"@en,
        "处理退货"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.3" ;
    skos:broader <https://oprocess.net/opf/node/6.3> ;
    skos:definition "Managing the recovery of costs from suppliers for individual claims."@en,
        "就单项索赔向供应商追偿成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.3" ;
    skos:prefLabel "Manage supplier recovery"@en,
        "管理供应商追偿"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/6.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:6.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/6.3.4> ;
    skos:definition "Determining and scheduling the resources required to fulfill customer service requirements. Create a detailed schedule about the service orders and development of these service orders."@en,
        "确定并统筹安排满足客户服务需求所需的资源；制定服务工单及其开发工作的详细排期计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "6.3.4.2" ;
    skos:prefLabel "Identify and schedule resources to meet service requirements"@en,
        "识别并调度资源以满足服务需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/7.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.3" ;
    skos:broader <https://oprocess.net/opf/node/7.5> ;
    skos:definition "Managing activities centered around delivering programs to support work/life balance for employees; developing family support systems; reviewing retention and motivation indicators; and reviewing compensation plans."@en,
        "统筹管理支持员工工作与生活平衡的项目；构建家庭支持体系；复审员工留任与激励指标；检视薪酬方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.3" ;
    skos:prefLabel "Manage employee assistance and retention"@en,
        "管理员工援助与留任"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/7.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/7.5.3> ;
    skos:definition "Designing programs that prompt proper balance between work (i.e., career and ambition) and lifestyle (i.e., health, pleasure, leisure, family, and spiritual development/meditation). Account for dependent care, flexible working arrangements, leaves of absence, on-the-job training, etc."@en,
        "设计促进职业发展（事业抱负）与生活方式（健康、休闲、家庭、精神成长/冥想）良性平衡的项目，涵盖照护依赖者、弹性工作安排、各类休假、在岗培训等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.5.3.1" ;
    skos:prefLabel "Deliver programs to support work/life balance for employees"@en,
        "实施支持员工工作与生活平衡的项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.1> ;
    skos:definition "Assessing the customer communities along with current IT operational capabilities and usage."@en,
        "评估客户群体构成，以及当前 IT 运营能力与实际使用情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.1.1" ;
    skos:prefLabel "Understand IT customer needs"@en,
        "理解IT客户需求"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/8.3.1.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.1.10" ;
    skos:broader <https://oprocess.net/opf/node/8.3.1> ;
    skos:definition "Developing activities to improve performance opportunities and lessen threats in IT. Evolve strategies and policies to attain organizational objectives."@en,
        "开展活动以提升 IT 绩效机会、降低威胁；持续优化策略与政策，支撑组织目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.1.10" ;
    skos:prefLabel "Create IT risk mitigation strategies and approaches"@en,
        "制定IT风险缓解策略与方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.3.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.3.8.4" ;
    skos:broader <https://oprocess.net/opf/node/8.3.8> ;
    skos:definition "Create and manage the process to authenticate IT users from user directory based on the internal policies."@en,
        "依据内部策略，建立并管理基于用户目录的身份认证流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.3.8.4" ;
    skos:prefLabel "Manage IT user authentication mechanisms"@en,
        "管理IT用户认证机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.4> ;
    skos:definition "Develop and implement strategies to plan and manage the flow of an information system's data from creation and initial storage to the time when it becomes obsolete and deleted."@en,
        "制定并实施信息生命周期管理策略，统筹信息系统数据从创建、初始存储至过时删除的全过程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.4.3" ;
    skos:prefLabel "Define and execute business information lifecycle planning and control"@en,
        "定义并执行业务信息生命周期规划与管控"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.4" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Managing accounts for large funds-invested projects. Manage and account for fixed assets projects (capital projects), which required significant capital investments over many years."@en,
        "大型资金投入项目的账务管理。管理并核算需多年持续投入大量资本的固定资产项目（即资本性项目）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.4" ;
    skos:prefLabel "Manage fixed-asset project accounting"@en,
        "管理固定资产项目会计"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/9.8.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.8.2" ;
    skos:broader <https://oprocess.net/opf/node/9.8> ;
    skos:definition "Performing planning, management, operations, and monitoring of internal control mechanism policies and procedures in order to manage internal controls."@en,
        "规划、管理、执行并监控内部控制机制的政策与程序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.8.2" ;
    skos:prefLabel "Operate controls and monitor compliance with internal controls policies and procedures"@en,
        "运行控制措施并监督内控政策与流程执行情况"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/9.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.9" ;
    skos:broader <https://oprocess.net/opf/node/9.0> ;
    skos:definition "Estimating the organization's periodic tax liabilities. Ensure that appropriate taxing authorities receive tax return filings and payments when due."@en,
        "测算组织周期性税务负债，确保按时向主管税务机关提交纳税申报表并缴纳税款。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.9" ;
    skos:prefLabel "Manage taxes"@en,
        "管理税务"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "Examining the market to identify customer required solutions. Assess the relevant market(s) to determine the products/services that are needed or wanted by customers. Carry out quantitative and qualitative analyses to capture and investigate products/services. Employ creative techniques that allow for a closer appreciation of the customer, and design relevant solutions."@en,
        "通过市场调研识别客户所需解决方案；评估相关市场，明确客户所需或期望的产品与服务；开展定量与定性分析，全面捕捉并深入探究产品与服务；运用创意方法深化客户理解，并据此设计适配方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.2" ;
    skos:prefLabel "Survey market and determine customer needs and wants"@en,
        "调研市场并确定客户需求与期望"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "Establishing the organization's long-term vision as a strategic positioning and engagement of stakeholders. Institute the vision by creating strategic orientations of all stakeholders. Understand the strategy development frameworks in this context."@en,
        "确立组织长期愿景，作为战略定位与利益相关方协同的基础。通过构建各利益相关方的战略导向机制来落实愿景；理解本语境下的战略制定框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.4" ;
    skos:prefLabel "Establish strategic vision"@en,
        "确立战略愿景"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "Examining the scope and contingencies for restructuring based on market situation and internal realities. Map the market forces over which any and all probabilities can be probed for utility and viability. Once the restructuring options have been analyzed and the due-diligence performed, execute the deal. Consider seeking professional services for assistance in formalizing these opportunities."@en,
        "基于市场态势与组织内部现实，研判组织重构的范围与潜在约束条件。系统梳理可被验证可行性与实用性的各类市场力量；在完成重构方案分析与尽职调查后，推进交易落地；必要时可引入专业服务机构协助正式化相关机会。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5" ;
    skos:prefLabel "Conduct organization restructuring opportunities"@en,
        "开展组织重构机会评估"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Establishing an overarching, compact statement that concisely underscores the mission of the organization. Define and communicate a clear and succinct mission statement, which encapsulates how the organization aims to proceed in order to Establish a strategic vision [10020]. Solicit critical inputs from senior management and strategy executives, and collaborate with marketing or personnel from allied functions."@en,
        "确立高度凝练、统摄全局的组织使命陈述。定义并传达清晰简明的使命陈述，精准概括组织为实现‘确立战略愿景’[10020]所采取的根本路径；广泛征询高管层与战略负责人意见，并协同营销或相关职能人员共同完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.1" ;
    skos:prefLabel "Develop overall mission statement"@en,
        "制定总体使命声明"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.6" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Developing overall goals for the organization that help in accomplishing its mission. Formulate organization-wide targets in the near to middle term, which will accumulate and propel the organization to realize its long-term objectives, as outlined in Develop an overall mission statement [10037]. Enlist business unit heads or equivalent personnel, in close collaboration with senior management executives."@en,
        "制定支撑组织使命达成的总体目标；设定中短期组织级目标，层层累积、持续推进，最终实现长期战略目标（参见“制定总体使命声明［10037］”）；联合业务单元负责人等关键人员，在高层管理者密切协同下完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.6" ;
    skos:prefLabel "Develop and set organizational objectives"@en,
        "制定并设定组织目标"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.7" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Charting a strategic course for business units in order to leverage opportunities, sidestep hurdles, and create synergies among each other. Create strategic road maps for the organization's units--in light of their individual resources and requirements, as well as their relationships with other business units--to achieve organizational goals."@en,
        "为各业务单元制定战略路径，以把握机遇、规避障碍、强化彼此协同；结合各单元资源禀赋、实际需求及其与其他业务单元的关联，制定单元级战略路线图，支撑组织整体目标实现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.7" ;
    skos:prefLabel "Formulate business unit strategies"@en,
        "制定业务单元战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.8.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8> ;
    skos:definition "Measuring customer feedback in regard to product and services effectiveness based on overall satisfaction. The data to be analyzed is collected through surveys, customer responses, and feedbacks based on the delivered products/services."@en,
        "基于整体满意度，衡量客户对产品与服务有效性的反馈；数据来源于客户调查、响应记录及产品/服务交付后的反馈。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.1" ;
    skos:prefLabel "Assess customer experience"@en,
        "评估客户体验"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Developing strategic projects that help fulfill long-term goals. Develop time-bound projects that are discretionary in nature and lie beyond the scope of the organization's routine operations."@en,
        "策划有助于实现长期目标的战略项目；开发有时限性、非例行性的战略性项目，超出组织日常运营范畴。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.1" ;
    skos:prefLabel "Develop strategic initiatives"@en,
        "制定战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Devising measures to examine strategic projects. Formulate evaluation criteria to assess the strategic initiatives for the level of impact."@en,
        "设计战略项目评估机制；制定评价准则，衡量战略举措的实际影响程度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.4" ;
    skos:prefLabel "Establish high-level measures"@en,
        "建立高层级衡量指标"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4" ;
    skos:broader <https://oprocess.net/opf/node/1.0> ;
    skos:definition "Establishing how an organization creates, delivers and captures value or makes profit. Identify the products or services that a business will sell, its target market, anticipated expenses, and other core aspects of its modus operandi. Revise the plan as required to reflect changing circumstances."@en,
        "明确组织如何创造、交付与获取价值（即盈利模式），包括界定拟销售的产品或服务、目标市场、预期成本及其他核心运营要素；并依实际情况动态修订该模式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4" ;
    skos:prefLabel "Develop and maintain business models"@en,
        "开发与维护业务模型"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Strategy Management" ;
    skos:broader <https://oprocess.net/opf/node/1.0> ;
    skos:definition "ITIL V5 practice: Strategy Management. Mapped to Develop Vision and Strategy."@en,
        "ITIL V5实践：战略管理（Strategy Management），映射至“愿景与战略制定”。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.5" ;
    skos:prefLabel "Strategy Management"@en,
        "战略管理"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/10.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.1" ;
    skos:broader <https://oprocess.net/opf/node/10.1> ;
    skos:definition "Strategizing a long-term vision for managing properties. Prepare strategies and a long-term vision for managing purchased/retained properties."@en,
        "制定设施长期管理战略与愿景；编制针对已购或持有物业的管理策略及长期发展规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.1" ;
    skos:prefLabel "Develop property strategy and long term vision"@en,
        "制定不动产战略及长期愿景"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.4" ;
    skos:broader <https://oprocess.net/opf/node/10.1> ;
    skos:definition "Managing all operational activities of the facility. Manage how each function/business unit works. Support the manufacturing facility to attain organizational goals."@en,
        "统筹管理设施全部运营活动。协调各职能/业务单元运作方式，支撑制造设施达成组织目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.4" ;
    skos:prefLabel "Manage facilities operations"@en,
        "管理设施运营"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.1" ;
    skos:broader <https://oprocess.net/opf/node/10.2> ;
    skos:definition "Producing and maintaining a planning schedule and a financial plan to purchase or manufacture assets. Determine the investment plan, monitor capital, and secure the necessary financing in order to realize completion of the program."@en,
        "编制资产购置或自建的进度计划与财务计划。确定投资方案，监控资本使用，落实必要融资，保障项目按期完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.1" ;
    skos:prefLabel "Manage capital program for assets"@en,
        "管理资产资本项目"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3" ;
    skos:broader <https://oprocess.net/opf/node/10.0> ;
    skos:definition "Preserving assets through the planning, managing, and performance of preventative, routine, and critical maintenance work."@en,
        "通过规划、统筹与执行预防性、例行性及关键性维护工作，实现资产全生命周期保值与效能延续。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3" ;
    skos:prefLabel "Maintain assets"@en,
        "资产维护"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/11.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Risk Management" ;
    skos:broader <https://oprocess.net/opf/node/11.1> ;
    skos:definition "ITIL V5 practice: Risk Management. Mapped to Manage enterprise risk."@en,
        "ITIL V5 实践：风险管理。映射至企业风险管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.4" ;
    skos:prefLabel "Risk Management"@en,
        "IT 风险管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2" ;
    skos:broader <https://oprocess.net/opf/node/11.0> ;
    skos:definition "Managing steps to confirm enduring compliance to industry regulations and government legislation."@en,
        "管理各项举措，确保持续符合行业监管要求与政府法律法规。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2" ;
    skos:prefLabel "Manage compliance"@en,
        "管理合规"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/12.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.3" ;
    skos:broader <https://oprocess.net/opf/node/12.2> ;
    skos:definition "Managing relations with organizations established and financed by businesses that operate in a specific industry. Participate in public relations actions such as lobbying and publishing, advertising, education, and political donations."@en,
        "管理与由企业设立并资助、专注于特定行业的组织的关系；参与游说、出版、广告、教育及政治捐赠等公共关系活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.3" ;
    skos:prefLabel "Manage relations with trade or industry groups"@en,
        "管理与行业协会或产业团体的关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Supplier Management" ;
    skos:broader <https://oprocess.net/opf/node/12.0> ;
    skos:definition "ITIL V5 practice: Supplier Management. Mapped to Manage External Relationships."@en,
        "ITIL V5 实践：供应商管理。对应‘管理外部关系’能力域。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.6" ;
    skos:prefLabel "Supplier Management"@en,
        "供应商管理"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.1> ;
    skos:definition "Evaluating and handling the performance of business processes. Provide training to process owners. Support the execution of business processes. Measure and report the performance of the business processes."@en,
        "评估与管控业务流程绩效：为流程负责人提供培训；支持业务流程执行；测量并报告业务流程绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.4" ;
    skos:prefLabel "Manage process performance"@en,
        "管理流程绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.10.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1> ;
    skos:definition "Identifying, documenting, and communicating sustainability requirements. Closely examine all standards and matters of compliance relating to ESG. Determine protocols or standards to comply with, set by regulatory agencies or the organizations stakeholders."@en,
        "识别、记录并传达可持续发展要求；全面审查与ESG相关的所有标准与合规事项；明确监管机构或组织利益相关方设定的合规协议或标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.1" ;
    skos:prefLabel "Identify sustainability requirements"@en,
        "识别可持续发展要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2" ;
    skos:broader <https://oprocess.net/opf/node/13.10> ;
    skos:definition "Managing sustainability across the organization. Provide training, support, reporting, and oversight to the distributed sustainability efforts across functional units and support services."@en,
        "统筹管理全组织可持续发展工作；为各职能单元及支持服务的分布式可持续发展实践提供培训、支持、报告与监督。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2" ;
    skos:prefLabel "Manage sustainability capability"@en,
        "管理可持续发展能力"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.2> ;
    skos:definition "Managing the business portfolio of the organization, including investments, holdings, products, businesses, and brands. Establish a portfolio strategy. Define portfolio governance. Monitor and control the portfolio."@en,
        "管理组织业务组合：涵盖投资、持股、产品、业务单元及品牌；制定组合战略；明确组合治理机制；监控与管控组合整体运行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.1" ;
    skos:prefLabel "Manage portfolio"@en,
        "管理项目组合"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Project Management" ;
    skos:broader <https://oprocess.net/opf/node/13.2> ;
    skos:definition "ITIL V5 practice: Project Management. Mapped to Manage portfolio, program, and project."@en,
        "ITIL V5 实践：项目管理。映射至‘管理投资组合、项目集与项目’。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.4" ;
    skos:prefLabel "Project Management"@en,
        "项目管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2> ;
    skos:definition "Examining the quality of organizational processes. Conduct tests. Collect information and data. Record the results of these tests. Determine the dispositions of the test results."@en,
        "检验组织流程质量：开展测试；采集信息与数据；记录测试结果；判定测试结果处置方式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.1" ;
    skos:prefLabel "Test against quality plan"@en,
        "依据质量计划开展测试"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.4.4" ;
    skos:broader <https://oprocess.net/opf/node/13.4> ;
    skos:definition "Sustaining the impact of the change process in order to enact continual process improvement. Monitor the performance of re-engineered business processes. Identify best practices and potential issues. Effectuate remedial steps."@en,
        "持续巩固变革成效，推动流程持续优化；监测再造后业务流程的运行绩效；识别最佳实践与潜在问题；落实整改措施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.4" ;
    skos:prefLabel "Sustain improvement"@en,
        "持续改进成效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Organizational Change Management" ;
    skos:broader <https://oprocess.net/opf/node/13.4> ;
    skos:definition "ITIL V5 practice: Organizational Change Management. Mapped to Manage change."@en,
        "ITIL V5 实践：组织变革管理（Organizational Change Management），对应「管理变更」能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.4.5" ;
    skos:prefLabel "Organizational Change Management"@en,
        "组织变革管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.2" ;
    skos:broader <https://oprocess.net/opf/node/13.5> ;
    skos:definition "Assessing the maturity of the existing initiatives in knowledge management, and evaluating existing KM approaches. Identify the gaps and needs in order to enhance the existing KM approaches. Develop and implement new KM approaches."@en,
        "评估现有知识管理举措的成熟度，诊断现行知识管理方法的适用性；识别能力缺口与改进需求；开发并推行新型知识管理方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.2" ;
    skos:prefLabel "Assess KM capabilities"@en,
        "评估知识管理能力"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.5.4" ;
    skos:broader <https://oprocess.net/opf/node/13.5> ;
    skos:definition "Developing resources for improved knowledge management and knowledge engineering."@en,
        "建设强化知识管理与知识工程能力所需的资源体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.4" ;
    skos:prefLabel "Evolve and sustain KM capabilities"@en,
        "演进并持续维护知识管理能力"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Knowledge Management" ;
    skos:broader <https://oprocess.net/opf/node/13.5> ;
    skos:definition "ITIL V5 practice: Knowledge Management. Mapped to Develop and manage enterprise-wide knowledge management (KM) capability."@en,
        "ITIL V5 实践：知识管理（Knowledge Management），对应「构建并管理企业级知识管理（KM）能力」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.5.5" ;
    skos:prefLabel "Knowledge Management"@en,
        "知识管理"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.2" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Developing and managing taxonomies, ontologies, and related semantic structures to classify, enrich, and relate enterprise content and knowledge assets, supporting consistent interpretation, discoverability, reuse, and advanced capabilities such as automated classification and semantic processing."@en,
        "开发与管理分类体系、本体及关联语义结构，对企业内容与知识资产进行分类、增强与关联，支撑统一解读、可发现性、复用性，以及自动分类、语义处理等高级能力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.2" ;
    skos:prefLabel "Develop and manage taxonomies"@en,
        "构建与管理分类体系（Taxonomies）"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.6" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Delivering approved content to intended audiences through appropriate channels, repositories, or platforms in accordance with defined standards and controls."@en,
        "依据既定标准与管控要求，通过合适渠道、知识库或平台向目标受众交付已批准内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.6" ;
    skos:prefLabel "Deliver approved content"@en,
        "发布已审批内容"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.6.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.6.7" ;
    skos:broader <https://oprocess.net/opf/node/13.6> ;
    skos:definition "Controlling the use, evaluation, retention, and disposition of delivered content to ensure continued relevance, compliance, and value over time. Includes monitoring content quality and semantic coherence."@en,
        "管控已交付内容的使用、评估、留存与处置，确保其长期相关性、合规性与价值；包括监测内容质量与语义连贯性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.6.7" ;
    skos:prefLabel "Control delivered content"@en,
        "管控已发布内容"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Measurement and Reporting" ;
    skos:broader <https://oprocess.net/opf/node/13.7> ;
    skos:definition "ITIL V5 practice: Measurement and Reporting. Mapped to Measure and benchmark."@en,
        "ITIL V5 实践：度量与报告（Measurement and Reporting），映射至「度量与基准比对」。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7.4" ;
    skos:prefLabel "Measurement and Reporting"@en,
        "度量与报告"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Determining the impacts of environmental health and safety. Create and implement the EHS program. Train and educate employees of the EHS function. Oversee and manage the EHS program."@en,
        "评估环境、健康与安全（EHS）影响；制定并实施EHS管理体系；开展员工EHS职能培训与宣贯；统筹监督与管理EHS体系运行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9" ;
    skos:prefLabel "Manage Environmental Health and Safety (EHS)"@en,
        "管理环境、健康与安全（EHS）"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/2.1.3> ;
    skos:definition "Aligning regulatory activities related to managing industry requirements. Train employees on regulatory requirements. Records for the appropriate regulatory agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization. The submission lifecycle - i.e. creation, review, and approval of the submission and its components must be managed in a collaborative fashion."@en,
        "统筹行业监管要求相关的合规活动；开展员工监管要求培训；向对应监管机构留存合规记录；新产品流程须获监管机构审批后方可正式发布；提交材料的全生命周期（含创建、评审与批准）须以协同方式统一管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.1.3.5" ;
    skos:prefLabel "Manage regulatory requirements"@en,
        "管理监管合规要求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/2.2> ;
    skos:definition "Coordinating R&D activity to identify new technologies to integrate into the revamped portfolio of products/services. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct early-stage R&D activity to close gaps between existing solution offerings and changing market expectations. Triangulate appropriate technologies that can support the development of a revised product/service portfolio."@en,
        "统筹研发活动，识别可融入重构后产品和服务组合的新技术（包括人工智能等新兴及演进中的技术）；开展早期研发工作，弥合现有解决方案与市场预期变化之间的差距；通过多源验证，遴选适配技术以支撑修订后产品和服务组合的开发。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.1" ;
    skos:prefLabel "Perform discovery research"@en,
        "开展探索性研究"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/2.2> ;
    skos:definition "Encompassing the identification and capture of new product/service requirements or potential improvements to current products/services. Collaborating with members of the supply chain to ensure the feasibility of what is being defined in the requirements. For example, a product with manufacturing requirements that supply chain cannot currently fulfill requires a corporate decision to either upgrade manufacturing capabilities or abandon the new product. Enterprise-level effects and needs must be considered. Depending on the nature of the final product or service, these requirements are often defined as a set of abilities, such as availability or reliability, that influence product development decisions."@en,
        "识别并捕获新产品/服务需求，或现有产品/服务的潜在改进点；协同供应链成员，确保所定义需求具备可行性（例如：若某产品制造需求超出当前供应链能力，则需企业决策升级制造能力或终止该新品）；统筹考量企业级影响与需求；最终需求常体现为一组影响产品开发决策的能力属性（如可用性、可靠性等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2.3" ;
    skos:prefLabel "Define product/service development requirements"@en,
        "定义产品和服务开发需求"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Business Analysis" ;
    skos:broader <https://oprocess.net/opf/node/2.0> ;
    skos:definition "ITIL V5 practice: Business Analysis. Mapped to Develop and Manage Products and Services."@en,
        "ITIL V5 实践：业务分析（Business Analysis），映射至‘产品与服务开发及管理’领域。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.4" ;
    skos:prefLabel "Business Analysis"@en,
        "业务分析"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1" ;
    skos:broader <https://oprocess.net/opf/node/3.0> ;
    skos:definition "Making sense of the market and customers to identify the right opportunities to be capitalized, given the organization's competencies. Discern trends and shift in the market and customers. Identify the right market opportunities that fit closely with the organization's capabilities and strategy by gathering intelligence on various attributes of different market/customer segments."@en,
        "深入理解市场与客户，结合组织能力识别高价值机会。洞察市场与客户发展趋势与变化；通过采集多维度市场/客户细分情报，精准识别与组织能力及战略高度契合的市场机会。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1" ;
    skos:prefLabel "Understand markets, customers, and capabilities"@en,
        "理解市场、客户与业务能力"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Refining the attributes of organizational offerings to define their value proposition for the customer. Clearly define the suite of offerings in terms of the value delivered, from the perspective of what the customer desires. Validate the benefits delivered to the customers against target market segments, using techniques such as minimum viable product. Position brands for the respective products/services, in line with their unique value proposition and aligned with customers needs."@en,
        "优化组织产品/服务属性以明确定义客户价值主张；从客户需求视角清晰界定产品/服务组合所交付的价值；借助最小可行产品（MVP）等方法，针对目标市场细分验证客户获益；围绕独特价值主张与客户需求，开展分产品/服务的品牌定位。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.1" ;
    skos:prefLabel "Define offering and customer value proposition"@en,
        "定义产品/服务及客户价值主张"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.4.7" ;
    skos:broader <https://oprocess.net/opf/node/3.2.4> ;
    skos:definition "Coordinating marketing and distribution efforts across different channels that integrate well with each other, are in conformance with company values, visual identity and branding, and offer uniform customer service experience that drives customer loyalty and repeat business."@en,
        "统筹跨渠道的营销与分销协同，确保渠道间高效整合、符合企业价值观与视觉识别体系、提供一致的客户服务体验，从而提升客户忠诚度与复购率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.4.7" ;
    skos:prefLabel "Orchestrate seamless customer experience across supported channels"@en,
        "统筹支持渠道间的无缝客户体验"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/3.5.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5.1" ;
    skos:broader <https://oprocess.net/opf/node/3.5.5> ;
    skos:definition "Imparting guidance and instruction to sales partners/alliances concerning products/services. Distribute literature about the organization's products/services. Conduct workshops. Disseminate useful media content to engage and enlighten partners. Create communities through group engagements."@en,
        "向销售合作伙伴/联盟提供产品/服务指导与培训；分发组织产品/服务宣传资料；举办专题研讨会；发布优质媒体内容以增强合作伙伴参与度与认知度；通过社群共建促进协同"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5.1" ;
    skos:prefLabel "Provide sales and product/service training to sales partners/alliances"@en,
