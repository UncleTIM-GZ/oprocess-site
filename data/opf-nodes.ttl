    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.2.5" ;
    skos:prefLabel "Define service delivery process"@en,
        "定义 service delivery process"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

