        "AI活动：开展AI影响评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.1.3" ;
    skos:prefLabel "Conduct AI impact assessments"@en,
        "开展人工智能影响评估"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

