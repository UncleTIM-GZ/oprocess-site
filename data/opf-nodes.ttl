    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.5> ;
    skos:definition "AI activity: Provide stakeholder AI literacy."@en,
        "AI活动：提升利益相关方的人工智能素养。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.5.3" ;
    skos:prefLabel "Provide stakeholder AI literacy"@en,
        "提升利益相关方的人工智能素养"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.5.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.5> ;
    skos:definition "AI activity: Publish AI transparency reports."@en,
        "AI活动：发布人工智能透明度报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.5.4" ;
    skos:prefLabel "Publish AI transparency reports"@en,
        "发布人工智能透明度报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.1.1" ;
    skos:broader <https://oprocess.net/opf/node/12.1> ;
    skos:definition "Building and managing relations with bankers or lenders through strong products/services strategies that bankers would want to invest in. Foster a receptive environment for low rates of interest, easy access to loans, etc."@en,
        "通过具有吸引力的产品和服务策略，建立并维护与银行或贷款机构的关系，营造有利于获取低利率、便捷融资等条件的友好环境。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.1.1" ;
    skos:prefLabel "Plan, build, and manage lender relations"@en,
        "规划、建立并管理贷款机构关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.1.2" ;
    skos:broader <https://oprocess.net/opf/node/12.1> ;
    skos:definition "Creating and maintaining long-term relations with analysts. Involve analysts in strategy and product decisions in order to elicit valuable information."@en,
        "建立并维系与分析师的长期关系；邀请分析师参与战略与产品决策，以获取有价值的信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.1.2" ;
    skos:prefLabel "Plan, build, and manage analyst relations"@en,
        "规划、建立并管理分析师关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.1.3" ;
    skos:broader <https://oprocess.net/opf/node/12.1> ;
    skos:definition "Practicing regular, transparent communication with shareholders through annual shareholders' meetings, quarterly earnings calls, shareholders letters, one-on-one emails or calls, etc."@en,
        "通过年度股东大会、季度财报电话会、致股东信、一对一邮件或电话等方式，开展定期、透明的股东沟通。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.1.3" ;
    skos:prefLabel "Communicate with shareholders"@en,
        "与股东沟通"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/12.1> ;
    skos:definition "AI-era activity: AI-Powered Partner Assessment."@en,
        "AI时代活动：AI赋能的合作伙伴评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.1.4" ;
    skos:prefLabel "AI-Powered Partner Assessment"@en,
        "人工智能驱动的合作伙伴评估"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Ascertaining how the business entity relates to all levels of government. Identify areas that needs further growth and resources to foster those relationships."@en,
        "厘清企业与各级政府的关联关系；识别需进一步投入资源以加强关系的领域。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.1" ;
    skos:prefLabel "Assess relationships"@en,
        "评估政企关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Assigning executive level resources to manage, grow, and drive relationships with government bodies."@en,
        "指派高管级资源负责政府关系的管理、拓展与推动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.2" ;
    skos:prefLabel "Appoint responsible executives"@en,
        "任命责任高管"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Analyzing current relationships with government bodies and entities."@en,
        "分析当前与政府机构及实体的关系现状。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.3" ;
    skos:prefLabel "Monitor relationships"@en,
        "监测政企关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Garnering internal advice from an informal group in order to successfully maintain and advance relationships."@en,
        "组建非正式内部顾问小组，为持续维护和推进政府关系提供支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.4" ;
    skos:prefLabel "Receive input from internal advisors"@en,
        "听取内部顾问意见"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.5" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Garnering third party advice from an informal group in order to successfully maintain and advance relationships."@en,
        "引入第三方非正式顾问小组，为持续维护和推进政府关系提供支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.5" ;
    skos:prefLabel "Receive input from external advisors"@en,
        "听取外部顾问意见"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.1.6" ;
    skos:broader <https://oprocess.net/opf/node/12.2.1> ;
    skos:definition "Meeting with government heads and representatives."@en,
        "与政府首脑及代表开展会晤。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.1.6" ;
    skos:prefLabel "Liaise with authorities"@en,
        "对接监管机构"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/12.2.2> ;
    skos:definition "Engaging government, regulatory, or industry agencies to establish relationships. Analyze steps and requirements necessary for inclusion, if needed."@en,
        "主动对接政府、监管或行业机构以建立合作关系；如需加入，应分析必要步骤与准入要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.2.1" ;
    skos:prefLabel "Establish relationships with agencies"@en,
        "与相关机构建立联系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/12.2.2> ;
    skos:definition "Cooperating with auditors regarding potential or ongoing inquiries."@en,
        "就潜在或正在进行的调查事项，配合审计机构开展工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.2.2" ;
    skos:prefLabel "Respond to audit inquiries"@en,
        "回应审计质询"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/12.2.2> ;
    skos:definition "Keeping a repository of documents that contain information about the network of partners, prospects and customers. Keep records up-to-date with routine reviews and modify as needed."@en,
        "建立并维护包含合作伙伴、潜在客户及客户网络信息的文档库；通过定期审查及时更新记录，并按需调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.2.3" ;
    skos:prefLabel "Maintain documentation of contacts"@en,
        "维护联络记录文档"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/12.2.2> ;
    skos:definition "Ensuring regular interaction between business entity and quasi-government bodies in order to maintain established relationships. Collect and record meeting data for further analysis and use."@en,
        "确保企业与准政府机构保持常态化互动以维系既有关系；系统收集并记录会议数据，用于后续分析与应用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.2.4" ;
    skos:prefLabel "Plan and manage meetings"@en,
        "规划并组织会议"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/12.2.3> ;
    skos:definition "Determining the requirements to enter in to an agreement with trade or industry agencies. Discover what activities or processes can be conducted to provide the best mutual outcome."@en,
        "明确与行业协会或行业机构达成合作所需条件；探索可实现互利共赢的具体活动或流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.3.1" ;
    skos:prefLabel "Evaluate the requirements for strategic relationships"@en,
        "评估战略性合作关系的需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/12.2.3> ;
    skos:definition "Analyzing current relationships with trade and industry groups. Ensure that the partnership in successful and make modifications where needed."@en,
        "评估当前与行业协会及行业团体的关系；确保合作成效，并在必要时进行优化调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.3.2" ;
    skos:prefLabel "Monitor the success of the partnerships"@en,
        "监测合作成效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/12.2.3> ;
    skos:definition "Providing additional information or inclusion for third party trade or industry entities; or changing existing parameters to modify the current relationship. Communicate and execute changes."@en,
        "向第三方行业协会或行业实体提供补充信息或扩大参与范围；或调整现有合作参数以优化关系；同步完成沟通与执行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.3.3" ;
    skos:prefLabel "Extend or change the relationships"@en,
        "拓展或调整合作关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.2.4" ;
    skos:broader <https://oprocess.net/opf/node/12.2> ;
    skos:definition "Managing lobbying activities to affect government policies."@en,
        "开展游说活动以影响政府政策制定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.2.4" ;
    skos:prefLabel "Manage lobby activities"@en,
        "管理游说活动"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.3.1" ;
    skos:broader <https://oprocess.net/opf/node/12.3> ;
    skos:definition "Reporting financial results to management, and releasing results to the public. Report financial statements, including the income statement, balance sheet, and statement of cash flows."@en,
        "向管理层报告财务结果，并对外发布；披露财务报表，包括利润表、资产负债表及现金流量表。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.3.1" ;
    skos:prefLabel "Report financial results"@en,
        "汇报财务成果"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.3.2" ;
    skos:broader <https://oprocess.net/opf/node/12.3> ;
    skos:definition "Reporting audit findings to management. Practice an internal audit with criteria for confirming a problem, a description of the situation, and the root cause of the problem. Make recommendations that resolve the issue."@en,
        "向管理层报告审计发现；开展内部审计，明确问题确认标准、情况描述及根本原因；提出切实可行的整改建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.3.2" ;
    skos:prefLabel "Report audit findings"@en,
        "汇报审计发现"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.1" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Creating a code of ethics that communicate the organization's philosophy to employees, vendors, customers, clients, and the public."@en,
        "制定行为准则，向员工、供应商、客户、服务对象及公众传达组织的价值观与伦理立场。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.1" ;
    skos:prefLabel "Create ethics policies"@en,
        "制定伦理政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.2" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Administering the system of rules, practices, and processes through which a company is directed and controlled. Balance stakeholder interests including shareholders, management, customers, suppliers, financiers, government, and the community. Outline a strategy for achieving organizational goals, from action plans and internal controls to performance measurement and corporate disclosure."@en,
        "实施公司治理机制，即指导与管控企业的规则体系、实践方式及运行流程；平衡股东、管理层、客户、供应商、融资方、政府及社区等多方利益；制定实现组织目标的战略路径，涵盖行动计划、内部控制、绩效评估及信息披露。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.2" ;
    skos:prefLabel "Manage corporate governance policies"@en,
        "管理公司治理政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.3" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Creating and applying programs and activities. Encourage the adherence preventive laws, such as environmental law, sex discrimination, computer law, estate planning, corporate compliance, business planning, and property transactions."@en,
        "设计并推行各类项目与活动，推动预防性法律法规的贯彻执行，包括环境保护法、反性别歧视法、计算机法、遗产规划、企业合规、商业规划及不动产交易等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.3" ;
    skos:prefLabel "Develop and perform preventive law programs"@en,
        "开发并实施预防性法律项目"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.4.1" ;
    skos:broader <https://oprocess.net/opf/node/12.4.4> ;
    skos:definition "Employing an internal system or process to identify and reduce the risk of breaching the Competition and Consumer Act 2010. Remedy any breach. Create a culture of compliance. Design compliance programs."@en,
        "运用内部机制或流程识别并降低违反《2010年竞争与消费者法》的风险；对违规行为及时整改；培育合规文化；设计合规专项计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.4.1" ;
    skos:prefLabel "Plan and initiate compliance program"@en,
        "规划并启动合规计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.4.2" ;
    skos:broader <https://oprocess.net/opf/node/12.4.4> ;
    skos:definition "Implementing the established compliance program in order to meet the government laws and regulations. Create a compliance team that scrutinizes the rules set out by government bodies such as the Securities and Exchange Commission."@en,
        "落实既定合规计划以满足政府法律法规要求；组建合规团队，严格审查美国证券交易委员会（SEC）等政府机构发布的监管规则。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.4.2" ;
    skos:prefLabel "Execute compliance program"@en,
        "执行合规计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.1" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Examining the problems and deciding the action requirements for engaging outside counsel. This process element calls upon the organization to internally analyze the issues for which assistance from external counsel is needed. Additionally, the organization needs to break-down the issue, identifying the tasks and exercises where outside counsel can help."@en,
        "评估问题并确定聘请外部法律顾问的行动需求。该流程要求组织内部分析需借助外部法律顾问协助解决的问题，并对问题进行拆解，明确可由外部法律顾问支持的具体任务与工作内容。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.1" ;
    skos:prefLabel "Assess problem and determine work requirements"@en,
        "评估问题并确定工作需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.2" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Recruiting the assistance of outside counsel for any legal and/or ethical concerns. Engage and/or retain any external counsel sought from subject matter experts and professionals."@en,
        "就法律和/或伦理相关事项引入外部法律顾问。遴选并聘用来自特定领域专家及专业人士的外部法律顾问。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.2" ;
    skos:prefLabel "Engage/Retain outside counsel if necessary"@en,
        "必要时聘请/留用外部法律顾问"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.3" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Making a financial plan. This strategy sets out, using figures, an organization's expected future results. Enlist the finance function to support work generated by other business functions in order to build and secure their support for the budget."@en,
        "制定财务计划。该策略以量化方式呈现组织预期的未来成果；协调财务职能，为其他业务职能产生的工作提供支持，以构建并巩固其对预算编制的支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.3" ;
    skos:prefLabel "Receive strategy/budget"@en,
        "接收策略与预算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.4" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Receiving deliverables from outside counsel, and monitoring the efforts committed by them. Track the progress of, collect, and validate the required work product from the subject matter experts and professionals engaged as external counsel. Verify the amount of effort dedicated by these counsels to the issue at hand, in order to confirm their fees."@en,
        "接收外部法律顾问交付成果，并监控其投入的工作量。跟踪所聘领域专家与专业人士的工作进展，收集并验证其交付的工作成果；核实其针对当前事项实际投入的工作量，以确认服务费用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.4" ;
    skos:prefLabel "Receive work product and manage/monitor case and work performed"@en,
        "接收工作成果，并管理/监控案件进展与工作执行情况"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.5" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Making payments to legal advisers for their services. Payments include addressing issues or suits by customers, suppliers, competitors, bankers, government agencies, etc."@en,
        "向法律顾问支付服务费用。费用涵盖处理客户、供应商、竞争对手、银行、政府机构等提出的争议或诉讼事项。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.5" ;
    skos:prefLabel "Process payment for legal services"@en,
        "处理法律服务付款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.5.6" ;
    skos:broader <https://oprocess.net/opf/node/12.4.5> ;
    skos:definition "Keeping track of the legal activities and performance of the organization."@en,
        "跟踪组织的法律活动及其合规绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.5.6" ;
    skos:prefLabel "Track legal activity/performance"@en,
        "跟踪法律活动与绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.6.1" ;
    skos:broader <https://oprocess.net/opf/node/12.4.6> ;
    skos:definition "Managing the patents and copyrights already held or sought by the organization. Administer and oversee applying for, securing, and maintaining intellectual property rights in the form of patents and copyrights. Submit applications for such rights. Handle associated legal issues. Draft and communicate proper attributions. Collect royalties. Monitor any misuse of the intellectual property rights."@en,
        "管理组织已持有或正在申请的专利与版权。统筹开展专利权与著作权的申请、确权及维护工作；提交相关权利申请；处理关联法律事务；拟定并传达规范署名要求；收取特许权使用费；监测知识产权被滥用的情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.6.1" ;
    skos:prefLabel "Manage copyrights, patents, and trademarks"@en,
        "管理著作权、专利与商标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.6.2" ;
    skos:broader <https://oprocess.net/opf/node/12.4.6> ;
    skos:definition "Managing the upkeep of intellectual property rights by creating and managing a framework of rules, policies, procedures, and restrictions. Outline a clear policy for any possible scenario of their use by any external agent."@en,
        "通过构建并管理规则、政策、程序及限制性条款框架，保障知识产权持续有效。针对任何外部主体可能使用知识产权的情形，制定清晰明确的政策指引。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.6.2" ;
    skos:prefLabel "Maintain intellectual property rights and restrictions"@en,
        "维护知识产权权利及限制条款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.6.3" ;
    skos:broader <https://oprocess.net/opf/node/12.4.6> ;
    skos:definition "Administering and overseeing the terms and policies associated with licensing the organization's intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization."@en,
        "统筹管理组织知识产权许可相关的条款与政策。制定并管理向外部主体授予许可的政策与条件；明确界定组织所持专利或版权许可授权的治理框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.6.3" ;
    skos:prefLabel "Administer licensing terms"@en,
        "管理许可条款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.6.4" ;
    skos:broader <https://oprocess.net/opf/node/12.4.6> ;
    skos:definition "Managing options regarding licensing agreements. Follow favorable terms and conditions."@en,
        "管理许可协议相关选项，确保遵循有利的条款与条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.6.4" ;
    skos:prefLabel "Administer options"@en,
        "管理期权事项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/12.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.7" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Resolving disputes or civil lawsuits internally or externally."@en,
        "在组织内部或外部解决争议或民事诉讼。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.7" ;
    skos:prefLabel "Resolve disputes and litigations"@en,
        "解决争议与诉讼"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.8" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Providing legal advice concerning the substance or procedure of a law in relation to a particular situation."@en,
        "就特定情形，就法律的实体内容或程序规则提供法律意见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.8" ;
    skos:prefLabel "Provide legal advice/counseling"@en,
        "提供法律咨询与建议"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.4.9" ;
    skos:broader <https://oprocess.net/opf/node/12.4> ;
    skos:definition "Negotiating terms to reach a final draft of a contract that is acceptable to all parties."@en,
        "协商合同条款，形成各方均可接受的最终合同草案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.4.9" ;
    skos:prefLabel "Negotiate and document agreements/contracts"@en,
        "谈判并签署协议/合同"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5.1" ;
    skos:broader <https://oprocess.net/opf/node/12.5> ;
    skos:definition "Developing and administering community relations. Establish business connections with the people constituting the environment the organization operates in and draws resources from in order to foster mutual understanding, trust, and support. Create programs that promote the organization's image in a positive and community-oriented way."@en,
        "开展并管理社区关系。与组织运营及资源获取所依托的当地社群建立商业联系，增进相互理解、信任与支持；设计并实施有助于提升组织正面形象、体现社区导向的专项活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5.1" ;
    skos:prefLabel "Manage community relations"@en,
        "管理社区关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5.2" ;
    skos:broader <https://oprocess.net/opf/node/12.5> ;
    skos:definition "Developing and managing relations with media. Develop connections with journalists to solicit critical, third-party endorsements for a product, issue, service, or organization."@en,
        "开展并管理媒体关系。与记者建立联系，争取第三方独立机构对产品、议题、服务或组织的关键性背书。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5.2" ;
    skos:prefLabel "Manage media relations"@en,
        "管理媒体关系"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5.3" ;
    skos:broader <https://oprocess.net/opf/node/12.5> ;
    skos:definition "Promoting political security and stability in the regions where the organization conducts business. Encourage political stability in the regions where the organization operates. Support civic programs, citizen engagement, connection platforms, etc."@en,
        "促进组织经营所在区域的政治安全与稳定。倡导所涉区域政治环境的稳定性；支持公民项目、公众参与机制、连接平台等建设。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5.3" ;
    skos:prefLabel "Promote political stability"@en,
        "促进政治稳定"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5.4" ;
    skos:broader <https://oprocess.net/opf/node/12.5> ;
    skos:definition "Developing press releases to communicate developments and generate interest in the organization."@en,
        "撰写新闻稿，用于传达组织重要进展并激发公众关注。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5.4" ;
    skos:prefLabel "Create press releases"@en,
        "撰写新闻稿"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:12.5.5" ;
    skos:broader <https://oprocess.net/opf/node/12.5> ;
    skos:definition "Issuing press releases to carefully selected media in distribution channels such as the web, newspapers, and social media."@en,
        "向经严格筛选的媒体（如网站、报纸、社交媒体等传播渠道）发布新闻稿。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.5.5" ;
    skos:prefLabel "Issue press releases"@en,
        "发布新闻稿"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Supplier Management" ;
    skos:broader <https://oprocess.net/opf/node/12.6> ;
    skos:definition "Activity within ITIL practice 'Supplier Management'."@en,
        "ITIL ‘供应商管理’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.6.1" ;
    skos:prefLabel "Evaluate and select suppliers"@en,
        "评估与遴选供应商"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Supplier Management" ;
    skos:broader <https://oprocess.net/opf/node/12.6> ;
    skos:definition "Activity within ITIL practice 'Supplier Management'."@en,
        "ITIL ‘供应商管理’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.6.2" ;
    skos:prefLabel "Manage supplier contracts"@en,
        "管理供应商合同"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/12.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Supplier Management" ;
    skos:broader <https://oprocess.net/opf/node/12.6> ;
    skos:definition "Activity within ITIL practice 'Supplier Management'."@en,
        "ITIL ‘供应商管理’实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "12.6.3" ;
    skos:prefLabel "Monitor supplier performance"@en,
        "监控供应商绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.1> ;
    skos:definition "Outlining and managing the methodology for administering business process management (BPM). Define the method for setting standards and priorities for BPM efforts. Identify BPM governance leaders. Define BPM project participants' roles."@en,
        "制定并管理业务流程管理（BPM）治理方法论。明确 BPM 标准设定与优先级排序方法；指定 BPM 治理负责人；界定 BPM 项目各参与方角色。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.1.1" ;
    skos:prefLabel "Define and manage governance approach"@en,
        "定义并管理治理方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1.1> ;
    skos:definition "Instituting, organizing, and maintaining the upkeep of the techniques used for business process management (BPM). Create and maintain templates of BPM tools that can be readily implemented, including process engine, business analytics, content management, and collaboration tools."@en,
        "建立、组织并持续维护业务流程管理（BPM）所用技术体系。创建并维护可快速部署的 BPM 工具模板，包括流程引擎、商业智能分析、内容管理及协同工具。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.1.2" ;
    skos:prefLabel "Establish and maintain process tools and templates"@en,
        "建立并维护流程工具与模板"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.1.1> ;
    skos:definition "Assigning resources (employees) ownership of tasks. These include the responsibility of identifying, analyzing, and improving business processes in order to meet the goals and objectives such as increasing profits and performance, reducing costs, and accelerating schedules."@en,
        "指派员工承担流程责任。职责包括识别、分析与优化业务流程，以实现提升利润与绩效、降低成本、加快交付周期等目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.1.3" ;
    skos:prefLabel "Assign and support process ownership"@en,
        "指定并支持流程负责人"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.1.1> ;
    skos:definition "Implementing and executing activities for governing business processes. Execute activities that encourage participation, accountability, transparency, responsiveness, equity and inclusiveness, etc. within the business processes."@en,
        "实施并执行业务流程治理活动。推动业务流程中各方的参与度、问责制、透明度、响应性、公平性与包容性等原则落地。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.1.4" ;
    skos:prefLabel "Perform process governance activities"@en,
        "开展流程治理活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.2> ;
    skos:definition "Defining and managing the framework that outlines the required business processes of the organization, key elements, and how they should interact. Institute strategy infrastructure and product, operations, and enterprise management."@en,
        "定义并管理组织所需业务流程框架，明确关键要素及其交互关系。构建战略基础设施，以及产品、运营与企业管理体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.2.1" ;
    skos:prefLabel "Establish and maintain process framework"@en,
        "建立并维护流程框架"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1.2> ;
    skos:definition "Recognizing the different functional areas working on the same project or goal."@en,
        "识别协同推进同一项目或目标的不同职能领域。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.2.2" ;
    skos:prefLabel "Identify cross-functional processes"@en,
        "识别跨职能流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Defining the extent and limits of business processes. Define the range and diversity of all the set of activities and tasks that, once completed, will accomplish an organizational goal."@en,
        "界定业务流程的范围与边界。明确为达成组织目标所需完成的一整套活动与任务的广度与多样性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.1" ;
    skos:prefLabel "Scope processes"@en,
        "界定流程范围"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3.2> ;
    skos:definition "Realizing those practices and procedures that are the most effective to the success of the business and making that information available."@en,
        "识别并推广对业务成功最有效的实践与规程，并确保相关信息可被广泛获取。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.2.1" ;
    skos:prefLabel "Identify published best practices"@en,
        "识别已发布的最佳实践"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Establishment of a \"checkpoint\" in a process that prevent the process from continuing unless all requirements are satisfied."@en,
        "在流程中设立“检查点”，确保未满足全部前提条件前流程不得继续推进。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.3" ;
    skos:prefLabel "Identify and denote process control points"@en,
        "识别并标注流程控制点"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. Identify processes, gather information gathering, interview participants, map processes, and perform analysis."@en,
        "明确业务实体的职责、责任人、执行标准及成效衡量方式。开展流程识别、信息采集、人员访谈、流程建模与分析等工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.4" ;
    skos:prefLabel "Model and document processes"@en,
        "建模并文档化流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/13.1.3> ;
    skos:definition "Disclosing the information available on business processes. Ensure the availability of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information."@en,
        "公开业务流程相关信息：确保流程团队成员、业务干系人及流程负责人均可获取业务流程相关的信息；借助业务流程管理（BPM）软件、业务流程图及文档等工具呈现所需信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.3.5" ;
    skos:prefLabel "Publish processes"@en,
        "发布流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.4> ;
    skos:definition "Providing training for the employees and process owners that administer the business processes. Design internal training programs or source third party agencies to provide the skills and training necessary."@en,
        "面向流程执行人员及流程负责人开展培训：设计内部培训课程，或委托第三方机构提供所需技能与培训。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.4.1" ;
    skos:prefLabel "Provide process training"@en,
        "提供流程培训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1.4> ;
    skos:definition "Assisting and executing the business processes. Use business process execution language (BEPL), which is a standard, executable language for specifying actions within the business processes with the use of web services."@en,
        "协助并执行业务流程：采用业务流程执行语言（BEPL）——一种基于Web服务的标准可执行语言，用于明确定义业务流程中的操作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.4.2" ;
    skos:prefLabel "Support process execution"@en,
        "支持流程执行"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.4.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.4.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.4.3> ;
    skos:definition "Determining the need for additional performance indicators that would be necessary to successfully achieve the business goal."@en,
        "识别实现业务目标所必需的补充性绩效指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.4.3.1" ;
    skos:prefLabel "Identify additional metrics as required"@en,
        "按需识别补充性指标"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.1.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.5.1" ;
    skos:broader <https://oprocess.net/opf/node/13.1.5> ;
    skos:definition "Helping a process owner to identify, analyze, and improve existing business processes within an organization to meet new goals and objectives."@en,
        "协助流程负责人识别、分析并改进组织现有业务流程，以达成新的目标与战略意图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.5.1" ;
    skos:prefLabel "Identify and select improvement opportunities"@en,
        "识别并遴选改进机会"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.5.2" ;
    skos:broader <https://oprocess.net/opf/node/13.1.5> ;
    skos:definition "Assessing and choosing methodologies to identify, analyze, and improve existing processes within an organization to meet new goals and objective. Assess the various methodologies available such as process mapping, statistical process control, and simulation. Choose the most appropriate and effective methodology."@en,
        "评估并遴选适用于识别、分析与改进组织现有流程的方法论：评估流程映射、统计过程控制、仿真建模等各类方法，择优选用最适配且高效的方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.5.2" ;
    skos:prefLabel "Select process improvement methodology"@en,
        "选择流程改进方法论"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.5.3" ;
    skos:broader <https://oprocess.net/opf/node/13.1.5> ;
    skos:definition "Developing and implementing a systematic approach to help the organization optimize its underlying processes in order to achieve more efficient results. Systematically gather information to clarify issues or problems. Intervene for improvements. Restructure training programs as appropriate to increase effectiveness."@en,
        "构建并实施系统化方法，助力组织优化底层业务流程以提升效能：系统收集信息厘清问题；主动介入推动改进；视需重构培训体系以增强实效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.5.3" ;
    skos:prefLabel "Manage improvement projects"@en,
        "管理改进项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.1.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.1.5.4" ;
    skos:broader <https://oprocess.net/opf/node/13.1.5> ;
    skos:definition "Persistently implementing activities for improving business processes."@en,
        "持续推进业务流程改进活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.1.5.4" ;
    skos:prefLabel "Perform continuous improvement activities"@en,
        "开展持续改进活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1.1> ;
    skos:definition "Defining and communicating sustainability disclosure requirements. Clarify and align disclosure requirements to other organizational reporting requirements and needs. Integrate preparation and reporting activities."@en,
        "界定并传达可持续发展信息披露要求；厘清并协同其他组织报告要求与业务需求；整合信息披露的准备与报告工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.1.1" ;
    skos:prefLabel "Define sustainability disclosure requirements"@en,
        "界定可持续发展信息披露要求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.10.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1.1> ;
    skos:definition "Defining governance requirements for sustainability. Include structure, roles, alignment to organization models, processes and standards to be applied."@en,
        "界定可持续发展治理要求，涵盖组织架构、角色职责、与组织模型的对齐关系，以及需采用的流程与标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.1.2" ;
    skos:prefLabel "Define sustainability governance requirements"@en,
        "界定可持续发展治理要求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.10.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1.1> ;
    skos:definition "Defining functional and performance requirements for sustainability. Align with ESG strategies, goals, and the implementation of sustainability efforts across the organization, provide a roadmap and visibility to shared and collective requirements."@en,
        "界定可持续发展功能与绩效要求；与ESG战略、目标及全组织可持续发展举措实施相协同，提供路线图并明晰共性与协同性要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.1.3" ;
    skos:prefLabel "Define sustainability functional and performance requirements"@en,
        "界定可持续发展职能与绩效要求"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.10.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.2" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1> ;
    skos:definition "Establishing organizational sustainability goals/objectives. Gather, align, and promote organization-wide sustainability goals that collectively address the overall sustainability requirements. Ensure the goals are measurable and have qualitative and quantitative targets."@en,
        "制定组织级可持续发展目标/对象；汇集、对齐并推广覆盖全组织的可持续发展目标，确保目标整体满足可持续发展要求；确保目标可衡量，并设定定性与定量指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.2" ;
    skos:prefLabel "Establish sustainability goals/objectives"@en,
        "设定可持续发展目标／目的"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1> ;
    skos:definition "Establishing, documenting, and communicating sustainability policies. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements."@en,
        "制定、记录并传达可持续发展政策；开发政策、书面程序及配套工具，明确组织落实政策要求的具体路径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.3" ;
    skos:prefLabel "Create sustainability policies"@en,
        "制定可持续发展政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.4" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1> ;
    skos:definition "Defining sustainability measures. Provide organization-wide measures, to include data collection strategies, calculations, analytics, and reporting formats."@en,
        "定义可持续发展度量指标；建立全组织统一的度量体系，涵盖数据采集策略、计算方法、分析模型及报告格式。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.4" ;
    skos:prefLabel "Define sustainability measures"@en,
        "定义可持续发展度量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.1.5" ;
    skos:broader <https://oprocess.net/opf/node/13.10.1> ;
    skos:definition "Creating sustainability plans. Develop and socialize sustainability plans for the organization, functional units, and support services. Ensure alignment to sustainability requirements, goals, and governance."@en,
        "制定可持续发展计划；为组织、职能单元及支持服务制定并推广可持续发展计划；确保计划与可持续发展要求、目标及治理框架保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.1.5" ;
    skos:prefLabel "Create sustainability plan(s)"@en,
        "制定可持续发展计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2.1" ;
    skos:broader <https://oprocess.net/opf/node/13.10.2> ;
    skos:definition "Providing sustainability training and awareness. Plan, prepare, and oversee delivery of sustainability education and enablement activities."@en,
        "开展可持续发展培训与意识宣贯；统筹规划、筹备并监督可持续发展教育与赋能活动的实施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2.1" ;
    skos:prefLabel "Provide sustainability training"@en,
        "提供可持续发展培训"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.10.2> ;
    skos:definition "Providing support for sustainability activities. Augment functional units and support teams with coaching, mentoring, and SME capacity to perform sustainability projects and activities."@en,
        "为可持续发展活动提供支持；通过辅导、导师制及领域专家（SME）能力补充，赋能职能单元与支持团队高效开展可持续发展项目与活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2.2" ;
    skos:prefLabel "Provide sustainability support"@en,
        "提供可持续发展支持"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.10.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/13.10.2.3> ;
    skos:definition "Measuring sustainability performance. Setup, collect, and validate sustainability data. Conduct audits and inspections. Evaluate results to requirements and targets. Identify and track resolution of gaps and variances."@en,
        "测量可持续发展绩效；建立、采集并校验可持续发展数据；开展审计与检查；对照要求与目标评估结果；识别、跟踪并闭环整改差距与偏差。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2.3.1" ;
    skos:prefLabel "Measure sustainability performance"@en,
        "衡量可持续发展绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.10.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.10.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/13.10.2.3> ;
    skos:definition "Preparing sustainability statements. Given the multitude of potential audiences for reporting, alignment and consistency of sustainability statements provides clarity and reusability for those audiences."@en,
        "编制可持续发展声明；鉴于报告受众多元，确保声明内容的一致性与协同性，以提升信息清晰度与复用价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.10.2.3.2" ;
    skos:prefLabel "Prepare sustainability statements"@en,
        "编制可持续发展声明"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/13.11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Continual Improvement" ;
    skos:broader <https://oprocess.net/opf/node/13.11> ;
    skos:definition "Activity within ITIL practice 'Continual Improvement'."@en,
        "ITIL‘持续改进’实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.11.1" ;
    skos:prefLabel "Identify improvement opportunities"@en,
        "识别改进机会"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.11.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Continual Improvement" ;
    skos:broader <https://oprocess.net/opf/node/13.11> ;
    skos:definition "Activity within ITIL practice 'Continual Improvement'."@en,
        "ITIL‘持续改进’实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.11.2" ;
    skos:prefLabel "Define improvement initiatives"@en,
        "定义改进举措"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.11.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Continual Improvement" ;
    skos:broader <https://oprocess.net/opf/node/13.11> ;
    skos:definition "Activity within ITIL practice 'Continual Improvement'."@en,
        "ITIL‘持续改进’实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.11.3" ;
    skos:prefLabel "Execute improvements"@en,
        "执行改进措施"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.11.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Continual Improvement" ;
    skos:broader <https://oprocess.net/opf/node/13.11> ;
    skos:definition "Activity within ITIL practice 'Continual Improvement'."@en,
        "ITIL‘持续改进’实践中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.11.4" ;
    skos:prefLabel "Evaluate improvement results"@en,
        "评估改进成效"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.12.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12.1> ;
    skos:definition "AI activity: Define AI maturity framework."@en,
        "AI活动：定义AI成熟度框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12.1.1" ;
    skos:prefLabel "Define AI maturity framework"@en,
        "定义人工智能（AI）成熟度框架"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.12.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12.1> ;
    skos:definition "AI activity: Benchmark current AI capabilities."@en,
