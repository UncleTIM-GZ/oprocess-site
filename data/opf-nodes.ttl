    skos:prefLabel "Analyze credit scoring history"@en,
        "分析 credit scoring history"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/9.2.1> ;
    skos:definition "Planning credit score requirements based on established credit policies."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.1.4" ;
    skos:prefLabel "Forecast credit scoring requirement"@en,
        "预测 credit scoring requirement"@zh ;
    opf:domain "management_support" ;
