    skos:definition "Delivering approved content to intended audiences through appropriate channels, repositories, or platforms in accordance with defined standards and controls."@en,
        "Delivering approved 内容 to intended audiences through appropriate channels, repositories, or platforms in accordance with defined standards and controls."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
