    skos:broader <https://oprocess.net/opf/node/4.1.8> ;
    skos:definition "Creating standard procedures for testing the quality of products/services. Describe the steps of key processes to help ensure consistent and quality output. Define the routine instructions for performing the quality testing activity."@en,
        "Creating standard procedures for testing the 质量 of products/services. Describe the steps of key processes to help ensure consistent and 质量 output. 定义 the routine instructions for performing the 质量 testing activity."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.8.2" ;
    skos:prefLabel "Develop standard testing procedures"@en,
        "开发 standard testing procedures"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

