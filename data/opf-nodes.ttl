    skos:broader <https://oprocess.net/opf/node/5.2.1> ;
    skos:definition "Overseeing all activities necessary to deliver services to customer. Revise forecast to account for any issues that may arise. This could be changes in market trend, resource changes, etc."@en,
        "Overseeing all activities necessary to deliver services to customer. Revise forecast to account for any issues that may arise. This could be 变更s in market trend, resource 变更s, etc."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1.6" ;
    skos:prefLabel "Monitor activity against forecast and revise forecast"@en,
        "监控 activity against forecast and revise forecast"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.2.1.7" ;
    skos:broader <https://oprocess.net/opf/node/5.2.1> ;
    skos:definition "Recognizing potential problems in the current forecast and making the necessary changes to align the forecast meet demand."@en,
        "Recognizing potential 问题s in the current forecast and making the necessary 变更s to align the forecast meet demand."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.2.1.7" ;
    skos:prefLabel "Evaluate and revise forecasting approach"@en,
        "评估 and revise forecasting approach"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.2.1.8> a skos:Concept,
        opf:ProcessNode ;
