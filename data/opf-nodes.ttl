        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "AI-era process group: AI Capabilities Development."@en,
        "AI时代流程组：AI能力开发。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12" ;
    skos:prefLabel "AI Capabilities Development"@en,
        "人工智能（AI）能力开发"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.12.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12> ;
    skos:definition "AI process: Assess AI Capability Maturity."@en,
        "AI流程：评估AI能力成熟度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12.1" ;
    skos:prefLabel "Assess AI Capability Maturity"@en,
        "评估人工智能（AI）能力成熟度"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.12.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12> ;
    skos:definition "AI process: Develop AI Knowledge and Skills."@en,
        "人工智能（AI）流程：培养人工智能知识与技能"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12.2" ;
    skos:prefLabel "Develop AI Knowledge and Skills"@en,
        "发展人工智能（AI）知识与技能"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.12.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12> ;
    skos:definition "AI process: Manage AI-Assisted Decision Making."@en,
        "人工智能（AI）流程：管理人工智能辅助决策"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12.3" ;
    skos:prefLabel "Manage AI-Assisted Decision Making"@en,
        "管理人工智能（AI）辅助决策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.12.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/13.12> ;
    skos:definition "AI process: Manage AI Innovation Pipeline."@en,
        "人工智能（AI）流程：管理人工智能创新管线"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.12.4" ;
    skos:prefLabel "Manage AI Innovation Pipeline"@en,
        "管理人工智能（AI）创新管线"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Managing investments, holdings, products, businesses, and brands, along with the related projects that together constitute a program."@en,
        "统筹管理投资、持股、产品、业务单元及品牌，及其共同构成的项目组合（Program）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2" ;
    skos:prefLabel "Manage portfolio, program, and project"@en,
        "管理项目组合、项目集与项目"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.2> ;
    skos:definition "Establishing, implementing, and managing business programs. Successfully handle related projects that together constitute a program. Establish the program structure and approach. Coordinate with stakeholders and partners. Execute the program. Assess and report the performance of the program. Coordinate and prioritize resources across projects. Manage links between the projects and the overall costs and risks of the program."@en,
        "建立、实施与管理业务项目组合：统筹管理构成该组合的各项关联项目；确立组合结构与实施路径；协同干系人与合作伙伴；执行组合计划；评估并报告组合绩效；跨项目协调与优先配置资源；统筹管理项目间依赖关系，以及组合整体成本与风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.2.2" ;
    skos:prefLabel "Manage programs"@en,
        "管理项目集"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/13.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Managing organizational attributes that are closely associated with the quality of output. Determine the quality requirements. Evaluate the correspondence between the quality performance and requirements. Manage non-conformance activities. Ensure implementation and maintenance of the enterprise quality management system."@en,
        "管理与输出质量密切相关的组织属性：确定质量要求；评估质量绩效与要求的符合程度；管理不符合项活动；确保企业质量管理体系的有效实施与持续维护。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3" ;
    skos:prefLabel "Manage enterprise quality"@en,
        "管理企业质量"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/13.3.1> ;
    skos:definition "Developing controls for managing the quality of enterprise. Define the process steps for quality controls and the sampling plan. Identify the tools and methods to measure quality. Define the competencies required."@en,
        "构建企业质量管控机制：定义质量控制流程步骤与抽样方案；识别用于质量测量的工具与方法；明确所需胜任力。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.1.3" ;
    skos:prefLabel "Develop quality controls"@en,
        "制定质量控制措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/13.3.2> ;
    skos:definition "Assessing the significance of the sample. Summarize the results of the test. Recommend improvement actions. Decide what steps to take next."@en,
        "评估样本代表性意义；汇总测试结果；提出改进建议；确定后续行动步骤。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.3.2.2" ;
    skos:prefLabel "Assess results of tests"@en,
        "评估测试结果"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/13.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.7" ;
    skos:broader <https://oprocess.net/opf/node/13.0> ;
    skos:definition "Defining and managing measurement and benchmarking. Measure and benchmark the performance of internal processes, as well as the organization as a whole."@en,
        "定义并管理度量与基准比对：衡量并比对内部流程及组织整体绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.7" ;
    skos:prefLabel "Measure and benchmark"@en,
        "度量与对标"@zh ;
    opf:domain "management_support" ;
    opf:level 2 .

<https://oprocess.net/opf/node/13.9.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:13.9.2" ;
    skos:broader <https://oprocess.net/opf/node/13.9> ;
    skos:definition "Identify the requirements for regulation and shareholders. Assess future risks and opportunities. Develop a policy for the EHS program. Record and manage EHS program events."@en,
        "识别法规与股东相关要求；评估未来风险与机遇；制定环境、健康与安全（EHS）计划政策；记录并管理EHS计划相关事件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "13.9.2" ;
    skos:prefLabel "Develop EHS program"@en,
        "制定环境、健康与安全（EHS）计划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.2" ;
    skos:broader <https://oprocess.net/opf/node/2.0> ;
    skos:definition "Identifying and describing new product or service thoughts based on organizational objectives/targets."@en,
        "基于组织目标/指标，识别并描述新产品或服务构想。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.2" ;
    skos:prefLabel "Generate and define new product/service ideas"@en,
        "生成并定义新产品/服务创意"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/2.3> ;
    skos:definition "Expanding on the marketplace analysis that took place earlier in the product development lifecycle by testing the market against offerings. The results from this in-depth analysis will help the organization finalize product/service characteristics and technical requirements and also identify any needed changes in the manufacturing and delivery processes that support market delivery. To prepare a detailed market study that accounts for any changes in the global environment, the organization may want to conduct a series of interviews, workshops, and focus groups with potential and existing customers."@en,
        "深化前期产品开发生命周期中已开展的市场分析，通过实际投放测试验证市场响应。该深度分析结果将支撑组织最终确定产品/服务特性与技术要求，并识别制造与交付流程中需适配市场交付需求的调整项；为编制兼顾全球环境变化的详尽市场研究报告，组织可开展面向潜在客户及现有客户的系列访谈、工作坊与焦点小组研讨。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "2.3.2" ;
    skos:prefLabel "Test market for new or revised products and services"@en,
        "新产品及服务的试销市场"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/3.1> ;
    skos:definition "Appraising market opportunities by quantifying and subjecting them to prioritization, as well as validation tests. Closely examine the market opportunities that have been identified by Perform customer and market intelligence analysis [10106]. Triangulate those opportunities to capitalize by finding a fit between identified opportunities and the composite of organizational capabilities and business strategy."@en,
        "通过量化、优先级排序及验证测试等方式评估市场机会。结合执行客户与市场情报分析［10106］所识别的机会，开展三角验证，确保市场机会与组织整体业务能力及业务战略相匹配。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.1.2" ;
    skos:prefLabel "Evaluate and prioritize market opportunities"@en,
        "评估并优先排序市场机会"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Defining and overseeing the positioning, value proposition, and governance of brands to ensure a consistent identity, clear differentiation, and alignment with overall marketing direction and business objectives across markets and offerings."@en,
        "定义并统筹管理品牌定位、价值主张与治理机制，确保品牌形象统一、差异化清晰，并与各市场、各产品/服务的整体营销方向及业务目标保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.2" ;
    skos:prefLabel "Develop and manage brands"@en,
        "品牌开发与管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/3.2> ;
    skos:definition "Creating a pricing strategy and mechanism that aligns with the benefits of the products/services, as perceived by customers. Chart a strategic course and a methodology that can guide the pricing of products/services. Draw heavily from the customer value proposition, and balance the expectations of different divisions inside the organization, while delivering the maximum ROI."@en,
        "制定与客户感知价值相匹配的定价策略与机制；规划指导产品/服务定价的战略路径与方法论；深度依托客户价值主张，在兼顾组织内各部门诉求的同时，实现投资回报率（ROI）最大化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.2.3" ;
    skos:prefLabel "Define pricing strategy"@en,
        "制定定价策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Creating a budget for the organization's marketing efforts, in line with the business-wide strategic outlook. Create a plan to distribute resources for achieving the marketing strategy in light of the overall business strategy. Make cost assumptions; calculate the estimated total revenue from the marketing activities against the costs/expenses of these activities. Forecast the return on investment. Attribute costs to the appropriate marketing activities such as promotional campaigns, advertising, marketing communications, PR campaigns, personnel, and office space. Enlist the financial and marketing functions."@en,
        "依据企业整体战略视角编制营销预算；制定资源分配计划，确保营销战略落地与业务战略协同；进行成本估算，测算营销活动预期总收入与成本/费用；预测投资回报率（ROI）；将成本归集至相应营销活动（如促销活动、广告、营销传播、公关活动、人员及办公场地等）；联动财务与市场职能共同完成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.2" ;
    skos:prefLabel "Establish marketing budgets"@en,
        "制定营销预算"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.3.7" ;
    skos:broader <https://oprocess.net/opf/node/3.3> ;
    skos:definition "Creating, executing, and administering a strategic road map for packaging products/services. Determine how to package products/services into finished offerings that can be directly marketed to prospective customers. Consider physicality, perishability, and shelf-life. Develop a strategy for packaging products/services. Test alternatives. Collect feedback. Refine the option chosen for execution. Have marketing, product development, and supply chain functions work together to develop sound packaging."@en,
        "制定、执行并管理产品/服务包装的战略路线图；明确如何将产品/服务组合为可直接面向潜在客户营销的成品方案；统筹考量物理形态、易腐性与保质期；制定包装策略；开展替代方案测试；收集反馈；迭代优化选定方案；推动市场营销、产品研发与供应链职能协同，打造优质包装方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.3.7" ;
    skos:prefLabel "Develop and manage packaging strategy"@en,
        "制定并管理包装策略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/3.4> ;
    skos:definition "Developing a sales forecast for the organization's portfolio of offerings, bearing in mind the effect of promotional events, and fine-tuning these in the context of the new forecast. Estimate the future demand for the organization's products/services by analyzing historical information and any promotional activity."@en,
        "结合促销活动影响，制定组织产品/服务组合的销售预测，并依据新预测动态校准。通过分析历史数据与促销活动，预估未来产品/服务需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.4.1" ;
    skos:prefLabel "Develop sales forecast"@en,
        "制定销售预测"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/3.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:3.5.5" ;
    skos:broader <https://oprocess.net/opf/node/3.5> ;
    skos:definition "Managing the organization's partners and alliances, with the objective of maximizing revenue. Train partners regarding the organization's portfolio of products/services. Craft sales forecasts. Examine their performance. Manage all data held by the organization on these partners."@en,
        "管理组织的合作伙伴与联盟关系，以最大化营收；面向合作伙伴开展产品/服务培训；制定销售预测；评估其业绩表现；统一管理组织持有的全部合作伙伴数据"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "3.5.5" ;
    skos:prefLabel "Manage sales partners and alliances"@en,
        "销售合作伙伴与联盟管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.1.6" ;
    skos:broader <https://oprocess.net/opf/node/4.1> ;
    skos:definition "Instituting the constraints for planning of distribution process. Create a plan that specifies every element in the distribution process from the blueprint of the distribution centers to how and when the inventory would reach the distribution centers."@en,
        "设定分销流程规划的约束条件。制定涵盖分销中心蓝图设计、库存抵达时间与方式等全流程要素的规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.6" ;
    skos:prefLabel "Establish distribution planning constraints"@en,
        "制定分销规划约束条件"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sFR3" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Fulfill Return Excess Product (sFR3)."@en,
        "SCOR DS 14.0：履行退回过剩产品（sFR3）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.10" ;
    skos:prefLabel "Fulfill Return Excess Product"@en,
        "履行过剩产品退货流程"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "Evaluating supplier options to select the most effective and efficient suppliers. Validate selected suppliers. Establish and manage supplier contracts."@en,
        "评估供应商选项，遴选最优供应商；验证入选供应商资质；建立并管理供应商合同。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.3" ;
    skos:prefLabel "Select suppliers and develop/maintain contracts"@en,
        "遴选供应商并制定/维护合同"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "Collecting and analyzing new information in order to track and rate suppliers and build relationships."@en,
        "持续收集与分析新信息，用于供应商绩效跟踪、评级及关系深化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.5" ;
    skos:prefLabel "Manage suppliers"@en,
        "供应商管理"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sS1" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "SCOR DS 14.0: Source Stocked Product (sS1)."@en,
        "SCOR DS 14.0：采购备货型产品（sS1）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.6" ;
    skos:prefLabel "Source Stocked Product"@en,
        "采购备货型产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sS2" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "SCOR DS 14.0: Source Make-to-Order Product (sS2)."@en,
        "供应链运作参考模型（SCOR）DS 14.0：采购按订单生产产品（sS2）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.7" ;
    skos:prefLabel "Source Make-to-Order Product"@en,
        "采购按订单生产（MTO）产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sS3" ;
    skos:broader <https://oprocess.net/opf/node/4.2> ;
    skos:definition "SCOR DS 14.0: Source Engineer-to-Order Product (sS3)."@en,
        "供应链运作参考模型（SCOR）DS 14.0：采购按订单设计产品（sS3）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.2.8" ;
    skos:prefLabel "Source Engineer-to-Order Product"@en,
        "采购按设计生产（ETO）产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.21> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sOr11" ;
    skos:broader <https://oprocess.net/opf/node/4.0> ;
    skos:definition "SCOR DS 14.0: Manage SC Sustainability (sOr11)."@en,
        "SCOR DS 14.0：管理供应链可持续性（sOr11）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.21" ;
    skos:prefLabel "Manage SC Sustainability"@en,
        "管理供应链可持续性"@zh ;
    opf:domain "operating" ;
    opf:level 2 .

<https://oprocess.net/opf/node/4.3.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.3.2.5" ;
    skos:broader <https://oprocess.net/opf/node/4.3.2> ;
    skos:definition "Integrating different resources in the production process: material, personnel, equipment, robotics, etc. Includes automating and controlling the plant, performing advanced process control and real-time optimization. This activity also includes managing plant alarms and alerts."@en,
        "整合生产过程中的各类资源（物料、人员、设备、机器人等）；实施工厂自动化与控制；开展先进过程控制与实时优化；管理工厂报警与告警系统。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.3.2.5" ;
    skos:prefLabel "Monitor and optimize production process"@en,
        "监控与优化生产过程"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sF2" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "SCOR DS 14.0: Fulfill Make-to-Order Product (sF2)."@en,
        "SCOR DS 14.0：按订单生产产品交付（sF2）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.10" ;
    skos:prefLabel "Fulfill Make-to-Order Product"@en,
        "按单生产产品（MTO）履约"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.2.5" ;
    skos:broader <https://oprocess.net/opf/node/4.4.2> ;
    skos:definition "Determining if a returned product can be salvaged or repaired. Salvage or repair is dependent upon the product, the condition of the product, or the availability of a like item."@en,
        "判定退货产品是否可修复或再利用。判定依据包括产品类型、实际状况及同类替代品的可获得性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.2.5" ;
    skos:prefLabel "Manage disposition of returned products"@en,
        "管理退货产品处置"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Creating a plan that specifies the schedule and system for transportation and delivery of the outbound products, as well as tracking the performance of the carrier delivery system. Conduct vehicle management and processing of all carrier-related documents."@en,
        "制定出库/发运产品的运输与交付计划，明确调度安排与执行系统，并对承运商交付绩效进行跟踪评估。开展车辆管理及全部承运相关单据的处理工作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.4" ;
    skos:prefLabel "Operate outbound transportation"@en,
        "开展出库运输运营"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "Validating specific service requirements for individual customers. Determine and schedule resource to fulfill these requirements. Provide service to specific individual customers. Ensure the quality of service delivery."@en,
        "校验单个客户的特定服务需求；确定并调度资源以满足该需求；面向特定客户提供服务；保障服务交付质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5" ;
    skos:prefLabel "Deliver last mile delivery services"@en,
        "提供末端配送服务"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:4.4.5.4" ;
    skos:broader <https://oprocess.net/opf/node/4.4.5> ;
    skos:definition "Guaranteeing the quality of service provided to customers. Identify the successful and unsuccessful orders along with the service failures. Collect customer feedback. Process the feedback to ensure the quality of service in the future."@en,
        "保障面向客户的整体服务质量；识别成功与失败订单及服务失效点；收集客户反馈；分析反馈以持续提升未来服务质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5.4" ;
    skos:prefLabel "Ensure quality of last mile delivery"@en,
        "保障末端配送服务质量"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/4.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sO1" ;
    skos:broader <https://oprocess.net/opf/node/4.4> ;
    skos:definition "SCOR DS 14.0: Order Stocked Product (sO1)."@en,
        "SCOR DS 14.0：订购现货产品（sO1）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.6" ;
    skos:prefLabel "Order Stocked Product"@en,
        "订购现货产品"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

