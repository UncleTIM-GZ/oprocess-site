<https://oprocess.net/opf/node/7.1.2.15> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:7.1.2.15" ;
    skos:broader <https://oprocess.net/opf/node/7.1.2> ;
    skos:definition "Overseeing a group of similar individual or teams with similar education, skills, training, or experience."@en,
        "Overseeing a group of similar individual or teams with similar education, skills, 训练, or experience."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
