    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.4.5" ;
    skos:prefLabel "Deliver last mile delivery services"@en ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/4.4.5.4> a skos:Concept,
