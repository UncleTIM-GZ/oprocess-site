<https://oprocess.net/opf/node/5.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/5.1.1> ;
    skos:definition "Providing a system for which to manage customer needs and a structure for which to facilitate service delivery to fulfill those needs."@en,
        "Providing a system for which to manage customer needs and a structure for which to facilitate service delivery to 履约 those needs."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.1.1" ;
    skos:prefLabel "Set up and maintain service delivery governance and management system"@en,
        "Set up and maintain service delivery 治理 and management system"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/5.1.1> ;
    skos:definition "Conducting and implementing performance measures to ensure successful delivery of service to the customer."@en,
        "Conducting and implementing 绩效 measures to ensure successful delivery of service to the customer."@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.1.2" ;
    skos:prefLabel "Manage service delivery performance"@en,
        "管理 service delivery 绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/5.1.1> ;
    skos:definition "Providing guidance of resources to ensure that the development and direction of service delivery is in line with customer needs."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "5.1.1.3" ;
    skos:prefLabel "Manage service delivery development and direction"@en,
        "管理 service delivery development and direction"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/5.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:5.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/5.1.1> ;
