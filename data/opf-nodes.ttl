<https://oprocess.net/opf/node/4.1.14.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "SCOR:DS14:sP6" ;
    skos:broader <https://oprocess.net/opf/node/4.1.14> ;
    skos:definition "SCOR DS 14.0 activity in 'Plan Return'."@en,
        "SCOR DS 14.0「规划退货」活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "4.1.14.1" ;
    skos:prefLabel "Assess return requirements"@en,
        "评估退货需求"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

