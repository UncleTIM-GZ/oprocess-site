@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix opf: <https://oprocess.net/ns/opf#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://oprocess.net/opf/node/1.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Identifying your competitors, their service and/or product. Evaluating competitors strategies to determine their strengths and weaknesses relative to those of your own product or service."@en,
        "识别竞争对手及其服务和/或产品；评估其竞争策略，比对其相对于本组织产品或服务的优势与劣势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.1" ;
    skos:prefLabel "Identify competitors"@en,
        "识别竞争对手"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.10" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Establishing measures and procedures for identifying various intellectual property threats and concerns."@en,
        "建立识别各类知识产权威胁与风险的措施与流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.10" ;
    skos:prefLabel "Evaluate intellectual property"@en,
        "评估知识产权"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Assessing the competitive forces in the marketplace that could potentially affect the organization. Analyze various aspects of business competition including competing firms. Aggregate competitive intelligence, create benchmarks to juxtapose processes and performance metrics, and inject crucial information about the competition into management models to synthesize insights."@en,
        "评估可能影响组织的市场中各类竞争力量。从竞争企业等多维度分析商业竞争要素；整合竞争情报，建立基准以对比流程与绩效指标，并将关键竞争信息注入管理模型，形成综合洞见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.2" ;
    skos:prefLabel "Analyze and evaluate competition"@en,
        "分析与评估竞争态势"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Examining if there are other existing products or services in the marketplace, and building the business case to make a go/no go decision based upon substitutions."@en,
        "考察市场上是否存在其他同类产品或服务，并基于可替代性构建商业论证，支撑“立项/否决”决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.3" ;
    skos:prefLabel "Identify potential product or service alternatives"@en,
        "识别潜在产品或服务替代方案"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Determining large-scale macroeconomic shifts and trends, with medium to long-term relevance for the organization. Vet the immediate and the larger economic ecosystem to identify broad-based movements that affect the organization. In the immediate vicinity, for example, examine the stock price of key vendors/suppliers in the organizational value-chain. In the larger economic ecosystem, analyze according to geographical distribution where factors such as interest rates, taxation structures, oil prices, and unemployment rates are explored."@en,
        "研判具有中长期组织相关性的宏观经济发展动向与趋势。审阅组织所处的即时经济生态与更广泛的宏观经济体系，识别影响组织的全局性变化。例如，在即时层面，考察组织价值链中关键供应商/厂商的股价；在宏观层面，按地理区域分析利率、税收结构、油价、失业率等因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.4" ;
    skos:prefLabel "Identify economic trends"@en,
        "识别经济趋势"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Identifying areas of concern pertaining to public policy and regulation, established by sovereign or multinational authorities. Examine various regions and geopolitical formations to identify those political and regulatory issues-present or developing-that can potentially affect the organization. Plan for an iterative process, partitioned across regional and geopolitical entities that have a direct bearing on the organization's activities. Assess changes in environmental compliance, product standards, trade barriers, etc."@en,
        "识别由主权国家或多边机构制定的公共政策与监管领域中的风险点。考察不同区域与地缘政治格局，识别当前存在或正在演化的、可能影响组织的政治与监管议题。规划覆盖各相关区域与地缘政治实体的迭代式评估流程；评估环境合规、产品标准、贸易壁垒等方面的变化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.5" ;
    skos:prefLabel "Identify political and regulatory factors"@en,
        "识别政治与监管因素"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.6" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Identifying changes in ecological ecosystems that can be directly or indirectly detrimental to the organization. Analyze ecological factors within the immediate ecosystem for near to middle-term impact. Analyze the ecology, at large, to get a sense of long-term shifts and concerns. Gather analyses from research publications. Speak to subject matter experts. Engage with advocacy groups, lawyers, journalists, and the active populations."@en,
        "识别可能直接或间接损害组织的生态环境变化。在组织所处近端生态系统内分析生态因素，评估其短期至中期影响；在宏观生态层面开展分析，把握长期演变趋势与关切议题。参考科研出版物分析成果；咨询领域专家；与倡导组织、律师、记者及公众代表开展交流。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.6" ;
    skos:prefLabel "Identify environmental factors"@en,
        "识别环境因素"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.7" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Distinguishing changes in societal makeup, as well as the cultural composite. Isolate shifts in the societal composition and distribution, as well as the value systems and attributes that bind the organization together. Analyze well-regarded publications--and gather the perspective of public intellectuals and opinion leaders--on relevant issues."@en,
        "辨识社会结构与文化构成的变化。厘清人口组成与分布、价值体系及维系组织凝聚力的关键属性之演变。借助权威出版物，并融合公共知识分子与意见领袖的观点，就相关议题开展分析。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.7" ;
    skos:prefLabel "Identify social and cultural changes"@en,
        "识别社会与文化变迁"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.8" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Assessing developments in technologies presently being used by the business, new technologies that have a potential for the business, and any disruptive innovations. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI).  Conduct a survey of advancement in technologies that are already deployed with inputs from the personnel closely working with them, tracking utility and feasibility for deployment. Arrange for mid- to senior-level management personnel who explore contingent uses to assess new and disruptive technologies. Follow up with desk research, involving physical scoping and viability assessment."@en,
        "评估组织当前使用的技术、具备应用潜力的新技术，以及颠覆性创新技术（含人工智能（AI）等各类新兴与演进技术）。调研已部署技术的进展，结合一线操作人员反馈，评估其实用性与部署可行性；安排中高层管理人员探索潜在应用场景，评估新技术与颠覆性技术；辅以案头研究，开展实地勘察与可行性评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.8" ;
    skos:prefLabel "Assess new technologies"@en,
        "评估新兴技术"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.1.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.1.9" ;
    skos:broader <https://oprocess.net/opf/node/1.1.1> ;
    skos:definition "Analyzing statistical data relating to the size, distribution, and composition of relevant populations, as well as their characteristics. Perform quantitative analysis over raw data-sets gathered from well-founded sources such as government census or large, private databases. Consider employing primary research in collecting required statistics. Use comprehensive studies (reports, briefs, and articles) to assist with the analysis, in place of raw data."@en,
        "分析与相关人口规模、分布、构成及特征相关的统计数据。基于政府人口普查或大型私营数据库等权威数据源，开展原始数据集的定量分析；必要时采用一手调研方式采集所需统计信息；亦可借助综合性研究报告、简报与专业文章辅助分析，替代原始数据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.1.9" ;
    skos:prefLabel "Analyze demographics"@en,
        "分析人口统计特征"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.2> ;
    skos:definition "Investigating key market features and customer characteristics, using qualitative and quantitative measures to capture relevant aspects. Distill key ingredients that allow the organization to Capture customer needs and wants [19946], and Assess customer needs and wants [19947]. Conduct standardized appraisals by defining selection parameters and setting quotas."@en,
        "运用定性与定量方法，调查关键市场特征与客户属性，以全面捕捉相关维度。提炼核心要素，支撑‘捕捉客户需求与期望’[19946]与‘评估客户需求与期望’[19947]两项活动。通过明确定义筛选参数与设定配额，实施标准化评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.2.1" ;
    skos:prefLabel "Conduct qualitative/quantitative research and assessments"@en,
        "开展定性/定量研究与评估"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.2> ;
    skos:definition "Identifying and collecting customers' wants and needs of a product and/or services from a marketing perspective. Identify which consumer needs are important and whether needs are being met by current products/services."@en,
        "从营销视角识别并收集客户对产品和/或服务的需求与期望；判断哪些消费者需求至关重要，以及当前产品或服务是否满足这些需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.2.2" ;
    skos:prefLabel "Capture customer needs and wants"@en,
        "捕捉客户需求与期望"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.2> ;
    skos:definition "Creating customer profiles to get a picture of customers and their needs. Identify particular groups of people/organizations that benefit from your product/services and then selling to them."@en,
        "构建客户画像，全面了解客户及其需求；识别可从本组织产品或服务中获益的特定人群或组织，并开展精准营销。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.2.3" ;
    skos:prefLabel "Assess customer needs and wants"@en,
        "评估客户需求与期望"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Identifying and examining key attributes that differentiate the organization in the market and those that underscore the core of its operations. Consider how the organization functions. Reflect over tangible and intangible aspects in order to spot critical correlations and the interplay between these attributes. Have senior executives conduct the analysis, with input from management and operational personnel."@en,
        "识别并审视使组织在市场中脱颖而出的关键属性，以及体现其运营核心的本质特征；思考组织运作方式；兼顾有形与无形要素，发现关键关联及其相互作用；由高级管理人员主导分析，并吸纳管理层与一线运营人员的意见。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.1" ;
    skos:prefLabel "Analyze organizational characteristics"@en,
        "分析组织特性"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Identify key elements of operations and measure effectiveness of these elements within internal operations."@en,
        "识别运营关键要素，并评估其在内部运营中的有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.2" ;
    skos:prefLabel "Analyze internal operations"@en,
        "分析内部运营"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Establishing baselines that provide standards for assessing performance levels and allow for a relational benchmarking of current processes. Undertake a survey of archival performance records, conducted in conjunction by the management and the operations personnel. Take into account the organization's internal objectives, particularly for process improvement and enhancement. Understand industry best practices."@en,
        "建立基准线，为绩效水平评估提供标准，并支持当前流程的关联性对标。联合管理层与运营人员开展历史绩效记录调查；兼顾组织内部目标，特别是流程改进与提升目标；了解行业最佳实践。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.3" ;
    skos:prefLabel "Create baselines for current processes"@en,
        "建立现有流程基线"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Analyzing the capabilities of technology and process automation systems deployed within the organization in order to direct future associated processes. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct a broad-based survey to examine various aspects associated with such systems and technologies, with the objective of identifying key facets that are of interest. Investigate the intended purpose, purpose served, utility, longevity, remaining service-life, repair or service requirements, etc."@en,
        "分析组织内部已部署的技术与流程自动化系统能力，以指导未来相关流程建设。涵盖所有新兴及演进中的技术形式，包括人工智能（AI）。开展广泛调研，全面考察此类系统与技术的各方面特征，识别关键关注维度；深入探究其设计目的、实际效用、使用寿命、剩余服务周期、维修或维保需求等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.4" ;
    skos:prefLabel "Analyze systems and technology"@en,
        "分析系统与技术"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Appraising the financial state of the organization so that management can create resource allocation strategies. Scrutinize the organization's financials--including balance sheets, statements of income, cash-flows, equity holdings, and liquidity--with the objective of understanding the organization's financial health and capacities. (This analysis directly feeds into Conduct organizational restructuring opportunities [16792] and Define a business concept and long-term vision [17040].)"@en,
        "评估组织财务状况，支撑管理层制定资源分配策略。审阅资产负债表、利润表、现金流量表、权益持有情况及流动性等财务数据，以全面把握组织财务健康状况与资源承载能力。（该分析直接支撑‘开展组织重构机会评估’[16792]与‘定义业务概念及长期愿景’[17040]两项活动。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.5" ;
    skos:prefLabel "Analyze financial health"@en,
        "分析财务健康状况"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.3.6" ;
    skos:broader <https://oprocess.net/opf/node/1.1.3> ;
    skos:definition "Determining a strategically significant aggregate of competence and capacities that differentiates the organization in the market. Identify distinguishing attributes including unique skills and resources and its brand and services in the marketplace. Have senior executives and management personnel assess competencies in order to further develop these capabilities into distinct commercial value propositions."@en,
        "识别一组具有战略意义的核心能力与资源组合，形成组织在市场中的差异化优势。明确独特技能、资源、品牌及服务等辨识性要素；由高管与管理人员共同评估现有能力，进一步将其发展为具备显著商业价值的价值主张。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.3.6" ;
    skos:prefLabel "Identify core competencies"@en,
        "识别核心能力"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.4> ;
    skos:definition "Developing goals to define organizations vision. Define and document ideas, direction, and activities which enable the organization to reach these goals."@en,
        "制定目标以界定组织愿景。明确并记录支撑目标实现的理念、方向与具体行动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.4.1" ;
    skos:prefLabel "Define the strategic vision"@en,
        "定义战略愿景"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.4> ;
    skos:definition "Orienting those entities, associated with the organization that have a direct bearing on its operations and output, in a way that advances its strategic vision. Map all stakeholders in strategic configurations, within the architectural layout of the marketplace, and position the organization relative to them. (This exercise is undertaken by senior strategy personnel, drawing upon the process Define a business concept and long-term vision [17040].)"@en,
        "对直接影响组织运营与产出的相关实体进行战略引导，推动其实现组织愿景。在市场架构图谱中完成全部利益相关方的战略映射，并准确定位组织与其关系。（此项工作由高级战略人员主导，依托‘定义业务概念及长期愿景’[17040]流程开展。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.4.2" ;
    skos:prefLabel "Align stakeholders around strategic vision"@en,
        "推动利益相关方对齐战略愿景"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.4> ;
    skos:definition "Developing and executing communication strategies to convey an alignment plan of all organizational stakeholders, which helps the organization realize its vision. Create custom communication strategies and delivery channels with the objective of orienting stakeholders according to the configuration maps created in the process Align stakeholders around a strategic vision [10035]. Have senior strategy personnel closely collaborate with the communications/marketing team."@en,
        "制定并执行沟通策略，推动全体组织利益相关方达成愿景对齐。基于‘围绕战略愿景协同利益相关方’[10035]流程所生成的配置图谱，定制化设计沟通策略与传递渠道；高级战略人员须与传播/营销团队紧密协作。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.4.3" ;
    skos:prefLabel "Communicate strategic vision to stakeholders"@en,
        "向利益相关方传达战略愿景"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5> ;
    skos:definition "Identifying opportunities for restructuring the organization, through an analysis of internal viability and external contingency. Conduct a broad-based survey of the market landscape, taking the large-scale trends and movements into account, to determine the necessity and possibility of restructuring the organization. Review the organization's internal capacities, the readiness of its process frameworks, the robustness of its financials, the capableness of its systems, the resourcefulness of its personnel, etc. for assimilating an extensive overhaul."@en,
        "通过内生可行性与外部环境约束分析，识别组织重构机会。综合考量宏观趋势与市场动态，开展全景式市场格局扫描，研判组织重构的必要性与可行性；同步审视组织内部能力、流程框架成熟度、财务稳健性、系统可靠性、人员应变力等，评估其承接重大变革的准备程度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.1" ;
    skos:prefLabel "Identify restructuring opportunities"@en,
        "识别重构机会"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5> ;
    skos:definition "Auditing the status quo of the probabilities, before formalizing any restructuring of the organization with another entity. Systematically investigate all entities discerned to be of interest in Identify restructuring opportunities [16793], to verify all tangible and substantial facts. Consider engaging specialist professional services including legal, accounting, and consulting help."@en,
        "在正式启动与他方组织的重构合作前，全面审计各方现状。系统核查‘识别重构机会’[16793]中筛选出的潜在合作方，核实所有实质性、可验证的事实；视需要引入法律、会计及咨询等专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.2" ;
    skos:prefLabel "Perform due-diligence"@en,
        "开展尽职调查"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.1.5.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5.3> ;
    skos:definition "Appraising entities identified as being suitable for acquisition, taking into account the restructuring opportunities in the internal and external context. Verify the appropriateness and viability of the short-listed options. Ensure these entities pertain to the state-of-affairs in the market, as well as fit with the resources and capabilities of the organization."@en,
        "评估适配收购的标的实体，结合内外部重构契机综合研判。验证短名单选项的适配性与可行性；确保标的契合当前市场态势，且与组织资源禀赋及核心能力相匹配。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.3.1" ;
    skos:prefLabel "Evaluate acquisition options"@en,
        "评估并购选项"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.1.5.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5.3> ;
    skos:definition "Appraising entities identified as being suitable for a merger, taking stock of the restructuring opportunities within the firm and the market. Verify the appropriateness and viability of such options. Assess these entities to ensure their pertinence to the contextual state-of-affairs in the market, as well as a fit with the resources and capabilities of the organization itself. (This process can be carried out, in its entirety, by qualified in-house personnel or may be designated to specialist professional services providers.)"@en,
        "评估适配合并的标的实体，统筹考量组织内部及市场层面的重构机遇。验证合并选项的适配性与可行性；确保标的契合市场现实情境，且与组织自身资源及能力高度匹配。（本流程可由合格内部人员全程执行，亦可委托专业服务机构承担。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.3.2" ;
    skos:prefLabel "Evaluate merger options"@en,
        "评估合并选项"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.1.5.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.3.3" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5.3> ;
    skos:definition "Evaluating departments and subsidiaries within the organization, and/or previously merged entities, to assess the appropriateness of a de-merger, taking account of the fit between these entities as well as any relevant externalities. Examine the pertinence and soundness of a formalized dissociation."@en,
        "评估组织内部部门、子公司及既往合并实体，研判分拆的适配性，兼顾实体间适配度及相关外部影响因素；审慎评估正式剥离的合理性与稳健性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.3.3" ;
    skos:prefLabel "Evaluate de-merger options"@en,
        "评估分拆选项"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.1.5.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.1.5.3.4" ;
    skos:broader <https://oprocess.net/opf/node/1.1.5.3> ;
    skos:definition "Evaluating departments and/or subsidiaries within the organization to assess the appropriateness of a divestment, taking account of all market externalities. Examine any internal entities that have been identified to be suitable for dismemberment from the organization. Ensure the pertinence and soundness of such a move."@en,
        "评估组织内部部门及/或子公司，研判剥离的适配性，全面考量市场外部性；审查已被识别为适宜从组织中分离的内部实体；确保该举措具备充分合理性与实施稳健性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.5.3.4" ;
    skos:prefLabel "Evaluate divesture options"@en,
        "评估剥离选项"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/1.1> ;
    skos:definition "AI-era activity: AI-Powered Market Analysis."@en,
        "AI时代专项活动：AI驱动的市场分析"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.1.6" ;
    skos:prefLabel "AI-Powered Market Analysis"@en,
        "AI驱动的市场分析"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.1> ;
    skos:definition "Defining the status quo relating to the de facto core of what the business is. Reflect over the fundamental essence of what the business accomplishes and the manner in which it operates. Look beyond the obvious solution capabilities to delineate capacities that form the basis of the business engine. Involve senior executives and management personnel and possibly professional services providers."@en,
        "界定业务实质现状，即组织事实上赖以立足的核心。反思业务的根本本质及其运作方式；超越显性解决方案能力，深入挖掘构成业务引擎底层基础的能力要素；需高管与管理人员深度参与，必要时引入专业服务机构支持。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.1.1" ;
    skos:prefLabel "Define current business"@en,
        "界定当前业务范围"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.1> ;
    skos:definition "Outlining actionable objectives that effectively set a course to fulfill the organization's vision. In this fundamental activity, articulate certain goals or targets in broad but practicable terms to reach long-term objectives."@en,
        "设定可执行目标，有效锚定组织愿景实现路径。在此基础性活动中，以宽泛但切实可行的方式，明确若干中长期目标或关键指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.1.2" ;
    skos:prefLabel "Formulate mission"@en,
        "拟定使命"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.1> ;
    skos:definition "Developing and executing a communication strategy to convey the mission statement. Create a universal communication strategy and appropriate delivery channels, with the objective of leveraging the latter to execute the former. Convey the inherent message of the mission to all stakeholders, including employees, customers, and the public. Ensure collaboration between senior strategy personnel and the communications/marketing team."@en,
        "制定并执行使命陈述传播策略。构建统一传播策略与适配传递渠道，以渠道赋能策略落地；向员工、客户及公众等全体利益相关方准确传达使命内涵；确保高级战略人员与传播/营销团队协同联动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.1.3" ;
    skos:prefLabel "Communicate mission"@en,
        "传达使命"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "AI-era activity: AI-Driven Scenario Planning."@en,
        "AI时代活动：人工智能驱动的情景规划（AI-Driven Scenario Planning）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.10" ;
    skos:prefLabel "AI-Driven Scenario Planning"@en,
        "AI驱动的情景规划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2.1> ;
    skos:definition "Supporting the design, manufacture and distribution of product and services through the extended enterprise model.  This is concerned with the strategic decisions on make vs buy, in house or out sourced.  Senior Executives map out how they want to run their business.  Make strategic choices as to whether to buy in components / sub-assemblies, run their own distribution fleet or contract out, own their dealerships or franchise out, etc.  Strategize with partnerships. Collaborate design consideration at strategy level for automotive and procurement act within the Target Operating Model set at strategy level."@en,
        "依托扩展型企业模式，支撑产品与服务的设计、制造与分销。聚焦“自建 vs 外购”“自主运营 vs 外包”等关键战略抉择；高管层统筹规划业务运营模式，如零部件/子系统采购策略、自有物流车队建设或外包选择、直营经销体系构建或特许经营模式采用等；开展战略级合作伙伴协同设计；在战略层设定目标运营模式（TOM），汽车与采购职能据此开展协同设计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.1.1" ;
    skos:prefLabel "Select partnerships and relationships to support the extended enterprise"@en,
        "遴选支撑扩展型企业的合作伙伴与合作关系"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.2.10> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.10" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating options for shared services and support functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and operational efficiencies."@en,
        "评估共享服务与支持职能的优化选项，涵盖组织架构、规模弹性、变革适应力及替代交付模式，以平衡成本、绩效与运营效率。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.10" ;
    skos:prefLabel "Evaluate shared services options"@en,
        "评估共享服务选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.11> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.11" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating options to enhance and optimize processes and functional areas. Understand alternatives to strengthen business capabilities, enhance process efficiencies, and advance performance standards."@en,
        "评估流程与职能领域优化提升选项。识别强化业务能力、提升流程效率、提高绩效标准的可行替代路径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.11" ;
    skos:prefLabel "Evaluate lean/continuous improvement options"@en,
        "评估精益/持续改进选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2.2> ;
    skos:definition "Determine impacts of elements such as staffing, skills, training, new markets, technology, or policies within operating model which needs change."@en,
        "识别运营模式变革所需的关键影响要素，包括人员配置、技能结构、培训需求、新市场拓展、技术升级及政策调整等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.2.1" ;
    skos:prefLabel "Identify implications for key operating model business elements that require change"@en,
        "识别关键运营模式业务要素所需变革的潜在影响"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2.2> ;
    skos:definition "Determining key factors for technology ROI, benefits, architecture, etc."@en,
        "确定技术投资回报率（ROI）、效益、架构等关键评估因子。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.2.2" ;
    skos:prefLabel "Identify implications for key technology aspects"@en,
        "识别关键技术要素的潜在影响"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating future business to business opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of stakeholders and partners to understand potential future impact."@en,
        "对照过往与当前实践及绩效表现，评估未来企业对企业（B2B）机会。收集竞争对手及其他同类组织的实践洞察，结合利益相关方与合作伙伴的需求、目标及期望，研判潜在未来影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.3" ;
    skos:prefLabel "Evaluate B2B options"@en,
        "评估B2B选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating future business to customer opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of customers and partners to understand potential future impact."@en,
        "对照过往与当前实践及绩效表现，评估未来企业对客户（B2C）机会。收集竞争对手及其他同类组织的实践洞察，结合客户与合作伙伴的需求、目标及期望，研判潜在未来影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.4" ;
    skos:prefLabel "Evaluate B2C options"@en,
        "评估B2C选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating partnership and alliance opportunities to deliver products/services. Understand existing product and market models in use across the markets you serve, evolving trends, and the cost/benefit of potential new/updated partnership/alliance options."@en,
        "评估通过合作伙伴关系与联盟交付产品/服务的机会。理解所服务市场的现有产品与市场模式、演进趋势，以及潜在新/更新型伙伴关系或联盟选项的成本效益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.5" ;
    skos:prefLabel "Evaluate partner/alliance options"@en,
        "评估合作伙伴/联盟选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.6" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating intellectual property acquisition options available to scale, modernize, and/or extend product/service reach. Understand the cost, risk, timing and lifecycle value of candidate acquisitions."@en,
        "评估知识产权收购选项，以实现产品/服务规模化、现代化或延展覆盖范围。厘清候选收购标的的成本、风险、时间周期及全生命周期价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.6" ;
    skos:prefLabel "Evaluate IP acquisition options"@en,
        "评估知识产权（IP）获取选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.7" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating innovation options to advance technology, products/services, and/or operational performance."@en,
        "评估技术创新选项，以推动技术、产品/服务及/或运营绩效升级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.7" ;
    skos:prefLabel "Evaluate innovation options"@en,
        "评估创新选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.8" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating sustainability requirements, stakeholder expectations, and value proposition for options. Understand the potential activities and changes across environmental, social, and governance, the effort required, cost to implement, and benefits gained. The analysis should consider sustainable product/service lifecycles, operations, infrastructure, performance, and workforce."@en,
        "评估可持续发展要求、利益相关方期望及各选项的价值主张。全面分析环境、社会与治理（ESG）维度的潜在行动与变革，评估实施所需投入、成本及预期收益；分析应覆盖可持续的产品/服务生命周期、运营、基础设施、绩效及人才体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.8" ;
    skos:prefLabel "Evaluate sustainability options"@en,
        "评估可持续发展选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.2.9" ;
    skos:broader <https://oprocess.net/opf/node/1.2.2> ;
    skos:definition "Evaluating options for global support services and functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and customer value."@en,
        "评估全球支持服务与职能的优化选项，涵盖组织架构、规模弹性、变革适应力及替代交付模式，以平衡成本、绩效与客户价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.2.9" ;
    skos:prefLabel "Evaluate global support options"@en,
        "评估全球支持选项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Defining direction and plan objectives for external relationships and partnering with other companies to deliver product/services. Focus on creating a vision and strategic objectives and culminate in creating measures for the strategic alliance or partnership."@en,
        "明确外部合作关系与跨企协同的战略方向与目标，聚焦产品/服务交付。以构建愿景与战略目标为起点，最终形成战略联盟或伙伴关系的衡量指标体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.1" ;
    skos:prefLabel "Develop partner/alliance strategy"@en,
        "制定合作伙伴/联盟战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Formulating strategic options that create opportunities for the sustenance and prosperity of the business in the long run. Go beyond business longevity to consider alternate strategies that allow the organizations preservation of vitality over time. Earmark resources and target processes, the former of which are dedicated to the absorption of sustainable practices in the latter."@en,
        "制定保障企业长期存续与繁荣的战略选项。超越单纯延续性，探索维持组织持久活力的替代路径；统筹配置资源并锁定重点流程，将可持续实践深度融入流程能力建设。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.2" ;
    skos:prefLabel "Develop sustainability strategy"@en,
        "制定可持续发展战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Defining a strategy for corporate development. Include providing a framework for evaluating merger and acquisition candidates; and planning for a value creation through merging/demerging with a company, acquiring a company, or exiting from an already merged/acquired company."@en,
        "制定企业发展战略，包括构建并购候选对象评估框架；规划通过合并、分拆、收购或退出已合并/已收购企业等方式实现价值创造。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.3" ;
    skos:prefLabel "Develop merger/demerger/acquisition/exit strategy"@en,
        "制定合并/分拆/收购/退出战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Developing a plan and vision to encourage advancements in technology or product/services. Create a roadmap for changing or innovating the business model to make business operations more competitive. Set up new R&D services for changing or bringing new value propositions, services, production processes, and invention of technology not previously used by competitors etc."@en,
        "制定技术或产品与服务创新的发展规划与愿景；设计业务模式变革或创新路线图，以提升运营竞争力；设立新的研发（R&D）服务，推动新价值主张、新服务、新生产工艺及竞争对手尚未采用的前沿技术发明。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.4" ;
    skos:prefLabel "Develop innovation strategy"@en,
        "制定创新战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Developing a plan to deploy support services and support functions throughout the organization globally. Arrange the organizations functional support areas to create efficiencies of scale in the delivery of support services, globally."@en,
        "制定全球范围内部署支持服务与支持职能的规划；统筹组织各职能支持领域，实现支持服务交付的全球规模效应。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.5" ;
    skos:prefLabel "Develop global support strategy"@en,
        "制定全球支持战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.6" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Charting a plan to leverage internal services and support functions throughout the organization. Delineate a framework of parameters and criteria to selectively filter service areas for inclusion among the organizations common resources. Arrange the organizations functional areas to create efficiencies of scale in the delivery of internal services."@en,
        "规划全组织范围内对内部服务与支持职能的协同利用；明确参数与筛选标准框架，择优将服务领域纳入组织共用资源池；整合各职能领域，实现内部服务交付的规模效益。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.6" ;
    skos:prefLabel "Develop shared services strategy"@en,
        "制定共享服务战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.3.7" ;
    skos:broader <https://oprocess.net/opf/node/1.2.3> ;
    skos:definition "Developing strategies for the optimization of processes and the improvement of functional areas in order to improve the bottom line. Create a road map of decision choices that would allow the organization to continuously enhance process efficiencies and advance performance standards."@en,
        "制定流程优化与职能领域改进策略，以提升盈利水平；绘制决策路径图，支撑组织持续提升流程效率、进阶绩效标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.3.7" ;
    skos:prefLabel "Develop Lean/continuous improvement strategy"@en,
        "制定精益管理/持续改进战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Aligning the approach and method of individual units, departments, systems, and operations within the organization, in accordance with the larger strategic course adopted. Employ the organization's strategic path to guide the functions, divisions, and operations. Calibrate the plan and method of each functional area, as well as the processes therein, to Select the long-term business strategy [10039]."@en,
        "统一组织内各单元、部门、系统及运营活动的方法与路径，使其契合整体战略方向；以组织战略路径为指引，统筹各职能、事业部及运营活动；校准各职能领域及其内部流程的方法与规划，对接长期业务战略［10039］。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.4" ;
    skos:prefLabel "Coordinate and align cross-functional and process strategies"@en,
        "统筹并协同跨职能及跨流程战略"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Evaluating the structural makeup of the organization, including pertinent features of and associated synergies among constituent elements. Examine the organization's architectural framework, paying close attention to the individual elements, the relations among them, and the conjoint and co-acting forces therein. Analyze functions and processes, as well as work-related positions. Scrutinize various relevant characteristics associated with each of them, depending upon the scale, scope, and type of organization."@en,
        "评估组织结构构成，包括各组成部分的关键特征及其协同效应；审视组织架构体系，重点关注各构成要素、要素间关系，以及共同作用与协同机制；分析职能、流程及岗位设置；依据组织规模、范围与类型，深入考察各项相关特征。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.1" ;
    skos:prefLabel "Evaluate breadth and depth of organizational structure"@en,
        "评估组织结构的广度与深度"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Appraising job-specific roles within the organizational chart and their hierarchical architecture. Analyze a map of work-related roles within the organizational structure. Examine the value added by the positions associated with jobs to be performed and how they stack up within the organization's operations."@en,
        "评估组织架构中岗位角色及其层级关系；分析组织结构内的岗位角色分布图；考察岗位所承载的工作职责对组织运营的价值贡献及其在组织中的定位。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.2" ;
    skos:prefLabel "Perform job-specific roles mapping and value-added analyses"@en,
        "开展岗位角色映射与增值分析"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Examining the constituent exercises and undertakings within a work-related position for the purpose of effective delegation. Deconstruct job-specific roles into activities and visualize the relations among them, with the objective of assigning responsibilities to the appropriate personnel."@en,
        "梳理岗位职责所涵盖的具体工作事项与任务，以支撑有效授权；将岗位职责逐层分解为具体活动，并可视化其相互关联，从而精准匹配人员责任。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.3" ;
    skos:prefLabel "Develop role activity diagrams to assess hand-off activity"@en,
        "绘制岗位活动图以评估交接环节"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Organizing workshop sessions to adopt organizational redesign. Communicate the organizational structure and mapping of responsibilities against job roles in order to facilitate an effective understanding among personnel. Use a collaborative process that may include participative workshop sessions."@en,
        "组织工作坊，推动组织重构落地；清晰传达组织架构及岗位—职责映射关系，促进员工准确理解；采用协作式方法，包括参与式工作坊等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.4" ;
    skos:prefLabel "Perform organization redesign workshops"@en,
        "组织架构重组工作坊"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Fleshing out the connections and dependencies among the various units of the organization. Delineate the relationship among business units or process frameworks within the organization, in terms of activities, synergies, and shared resources and responsibilities. Formalize relationships among business units so that any mutual coherence is clearly understood and can be attended to."@en,
        "厘清组织各单元间的联系与依赖关系；界定业务单元或流程框架之间在活动、协同效应、共享资源与共担责任等方面的关联；正式化业务单元间关系，确保协同一致性清晰可识别、可管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.5" ;
    skos:prefLabel "Design the relationships between organizational units"@en,
        "设计组织单元间的协作关系"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.6" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Creating an understanding of the fit between job roles and organizational processes in order to properly place personnel. Deconstruct key processes into constituent activities, and examine job-related roles. Take cues from Develop role activity diagrams to assess hand-off activity [10051]. Map appropriate positions against these important processes, which in turn expedite the deployment of staff members."@en,
        "建立岗位角色与组织流程的适配认知，实现人岗精准匹配；将关键流程逐层拆解为具体活动，结合岗位职责开展分析；参考“开发角色—活动图以评估交接活动［10051］”，将关键岗位映射至核心流程，加速人员部署。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.6" ;
    skos:prefLabel "Develop role analysis and activity diagrams for key processes"@en,
        "为关键流程开展岗位分析与活动图设计"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.7" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Probing the repercussions of all practicable organizational design options. Analyze the significance and impact of workable organizational structure options. Closely examine the long-term impact of these frameworks over the functioning of the organization."@en,
        "全面评估所有可行组织设计方案的影响；分析各类可行组织结构方案的意义与影响；重点研判这些框架对组织长期运行效能的深远影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.7" ;
    skos:prefLabel "Assess organizational implication of feasible alternatives"@en,
        "评估可行备选方案对组织的影响"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.5.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.5.8" ;
    skos:broader <https://oprocess.net/opf/node/1.2.5> ;
    skos:definition "Embracing and ratifying a new organizational structure. (Assume the new framework to be the best fit through Assess the organizational implications of feasible alternatives [10055].)"@en,
        "采纳并正式批准新组织架构。（基于“评估可行替代方案的组织影响［10055］”认定该框架为最优适配方案。）"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.5.8" ;
    skos:prefLabel "Migrate to new organization"@en,
        "实施组织架构迁移"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.6.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.6> ;
    skos:definition "Creating and developing strategic objectives that establishes a process to outline expected outcomes and guide employees' efforts."@en,
        "制定并完善战略目标，建立预期成果界定机制，引导员工行动方向。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.6.1" ;
    skos:prefLabel "Identify organizational objectives"@en,
        "识别组织目标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.6.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.6> ;
    skos:definition "Establishing baselines that provide standards for assessing performance. Create metrics and KPI's for various functions/processes/activities based on organizational goals."@en,
        "确立绩效评估基准，为各职能、流程及活动设定衡量标准；依据组织目标，构建相应指标与KPI。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.6.2" ;
    skos:prefLabel "Establish baseline metrics"@en,
        "建立基准度量指标"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.6.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.6> ;
    skos:definition "Defining methodology and frequency of assessment for measuring and monitoring performance of various functions/processes/activities against standard set goals."@en,
        "明确绩效评估的方法与频次，用于衡量和监控各职能、流程及活动对既定目标的达成情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.6.3" ;
    skos:prefLabel "Monitor performance against objective"@en,
        "监控目标达成绩效"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.7.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.7> ;
    skos:definition "Assessing the performance of a business unit against set organizational goals which are based on pre-defined metrics collected through various business unit operations."@en,
        "依据预设指标（源自各业务单元运营数据），评估业务单元对组织目标的达成情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.7.1" ;
    skos:prefLabel "Analyze business unit strategies"@en,
        "分析业务单元战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.7.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.7> ;
    skos:definition "Determining the resources and skills of each business unit based on knowledge and technical capacity. Enable business units to meet customer needs and grow in a competitive marketplace."@en,
        "基于知识储备与技术能力，评估各业务单元的资源与技能水平；赋能业务单元更好满足客户需求，在竞争市场中持续成长。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.7.2" ;
    skos:prefLabel "Identify core competency for each business unit"@en,
        "识别各业务单元的核心能力"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.7.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.7> ;
    skos:definition "Evaluating existing business unit strategy based on the company's strategy and eliminate unwanted/unnecessary resources/elements and re-consider necessary resources to meet the overall company's strategy."@en,
        "依据公司整体战略，评估现有业务单元战略，剔除冗余/非必要资源与要素，重新审视并配置必要资源，确保全面支撑公司战略落地。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.7.3" ;
    skos:prefLabel "Refine business unit strategies in support of organizational strategy"@en,
        "优化业务单元战略以支撑整体组织战略"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.8.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.1> ;
    skos:definition "Creating methods to gauge customer experiences, expectations, and suggestions. Review both liked and disliked areas of product/services to be delivered. Evaluate touchpoints based on the nature of product/service in the market e.g., billboards, web sites, direct mail, service calls, etc."@en,
        "构建客户体验、期望与建议的评估方法；复盘产品/服务中客户喜爱与不满意的环节；结合产品/服务特性（如广告牌、网站、直邮、服务电话等），评估各触点表现。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.1.1" ;
    skos:prefLabel "Identify and review customer touchpoints"@en,
        "识别并评审客户触点"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.1> ;
    skos:definition "Evaluating customer experiences, expectations, and suggestions in both liked and disliked areas of the product or services. Analyze all modes of communication, human and physical interactions, or customers experience during the relationship lifecycle with your organization. Evaluate the gaps/further development/alterations to the existing product/service to attain better customer response."@en,
        "在客户喜爱与不满意的维度上，全面评估其体验、期望与建议；分析客户与组织全生命周期中的人机交互、物理接触及各类沟通渠道；识别现有产品/服务需弥补的差距、迭代方向或优化空间，以提升客户响应效果。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.1.2" ;
    skos:prefLabel "Assess customer experience across touchpoints"@en,
        "评估全触点客户体验"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.1> ;
    skos:definition "Analyzing the core reason for the customer experience/feedback/response about the product/service to take considerable action for better customer experience."@en,
        "深度剖析客户针对产品/服务的体验、反馈或响应的根本成因，据此采取切实举措，持续优化客户体验。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.1.3" ;
    skos:prefLabel "Perform root cause analysis of problematic customer experiences"@en,
        "针对问题客户体验开展根因分析"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Identifying a set of characteristics that define the demographic and behavioral patterns of the customer. Further, use persona scoring to design your marketing strategies around personas, and measure and optimize your interactions with the contacts classified by a certain persona."@en,
        "识别定义客户人口统计与行为特征的关键属性；进一步运用用户画像评分，围绕典型客户画像定制营销策略，并对归类于特定画像的客户触点进行效果度量与持续优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.1" ;
    skos:prefLabel "Define and manage personas"@en,
        "定义并管理用户画像"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Creating a story of the customer's experience: from initial contact, through the process of engagement and into a long-term relationship. The goal is to teach organization about the customer."@en,
        "构建客户旅程故事：覆盖初次接触、互动参与直至长期关系建立全过程；旨在帮助组织深入理解客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.2" ;
    skos:prefLabel "Create customer journey maps"@en,
        "绘制客户旅程地图"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.3" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Defining parameters to show aggregated, consistent, and holistic representation of known data about customers. Define key parameters which enable the tracking of customers and communications across every channel."@en,
        "定义关键参数，实现客户数据的聚合化、一致性与全景化呈现；明确支撑跨渠道客户追踪与沟通管理的核心参数。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.3" ;
    skos:prefLabel "Define single view of the customer for the organization"@en,
        "构建企业级统一客户视图"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Establishing a direction and vision on how the organization behaves towards customers in a consistent, effective way. The key attributes for customer experience vision consists of emotional connection, commitments and expectations, compelling value proposition, and ease of understanding the organization's behavior."@en,
        "确立组织面向客户的统一行为方向与体验愿景，确保一致、高效；客户体验愿景的核心要素包括情感连接、承诺与期望管理、有力的价值主张，以及组织行为的易理解性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.4" ;
    skos:prefLabel "Define a vision for the customer experience"@en,
        "确立客户体验愿景"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.5" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Creating a process to validate the sales process and the assumptions that underpin the business model. Understand if the products/services have a repeatable, scalable business model around that product."@en,
        "验证销售流程及业务模式底层假设；判断产品/服务是否具备可复制、可扩展的商业模式基础。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.5" ;
    skos:prefLabel "Validate with customers"@en,
        "开展客户验证"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.6" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Aligning and defining a relevant, differentiated, and credible value proposition for the brand. Align experience to ensure that the product and service quality is consistent with brand promise and business strategies."@en,
        "对齐并定义品牌相关、差异化且可信的价值主张；确保客户体验与品牌承诺、业务战略保持一致，保障产品与服务质量稳定可靠。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.6" ;
    skos:prefLabel "Align experience with brand values and business strategies"@en,
        "确保客户体验与品牌价值观及业务战略一致"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.2.7" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.2> ;
    skos:definition "Planning, development, and management of content-written or in other media. Getting the right content to the right user at the right time through strategic planning of content creation, delivery, and governance."@en,
        "开展内容（文字或其他媒介形式）的规划、开发与管理工作；通过内容创作、交付与治理的战略规划，实现“在正确时间、向正确用户、传递正确内容”。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.2.7" ;
    skos:prefLabel "Develop content strategy"@en,
        "制定内容策略"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.3> ;
    skos:definition "Determining the necessary skills and competencies required to efficiently collect customer experiences through the support structure."@en,
        "明确支撑结构所需具备的客户体验采集能力与胜任力要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.3.1" ;
    skos:prefLabel "Identify required capabilities"@en,
        "识别所需业务能力"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8.3> ;
    skos:definition "Identifying the affect of customer experience through customer experience support structure on other functions of customer services related to customer."@en,
        "识别客户体验支持结构对客户服务其他职能（面向客户）产生的影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.3.2" ;
    skos:prefLabel "Identify impact on functional processes"@en,
        "识别对职能流程的影响"@zh ;
    opf:domain "operating" ;
    opf:level 5 .

<https://oprocess.net/opf/node/1.2.8.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.8.4" ;
    skos:broader <https://oprocess.net/opf/node/1.2.8> ;
    skos:definition "Defining a standard guideline to create and execute the capacities of registering customer experiences in a timely manner. Create a common understanding of what behaviors are required to implement the strategy. Define what talent/skills your organization needs to reach customer experience goals."@en,
        "制定客户体验登记能力的标准化指南，确保及时登记；统一战略执行所需的行为规范；明确组织达成客户体验目标所需的人才与技能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.8.4" ;
    skos:prefLabel "Develop customer experience roadmap to develop and implement defined capabilities"@en,
        "制定客户体验路线图，推动能力开发与落地"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.2.9" ;
    skos:broader <https://oprocess.net/opf/node/1.2> ;
    skos:definition "Conveying planned procedures and methods to both internal departments and external stakeholders like customers, suppliers, etc., in an effective manner based on organizational objective."@en,
        "依据组织目标，以高效方式向内部部门及客户、供应商等外部利益相关方传达既定流程与方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.2.9" ;
    skos:prefLabel "Communicate strategies internally and externally"@en,
        "内外部战略沟通"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.3.1> ;
    skos:definition "Creating a statement of the organization's direction to guide decision making around the allocation of resources. Provide a focus on the organization's overarching goals to ensure coherent and considered action. Strategic objectives are ranked by their importance in achieving the strategic goals. All subsequent operational or tactical planning and resource allocation is based on strategic priorities"@en,
        "制定组织发展方向声明，指导资源配置决策；聚焦组织总体目标，确保行动连贯且审慎；按对达成战略目标的重要程度排序战略目标；后续所有运营或战术规划及资源分配均以战略优先级为依据。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.1.1" ;
    skos:prefLabel "Identify strategic priorities"@en,
        "识别战略优先事项"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.3.1> ;
    skos:definition "Creating a statement of the organization's direction based on what is considered \"value\" to the customer or business."@en,
        "基于客户或业务所认定的“价值”，制定组织发展方向声明。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.1.2" ;
    skos:prefLabel "Develop strategic initiatives based on business/customer value"@en,
        "基于业务价值与客户价值制定战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.3.1> ;
    skos:definition "Developing a process for stakeholder dialog that is integrated into the assessment of business strategies. Report on the evaluation of the business objectives, strategies, subject, or past events."@en,
        "建立嵌入业务战略评估全过程的利益相关方对话机制；就业务目标、战略、主题或过往事件的评估结果进行汇报。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.1.3" ;
    skos:prefLabel "Review with stakeholders"@en,
        "与相关方评审"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.3.2> ;
    skos:definition "Establishing a standard measure of value to determine the business worth for each of the Identify strategic priorities [19975]. List the effectiveness and utility for every important strategic element based on the benefit it adds to the business."@en,
        "建立统一价值衡量标准，用于评估每一项已识别战略优先事项[19975]的商业价值；基于各关键战略要素为业务带来的收益，分别评估其有效性与实用性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.2.1" ;
    skos:prefLabel "Determine business value for each strategic priority"@en,
        "确定各战略优先事项的业务价值"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.3.2> ;
    skos:definition "Analyzing the value preposition; the value the customer gets from a product/services for each of your Identify strategic priorities [19975]. Customer value is the satisfaction a consumer feels after making a purchase for goods or services relative to what he/she must give up to receive them."@en,
        "分析价值主张——即客户从产品/服务中获得的价值（对应每一项已识别战略优先事项[19975]）；客户价值指消费者在购买商品或服务后，所获满足感与其所付出成本之间的相对关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.2.2" ;
    skos:prefLabel "Determine the customer value for each strategic priority"@en,
        "确定各战略优先事项的客户价值"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/1.3.3> ;
    skos:definition "Listing the most effective procedures in the order of most important to the least. Create measures or filter for determining which of many \"strategic initiatives\" is most important to the least important."@en,
        "按重要性由高到低排序最有效的流程；建立衡量标准或筛选机制，对多项“战略举措”进行重要性分级。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.3.1" ;
    skos:prefLabel "Prioritize strategic initiatives"@en,
        "对战略举措进行优先级排序"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/1.3.3> ;
    skos:definition "Establishing procedures for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and stakeholders (internal and external)."@en,
        "建立组织内部沟通规程，为业务单元及内外部利益相关方理解战略举措提供清晰路径图。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.3.2" ;
    skos:prefLabel "Communicate strategic initiatives to business units and stakeholders"@en,
        "向业务单元及相关方传达战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.4.1" ;
    skos:broader <https://oprocess.net/opf/node/1.3.4> ;
    skos:definition "Determining key indicators or factors responsible for driving business value. Key business value drivers comprise of operational, financial, and sustainability drivers."@en,
        "识别驱动业务价值的关键指标或因素；核心业务价值驱动因素包括运营类、财务类及可持续性类驱动因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.4.1" ;
    skos:prefLabel "Identify business value drivers"@en,
        "识别业务价值驱动因素"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.4.2" ;
    skos:broader <https://oprocess.net/opf/node/1.3.4> ;
    skos:definition "Establishing baseline measures that provide standards for assessing performance of Identify business value drivers [19982]."@en,
        "建立基准值，作为评估“识别业务价值驱动因素”[19982]绩效的标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.4.2" ;
    skos:prefLabel "Establish baselines for business value drivers"@en,
        "为业务价值驱动因素设定基准线"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.4.3" ;
    skos:broader <https://oprocess.net/opf/node/1.3.4> ;
    skos:definition "Overseeing the progress of activities to ensure they are on-course and on-schedule in meeting the objectives and performance targets against Establish baselines for business value drivers [19983]."@en,
        "监控各项活动进展，确保其按既定目标与绩效指标推进，并对标“为业务价值驱动因素建立基准值”[19983]持续校准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.4.3" ;
    skos:prefLabel "Monitor performance against baselines"@en,
        "监控实际绩效与基准线的偏差"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Successfully implement strategic initiatives. Execution of strategy is also defined as the process of implementing logical set of connected activities by an organization to make a strategy work."@en,
        "高效落地战略举措；战略执行亦指组织为使战略生效而系统开展的一系列逻辑关联活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.5" ;
    skos:prefLabel "Execute strategic initiatives"@en,
        "执行战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.6" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Periodic review of initiatives based performance, conditions, and marketplace response."@en,
        "依据绩效表现、环境变化及市场反馈，定期复盘战略举措。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.6" ;
    skos:prefLabel "Review execution of strategic initiatives"@en,
        "评审战略举措执行情况"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.3.7" ;
    skos:broader <https://oprocess.net/opf/node/1.3> ;
    skos:definition "Performing required updates to strategic initiatives based upon changes in the marketplace or performance."@en,
        "根据市场变化或绩效结果，及时更新战略举措。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.3.7" ;
    skos:prefLabel "Refine strategic initiatives and project plans as needed"@en,
        "按需优化战略举措及项目计划"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/1.4.1> ;
    skos:definition "Collecting all relevant materials needed to develop the business model, so that it can adequately model its processes."@en,
        "全面收集构建业务模型所需的全部相关资料，确保模型能准确刻画组织业务流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.1.1" ;
    skos:prefLabel "Assemble business model information"@en,
        "汇总业务模型信息"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/1.4.1> ;
    skos:definition "Obtaining required permissions, licenses and authorizations that legitimize the business, help to mitigate associated risks and safeguard the operations."@en,
        "获取必要的许可、资质与授权，以合法化经营、降低关联风险并保障运营安全。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.1.2" ;
    skos:prefLabel "Secure appropriate approvals"@en,
        "获取必要审批"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.1.3" ;
    skos:broader <https://oprocess.net/opf/node/1.4.1> ;
    skos:definition "Ensuring coherence with pre-exsiting models to avoid contradictions between models. Make sure that all models represent the same long-term vision."@en,
        "确保与既有模型保持一致，避免模型间矛盾；所有模型须共同支撑同一长期愿景。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.1.3" ;
    skos:prefLabel "Identify integration points with existing models"@en,
        "识别与现有模型的集成点"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.1.4" ;
    skos:broader <https://oprocess.net/opf/node/1.4.1> ;
    skos:definition "Consenting to a particular business model and formally accepting it to serve as the set of guiding principles in operating the company."@en,
        "正式批准并采纳特定业务模型，将其确立为公司日常运营的指导原则体系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.1.4" ;
    skos:prefLabel "Adopt the business model"@en,
        "正式采纳业务模型"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.2.1" ;
    skos:broader <https://oprocess.net/opf/node/1.4.2> ;
    skos:definition "Determining the timeline, procedures and responsibilities for reviewing the business model and for updating it to best serve the organization."@en,
        "明确业务模型评审与更新的时间节点、操作规程及责任主体，确保模型持续适配组织需求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.2.1" ;
    skos:prefLabel "Establish business model maintenance parameters"@en,
        "设定业务模型维护参数"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.2.2" ;
    skos:broader <https://oprocess.net/opf/node/1.4.2> ;
    skos:definition "Deciding the type of responses, reactions, sentiments and insights that are crucial to be taken into consideration with business model maintenance."@en,
        "界定业务模型维护过程中需重点关注的反馈类型，包括响应、反应、情绪倾向及深层洞察。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.2.2" ;
    skos:prefLabel "Accept business model feedback parameters"@en,
        "明确业务模型反馈接收机制"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.2.3" ;
    skos:broader <https://oprocess.net/opf/node/1.4.2> ;
    skos:definition "Evaluating the feedback regarding products, services, processes or resources. Determine which judgments are critical and mandate changes to the current business model to better deliver the desired value"@en,
        "评估关于产品、服务、流程或资源的反馈；识别关键判断结论，据此决定是否必须调整现行业务模型，以更有效地交付预期价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.2.3" ;
    skos:prefLabel "Prioritize and manage incoming feedback"@en,
        "对输入反馈进行优先级排序与管理"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.2.4" ;
    skos:broader <https://oprocess.net/opf/node/1.4.2> ;
    skos:definition "Modifying the business models that are presently in use in response to incoming feedback or changing markets to achieve the enterprise business goals."@en,
        "依据新反馈或市场变化，及时调整现行业务模型，以支撑企业整体业务目标的达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.2.4" ;
    skos:prefLabel "Update existing models"@en,
        "更新现有业务模型"@zh ;
    opf:domain "operating" ;
    opf:level 4 .

<https://oprocess.net/opf/node/1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/1.4> ;
    skos:definition "Creating and implementing a strategy, responsibilities and control mechanisms for managing business models that are timely, efficient and cost-effective."@en,
        "构建并实施一套及时、高效、低成本的业务模型管理策略、职责体系与管控机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.4.3" ;
    skos:prefLabel "Establish business model governance"@en,
        "建立业务模型治理机制"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Strategy Management" ;
    skos:broader <https://oprocess.net/opf/node/1.5> ;
    skos:definition "Activity within ITIL practice 'Strategy Management'."@en,
        "ITIL“战略管理”实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.5.1" ;
    skos:prefLabel "Define IT strategy alignment"@en,
        "定义IT战略对齐机制"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Strategy Management" ;
    skos:broader <https://oprocess.net/opf/node/1.5> ;
    skos:definition "Activity within ITIL practice 'Strategy Management'."@en,
        "ITIL“战略管理”实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.5.2" ;
    skos:prefLabel "Assess strategic options"@en,
        "评估战略备选方案"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/1.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Strategy Management" ;
    skos:broader <https://oprocess.net/opf/node/1.5> ;
    skos:definition "Activity within ITIL practice 'Strategy Management'."@en,
        "ITIL“战略管理”实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "1.5.3" ;
    skos:prefLabel "Execute strategic initiatives"@en,
        "执行战略举措"@zh ;
    opf:domain "operating" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/10.1.1> ;
    skos:definition "Creating alignment between the requirement of properties and the overall business strategy. This process requires the organization to align the requirement of properties in accordance with its business strategies of the organization."@en,
        "实现物业需求与整体业务战略的协同；确保物业配置规划与组织业务战略保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.1.1" ;
    skos:prefLabel "Confirm alignment of property requirements with business strategy"@en,
        "确认不动产需求与业务战略的一致性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/10.1.1> ;
    skos:definition "Evaluating the impact of the external environment. Evaluate the circumstances, objects, events, and aspects surrounding an organization that affects its actions and selections and that recognizes its opportunities and risks."@en,
        "评估外部环境影响；研判组织所处环境中影响其决策与行动的各类因素（包括形势、对象、事件及要素），识别发展机遇与风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.1.2" ;
    skos:prefLabel "Appraise the external environment"@en,
        "评估外部环境"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/10.1.1> ;
    skos:definition "Deciding whether to buy or build properties. Study the market forces about property prices and cost of construction in order to take decisions based on the market research."@en,
        "决策自建或购置物业；基于房地产市场价格与建造成本等市场调研结果作出决策。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.1.3" ;
    skos:prefLabel "Determine build, buy, or lease decision"@en,
        "决策自建、购置或租赁方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/10.1.2> ;
    skos:definition "Preparing and analyzing different designs for a facility in order to finalize which design will be the most suitable option."@en,
        "编制并比选多种设施设计方案，最终确定最优方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2.1" ;
    skos:prefLabel "Design facility"@en,
        "设计设施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/10.1.2> ;
    skos:definition "Evaluating the feasibility of budgets prepared for the construction of facilities."@en,
        "评估设施建设项目预算的可行性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2.2" ;
    skos:prefLabel "Analyze budget"@en,
        "分析预算"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/10.1.2> ;
    skos:definition "Assessing and choosing the appropriate property. Analyze the property requirements. Review the available property options. Finalize the most suitable option."@en,
        "评估并选定适配物业；分析物业需求，梳理可选资源，择优确定最终方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2.3" ;
    skos:prefLabel "Select property"@en,
        "遴选不动产"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/10.1.2> ;
    skos:definition "Discussing the terms and conditions of facilities to be occupied according to the business requirements and availability of budgets."@en,
        "依据业务需求及预算可用性，协商拟入驻设施的条款与条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2.4" ;
    skos:prefLabel "Negotiate terms for facility"@en,
        "协商设施条款"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/10.1.2> ;
    skos:definition "Constructing the buildings. Manage renovations according to requirements and demands."@en,
        "组织实施建筑施工及按需开展的装修改造。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.2.5" ;
    skos:prefLabel "Manage construction or modification to building"@en,
        "管理建筑施工或改造工程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/10.1.3> ;
    skos:definition "Attaining the office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements."@en,
        "按需落实配备齐全（含桌椅、计算机、行政人员等）的办公空间。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.3.1" ;
    skos:prefLabel "Acquire workspace and facilities"@en,
        "获取办公场所与配套设施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/10.1.3> ;
    skos:definition "Modifying the formation of the workspace and its assets. Make necessary changes in an office space with all assets (tables, chairs, computers, admin staff, interior designing, etc.) according to requirements."@en,
        "调整办公场所及其资产的布局配置。根据业务需求，对办公空间内的全部资产（如桌椅、计算机、行政人员、室内设计等）进行必要变更。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.3.2" ;
    skos:prefLabel "Change fit/form/function of workspace and facilities"@en,
        "调整工作场所与设施的形态、功能与适配性"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.4.1" ;
    skos:broader <https://oprocess.net/opf/node/10.1.4> ;
    skos:definition "Shifting staff or employees from one place to another place according to changes in business requirements."@en,
        "依据业务需求变化，实施员工跨地点调配。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.4.1" ;
    skos:prefLabel "Relocate people"@en,
        "人员搬迁"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.4.2" ;
    skos:broader <https://oprocess.net/opf/node/10.1.4> ;
    skos:definition "Relocating the tools and raw materials. Shift raw or finished material and machines of company from one place to another place according to changes in business requirements."@en,
        "实施工具与原材料的搬迁。依据业务需求变化，将公司原材料、产成品及设备在不同地点间转移。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.4.2" ;
    skos:prefLabel "Relocate material and tools"@en,
        "物资与工具搬迁"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.1.4.3" ;
    skos:broader <https://oprocess.net/opf/node/10.1.4> ;
    skos:definition "Ensuring safe, controlled access to organizational facilities by implementing and maintaining physical security protocols, systems, and procedures. This includes issuing and managing access credentials; monitoring entry points; coordinating visitor access; and operating security technologies such as surveillance, alarms, and access-control systems. Establish and enforce policies to protect employees, visitors, assets, and information; respond to security incidents or breaches; and routinely assess the effectiveness of security measures."@en,
        "通过建立并持续维护物理安全制度、系统与流程，确保组织设施的安全、受控访问。包括：门禁凭证的发放与管理；出入口监控；访客通行协调；以及视频监控、报警系统、门禁控制系统等安防技术的运行。制定并执行保护员工、访客、资产及信息的安全政策；响应安全事件或违规行为；定期评估安全措施有效性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.4.3" ;
    skos:prefLabel "Provide facility access and security"@en,
        "提供设施出入权限与安全保障"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/10.1> ;
    skos:definition "AI-era activity: AI-Powered Predictive Maintenance."@en,
        "AI时代活动：AI驱动的预测性维护（Predictive Maintenance）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.1.5" ;
    skos:prefLabel "AI-Powered Predictive Maintenance"@en,
        "AI驱动的预测性维护"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/10.2.1> ;
    skos:definition "Establishing what funds will be invested in the construction of assets for the advancement of established business objectives."@en,
        "明确为实现既定业务目标而投入资产建设的资金规模。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.1.1" ;
    skos:prefLabel "Define capital investment plan"@en,
        "制定资本投资计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/10.2.1> ;
    skos:definition "Monitoring plans on capital projects. Capital projects can be purchasing buildings, lands, etc."@en,
        "监控资本性项目计划执行情况。资本性项目包括购置楼宇、土地等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.1.2" ;
    skos:prefLabel "Monitor capital program"@en,
        "监控资本项目执行"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/10.2.1> ;
    skos:definition "Acquiring the loans needed to construct necessary assets."@en,
        "筹措资产建设所需的贷款资金。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.1.3" ;
    skos:prefLabel "Secure construction financing"@en,
        "筹措工程建设融资"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/10.2.2> ;
    skos:definition "Developing a strategy to perform asset construction. Assure that timelines, regulations, and resources are on task and on budget."@en,
        "制定资产建造实施策略，确保工期、法规遵从性及资源配置均符合进度与预算要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2.1" ;
    skos:prefLabel "Develop construction strategy"@en,
        "制定工程建设策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/10.2.2> ;
    skos:definition "Managing the construction process to ensure that activates are on task, on budget, and are being performed with safety and quality in mind."@en,
        "全过程管控建设实施，确保作业按期、按预算推进，并兼顾安全与质量。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2.2" ;
    skos:prefLabel "Perform construction performance management"@en,
        "实施工程建设绩效管理"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/10.2.2> ;
    skos:definition "Gathering the required permits for construction from the proper jurisdiction. This may include inspections during and after construction to verify that the new asset meets all national, regional, and local codes."@en,
        "向属地主管部门申领建设所需全部许可。包括建设期间及竣工后的各类检查，以验证新建资产符合国家、区域及地方各项规范标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2.3" ;
    skos:prefLabel "Obtain construction permissions"@en,
        "获取工程建设许可"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/10.2.2> ;
    skos:definition "Designing assets to meet organizational needs as well as ensuring that the asset adheres to all national, regional, and local construction codes."@en,
        "开展资产设计，满足组织功能需求，并确保完全符合国家、区域及地方各项建设规范。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2.4" ;
    skos:prefLabel "Design assets"@en,
        "资产设计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/10.2.2> ;
    skos:definition "Determining what resources will need to be acquired in order to carry out construction. Plan when, where, and how resources will be used. Determine the length of time resources will be utilized."@en,
        "识别建设所需各类资源，规划其使用时间、地点与方式，并明确资源使用周期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.2.5" ;
    skos:prefLabel "Plan construction resources"@en,
        "规划工程建设资源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/10.2.3> ;
    skos:definition "Defining a timetable for which to execute the construction of the asset."@en,
        "明确资产建设任务的具体执行时间表。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.1" ;
    skos:prefLabel "Schedule construction work"@en,
        "安排工程建设作业计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/10.2.3> ;
    skos:definition "Gathering resources needed to complete all construction work. Verify that all resources have the proper training and skills to perform the work."@en,
        "整合完成全部建设工作所需资源，并确认相关人员具备相应资质与技能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.2" ;
    skos:prefLabel "Obtain resources"@en,
        "获取工程建设所需资源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/10.2.3> ;
    skos:definition "Building new assets necessary for the organization. Be aware of any construction codes and permits that need to be addressed."@en,
        "新建组织必需的资产，同步关注需履行的建设规范与许可要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.3" ;
    skos:prefLabel "Construct new assets"@en,
        "新建资产"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/10.2.3> ;
    skos:definition "Modifying existing assets to align with the changing needs of the organization. Be aware of any construction codes and permits that need to be addressed."@en,
        "改造现有资产以适配组织发展新需求，同步关注需履行的建设规范与许可要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.4" ;
    skos:prefLabel "Augment existing assets"@en,
        "扩充现有资产"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.3.5" ;
    skos:broader <https://oprocess.net/opf/node/10.2.3> ;
    skos:definition "Determining the need to replace existing assets. Be aware of any construction codes and permits that need to be addressed."@en,
        "评估现有资产更换必要性，并同步关注需履行的建设规范与许可要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.3.5" ;
    skos:prefLabel "Renew/Replace assets"@en,
        "更新或替换资产"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/10.2.4> ;
    skos:definition "Monitoring construction to insure that all regulatory laws are being adhered to, that all work is being performed in a timely manner, and that quality assurance is met at all steps of the construction process."@en,
        "全过程监控建设实施，确保各项法规得到贯彻、作业按期推进、各阶段质量达标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.1" ;
    skos:prefLabel "Monitor work performance"@en,
        "监控工程建设绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/10.2.4> ;
    skos:definition "Implementing a checks and balances system to verify that the construction was performed correctly. Rework when errors are found."@en,
        "建立复核机制，验证建设成果是否符合要求；发现问题及时返工整改。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.2" ;
    skos:prefLabel "Undertake construction quality control"@en,
        "开展工程建设质量控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4.3" ;
    skos:broader <https://oprocess.net/opf/node/10.2.4> ;
    skos:definition "Implementing records to include all construction work that has been performed. Include all new or modified construction, and any construction or regulatory issues that might have occurred."@en,
        "建立完整建设档案，涵盖全部新建或改造工程内容，以及过程中出现的任何工程或合规问题。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.3" ;
    skos:prefLabel "Create work and asset records"@en,
        "建立作业与资产记录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4.4" ;
    skos:broader <https://oprocess.net/opf/node/10.2.4> ;
    skos:definition "Ensuring that safety, security, and access is maintained. Provide a workplace that meets and exceeds all local, state, and federal guidelines. Provide security and access to the building site as set forth by safety and organizational guidelines."@en,
        "持续保障现场安全、安保与访问可控性；提供符合并优于国家、省、市各级安全规范的工作环境；按组织安全准则与现场管理要求，落实工地安保与出入管控。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.4" ;
    skos:prefLabel "Manage safety, security, and access to sites"@en,
        "管理施工现场的安全、安保与出入管控"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.2.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.2.4.5" ;
    skos:broader <https://oprocess.net/opf/node/10.2.4> ;
    skos:definition "Scheduling and performing commissioning activities to verify that constructed assets operate as intended, meet specified requirements, and are ready for handover, use, or operational acceptance."@en,
        "统筹安排并执行系统联调与试运行（Commissioning），验证建成资产功能符合设计意图、满足技术规格要求，并具备移交、启用或正式验收条件。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.2.4.5" ;
    skos:prefLabel "Schedule and perform commissioning"@en,
        "安排并执行资产投运（Commissioning）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.1" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Creating goals and agendas to better realize the success of the maintenance policies that have been put into place."@en,
        "设定阶段性目标与工作重点，推动既定资产维护政策有效落地并持续优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.1" ;
    skos:prefLabel "Develop maintenance strategies"@en,
        "制定维护策略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.2" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Evaluating assets in order to project future requirements for maintenance. Evaluate the present working condition of assets. Determine the future maintenance requirements of assets."@en,
        "开展资产状态评估，预判未来维护需求；分析资产当前运行状况，明确中长期维护计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.2" ;
    skos:prefLabel "Analyze assets and predict maintenance requirements"@en,
        "分析资产状态并预测维护需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.3" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Communicating policies in regards to asset maintenance. Provide a clear set of procedures and policies that outline what will be involved in the maintenance process."@en,
        "宣贯资产维护相关政策，提供清晰、可操作的维护流程与管理规范。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.3" ;
    skos:prefLabel "Specify maintenance policies"@en,
        "明确维护政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.4" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Devising a methodology and procedure for assimilating the works of planned maintenance into the schedule scheme for the processing of finished products that utilizes the same machinery."@en,
        "制定计划性维护作业与产线生产排程的协同机制，确保共用设备的维护窗口与产品交付节奏相匹配。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.4" ;
    skos:prefLabel "Integrate preventive maintenance into operations schedule"@en,
        "将预防性维护纳入运营排程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.5" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Identifying the steps needed for asset maintenance. List out the those tasks that are involved in completing this process. Prioritize the tasks that are created."@en,
        "梳理资产维护全流程关键步骤，形成标准化任务清单，并依风险、影响与紧急程度进行优先级排序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.5" ;
    skos:prefLabel "Identify work management tasks & priorities"@en,
        "识别维修作业任务及优先级"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.6" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Analyzing workload needs in relation to asset maintenance and plan resources around those needs."@en,
        "分析资产维护工作量需求，据此统筹配置人力资源、备件库存及技术支持等要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.6" ;
    skos:prefLabel "Conduct resource planning"@en,
        "开展资源规划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.1.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.1.7" ;
    skos:broader <https://oprocess.net/opf/node/10.3.1> ;
    skos:definition "Creating procedures on how to maintain assets."@en,
        "制定资产日常维护、定期保养及应急维修等标准化作业规程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.1.7" ;
    skos:prefLabel "Create asset work plans"@en,
        "制定资产维修作业计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.1" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Defining a timetable for which to execute the maintenance of the asset."@en,
        "明确资产维护作业的具体执行时间表。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.1" ;
    skos:prefLabel "Schedule maintenance work"@en,
        "安排维护作业计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.2" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Gathering resources needed to complete all maintenance work. Verify that all resources have the proper training and skills to perform the work."@en,
        "统筹完成所有维护工作所需的资源，并验证相关人员是否具备相应培训与技能。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.2" ;
    skos:prefLabel "Obtain required resources"@en,
        "获取所需资源"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.3" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Implementing a checks and balances system to verify that the maintenance was performed correctly. Rework when errors are found."@en,
        "建立核查与制衡机制，确保维护工作执行正确；发现问题时及时返工。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.3" ;
    skos:prefLabel "Undertake quality control"@en,
        "实施质量控制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.4" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Modifying existing maintenance records to include all new work that has been performed, what assets were serviced, and any issues that might have arisen."@en,
        "更新现有维护记录，完整纳入新开展的维护作业、所涉资产及过程中发现的任何问题。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.4" ;
    skos:prefLabel "Update work and asset records"@en,
        "更新工作与资产记录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.5" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Assuring that all safety laws and regulations are being implemented and followed. Align practices with regulatory bureaus such as OSHA , EHS, and ISO."@en,
        "确保全面贯彻并遵守各项安全法律法规，实践与职业安全与健康管理局（OSHA）、环境健康与安全部（EHS）、国际标准化组织（ISO）等监管机构要求保持一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.5" ;
    skos:prefLabel "Manage maintenance work safety"@en,
        "管理维修作业安全"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.6" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Outlining what should be achieved through predictive indicators with regard to performing maintenance. This could include the length of time it takes to perform routine maintenance or how often unplanned maintenance feasibly occur."@en,
        "明确预测性指标应达成的维护目标，例如例行维护平均耗时、非计划维护发生频次等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.6" ;
    skos:prefLabel "Define maintenance performance targets"@en,
        "设定维修绩效目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.2.7" ;
    skos:broader <https://oprocess.net/opf/node/10.3.2> ;
    skos:definition "Following set performance targets, monitor and gage the success of the organization in meeting those targets."@en,
        "依据既定绩效目标开展监测与评估，衡量组织目标达成成效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.2.7" ;
    skos:prefLabel "Monitor maintenance performance against targets/contracts"@en,
        "监控维修绩效（对标目标/合同）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/10.3.3> ;
    skos:definition "Performing prophylactic maintenance in an effort to avoid corrective or unplanned repairs."@en,
        "开展预防性维护，以避免纠正性或非计划性维修。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3.1" ;
    skos:prefLabel "Perform preventative asset maintenance"@en,
        "开展预防性资产维修"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3.2" ;
    skos:broader <https://oprocess.net/opf/node/10.3.3> ;
    skos:definition "Carrying out required maintenance to continue upkeep of equipment or assets."@en,
        "执行必要维护，持续保障设备或资产良好状态。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3.2" ;
    skos:prefLabel "Perform routine asset maintenance"@en,
        "开展例行性资产维修"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3.3" ;
    skos:broader <https://oprocess.net/opf/node/10.3.3> ;
    skos:definition "Repairing or correcting faults that occur with an asset. This could be a break or other repairable damage."@en,
        "修复资产故障，包括破损或其他可修复性损伤。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3.3" ;
    skos:prefLabel "Perform corrective asset maintenance and repairs"@en,
        "开展纠正性资产维修与修复"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3.4" ;
    skos:broader <https://oprocess.net/opf/node/10.3.3> ;
    skos:definition "Realizing potential or current problems with assets that would require unplanned maintenance. Unplanned maintenance is a repair or change that needs to be made that is not preventative or routine."@en,
        "识别资产当前或潜在问题，触发非计划性维护；此类维护不属于预防性或例行性范畴。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3.4" ;
    skos:prefLabel "Identify unplanned maintenance requirements"@en,
        "识别非计划维修需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.3.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.3.3.5" ;
    skos:broader <https://oprocess.net/opf/node/10.3.3> ;
    skos:definition "Performing repairs that occur outside of normal routine or preventative maintenance."@en,
        "执行超出常规例行或预防性维护范围的维修作业。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.3.3.5" ;
    skos:prefLabel "Perform unplanned maintenance and repairs"@en,
        "开展非计划维修与修复"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.1.1" ;
    skos:broader <https://oprocess.net/opf/node/10.4.1> ;
    skos:definition "Monitoring assets against their planned useful life. Each asset may have specific criteria that indicate their usability. This may include time-based, maintenance history, capacity planning, etc."@en,
        "对照资产规划使用寿命开展动态监控；各资产可设定特定可用性判定标准，如使用年限、维护历史、容量规划等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.1.1" ;
    skos:prefLabel "Monitor useful life of assets"@en,
        "监控资产使用寿命"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.1.2" ;
    skos:broader <https://oprocess.net/opf/node/10.4.1> ;
    skos:definition "Cost/benefit analysis of assets to determine retention or end-of-life. Evaluating asset total lifecycle cost against other factors such as repair/refurbishment, replacement, and alternate solutions."@en,
        "开展资产成本效益分析，综合评估保留或退役决策；比对资产全生命周期成本与维修/翻新、更换及替代方案等因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.1.2" ;
    skos:prefLabel "Perform cost vs. benefit analysis for replacement"@en,
        "开展更换成本效益分析"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.10.1" ;
    skos:broader <https://oprocess.net/opf/node/10.4.10> ;
    skos:definition "Demolishing and securing asset and resulting parts/debris."@en,
        "拆除并妥善管控资产本体及其产生的部件/残骸。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.10.1" ;
    skos:prefLabel "Demolish and secure"@en,
        "拆除并封存"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.10.2" ;
    skos:broader <https://oprocess.net/opf/node/10.4.10> ;
    skos:definition "Performing remediation or restoration activities."@en,
        "开展整改或生态修复活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.10.2" ;
    skos:prefLabel "Restore site"@en,
        "恢复场地"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.10.3" ;
    skos:broader <https://oprocess.net/opf/node/10.4.10> ;
    skos:definition "Managing and reporting site status. Align efforts to all legal, regulatory and social/environmental responsibilities."@en,
        "管理并报告场地现状，确保各项工作符合法律、法规及社会责任与生态环境要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.10.3" ;
    skos:prefLabel "Monitor site for duration of time required by regulators"@en,
        "按监管要求时限持续监测场地"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.10.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.10.4" ;
    skos:broader <https://oprocess.net/opf/node/10.4.10> ;
    skos:definition "Supporting handover to new operator or landowner. Include proper documentation on asset history and current state to enable orderly transition."@en,
        "支持移交至新运营方或土地所有权人，提供完整资产历史与现状文档，保障平稳过渡。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.10.4" ;
    skos:prefLabel "Prepare handover to new operator or landowner"@en,
        "向新运营方或土地所有者移交"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.1" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Preparing material safety sheets. Capture material safety records to properly apply handling and disposal requirements."@en,
        "编制化学品安全技术说明书（MSDS），归档物质安全记录，支撑合规性操作与处置。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.1" ;
    skos:prefLabel "Maintain material safety data sheets"@en,
        "维护化学品安全技术说明书（MSDS）"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.2" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Understanding and communicating hazardous material regulatory requirements."@en,
        "准确理解并传达危险物质相关监管要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.2" ;
    skos:prefLabel "Maintain awareness of and communicate regulatory requirements"@en,
        "持续跟踪并传达监管要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.3" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Planning, overseeing, and tracking hazardous material handling and disposal."@en,
        "统筹规划、监督并追踪危险物质的搬运与处置全过程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.3" ;
    skos:prefLabel "Maintain hazardous material handling and disposal"@en,
        "规范危险品搬运与处置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.4" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Planning, supporting, and documenting hazardous material audits."@en,
        "规划、支持并记录危险物质合规性审计。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.4" ;
    skos:prefLabel "Manage compliance audits"@en,
        "管理合规性审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.5" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Identifying and establishing approaches to dispose of hazardous materials/waste."@en,
        "识别并确立危险物质/废弃物的合规处置路径。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.5" ;
    skos:prefLabel "Recognize need to disposition hazardous materials/waste"@en,
        "识别危险品/废弃物处置需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.6" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Evaluating hazardous materials and waste for appropriate disposition. Apply requirements and initiate disposition activities."@en,
        "评估危险物质及废弃物的适宜处置方式，落实相关要求并启动处置流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.6" ;
    skos:prefLabel "Determine disposition and associated processing"@en,
        "确定处置方式及关联处理流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.7" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Performing disposition, disposal, and reprocessing activities."@en,
        "执行处置、销毁及再加工活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.7" ;
    skos:prefLabel "Manage disposition, disposal, reprocessing activities"@en,
        "统筹处置、销毁、再加工等活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.11.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.11.8" ;
    skos:broader <https://oprocess.net/opf/node/10.4.11> ;
    skos:definition "Documenting and reporting disposition, disposal, and reprocessing activities."@en,
        "记录并报告处置、销毁及再加工全过程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.11.8" ;
    skos:prefLabel "Manage documentation and reporting"@en,
        "管理相关文档与报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/10.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.2" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Retiring assets that are no longer viable to the business. Decommission assets that are no longer in working order, are out of date, or whose maintenance exceeds the cost of replacement."@en,
        "退役不再支撑业务运营的资产；对失效、过时或维护成本高于更换成本的资产实施停用。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.2" ;
    skos:prefLabel "Decommission productive assets"@en,
        "停用生产性资产"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.3" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Performing the sale of assets. Achieve and complete the sale process. Deliver the end product to the customers."@en,
        "执行资产出售，完成销售全流程并交付最终产品至客户。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.3" ;
    skos:prefLabel "Perform sale or trade"@en,
        "开展资产出售或置换"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.4" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Managing locations where end-of-life assets are evaluated for decommissioning, disassembly, recycling, etc."@en,
        "管理资产退役评估场所，支持停用、拆解、回收等处置活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.4" ;
    skos:prefLabel "Manage take-back centers"@en,
        "管理回收中心"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.5" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Dismantling an asset into manageable parts. The parts may follow different dispositions, such as resale, reuse, recycle, etc."@en,
        "将资产拆解为可操作部件，各部件按不同路径处置，如转售、再利用、回收等。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.5" ;
    skos:prefLabel "Dismantle assets"@en,
        "拆解资产"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.6" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Tracking the disposition of all parts from end-of-life assets. Tracking should provide an audit trail to include source, rational for disposition, and destination."@en,
        "全程追踪退役资产各部件处置流向，形成包含来源、处置依据及去向的完整审计轨迹。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.6" ;
    skos:prefLabel "Track parts"@en,
        "追踪零部件"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.7" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Recycling parts in accordance with legal, regulatory, and social/environmental responsibilities."@en,
        "依法依规并兼顾社会责任与生态环境要求开展部件回收。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.7" ;
    skos:prefLabel "Recycle parts"@en,
        "回收零部件"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.8" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Planning, conducting, and tracking shipment of hazardous materials."@en,
        "规划、执行并追踪危险品运输。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.8" ;
    skos:prefLabel "Ship hazardous material"@en,
        "运输危险品"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/10.4.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:10.4.9" ;
    skos:broader <https://oprocess.net/opf/node/10.4> ;
    skos:definition "Preparing and distributing government reports."@en,
        "编制并分发政府监管报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "10.4.9" ;
    skos:prefLabel "Provide government reporting"@en,
        "完成政府监管报告"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.1.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1.1" ;
    skos:broader <https://oprocess.net/opf/node/11.1.1> ;
    skos:definition "Recognizing the organization's tolerance for risk, given risk-return trade-offs for one or more anticipated and predictable consequences."@en,
        "基于风险与收益的权衡，识别组织可接受的风险容忍度，针对一项或多项可预期、可预测的后果进行界定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1.1" ;
    skos:prefLabel "Determine risk tolerance for organization"@en,
        "确定组织风险容忍度"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1.2" ;
    skos:broader <https://oprocess.net/opf/node/11.1.1> ;
    skos:definition "Establishing and maintaining the policies and procedures for managing risk. Create rules and regulations for enterprise risk dealing with hazardous, financial, operational, and strategic risks."@en,
        "建立并持续维护风险管理政策与流程；制定并更新企业风险管理制度，覆盖危害性、财务、运营及战略风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1.2" ;
    skos:prefLabel "Develop and maintain enterprise risk policies and procedures"@en,
        "制定并维护企业风险政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/11.1.1> ;
    skos:definition "Recognizing and implementing tools for managing risk. Identify and apply enterprise risk management tools. Leverage methods and processes to manage risks and opportunities associated with business objectives."@en,
        "识别并落地实施风险管理工具；选用适配的企业风险管理工具；运用方法与流程统筹管理与业务目标相关的风险与机遇。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1.3" ;
    skos:prefLabel "Identify and implement enterprise risk management tools"@en,
        "识别并实施企业风险管理工具"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1.4" ;
    skos:broader <https://oprocess.net/opf/node/11.1.1> ;
    skos:definition "Communicating the knowledge about risk within the organization. Identify operational risks. Share risk information within the organization."@en,
        "在组织内部开展风险知识共享与沟通；识别运营风险；跨部门传递风险信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1.4" ;
    skos:prefLabel "Coordinate the sharing of risk knowledge across the organization"@en,
        "统筹组织内风险知识共享"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.1.5" ;
    skos:broader <https://oprocess.net/opf/node/11.1.1> ;
    skos:definition "Preparing and presenting reports about enterprise risk to the management of the organization. Create reports for management on hazard risks (e.g., property damage and liability torts), financial risks (e.g., currency and liquidity risks), and operational risks (e.g., product failure, customer satisfaction, social trends, and competition)."@en,
        "编制并向管理层提交企业风险报告；内容涵盖危害风险（如财产损失、侵权责任）、财务风险（如汇率风险、流动性风险）及运营风险（如产品失效、客户满意度、社会趋势、市场竞争等）。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.1.5" ;
    skos:prefLabel "Prepare and report enterprise risk to executive management and board"@en,
        "编制并向高管层及董事会报告企业风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.1" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Determining risks that could thwart objectives, including crises that may impact customer service such as data breaches or significant product issues. Document and communicate the concern."@en,
        "识别可能阻碍目标达成的风险，包括影响客户服务的重大危机（如数据泄露、重大产品质量问题）；记录并通报相关风险关切。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.1" ;
    skos:prefLabel "Identify enterprise level risks"@en,
        "识别企业级风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.2" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Identifying options/actions to enhance opportunities and reduce threats. Recognize the root reasons of the identified risks."@en,
        "识别提升机遇与降低威胁的可行选项与行动方案；追溯已识别风险的根本成因。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.2" ;
    skos:prefLabel "Assess risks to determine which to mitigate"@en,
        "评估风险以确定需缓解的风险项"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.3" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Developing activities to improve opportunities and lessen threats. Specify the organization's objectives. Evolve strategies and policies to attain these objectives. Assign resources to project objectives."@en,
        "制定提升机遇、缓解威胁的具体举措；明确组织目标；制定并优化实现目标的战略与政策；将资源分配至项目目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.3" ;
    skos:prefLabel "Develop risk mitigation and management strategy and integrate with existing performance management processes"@en,
        "制定风险缓解与管理策略，并融入现有绩效管理流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.4" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Checking that the blueprint created for managing risk in individual business units and divisions is correctly effectuated. Validate the implementation of all activities geared to mitigate risks."@en,
        "核查各业务单元与职能部门所制定的风险管理蓝图是否有效执行；验证所有风险缓释活动的落实情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.4" ;
    skos:prefLabel "Verify business unit and functional risk mitigation plans are implemented"@en,
        "验证各业务单元及职能部门的风险缓解计划已落实"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.5" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Ensuring risk monitoring and mitigation activities. Monitor actions to enhance opportunities and reduce threats to project objectives."@en,
        "确保风险监测与缓释活动持续开展；跟踪为提升机遇、降低威胁而采取的各项措施对项目目标的影响。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.5" ;
    skos:prefLabel "Ensure risks and risk mitigation actions are monitored"@en,
        "确保风险及其缓解措施持续受监控"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.6" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Creating a report of activities to address hazard risks, liability torts, financial risks, operational risks, social trends, competition, etc."@en,
        "编制风险应对活动报告，覆盖危害风险、侵权责任、财务风险、运营风险、社会趋势、市场竞争等维度。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.6" ;
    skos:prefLabel "Report on enterprise risk activities"@en,
        "报告企业风险管理活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.7" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Coordinating risk management activities to improve opportunities and lessen threats. Specify the organization's objectives. Assign resources to project objectives."@en,
        "统筹协调各业务单元与职能部门的风险管理活动，以提升机遇、降低威胁；明确组织目标；将资源分配至项目目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.7" ;
    skos:prefLabel "Coordinate business unit and functional risk management activities"@en,
        "协调各业务单元及职能部门的风险管理活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.8" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Checking each business unit's/function's options and activities to improve opportunities and lessen threats."@en,
        "审查各业务单元/职能领域提出的提升机遇、降低威胁的备选方案与具体行动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.8" ;
    skos:prefLabel "Ensure that each business unit/function follows the enterprise risk management process"@en,
        "确保各业务单元/职能部门遵循企业风险管理流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.2.9" ;
    skos:broader <https://oprocess.net/opf/node/11.1.2> ;
    skos:definition "Checking the reporting process of each business unit's/function's options and activities to improve opportunities and lessen threats."@en,
        "审查各业务单元/职能领域关于提升机遇、降低威胁的备选方案与行动的报告机制。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.2.9" ;
    skos:prefLabel "Ensure that each business unit/function follows the enterprise risk reporting process"@en,
        "确保各业务单元/职能部门遵循企业风险报告流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.1" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Developing a timely and continuous process to identify activities that might hinder a project's goals."@en,
        "建立及时、持续的风险识别机制，发现可能妨碍项目目标实现的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.1" ;
    skos:prefLabel "Identify risks"@en,
        "识别风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.2" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Determining the possibility that a specified undesirable event will occur using established tools, implements, and frameworks. Use risk assessments to determine, for example, whether to undertake a particular venture, what rate of return a particular investment requires, and how to mitigate an activity's potential losses."@en,
        "运用既定工具、手段与框架，评估特定不利事件发生的可能性；通过风险评估辅助决策，例如是否启动某项业务、某项投资所需回报率、以及如何缓释某项活动的潜在损失。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.2" ;
    skos:prefLabel "Assess risks using enterprise risk framework policies and procedures"@en,
        "依据企业风险框架的政策与流程评估风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.3.1" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3.3> ;
    skos:definition "Evaluating the changing needs for insurance coverage. Research available insurance providers and offerings."@en,
        "评估保险保障需求的动态变化；调研可选保险供应商及其产品。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.3.1" ;
    skos:prefLabel "Assess adequacy of insurance coverage"@en,
        "评估保险覆盖充分性"@zh ;
    opf:domain "management_support" ;
    opf:level 5 .

<https://oprocess.net/opf/node/11.1.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.4" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Executing mitigation plans to improve opportunities and reduce deviations to project objectives."@en,
        "执行风险缓释计划，以提升机遇、减少对项目目标的偏离。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.4" ;
    skos:prefLabel "Implement mitigation plans for risks"@en,
        "实施风险缓解计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.5" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Identifying, examining, and recognizing/justifying any improbability in investment decision making."@en,
        "识别、分析并论证投资决策中可能存在的非理性因素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.5" ;
    skos:prefLabel "Monitor risks"@en,
        "监控风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.6" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Examining the impact of risk activities in order to update the existing scheme of risk management. Analyze and substantiate the potential for adverse consequences to occur. Consider the risks associated with the activity and the methods available to manage those risks."@en,
        "评估风险活动影响，以更新现有风险管理体系；分析并佐证不利后果发生的潜在可能性；综合考量活动相关风险及可用的风险管理方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.6" ;
    skos:prefLabel "Analyze risk activities and update plans"@en,
        "分析风险活动并更新计划"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.3.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.1.3.7" ;
    skos:broader <https://oprocess.net/opf/node/11.1.3> ;
    skos:definition "Creating reports on risk activities, and communicating them to management. Prepare reports on the potential for adverse safety consequences."@en,
        "编制风险活动报告并向管理层通报；重点准备有关安全不利后果潜在风险的专项报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.3.7" ;
    skos:prefLabel "Report on risk activities"@en,
        "报告风险活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Risk Management" ;
    skos:broader <https://oprocess.net/opf/node/11.1.4> ;
    skos:definition "Activity within ITIL practice 'Risk Management'."@en,
        "ITIL 风险管理实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.4.1" ;
    skos:prefLabel "Assess IT risks"@en,
        "评估 IT 风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Risk Management" ;
    skos:broader <https://oprocess.net/opf/node/11.1.4> ;
    skos:definition "Activity within ITIL practice 'Risk Management'."@en,
        "ITIL 风险管理实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.4.2" ;
    skos:prefLabel "Treat IT risks"@en,
        "处置 IT 风险"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.1.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Risk Management" ;
    skos:broader <https://oprocess.net/opf/node/11.1.4> ;
    skos:definition "Activity within ITIL practice 'Risk Management'."@en,
        "ITIL 风险管理实践中的具体活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.1.4.3" ;
    skos:prefLabel "Monitor IT risk landscape"@en,
        "监控 IT 风险态势"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/11.2.1> ;
    skos:definition "Creating a standardized approach to ethics and compliance. Have a programmatic approach for compliance that focuses on the definite risks the organization faces."@en,
        "构建标准化的伦理与合规方法；建立聚焦组织实际面临具体风险的体系化合规方案。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.1.1" ;
    skos:prefLabel "Develop enterprise compliance policies and procedures"@en,
        "制定企业合规政策与流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/11.2.1> ;
    skos:definition "Implementing standardized for ethics and compliance. Have a programmatic approach, built from the top down, to enterprise compliance that focuses on the definite risks the organization faces."@en,
        "推行标准化的伦理与合规实践；自上而下构建企业级合规体系，聚焦组织实际面临的具体风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.1.2" ;
    skos:prefLabel "Implement enterprise compliance activities"@en,
        "实施企业合规活动"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/11.2.1> ;
    skos:definition "Managing accounts and prepare regular reports on financial performance."@en,
        "管理账务并定期编制财务绩效报告。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.1.3" ;
    skos:prefLabel "Manage internal audits"@en,
        "管理内部审计"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/11.2.1> ;
    skos:definition "Managing technologies and tools related to the confidentiality, integrity, and availability of data in order to ensure the security of the organization's information. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "管理与数据保密性、完整性、可用性相关的技术与工具，保障组织信息安全；涵盖人工智能（AI）等各类新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.1.4" ;
    skos:prefLabel "Maintain controls-related technologies and tools"@en,
        "维护与控制相关的技术及工具"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Developing procedures and methodologies to comply with relevant laws and regulations of an organization's obedience to laws, guidelines, strategies and stipulations related to business."@en,
        "制定并实施合规程序与方法，确保组织在法律法规、指南、策略及规定等方面持续合规。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.1" ;
    skos:prefLabel "Develop regulatory compliance procedures"@en,
        "制定监管合规流程"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Determining the regulatory requirements that are most appropriate for the organization. Identify goals in order to follow the appropriate rules and regulations, guidelines, and strategies."@en,
        "识别最适用于本组织的监管要求；设定合规目标，以落实相应法规、指南与策略。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.2" ;
    skos:prefLabel "Identify applicable regulatory requirements"@en,
        "识别适用的监管要求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Analyzing and overseeing the regulatory environment in order to spot any changing or emerging regulations. This process element calls upon the organization to monitor the regulatory environment for any new statutes, policies, and enactments issued by the respective government authorities or those which have been updated."@en,
        "分析并持续监控监管环境，及时识别新出台或正在演进的监管要求；该环节要求组织主动跟踪各级政府主管部门发布的新增或修订的法律、政策与规章。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.3" ;
    skos:prefLabel "Monitor the regulatory environment for changing or emerging regulations"@en,
        "持续监测监管环境，识别变化或新兴法规"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Evaluating current regulatory policies and regulations. Assess their performance. Make necessary changes."@en,
        "评估现行监管政策与法规的有效性；审视其执行成效；必要时进行修订与优化。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.4" ;
    skos:prefLabel "Assess current compliance position and identify weaknesses or shortfalls therein"@en,
        "评估当前合规状况，识别薄弱环节或差距"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Assessing the current policies and policies. Implement missing and necessary changes environmental changes, political changes, technological changes, etc."@en,
        "评估现行制度，并针对环境变化、政治变化、技术变化等实施缺失且必要的制度调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.5" ;
    skos:prefLabel "Implement missing or stronger regulatory compliance controls and policies"@en,
        "实施缺失或更严格的监管合规控制措施与政策"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.6" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Monitoring, appraising, and evaluating the compliance position of the organization in order to fine-tune for effective remediation. Track efforts for handling regulatory and compliance requirements necessitated by law. Test the robustness of internal frameworks, procedures, and approaches for dealing with these requirements, in order to clearly identify any necessary changes."@en,
        "监测、评估和审查组织的合规状况，以优化整改成效；跟踪落实法律法规所要求的监管与合规事项；测试内部框架、流程及应对方法的稳健性，明确识别所需改进之处。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.6" ;
    skos:prefLabel "Monitor and test regulatory compliance position and existing controls"@en,
        "监控并测试监管合规现状及现有控制措施"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.7" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Creating a graphical representation of metrics in order to communicate the general health of the organization in relation to risk and compliancy."@en,
        "构建指标可视化图表，直观呈现组织在风险与合规方面的整体健康状况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.7" ;
    skos:prefLabel "Compile and communicate compliance scorecard(s)"@en,
        "编制并通报合规记分卡"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.8" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Submitting compliance reports to regulatory agencies. These reports can be made to environmental, securities, or human resources agencies as stipulated by the local governing body."@en,
        "向监管机构提交合规报告，包括环保、证券或人力资源等主管部门，具体依属地监管要求而定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.8" ;
    skos:prefLabel "Compile and communicate internal and regulatory compliance reports"@en,
        "编制并通报内部及监管合规报告"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.2.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.2.2.9" ;
    skos:broader <https://oprocess.net/opf/node/11.2.2> ;
    skos:definition "Developing and preserving relationships with the regulators, without compromising the legal basis of the relationship."@en,
        "在不损害法律基础的前提下，建立并维护与监管机构的良好关系。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.2.9" ;
    skos:prefLabel "Maintain relationships with regulators as appropriate"@en,
        "视情况维护与监管机构的关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/11.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.2> ;
    skos:definition "AI-era activity: AI-Enhanced Compliance Monitoring."@en,
        "人工智能（AI）时代活动：AI增强型合规监测。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.2.3" ;
    skos:prefLabel "AI-Enhanced Compliance Monitoring"@en,
        "人工智能增强型合规监控"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.1" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Creating plans for remediation efforts. Make a plan to address a case of environmental adulteration. Identify and treat the adulteration so that the area will become operational again."@en,
        "制定整改行动计划。例如，针对环境污染事件制定处置方案，识别并治理污染源，恢复区域正常运行。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.1" ;
    skos:prefLabel "Create remediation plans"@en,
        "制定整改计划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.2" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Discussing and soliciting advice from experts for in order to incorporate their suggestion (regarding Create remediation plans [11201])."@en,
        "就整改计划制定（11201）征求并吸纳专家意见与建议。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.2" ;
    skos:prefLabel "Contact and confer with experts"@en,
        "联系并会商专家"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.3" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Identifying and dedicating the resources for managing remediation efforts. Discern the resources needed for remediation efforts. Dispense with resources in a sound and well-reasoned manner."@en,
        "识别并配置整改所需资源。厘清整改任务所需的各类资源，并以审慎、合理的方式予以调配。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.3" ;
    skos:prefLabel "Identify/Dedicate resources"@en,
        "识别/调配资源"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.4" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Examining regulatory and legislative frameworks. Obligate the organization to remediate any damages through compensations, fines, and any other remedial efforts necessitated to correct the situations. Analyze local environmental laws, binding international covenants, etc. in order to examine legal accuracy about the rules and procedures."@en,
        "梳理监管与立法框架，明确组织须通过赔偿、罚款及其他必要补救措施履行整改义务；分析本地环境法规、具有约束力的国际公约等，确保相关规则与程序的法律准确性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.4" ;
    skos:prefLabel "Investigate legal aspects"@en,
        "调查法律相关事项"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.5" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Studying the causes of damage, which could be environmental, physical, social, etc. at country level in order to institute better policies and regulations."@en,
        "在国家层面研究损害成因（如环境、物理、社会等维度），以支撑更优政策与法规的制定。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.5" ;
    skos:prefLabel "Investigate damage cause"@en,
        "调查损害成因"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.3.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.3.6" ;
    skos:broader <https://oprocess.net/opf/node/11.3> ;
    skos:definition "Crafting a new framework of policies and procedures for deploying remediation efforts, or change existing policies and procedures. Adapt the policy structure to the context of the apposite national and international regulatory frameworks."@en,
        "构建或修订用于开展整改工作的政策与程序新框架，使其适配适用的国家及国际监管框架。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.3.6" ;
    skos:prefLabel "Amend or create policy"@en,
        "修订或制定政策"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4.1" ;
    skos:broader <https://oprocess.net/opf/node/11.4> ;
    skos:definition "Creating a strategy for rapidly adapting to disturbances. Maintain continuous business processes and protecting employees, assets, and overall brand equity. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en,
        "制定快速应对干扰的战略，保障业务连续运行，保护员工、资产及整体品牌价值；涵盖人工智能（AI）等新兴与演进技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4.1" ;
    skos:prefLabel "Develop the business resilience strategy"@en,
        "制定业务韧性战略"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4.2" ;
    skos:broader <https://oprocess.net/opf/node/11.4> ;
    skos:definition "Developing plans to ensure continuous business operations."@en,
        "制定业务连续性保障计划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4.2" ;
    skos:prefLabel "Perform continuous business operations planning"@en,
        "持续开展业务连续性规划"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4.3" ;
    skos:broader <https://oprocess.net/opf/node/11.4> ;
    skos:definition "Assessing ongoing activities within the organization that are not intended to stop except for in an emergency."@en,
        "评估组织内非紧急情况下不得中止的持续性运营活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4.3" ;
    skos:prefLabel "Test continuous business operations"@en,
        "测试业务连续性"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4.4" ;
    skos:broader <https://oprocess.net/opf/node/11.4> ;
    skos:definition "Evaluating business operations. Determine which activities generate revenues, perform best, and provide good returns."@en,
        "评估业务运营，识别创收能力强、绩效优异、投资回报良好的关键活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4.4" ;
    skos:prefLabel "Maintain continuous business operations"@en,
        "维持业务连续性运行"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:11.4.5" ;
    skos:broader <https://oprocess.net/opf/node/11.4> ;
    skos:definition "Sharing information about risks and resilience strategies of business operations across the organization so that prospective risks can be avoided."@en,
        "在组织内部共享业务运营的风险信息与韧性策略，以前瞻性规避潜在风险。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.4.5" ;
    skos:prefLabel "Share knowledge of specific risks across other parts of the organization"@en,
        "在组织其他部门共享特定风险知识"@zh ;
    opf:domain "management_support" ;
    opf:level 3 .

<https://oprocess.net/opf/node/11.5.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "oprocess:ai-era" ;
    skos:broader <https://oprocess.net/opf/node/11.5.1> ;
    skos:definition "AI activity: Define AI ethics principles."@en,
        "AI活动：定义AI伦理原则。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.1.1" ;
    skos:prefLabel "Define AI ethics principles"@en,
        "定义人工智能伦理原则"@zh ;
