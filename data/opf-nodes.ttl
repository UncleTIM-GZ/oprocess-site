        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.5" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Maintaining reserves for write-offs and adjustments. Adjust or write off certain expenses and losses."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.5" ;
    skos:prefLabel "Process adjustments/write off balances"@en,
        "处理 adjustments/write off balances"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.6" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Renegotiating the terms of a loan agreement in order to recoup money from a default account."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.6" ;
    skos:prefLabel "Perform recovery workout"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.4.7" ;
    skos:broader <https://oprocess.net/opf/node/9.2.4> ;
    skos:definition "Managing accounts that have not met the requirements agreed upon to pay off outstanding debts."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "9.2.4.7" ;
    skos:prefLabel "Manage default accounts"@en,
        "管理 default accounts"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/9.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:9.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/9.2.5> ;
