<https://oprocess.net/opf/node/8.2.1.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Building and maintaining intelligence towards changing organizational goals, supporting management, and operational or functional levels of the business. It is the ability to understand business trends that present threats or opportunities for IT in an organization."@en,
        "构建并持续更新面向组织目标变化的情报能力，支撑管理层及业务运营/职能层决策；即准确识别可能给IT带来威胁或机遇的业务趋势。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.1" ;
    skos:prefLabel "Build and maintain IT strategic intelligence"@en,
        "构建并维护IT战略情报"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.1.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Monitoring and evaluating existing and forthcoming technologies to meet the current and future growth plans for business operations."@en,
        "持续监测与评估现有及新兴技术，以匹配当前及未来业务增长规划。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.2" ;
    skos:prefLabel "Monitor and map current and emerging technologies"@en,
        "监测并梳理当前及新兴技术"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.1.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Defining the integration of digital technology into business operations and service delivery, and convey the strategy to different segments of business. It is always backed by continuous improvement followed by periodic review and change per requirement of the business."@en,
        "定义数字化技术在业务运营与服务交付中的融合路径，并向各业务单元宣贯数字化战略；该战略始终以持续改进为基础，依业务需求定期评审并动态调整。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.3" ;
    skos:prefLabel "Define and communicate digital transformation strategy"@en,
        "制定并宣贯数字化转型战略"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.1.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Developing the process of aligning the organization's business divisions and staff members with the organization's planned objectives for IT."@en,
        "建立流程，推动组织各业务部门及员工与既定IT目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.4" ;
    skos:prefLabel "Develop IT strategic alignment"@en,
        "推进IT战略对齐"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.1.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Systematic approach to clearly communicate and operate the usage of information technology as it relates to business objectives."@en,
        "系统化地清晰传达并落实信息技术的应用，确保其紧密支撑业务目标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.5" ;
    skos:prefLabel "Articulate IT alignment principles"@en,
        "阐明IT对齐原则"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.1.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.1.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2.1> ;
    skos:definition "Maintaining alignment of the organization's business divisions and staff members with the organization's planned objectives for IT."@en,
        "持续维护组织各业务部门及员工与既定IT目标的一致性。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.1.6" ;
    skos:prefLabel "Maintain IT strategic alignment"@en,
        "持续维护IT战略对齐"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.10.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Financial Management" ;
    skos:broader <https://oprocess.net/opf/node/8.2.10> ;
    skos:definition "Activity within ITIL practice 'Service Financial Management'."@en,
        "ITIL 实践‘服务财务管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.10.1" ;
    skos:prefLabel "Plan IT budgets and costs"@en,
        "规划IT预算与成本"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.10.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Financial Management" ;
    skos:broader <https://oprocess.net/opf/node/8.2.10> ;
    skos:definition "Activity within ITIL practice 'Service Financial Management'."@en,
        "ITIL 实践‘服务财务管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.10.2" ;
    skos:prefLabel "Account for IT services"@en,
        "核算IT服务成本"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.10.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "ITIL:V5:Service Financial Management" ;
    skos:broader <https://oprocess.net/opf/node/8.2.10> ;
    skos:definition "Activity within ITIL practice 'Service Financial Management'."@en,
        "ITIL 实践‘服务财务管理’中的活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.10.3" ;
    skos:prefLabel "Charge for IT services"@en,
        "向IT服务收费"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Create and certify the standards to determine the value of the investments, projects, and activities of IT function for the overall business objectives."@en,
        "制定并确认评估标准，用于衡量IT职能在支撑整体业务目标方面的投资、项目与活动价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.1" ;
    skos:prefLabel "Establish and validate IT value criteria"@en,
        "建立并验证IT价值评估标准"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Determining the uninvested amount out of the total approved amount for overall IT management, IT investments, projects, and activities."@en,
        "核算已批准IT总预算中尚未投入使用的余额，覆盖IT整体管理、投资、项目及活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.2" ;
    skos:prefLabel "Determine IT portfolio investment balance"@en,
        "确定IT投资组合的资源配置平衡"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Evaluating IT investment projects to achieve overall business objectives in regard to implementation, efficiency, and profitability."@en,
        "评估IT投资项目在实施成效、运行效率及盈利性等方面对整体业务目标的达成情况。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.3" ;
    skos:prefLabel "Evaluate proposed IT investment projects"@en,
        "评估拟议的IT投资项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Listing the IT projects in the order of most important to the least. Determining which of many IT projects are most important or critical to business operations."@en,
        "对IT项目按重要性由高至低排序，识别其中对业务运营最关键或最紧迫的项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.4" ;
    skos:prefLabel "Prioritize IT projects"@en,
        "对IT项目进行优先级排序"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Aligning physical IT resources like software, IT infrastructure, networks, and non-physical resources like technology expertise, to strategic objectives ranked by their importance in achieving the strategic goals."@en,
        "将软件、IT基础设施、网络等物理IT资源，以及技术专长等非物理资源，与战略目标对齐，并依据其对实现战略目标的重要程度进行优先级排序。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.5" ;
    skos:prefLabel "Align IT resources to strategic priorities"@en,
        "将信息技术资源与战略优先事项对齐"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.2.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.2.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2.2> ;
    skos:definition "Aligning IT investments, projects, and activities to achieve overall business objectives."@en,
        "将IT投资、项目及活动与整体业务目标对齐。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.2.6" ;
    skos:prefLabel "Align IT portfolio to business objectives"@en,
        "将IT投资组合与业务目标对齐"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.3.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.3.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.3> ;
    skos:definition "Creating and publishing high level statements of the fundamental values (principles) based on the organization's objectives that guide Information Technology decision-making and activities, and are the foundation for enterprise architecture."@en,
        "基于组织目标，制定并发布高层级的根本性价值观（原则）声明，用以指导信息技术决策与活动，并作为企业架构的基础。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.3.1" ;
    skos:prefLabel "Create and publish enterprise architecture principles"@en,
        "制定并发布企业架构原则"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.3.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.3.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.3> ;
    skos:definition "Establishing and operating a structure by which an enterprise defines appropriate strategies and ensures development alignment with those strategies. Create and establish the rules, regulations, policies, and standards that will govern the individual components of the IT architecture, as well as the architecture in its entirety."@en,
        "建立并运行一套治理结构，使组织能够制定恰当的战略，并确保各项开发工作与该战略保持一致；制定并确立适用于IT架构各组成部分及整体架构的规则、规范、政策与标准。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.3.2" ;
    skos:prefLabel "Establish and operate enterprise architecture governance"@en,
        "建立并运行企业架构治理机制"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.3.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.3.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.3> ;
    skos:definition "Systematically investigating and studying materials and sources relevant to the IT function. Reach meaningful insights and conclusions in the form of new ideas and innovation for delivering IT services and solutions."@en,
        "系统性地调研与研究与IT职能相关的材料与信息源，形成关于IT服务与解决方案交付的新思路与创新性结论。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.3.3" ;
    skos:prefLabel "Research technologies to innovate IT services and solutions"@en,
        "研究新兴技术以推动IT服务与解决方案创新"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.3.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.3.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.3> ;
    skos:definition "Analyze the value driven through IT projects and redefine and/or reprioritize. Evaluate planning, organizing, and implementation of IT projects based on research outcomes and business objectives."@en,
        "分析IT项目所创造的价值，并据此重新定义和（或）调整优先级；基于研究成果与业务目标，评估IT项目的规划、组织与实施。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.3.4" ;
    skos:prefLabel "Provide input to definition and prioritization of IT projects"@en,
        "为IT项目的定义与优先级排序提供输入"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Implementing strategy for designing, delivering, managing, and improving the way information technology be used in the organization. The goal of IT Service Management is to ensure that the right processes, people, and technology are in place to meet business goals."@en,
        "实施信息技术服务管理（ITSM）战略，涵盖信息技术在组织内的设计、交付、管理与持续改进；其目标是确保具备恰当的流程、人员与技术，以支撑业务目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.1" ;
    skos:prefLabel "Establish IT service management strategy and goals"@en,
        "制定IT服务管理战略与目标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Identifying operating and process requirement for designing, delivering, managing, and improving the way information technology be used in the organization."@en,
        "识别支撑信息技术在组织内设计、交付、管理与持续改进所需的运营与流程要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.2" ;
    skos:prefLabel "Identify IT service operating and process requirements"@en,
        "识别IT服务运营与流程需求"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization."@en,
        "构建并设计一个结构化、可管理的IT相关服务目录，涵盖组织可执行、为组织执行或在组织内部执行的所有IT服务。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.3" ;
    skos:prefLabel "Define IT service catalog"@en,
        "定义IT服务目录"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Create a layered structure for IT service management framework ensuring right processes, people, and technology are in place to meet business goals."@en,
        "构建分层式IT服务管理框架，确保流程、人员与技术配置合理，以支撑业务目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.4" ;
    skos:prefLabel "Establish IT service management framework"@en,
        "建立IT服务管理框架"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Defining and implementing activities involved in designing, creating, delivering, supporting, and managing the lifecycle of information technology services within an organization."@en,
        "定义并实施涵盖信息技术服务全生命周期的设计、开发、交付、支持与管理等活动。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.5" ;
    skos:prefLabel "Define and implement IT service management"@en,
        "定义并实施IT服务管理"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Establishing services for providing support to users of IT services and solutions. Define the plethora of services along with tools and methods by which the organization assists users of computers, software products, or other electronic/mechanical products."@en,
        "建立面向IT服务与解决方案用户的支撑服务体系；明确定义各类服务内容，以及组织用于协助计算机、软件产品或其他电子/机械设备用户所采用的工具与方法。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.6" ;
    skos:prefLabel "Define and deploy support service management process tools and methods"@en,
        "定义并部署支持服务管理的流程工具与方法"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.4.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.4.7" ;
    skos:broader <https://oprocess.net/opf/node/8.2.4> ;
    skos:definition "Supervising, analyzing, and reporting performance of information technology to ensure they are on-course and on-schedule in meeting the organizational objectives and performance targets."@en,
        "监督、分析并报告信息技术绩效，确保其按既定路线与时间节点达成组织目标与绩效指标。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.4.7" ;
    skos:prefLabel "Monitor and report IT performance"@en,
        "监控并报告IT绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Determining measures for evaluating the performance of IT services in the organization. Establish key performance indicators, including the IT services performance index."@en,
        "制定用于评估组织内IT服务绩效的度量方法；建立关键绩效指标（KPI），包括IT服务绩效指数。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.1" ;
    skos:prefLabel "Determine IT performance measures"@en,
        "确定IT绩效度量指标"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Establishing a governance model with its own structure and functions from where full or partial control can be exercised over the entire IT management system. Specify evaluation and quality control procedures in the structure."@en,
        "建立具备自身结构与职能的治理模型，实现对整个IT管理体系的全面或部分管控；在该结构中明确评估与质量控制流程。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.2" ;
    skos:prefLabel "Define IT control points and assurance procedures governance model"@en,
        "定义IT控制点与保障程序的治理模型"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Monitoring and analyzing information technology performance measures to ensure timely completion, and that quality assurance is met at all steps of IT services."@en,
        "监控与分析IT绩效度量，确保IT服务各环节按时完成且满足质量保障要求。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.3" ;
    skos:prefLabel "Monitor and analyze overall IT performance"@en,
        "监控与分析整体IT绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Checking and analyzing predetermined financial targets and timelines of IT management system. Monitoring their profitability, feasibility, and consistency. Study the revenues generated."@en,
        "核查与分析IT管理体系预设的财务目标与时间节点，监控其盈利能力、可行性与一致性，并研究收入来源。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.4" ;
    skos:prefLabel "Monitor and analyze IT financial performance"@en,
        "监控与分析IT财务绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Examining and analyzing the value and benefits of IT service management to ensure benefits outweigh incurred costs."@en,
        "评估IT服务管理的价值与收益，确保收益大于投入成本。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.5" ;
    skos:prefLabel "Monitor and analyze IT value and benefits"@en,
        "监控与分析IT价值与收益"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Create process to assign and manage IT assets that support organization's strategic goals."@en,
        "建立流程，对支撑组织战略目标的IT资产进行分配与管理。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.6" ;
    skos:prefLabel "Optimize IT resource allocation"@en,
        "优化IT资源配置"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.7" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Manage capabilities required for the successful delivery of information technology projects, which, by extension, affect the success of the overall IT services."@en,
        "管理成功交付信息技术项目所需的能力，进而保障整体IT服务的成功交付。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.7" ;
    skos:prefLabel "Manage IT projects and services interdependencies"@en,
        "管理IT项目与服务间的相互依赖关系"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.8> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.8" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Process of collecting, analyzing, and reporting information regarding the performance of IT services and projects."@en,
        "收集、分析并报告IT服务与项目绩效相关信息。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.8" ;
    skos:prefLabel "Report IT service and project performance"@en,
        "报告IT服务与项目绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.5.9> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.5.9" ;
    skos:broader <https://oprocess.net/opf/node/8.2.5> ;
    skos:definition "Select, establish, and operate analytics tool to analyze data and extract actionable and commercially relevant information on IT performance to evaluate or increase performance."@en,
        "遴选、建立并运行分析工具，对数据进行分析，提取可操作且具有商业价值的IT绩效信息，以评估或提升绩效。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.5.9" ;
    skos:prefLabel "Select, deploy, and operate IT performance analytics tools"@en,
        "遴选、部署并运行IT绩效分析工具"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.6.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.6.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.6> ;
    skos:definition "Process of evaluating performance to collect and analyze IT services and projects. Ensure expected IT service and project value based on established criteria."@en,
        "通过绩效评估，收集并分析IT服务与项目数据，确保其价值符合既定标准与预期。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.6.1" ;
    skos:prefLabel "Assess performance against IT service and project value criteria"@en,
        "依据IT服务与项目价值标准评估绩效"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.6.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.6.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.6> ;
    skos:definition "Evaluate the value of the investments, projects, and activities of IT function by assigning it a quantifiable value with a profitable return to business operations."@en,
        "通过赋予量化价值并确保产生可盈利回报，评估IT职能所涉投资、项目与活动的价值。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.6.2" ;
    skos:prefLabel "Quantify value of IT service and project portfolio investments"@en,
        "量化IT服务与项目投资组合的价值"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.6.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.6.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.6> ;
    skos:definition "Conveying the value addition through adopting technology targeting towards integrated profitable business operations."@en,
        "阐明技术采纳所带来的价值增值，推动实现集成化、盈利性的业务运营。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.6.3" ;
    skos:prefLabel "Communicate business technology value contribution"@en,
        "沟通信息技术对业务的价值贡献"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.6.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.6.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.6> ;
    skos:definition "Determining and implementing IT investments, projects, and activities based on trending technological advancements in the existing environment in order to achieve overall business objectives."@en,
        "依据现有环境中新兴技术发展趋势，确定并实施IT投资、项目与活动，以支撑整体业务目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.6.4" ;
    skos:prefLabel "Determine and implement IT portfolio adjustments"@en,
        "确定并实施IT投资组合调整方案"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.1> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.1" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Establishing the standard for selecting IT research initiatives to align with organizational criteria for implementing future technologies."@en,
        "制定IT研究项目遴选标准，确保其与组织未来技术实施准则相一致。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.1" ;
    skos:prefLabel "Establish selection criteria for research initiatives"@en,
        "建立研发项目遴选标准"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.2> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.2" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Assessing new and future technologies relevant to the organization's vision of its IT capabilities."@en,
        "评估与组织IT能力愿景相关的新技术与未来技术。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.2" ;
    skos:prefLabel "Analyze emerging technology concepts"@en,
        "分析新兴技术概念"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.3> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.3" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Identification of conceptual elements that define the benefits of technology to business."@en,
        "识别界定技术对业务价值贡献的概念性要素。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.3" ;
    skos:prefLabel "Identify technology concepts and capabilities"@en,
        "识别技术概念与能力"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.4> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.4" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Implement information technology research projects that focus on meeting the goals of the organization's IT services and capabilities."@en,
        "实施聚焦于达成组织IT服务与能力目标的信息技术研究项目。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.4" ;
    skos:prefLabel "Execute IT research projects"@en,
        "执行IT研发项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.5> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.5" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Assessing IT research projects based on defined outcome expectations."@en,
        "依据既定成果预期，对IT研究项目进行评估。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.5" ;
    skos:prefLabel "Evaluate IT research project outcomes"@en,
        "评估IT研发项目成果"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.6> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.6" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Determine project viability. Promote relevant IT innovations that meet business objectives."@en,
        "评估项目可行性；推广契合业务目标的相关IT创新。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.6" ;
    skos:prefLabel "Identify and promote viable concepts"@en,
        "识别并推广可行的技术概念"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

<https://oprocess.net/opf/node/8.2.7.7> a skos:Concept,
        opf:ProcessNode ;
    dcterms:source "PCF:8.2.7.7" ;
    skos:broader <https://oprocess.net/opf/node/8.2.7> ;
    skos:definition "Develop and plan long-term allocation of funds for information technology endeavors to meet business goals."@en,
        "制定并规划长期信息技术资金投入方案，以支撑业务目标达成。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "8.2.7.7" ;
    skos:prefLabel "Develop and plan IT investment projects"@en,
        "开发并规划IT投资项目"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

