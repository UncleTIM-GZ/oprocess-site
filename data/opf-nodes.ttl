    dcterms:source "PCF:7.1.1.3" ;
    skos:broader <https://oprocess.net/opf/node/7.1.1> ;
    skos:definition "Establishing the roles that are required to execute the HR function.  This process also examines the organizational structure required to support the organization."@en ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "7.1.1.3" ;
    skos:prefLabel "Determine HR function roles and structure"@en ;
    opf:domain "management_support" ;
    opf:level 4 .

