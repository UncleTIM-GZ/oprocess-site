        "AI活动：设立伦理审查委员会。"@zh ;
    skos:inScheme <https://oprocess.net/opf> ;
    skos:notation "11.5.1.2" ;
    skos:prefLabel "Establish ethics review board"@en,
        "设立伦理审查委员会"@zh ;
    opf:domain "management_support" ;
    opf:level 4 .

